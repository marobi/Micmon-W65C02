00B7B1  2               ; ------------------------------------------------------------
00B7B1  2               ; SIMPLE ASSEMBLER COMMAND
00B7B1  2               ; Syntax:
00B7B1  2               ;   A [addr] mnemonic [operand]
00B7B1  2               ;
00B7B1  2               ; If addr is omitted, MEM is used.
00B7B1  2               ; On success MEM is updated to the next address.
00B7B1  2               ; ------------------------------------------------------------
00B7B1  2               cmd_asm:
00B7B1  2  20 19 B4         jsr advance_lineptr
00B7B4  2  20 AC B2         jsr next_token
00B7B7  2  B0 03            bcs ca_have_first
00B7B9  2  4C 27 B2         jmp cmd_error
00B7BC  2               
00B7BC  2               ca_have_first:
00B7BC  2  A0 00            ldy #0
00B7BE  2  B1 C2            lda (lineptr),y
00B7C0  2  20 2F B4         jsr toupper
00B7C3  2  C9 41            cmp #'A'
00B7C5  2  90 04            bcc ca_with_addr
00B7C7  2  C9 5B            cmp #'Z'+1
00B7C9  2  90 0E            bcc ca_default_addr
00B7CB  2               
00B7CB  2               ca_with_addr:
00B7CB  2  20 FD B2         jsr parse_word
00B7CE  2  20 43 B4         jsr copy_T0_R0
00B7D1  2  20 AC B2         jsr next_token
00B7D4  2  B0 06            bcs ca_mnemonic
00B7D6  2  4C 27 B2         jmp cmd_error
00B7D9  2               
00B7D9  2               ca_default_addr:
00B7D9  2  20 67 B4         jsr copy_MEM_R0
00B7DC  2               
00B7DC  2               ca_mnemonic:
00B7DC  2  20 5E B4         jsr copy_R0_R2
00B7DF  2  20 F8 B7         jsr parse_mnemonic
00B7E2  2  20 5D B8         jsr parse_asm_operand
00B7E5  2  20 AC B2         jsr next_token
00B7E8  2  90 03            bcc ca_find
00B7EA  2  4C 27 B2         jmp cmd_error
00B7ED  2               
00B7ED  2               ca_find:
00B7ED  2  20 83 B9         jsr find_opcode
00B7F0  2  B0 03            bcs ca_emit
00B7F2  2  4C 27 B2         jmp cmd_error
00B7F5  2               
00B7F5  2               ca_emit:
00B7F5  2  4C 06 BA         jmp emit_instruction

00E9C6  2               ; ------------------------------------------------------------
00E9C6  2               ; COMPUTE_REL_OFFSET
00E9C6  2               ;
00E9C6  2               ; Input:
00E9C6  2               ;   A  = instruction length (2 or 3)
00E9C6  2               ;   R0 = instruction address
00E9C6  2               ;   T0 = target address
00E9C6  2               ;
00E9C6  2               ; Output:
00E9C6  2               ;   A  = signed 8-bit relative offset
00E9C6  2               ;
00E9C6  2               ; Error:
00E9C6  2               ;   jumps to cmd_error if target is out of range
00E9C6  2               ; ------------------------------------------------------------
00E9C6  2               compute_rel_offset:
00E9C6  2  85 D4            sta parm_count
00E9C8  2               
00E9C8  2                   ; R3 = base = R0 + instruction length
00E9C8  2  A5 C6            lda R0L
00E9CA  2  18               clc
00E9CB  2  65 D4            adc parm_count
00E9CD  2  85 CC            sta R3L
00E9CF  2  A5 C7            lda R0H
00E9D1  2  69 00            adc #0
00E9D3  2  85 CD            sta R3H
00E9D5  2               
00E9D5  2                   ; diff = target - base   (wrapped 16-bit subtraction)
00E9D5  2  38               sec
00E9D6  2  A5 CE            lda T0L
00E9D8  2  E5 CC            sbc R3L
00E9DA  2  85 D0            sta T1L
00E9DC  2  A5 CF            lda T0H
00E9DE  2  E5 CD            sbc R3H
00E9E0  2  85 D1            sta T1H
00E9E2  2               
00E9E2  2                   ; valid if:
00E9E2  2                   ;   T1 = 00:00..00:7F   (+0 .. +127)
00E9E2  2                   ;   T1 = FF:80..FF:FF   (-128 .. -1)
00E9E2  2               
00E9E2  2  A5 D1            lda T1H
00E9E4  2  F0 07            beq cro_pos
00E9E6  2  C9 FF            cmp #$FF
00E9E8  2  F0 0C            beq cro_neg
00E9EA  2  4C 28 E2         jmp cmd_error
00E9ED  2               
00E9ED  2               cro_pos:
00E9ED  2  A5 D0            lda T1L
00E9EF  2  C9 80            cmp #$80
00E9F1  2  90 0C            bcc cro_ok
00E9F3  2  4C 28 E2         jmp cmd_error
00E9F6  2               
00E9F6  2               cro_neg:
00E9F6  2  A5 D0            lda T1L
00E9F8  2  C9 80            cmp #$80
00E9FA  2  B0 03            bcs cro_ok
00E9FC  2  4C 28 E2         jmp cmd_error
00E9FF  2               
00E9FF  2               cro_ok:
00E9FF  2  A5 D0            lda T1L
00EA01  2  60               rts

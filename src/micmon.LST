00EA11  2               ; ------------------------------------------------------------
00EA11  2               ; EMIT INSTRUCTION
00EA11  2               ; Uses asm_opcode, asm_mode and operand value(s).
00EA11  2               ; Updates MEM to next address.
00EA11  2               ; Writes nothing if relative offset is out of range.
00EA11  2               ; ------------------------------------------------------------
00EA11  2               emit_instruction:
00EA11  2  A5 D5            lda asm_mode
00EA13  2  20 33 E8         jsr get_oplen_from_mode
00EA16  2  85 D4            sta tmp
00EA18  2               
00EA18  2                   ; for relative forms, validate offset before storing opcode
00EA18  2  A5 D5            lda asm_mode
00EA1A  2  C9 0D            cmp #AM_REL
00EA1C  2  F0 07            beq ei_prep_rel
00EA1E  2  C9 0E            cmp #AM_ZPREL
00EA20  2  F0 0D            beq ei_prep_zprel
00EA22  2  4C 39 EA         jmp ei_store
00EA25  2               
00EA25  2               ei_prep_rel:
00EA25  2  A9 02            lda #2
00EA27  2  20 D5 E9         jsr compute_rel_offset
00EA2A  2  85 CF            sta T1H
00EA2C  2  4C 39 EA         jmp ei_store
00EA2F  2               
00EA2F  2               ei_prep_zprel:
00EA2F  2  A9 03            lda #3
00EA31  2  20 D5 E9         jsr compute_rel_offset
00EA34  2  85 CF            sta T1H
00EA36  2  4C 39 EA         jmp ei_store
00EA39  2               
00EA39  2               ei_store:
00EA39  2  A0 00            ldy #0
00EA3B  2  A5 D6            lda asm_opcode
00EA3D  2  91 C4            sta (R0L),y
00EA3F  2               
00EA3F  2  A5 D4            lda tmp
00EA41  2  C9 01            cmp #1
00EA43  2  F0 32            beq ei_finish
00EA45  2               
00EA45  2  A5 D5            lda asm_mode
00EA47  2  C9 0D            cmp #AM_REL
00EA49  2  F0 18            beq ei_rel
00EA4B  2  C9 0E            cmp #AM_ZPREL
00EA4D  2  F0 1D            beq ei_zprel
00EA4F  2               
00EA4F  2  A0 01            ldy #1
00EA51  2  A5 CC            lda T0L
00EA53  2  91 C4            sta (R0L),y
00EA55  2               
00EA55  2  A5 D4            lda tmp
00EA57  2  C9 02            cmp #2
00EA59  2  F0 1C            beq ei_finish
00EA5B  2               
00EA5B  2  C8               iny
00EA5C  2  A5 CD            lda T0H
00EA5E  2  91 C4            sta (R0L),y
00EA60  2  4C 77 EA         jmp ei_finish
00EA63  2               
00EA63  2               ei_rel:
00EA63  2  A0 01            ldy #1
00EA65  2  A5 CF            lda T1H
00EA67  2  91 C4            sta (R0L),y
00EA69  2  4C 77 EA         jmp ei_finish
00EA6C  2               
00EA6C  2               ei_zprel:
00EA6C  2  A0 01            ldy #1
00EA6E  2  A5 CE            lda T1L
00EA70  2  91 C4            sta (R0L),y
00EA72  2  C8               iny
00EA73  2  A5 CF            lda T1H
00EA75  2  91 C4            sta (R0L),y
00EA77  2               
00EA77  2               ei_finish:
00EA77  2  A5 D4            lda tmp
00EA79  2  20 83 E4         jsr add_R0_A
00EA7C  2  A5 C4            lda R0L
00EA7E  2  85 D0            sta MEML
00EA80  2  A5 C5            lda R0H
00EA82  2  85 D1            sta MEMH
00EA84  2  60               rts

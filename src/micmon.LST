00E65E  2  85 C4            sta jmpvec
00E660  2  E8               inx
00E661  2  BD BA E7         lda operand_vecs,x
00E664  2  85 C5            sta jmpvec+1
00E666  2  6C C4 00         jmp (jmpvec)

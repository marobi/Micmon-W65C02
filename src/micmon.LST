00E485  1  D0 02            bne inc_r2_done
00E487  1  E6 C9            inc R2H
00E489  1               inc_r2_done:
00E489  1  60               rts
00E48A  1               
00E48A  1               add_R0_A:
00E48A  1  18               clc
00E48B  1  65 C4            adc R0L
00E48D  1  85 C4            sta R0L
00E48F  1  90 02            bcc add_r0_done
00E491  1  E6 C5            inc R0H
00E493  1               add_r0_done:
00E493  1  60               rts
00E494  1               
00E494  1               add_R1_A:
00E494  1  18               clc
00E495  1  65 C6            adc R1L
00E497  1  85 C6            sta R1L
00E499  1  90 02            bcc add_r1_done
00E49B  1  E6 C7            inc R1H
00E49D  1               add_r1_done:
00E49D  1  60               rts
00E49E  1               
00E49E  1               add_T1_T0:
00E49E  1  18               clc
00E49F  1  A5 CC            lda T0L
00E4A1  1  65 CE            adc T1L
00E4A3  1  85 CC            sta T0L
00E4A5  1  A5 CD            lda T0H
00E4A7  1  65 CF            adc T1H
00E4A9  1  85 CD            sta T0H
00E4AB  1  60               rts
00E4AC  1               
00E4AC  1               ; ------------------------------------------------------------
00E4AC  1               ; ADD_R2_A
00E4AC  1               ; Add unsigned byte in A to 16-bit register R2.
00E4AC  1               ; ------------------------------------------------------------
00E4AC  1               add_R2_A:
00E4AC  1  18               clc
00E4AD  1  65 C8            adc R2L
00E4AF  1  85 C8            sta R2L
00E4B1  1  90 02            bcc add_r2_done
00E4B3  1  E6 C9            inc R2H
00E4B5  1               add_r2_done:
00E4B5  1  60               rts
00E4B6  1               
00E4B6  1               cmp_R2_R1:
00E4B6  1  A5 C9            lda R2H
00E4B8  1  C5 C7            cmp R1H
00E4BA  1  D0 04            bne cmp_r2_r1_done
00E4BC  1  A5 C8            lda R2L
00E4BE  1  C5 C6            cmp R1L
00E4C0  1               cmp_r2_r1_done:
00E4C0  1  60               rts
00E4C1  1               
00E4C1  1               ;------------------------------------------------
00E4C1  1               print_hex8:
00E4C1  1  48               pha
00E4C2  1  4A               lsr
00E4C3  1  4A               lsr
00E4C4  1  4A               lsr
00E4C5  1  4A               lsr
00E4C6  1  20 CC E4         jsr print_hex_digit
00E4C9  1  68               pla
00E4CA  1  29 0F            and #$0F
00E4CC  1               ;    jsr print_hex_digit
00E4CC  1               ;    rts
00E4CC  1               
00E4CC  1               print_hex_digit:
00E4CC  1  C9 0A            cmp #10
00E4CE  1  90 06            bcc print_hex_num
00E4D0  1  18               clc
00E4D1  1  69 37            adc #'A'-10
00E4D3  1  4C 09 E5         jmp putchar
00E4D6  1               
00E4D6  1               print_hex_num:
00E4D6  1  18               clc
00E4D7  1  69 30            adc #'0'
00E4D9  1  4C 09 E5         jmp putchar
00E4DC  1               
00E4DC  1               ; ------------------------------------------------------------
00E4DC  1               ; PRINT_HEX16
00E4DC  1               ; Print 16-bit value in hexadecimal.
00E4DC  1               ;
00E4DC  1               ; Input
00E4DC  1               ;   A = high byte
00E4DC  1               ;   X = low byte
00E4DC  1               ; ------------------------------------------------------------
00E4DC  1               print_hex16:
00E4DC  1  DA               phx
00E4DD  1  20 C1 E4         jsr print_hex8
00E4E0  1  FA               plx
00E4E1  1  8A               txa
00E4E2  1  4C C1 E4         jmp print_hex8
00E4E5  1               
00E4E5  1               
00E4E5  1               print_ascii:
00E4E5  1  C9 20            cmp #$20
00E4E7  1  90 07            bcc ascii_dot
00E4E9  1  C9 7F            cmp #$7F
00E4EB  1  B0 03            bcs ascii_dot
00E4ED  1  4C 09 E5         jmp putchar
00E4F0  1               
00E4F0  1               
00E4F0  1               ascii_dot:
00E4F0  1  A9 2E            lda #'.'
00E4F2  1  4C 09 E5         jmp putchar
00E4F5  1               
00E4F5  1               print_space:
00E4F5  1  A9 20            lda #' '
00E4F7  1  4C 09 E5         jmp putchar
00E4FA  1               
00E4FA  1               newline:
00E4FA  1  A9 0D            lda #$0D
00E4FC  1               ;    jsr putchar
00E4FC  1               ;    lda #$0A
00E4FC  1  4C 09 E5         jmp putchar
00E4FF  1               
00E4FF  1               print_prompt:
00E4FF  1  A9 4D        		lda #<prompt_text
00E501  1  A2 EF            ldx #>prompt_text
00E503  1  4C 5F E2         jmp print_str
00E506  1               
00E506  1               ; ------------------------------------------------------------
00E506  1               ; I/O
00E506  1               ; ------------------------------------------------------------
00E506  1               getchar
00E506  1  4C 00 FE     		jmp BIOS_INCHAR
00E509  1               
00E509  1               putchar:
00E509  1  4C 03 FE         jmp BIOS_OUTCHAR
00E50C  1               
00E50C  1               ; ------------------------------------------------------------
00E50C  1               ; CHECK_ABORT
00E50C  1               ; Test if the user pressed ^C.
00E50C  1               ;
00E50C  1               ; Returns
00E50C  1               ;   C = 1  abort requested
00E50C  1               ;   C = 0  continue
00E50C  1               ;
00E50C  1               ; Wrapper around BIOS_STPKEY so the monitor depends only on
00E50C  1               ; this primitive instead of calling the BIOS everywhere.
00E50C  1               ; ------------------------------------------------------------
00E50C  1               check_abort:
00E50C  1  4C 09 FE         jmp BIOS_STPKEY
00E50F  1               
00E50F  1               ; ------------------------------------------------------------
00E50F  1               ; GETLINE
00E50F  1               ; Read a line from input into linebuf.
00E50F  1               ;
00E50F  1               ; Assumptions
00E50F  1               ; - host terminal performs line editing
00E50F  1               ; - CR (0x0D) terminates the line
00E50F  1               ; - line is zero terminated
00E50F  1               ; - max length = 127 characters
00E50F  1               ; ------------------------------------------------------------
00E50F  1               getline:
00E50F  1  A2 00            ldx #0
00E511  1               
00E511  1               getline_loop:
00E511  1  20 06 E5         jsr getchar
00E514  1  C9 0D            cmp #$0D
00E516  1  F0 0F            beq getline_done
00E518  1  C9 0A            cmp #$0A
00E51A  1  F0 0B            beq getline_done
00E51C  1               
00E51C  1  E0 3B            cpx #59
00E51E  1  B0 F1            bcs getline_loop
00E520  1               
00E520  1  9D 00 02         sta linebuf,x
00E523  1  E8               inx
00E524  1  4C 11 E5         jmp getline_loop
00E527  1               
00E527  1               getline_done:
00E527  1  A9 00            lda #0
00E529  1  9D 00 02         sta linebuf,x
00E52C  1  60               rts
00E52D  1               
00E52D  1               print_error:
00E52D  1  A9 3F        		lda #'?'
00E52F  1  20 09 E5     		jsr putchar
00E532  1  4C FA E4     		jmp newline
00E535  1               
00E535  1               ; command implementations
00E535  1               .include "disasm.asm"
00E535  2               ; ------------------------------------------------------------
00E535  2               ; DISASSEMBLER COMMAND
00E535  2               ; Syntax:
00E535  2               ;   D
00E535  2               ;   D start
00E535  2               ;   D start end
00E535  2               ;
00E535  2               ; Default start is MEM.
00E535  2               ; Default length is 12 instructions.
00E535  2               ; MEM is updated to the next address after the disassembly.
00E535  2               ; ------------------------------------------------------------
00E535  2               cmd_disasm:
00E535  2  20 1C E4         jsr advance_lineptr
00E538  2  20 AF E2         jsr next_token
00E53B  2  90 19            bcc dis_default
00E53D  2               
00E53D  2  20 00 E3         jsr parse_word
00E540  2  20 46 E4         jsr copy_T0_R0
00E543  2               
00E543  2  20 AF E2         jsr next_token
00E546  2  90 11            bcc dis_one_param
00E548  2               
00E548  2  20 00 E3         jsr parse_word
00E54B  2  20 4F E4         jsr copy_T0_R1
00E54E  2               
00E54E  2               dis_prepare_range:
00E54E  2  20 AF E2         jsr next_token
00E551  2  90 27            bcc dis_range_ok
00E553  2  4C 2B E2         jmp cmd_error
00E556  2               
00E556  2               dis_default:
00E556  2  20 6A E4         jsr copy_MEM_R0
00E559  2               
00E559  2               dis_one_param:
00E559  2  20 58 E4         jsr copy_R0_R1
00E55C  2  A9 0C            lda #12
00E55E  2  85 D2            sta parm_count
00E560  2               
00E560  2               dis_prepare_count:
00E560  2  20 AF E2         jsr next_token
00E563  2  90 03            bcc dis_count_ok
00E565  2  4C 2B E2         jmp cmd_error
00E568  2               
00E568  2               dis_count_ok:
00E568  2  20 61 E4         jsr copy_R0_R2
00E56B  2               
00E56B  2               dis_loop_count:
00E56B  2  20 0C E5         jsr check_abort
00E56E  2  B0 1F            bcs dis_abort
00E570  2  20 92 E5         jsr disasm_line
00E573  2  C6 D2            dec parm_count
00E575  2  D0 F4            bne dis_loop_count
00E577  2  4C 73 E4         jmp copy_R2_MEM
00E57A  2               
00E57A  2               dis_range_ok:
00E57A  2  20 61 E4         jsr copy_R0_R2
00E57D  2               
00E57D  2               dis_loop_range:
00E57D  2  20 0C E5         jsr check_abort
00E580  2  B0 0D            bcs dis_abort
00E582  2  20 92 E5         jsr disasm_line
00E585  2  20 B6 E4         jsr cmp_R2_R1
00E588  2  90 F3            bcc dis_loop_range
00E58A  2  F0 F1            beq dis_loop_range
00E58C  2  4C 73 E4         jmp copy_R2_MEM
00E58F  2               
00E58F  2               dis_abort:
00E58F  2  4C 2B E2         jmp cmd_error
00E592  2               
00E592  2               ; ------------------------------------------------------------
00E592  2               ; DISASSEMBLE ONE LINE
00E592  2               ;
00E592  2               ; Input
00E592  2               ;   R2 = current PC
00E592  2               ;
00E592  2               ; Internal use
00E592  2               ;   T0L = opcode
00E592  2               ;   R3L = addressing mode
00E592  2               ;   R3H = instruction length
00E592  2               ;   T1  = pointer to mnemonic string
00E592  2               ;
00E592  2               ; Output
00E592  2               ;   prints one disassembly line
00E592  2               ;   advances R2 by instruction length
00E592  2               ; ------------------------------------------------------------
00E592  2               disasm_line:
00E592  2  A5 C8            lda R2L
00E594  2  85 CC            sta T0L
00E596  2  A5 C9            lda R2H
00E598  2  85 CD            sta T0H
00E59A  2  20 A9 E2         jsr print_address_T0_2spaces
00E59D  2               
00E59D  2  A0 00            ldy #0
00E59F  2  B1 C8            lda (R2L),y
00E5A1  2  85 CC            sta T0L
00E5A3  2  AA               tax
00E5A4  2               
00E5A4  2  BD 38 EC         lda mode_table,x
00E5A7  2  85 CA            sta R3L
00E5A9  2  20 3A E8         jsr get_oplen_from_mode
00E5AC  2  85 CB            sta R3H
00E5AE  2               
00E5AE  2  20 24 E8         jsr get_mnemonic_id_x
00E5B1  2  20 28 E8         jsr get_mnemonic_ptr_id
00E5B4  2               
00E5B4  2  20 CB E5         jsr print_disasm_bytes
00E5B7  2  20 F5 E4         jsr print_space
00E5BA  2  20 F5 E4         jsr print_space
00E5BD  2  20 FB E5         jsr print_mnemonic
00E5C0  2  20 05 E6         jsr print_operand
00E5C3  2  20 FA E4         jsr newline
00E5C6  2               
00E5C6  2  A5 CB            lda R3H
00E5C8  2  4C AC E4         jmp add_R2_A
00E5CB  2               
00E5CB  2               
00E5CB  2               ; ------------------------------------------------------------
00E5CB  2               ; PRINT RAW BYTES FIELD
00E5CB  2               ; Shows 1..3 actual instruction bytes and pads to fixed width.
00E5CB  2               ; R3H = instruction length
00E5CB  2               ; ------------------------------------------------------------
00E5CB  2               print_disasm_bytes:
00E5CB  2  A0 00            ldy #0
00E5CD  2               
00E5CD  2               pdb_real_loop:
00E5CD  2  C4 CB            cpy R3H
00E5CF  2  F0 0E            beq pdb_pad
00E5D1  2  B1 C8            lda (R2L),y
00E5D3  2  20 C1 E4         jsr print_hex8
00E5D6  2  20 F5 E4         jsr print_space
00E5D9  2  C8               iny
00E5DA  2  C0 03            cpy #3
00E5DC  2  D0 EF            bne pdb_real_loop
00E5DE  2  60               rts
00E5DF  2               
00E5DF  2               pdb_pad:
00E5DF  2  C0 03            cpy #3
00E5E1  2  F0 11            beq pdb_done
00E5E3  2  A9 20            lda #' '
00E5E5  2  20 09 E5         jsr putchar
00E5E8  2  A9 20            lda #' '
00E5EA  2  20 09 E5         jsr putchar
00E5ED  2  20 F5 E4         jsr print_space
00E5F0  2  C8               iny
00E5F1  2  4C DF E5         jmp pdb_pad
00E5F4  2               
00E5F4  2               pdb_done:
00E5F4  2  60               rts
00E5F5  2               
00E5F5  2               ; ------------------------------------------------------------
00E5F5  2               ; GAP BETWEEN BYTE FIELD AND MNEMONIC
00E5F5  2               ; ------------------------------------------------------------
00E5F5  2               print_disasm_gap:
00E5F5  2  20 F5 E4         jsr print_space
00E5F8  2  4C F5 E4         jmp print_space
00E5FB  2               
00E5FB  2               ; ------------------------------------------------------------
00E5FB  2               ; PRINT MNEMONIC
00E5FB  2               ; T1 = pointer to zero-terminated mnemonic string
00E5FB  2               ; ------------------------------------------------------------
00E5FB  2               print_mnemonic:
00E5FB  2  A5 CE            lda T1L
00E5FD  2  A6 CF            ldx T1H
00E5FF  2  20 5F E2         jsr print_str
00E602  2  4C F5 E4         jmp print_space
00E605  2               
00E605  2               ; ------------------------------------------------------------
00E605  2               ; PRINT OPERAND
00E605  2               ; R3L = addressing mode
00E605  2               ; R2  = current instruction address
00E605  2               ; ------------------------------------------------------------
00E605  2               print_operand:
00E605  2  A5 CA            lda R3L
00E607  2  0A               asl
00E608  2  AA               tax
00E609  2  BD 73 E7         lda operand_vecs,x
00E60C  2  85 C2            sta jmpvec
00E60E  2  E8               inx
00E60F  2  BD 73 E7         lda operand_vecs,x
00E612  2  85 C3            sta jmpvec+1
00E614  2  6C C2 00         jmp (jmpvec)
00E617  2               
00E617  2               ; ------------------------------------------------------------
00E617  2               ; ADDRESSING MODE FORMATTERS
00E617  2               ; ------------------------------------------------------------
00E617  2               fmt_imp:
00E617  2  60               rts
00E618  2               
00E618  2               fmt_acc:
00E618  2  A9 41            lda #'A'
00E61A  2  4C 09 E5         jmp putchar
00E61D  2               
00E61D  2               fmt_imm:
00E61D  2  A9 23            lda #'#'
00E61F  2  20 09 E5         jsr putchar
00E622  2  A9 24            lda #'$'
00E624  2  20 09 E5         jsr putchar
00E627  2  A0 01            ldy #1
00E629  2  B1 C8            lda (R2L),y
00E62B  2  4C C1 E4         jmp print_hex8
00E62E  2               
00E62E  2               fmt_zp:
00E62E  2  A9 24            lda #'$'
00E630  2  20 09 E5         jsr putchar
00E633  2  A0 01            ldy #1
00E635  2  B1 C8            lda (R2L),y
00E637  2  4C C1 E4         jmp print_hex8
00E63A  2               
00E63A  2               fmt_zpx:
00E63A  2  20 2E E6         jsr fmt_zp
00E63D  2  A9 2C            lda #','
00E63F  2  20 09 E5         jsr putchar
00E642  2  A9 58            lda #'X'
00E644  2  4C 09 E5         jmp putchar
00E647  2               
00E647  2               fmt_zpy:
00E647  2  20 2E E6         jsr fmt_zp
00E64A  2  A9 2C            lda #','
00E64C  2  20 09 E5         jsr putchar
00E64F  2  A9 59            lda #'Y'
00E651  2  4C 09 E5         jmp putchar
00E654  2               
00E654  2               fmt_abs:
00E654  2  A9 24            lda #'$'
00E656  2  20 09 E5         jsr putchar
00E659  2  A0 01            ldy #1
00E65B  2  B1 C8            lda (R2L),y
00E65D  2  AA               tax

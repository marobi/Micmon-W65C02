000000r 1               ; ---------------------------------------------------------------------------
000000r 1               ; MICMON – Minimal Interactive Command Monitor for the W65C02
000000r 1               ; (c) 2026 Rien Matthijsse
000000r 1               ; ---------------------------------------------------------------------------
000000r 1               .include "readme.asm"
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; MICMON – Minimal Interactive Command Monitor for the W65C02
000000r 2               ; (c) 2026 Rien Matthijsse
000000r 2               ;
000000r 2               ; Overview
000000r 2               ; --------
000000r 2               ; Micmon is a compact machine-level monitor for the W65C02, designed to fit
000000r 2               ; within a 4 KB ROM. It provides essential debugging, inspection and control
000000r 2               ; facilities while remaining small, deterministic, and fully self-hosting.
000000r 2               ;
000000r 2               ; The monitor follows a strict "round-trip" philosophy: all output is valid
000000r 2               ; input. Any command output (e.g. memory dumps) can be edited and fed back
000000r 2               ; into the monitor for execution. This enables interactive workflows using
000000r 2               ; external terminals or VDUs with line editing capabilities.
000000r 2               ;
000000r 2               ; Design Goals
000000r 2               ; ------------
000000r 2               ; - Minimal footprint (fits in 4 KB ROM)
000000r 2               ; - Deterministic behaviour (no hidden state, no dynamic allocation)
000000r 2               ; - Table-driven architecture (command dispatch, disassembler, assembler)
000000r 2               ; - Round-trip capable output (monitor output is executable input)
000000r 2               ; - Tight integration with external VDU/GDU systems
000000r 2               ;
000000r 2               ; Functional Scope
000000r 2               ; ----------------
000000r 2               ; - Memory inspection and modification
000000r 2               ; - CPU register inspection and editing
000000r 2               ; - Program execution control (GO)
000000r 2               ; - Disassembler (W65C02 complete)
000000r 2               ; - Inline assembler (single-line, immediate emission)
000000r 2               ; - Command-driven interface with single-character dispatch
000000r 2               ;
000000r 2               ; Command Summary
000000r 2               ; ---------------
000000r 2               ;   H          Help / command overview
000000r 2               ;   M addr     Dump memory
000000r 2               ;   > addr     Modify memory (hex byte stream)
000000r 2               ;   R          Show CPU registers
000000r 2               ;   ;          Modify CPU registers
000000r 2               ;   G [addr]   Execute code at address
000000r 2               ;   D [addr]   Disassembler
000000r 2               ;   A [addr]   Assemble single instruction at address
000000r 2               ;
000000r 2               ; Notes:
000000r 2               ; - Default address is MEM unless explicitly provided
000000r 2               ; - Commands are line-oriented and CR-terminated
000000r 2               ; - Where possible: output format is compatible with monitor input (round-trip)
000000r 2               ;
000000r 2               ; Execution Model
000000r 2               ; ---------------
000000r 2               ; - RESET:
000000r 2               ;     Initializes CPU state and monitor environment
000000r 2               ;     Enters monitor via BRK vector
000000r 2               ;
000000r 2               ; - BRK handler:
000000r 2               ;     Saves full CPU context (A, X, Y, P, SP, PC)
000000r 2               ;     Transfers control to command interpreter
000000r 2               ;
000000r 2               ; - Command loop:
000000r 2               ;     Line-oriented input
000000r 2               ;     Single-character command dispatch via table
000000r 2               ;     Commands operate directly on memory and CPU image
000000r 2               ;
000000r 2               ; Interaction Model
000000r 2               ; -----------------
000000r 2               ; Micmon assumes the host terminal or VDU performs line editing.
000000r 2               ; Input is processed per line (CR-terminated).
000000r 2               ;
000000r 2               ; Output is formatted to be re-consumable:
000000r 2               ;
000000r 2               ;     M 0200 020F
000000r 2               ;     > 0200 A9 01 8D 00 02 ...
000000r 2               ;
000000r 2               ; Can be edited into:
000000r 2               ;
000000r 2               ;     > 0200 A9 FF 8D 00 02
000000r 2               ;
000000r 2               ; and executed directly by the monitor.
000000r 2               ;
000000r 2               ; Parameter Formats
000000r 2               ; -----------------
000000r 2               ; All numeric parameters support multiple input formats. The parser auto-
000000r 2               ; detects the format based on prefix or content.
000000r 2               ;
000000r 2               ; Supported formats:
000000r 2               ;
000000r 2               ;   Hexadecimal (default)
000000r 2               ;     0200      $0200
000000r 2               ;
000000r 2               ;   Decimal
000000r 2               ;     +123
000000r 2               ;
000000r 2               ;   Binary
000000r 2               ;     %10101010
000000r 2               ;
000000r 2               ;   ASCII
000000r 2               ;     'A        -> $41
000000r 2               ;
000000r 2               ; Rules:
000000r 2               ; - Hex is assumed if no prefix is present
000000r 2               ;       $   = hex (optional, since default)
000000r 2               ;       %   = binary
000000r 2               ;       +   = decimal
000000r 2               ;       '   = ASCII single byte
000000r 2               ;
000000r 2               ; - All parsed values result in:
000000r 2               ;       T0 = value (byte or word)
000000r 2               ;       value_size >= 1 indicates success
000000r 2               ;
000000r 2               ; - Commands are literal
000000r 2               ;
000000r 2               ; Examples:
000000r 2               ;   M $C000
000000r 2               ;   M %1100000000000000
000000r 2               ;   M +49152
000000r 2               ;
000000r 2               ;   > 0200 'A $42 %01000011
000000r 2               ;
000000r 2               ;   A 0300 LDA #'A
000000r 2               ;   A 0302 LDA #$41
000000r 2               ;
000000r 2               ; Architecture Notes
000000r 2               ; ------------------
000000r 2               ; - All decoding (disassembler/assembler) is table-driven
000000r 2               ; - Opcode metadata shared between assembler and disassembler
000000r 2               ; - Zero-page used from $00C0-$00DF
000000r 2               ; - Strict separation between parsing, decoding and execution
000000r 2               ;
000000r 2               ; Extensibility
000000r 2               ; -------------
000000r 2               ; Micmon is intentionally designed for easy extension:
000000r 2               ;
000000r 2               ; - New commands can be added by inserting entries in:
000000r 2               ;       cmd_chars / cmd_addrs tables
000000r 2               ;
000000r 2               ; - No central switch-case logic: dispatch is fully table-driven
000000r 2               ; - Parsing helpers (parse_word, next_token, etc.) are reusable
000000r 2               ; - Disassembler and assembler share data tables, reducing duplication
000000r 2               ; - New addressing modes or instructions require only table updates
000000r 2               ;
000000r 2               ; This allows incremental growth without restructuring the monitor core.
000000r 2               ;
000000r 2               ; Limitations
000000r 2               ; -----------
000000r 2               ; - No multi-line assembly or label resolution
000000r 2               ; - No expression evaluator
000000r 2               ; - Branch range limited to signed 8-bit (hardware constraint)
000000r 2               ;
000000r 2               ; Target
000000r 2               ; ------
000000r 2               ; WDC W65C02 (fully supported instruction set)
000000r 2               ;
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               
000000r 1               
000000r 1               	.setcpu "65C02"
000000r 1               
000000r 1               .include "../bios/bios.h"
000000r 2               ;
000000r 2               ; BIOS jumptable + ...
000000r 2               ;
000000r 2               BIOS_CMD_PORT   =   $D002
000000r 2               BIOS_STAT_PORT  =   $D003
000000r 2               BIOS_SYNC_PORT  =   $D004
000000r 2               
000000r 2               BIOS_BASE       =  	$F000
000000r 2               BIOS_INCHAR     =   BIOS_BASE
000000r 2               BIOS_OUTCHAR    =   BIOS_BASE+3
000000r 2               BIOS_INKEY      =   BIOS_BASE+6
000000r 2               BIOS_STPKEY		=	BIOS_BASE+9
000000r 2               BIOS_CONTEXT    =   BIOS_BASE+12
000000r 2               
000000r 1               
000000r 1               	.segment "ZEROPAGE"
000000r 1               	.org $00C0								; nicer listing
0000C0  1               
0000C0  1               ; IRQ hander vector
0000C0  1  xx           irq_vecL:   .res 1
0000C1  1  xx           irq_vecH:   .res 1
0000C2  1               
0000C2  1               ; parser / dispatcher pointers
0000C2  1  xx xx        lineptr:    .res 2
0000C4  1  xx xx        jmpvec:     .res 2
0000C6  1               
0000C6  1               ; 16-bit working registers for commands
0000C6  1  xx           R0L:        .res 1
0000C7  1  xx           R0H:        .res 1
0000C8  1  xx           R1L:        .res 1
0000C9  1  xx           R1H:        .res 1
0000CA  1  xx           R2L:        .res 1
0000CB  1  xx           R2H:        .res 1
0000CC  1  xx           R3L:        .res 1
0000CD  1  xx           R3H:        .res 1
0000CE  1               
0000CE  1               ; temporary registers used by parser and utility routines
0000CE  1  xx           T0L:        .res 1
0000CF  1  xx           T0H:        .res 1
0000D0  1  xx           T1L:        .res 1
0000D1  1  xx           T1H:        .res 1
0000D2  1               
0000D2  1               ; monitor remembers last referenced memory address
0000D2  1  xx           MEML:       .res 1
0000D3  1  xx           MEMH:       .res 1
0000D4  1               
0000D4  1               ; parser state
0000D4  1  xx           parm_count: .res 1
0000D5  1  xx           value_size: .res 1
0000D6  1  xx           tmp:        .res 1
0000D7  1               
0000D7  1  xx           asm_mode:   .res 1
0000D8  1  xx           asm_opcode: .res 1
0000D9  1  xx           mnem_len:   .res 1
0000DA  1               
0000DA  1               ; context
0000DA  1  xx           save_sp:	.res 1
0000DB  1               
0000DB  1               	.segment "BSS"
0000DB  1               	.org $0200							; nicer listing
000200  1               
000200  1               ; input buffer
000200  1  xx xx xx xx  linebuf:    .res 40
000204  1  xx xx xx xx  
000208  1  xx xx xx xx  
000228  1               
000228  1               ; saved CPU image
000228  1  xx           reg_pch:    .res 1
000229  1  xx           reg_pcl:    .res 1
00022A  1  xx           reg_sr:     .res 1
00022B  1  xx           reg_a:      .res 1
00022C  1  xx           reg_x:      .res 1
00022D  1  xx           reg_y:      .res 1
00022E  1  xx           reg_sp:     .res 1
00022F  1               
00022F  1               	.segment "CODE"
00022F  1               	.org $B000				; nicer listing
00B000  1               
00B000  1               ; ------------------------------------------------------------
00B000  1               ; RESET
00B000  1               ; Basic CPU setup, monitor state initialization, then enter
00B000  1               ; the monitor through BRK so startup uses the normal entry path.
00B000  1               ; ------------------------------------------------------------
00B000  1               	.export reset
00B000  1               reset:
00B000  1  78               sei						; disable interrupts
00B001  1  D8               cld
00B002  1  A2 FF            ldx #$FF
00B004  1  9A               txs						; init stack
00B005  1               
00B005  1  64 D2            stz MEML
00B007  1  64 D3            stz MEMH
00B009  1  A9 29        	lda #<context_switch	; set interrupt vector
00B00B  1  85 C0            sta irq_vecL
00B00D  1  A9 B0        	lda #>context_switch
00B00F  1  85 C1            sta irq_vecH
00B011  1               
00B011  1  A9 36            lda #<welcome_text		; say hello
00B013  1  A2 BF            ldx #>welcome_text
00B015  1  20 7F B2         jsr print_str
00B018  1               
00B018  1  00           	brk						; enter monitor
00B019  1               
00B019  1               ; ------------------------------------------------------------
00B019  1               ; IRQ / BRK ENTRY
00B019  1               ; Shared entry for hardware IRQ and BRK.
00B019  1               ;
00B019  1               ; BRK enters the monitor.
00B019  1               ; IRQ dispatches through irq_vec
00B019  1               ; ------------------------------------------------------------
00B019  1               	.export irq_entry
00B019  1               irq_entry:
00B019  1  48               pha						; save rest of context
00B01A  1  DA               phx
00B01B  1  5A               phy
00B01C  1               
00B01C  1  BA               tsx
00B01D  1  86 DA        	stx save_sp				; save current SP
00B01F  1  BD 04 01         lda $0104,x             ; stacked SR after PHA/PHX/PHY
00B022  1  29 10            and #$10
00B024  1  D0 23            bne brk_entry			; BREAK
00B026  1               
00B026  1               irq_dispatch:				; IRQ
00B026  1  6C C0 00         jmp (irq_vecL)
00B029  1               
00B029  1               ; ------------------------------------------------------------
00B029  1               ; expects the full context to be saved on stack
00B029  1               ; micmon must be shared between all contexts and loaded last
00B029  1               ;
00B029  1               context_switch:				; for now default irq vector
00B029  1  AD 04 D0     	lda BIOS_SYNC_PORT
00B02C  1  F0 FB        	beq context_switch		; wait for prev release, should not happen
00B02E  1               							; now 1
00B02E  1  9C 04 D0     	stz BIOS_SYNC_PORT		; arm
00B031  1               							; now 0
00B031  1               wait_ack:					; rp2350 will perform context switch
00B031  1  AD 04 D0     	lda BIOS_SYNC_PORT
00B034  1  F0 FB        	beq wait_ack			; wait for completion
00B036  1               							; now 1
00B036  1  AD 03 D0     	lda BIOS_STAT_PORT		; what to do?
00B039  1  C9 01        	cmp #$01				; when 1
00B03B  1  F0 03        	beq irq_restore			; restore context
00B03D  1  6C FC FF     	jmp ($FFFC)				; else exec reset
00B040  1               
00B040  1               irq_restore:				; context switched
00B040  1  A6 DA        	ldx save_sp
00B042  1  9A           	txs						; restore SP
00B043  1  7A               ply						; restore context
00B044  1  FA               plx
00B045  1  68               pla
00B046  1  40               rti						; and continue
00B047  1               
00B047  1               	.export nmi_entry
00B047  1               nmi_entry:
00B047  1  40               rti						; stub
00B048  1               
00B048  1               print_context:
00B048  1  BA               tsx
00B049  1               
00B049  1               ; ------------------------------------------------------------
00B049  1               ; BRK ENTRY
00B049  1               ; Save CPU state into monitor RAM and discard interrupt frame.
00B049  1               ; BRK pushes PC+2, so saved PC is corrected back to BRK opcode.
00B049  1               ; ------------------------------------------------------------
00B049  1               brk_entry:
00B049  1  68               pla						; save context
00B04A  1  8D 2D 02         sta reg_y
00B04D  1  68               pla
00B04E  1  8D 2C 02         sta reg_x
00B051  1  68               pla
00B052  1  8D 2B 02         sta reg_a
00B055  1  68               pla
00B056  1  8D 2A 02         sta reg_sr
00B059  1  68               pla
00B05A  1  8D 29 02         sta reg_pcl
00B05D  1  68               pla
00B05E  1  8D 28 02         sta reg_pch
00B061  1               
00B061  1  BA               tsx
00B062  1  8E 2E 02         stx reg_sp
00B065  1               
00B065  1  D8               cld
00B066  1  38               sec						; correct PC =-2
00B067  1  AD 29 02         lda reg_pcl
00B06A  1  E9 02            sbc #2
00B06C  1  8D 29 02         sta reg_pcl
00B06F  1  AD 28 02         lda reg_pch
00B072  1  E9 00            sbc #0
00B074  1  8D 28 02         sta reg_pch
00B077  1               
00B077  1               ; ------------------------------------------------------------
00B077  1               ; MONITOR ENTRY
00B077  1               ; Every BRK entry shows the saved registers, then drops into
00B077  1               ; the command loop.
00B077  1               ; ------------------------------------------------------------
00B077  1               monitor_entry:
00B077  1  58           	cli					; enable interrupts
00B078  1  20 56 B1         jsr show_registers	; show regs and fall through
00B07B  1  20 2A B5     	jsr print_prompt
00B07E  1               
00B07E  1               ; ------------------------------------------------------------
00B07E  1               ; MAIN MONITOR LOOP
00B07E  1               ; Read one full line, execute it
00B07E  1               ; ------------------------------------------------------------
00B07E  1               monitor_loop:
00B07E  1  20 31 B5         jsr getline					; read line
00B081  1  A9 00            lda #<linebuf
00B083  1  85 C2            sta lineptr
00B085  1  A9 02            lda #>linebuf
00B087  1  85 C3            sta lineptr+1
00B089  1               
00B089  1               execute_line:
00B089  1  20 3F B4         jsr skip_spaces
00B08C  1  A0 00            ldy #0
00B08E  1  B1 C2            lda (lineptr),y			; get cmd
00B090  1  F0 0A            beq exec_done
00B092  1  20 4E B4         jsr toupper
00B095  1  91 C2            sta (lineptr),y			; save uppercase
00B097  1  20 A2 B0         jsr dispatch_command
00B09A  1  B0 03        	bcs exec_nopr
00B09C  1               exec_done:
00B09C  1  20 2A B5     	jsr print_prompt
00B09F  1               
00B09F  1               exec_nopr:
00B09F  1  4C 7E B0         jmp monitor_loop
00B0A2  1               
00B0A2  1               ; ------------------------------------------------------------
00B0A2  1               ; COMMAND DISPATCH
00B0A2  1               ; ------------------------------------------------------------
00B0A2  1               dispatch_command:
00B0A2  1  A0 00            ldy #0
00B0A4  1  B1 C2            lda (lineptr),y
00B0A6  1  85 D6            sta tmp
00B0A8  1               
00B0A8  1  A2 00            ldx #0
00B0AA  1               dispatch_loop:
00B0AA  1  BD 1A BF         lda cmd_chars,x
00B0AD  1  F0 19            beq dispatch_error
00B0AF  1  C5 D6            cmp tmp
00B0B1  1  F0 04            beq dispatch_found
00B0B3  1  E8               inx
00B0B4  1  4C AA B0         jmp dispatch_loop
00B0B7  1               
00B0B7  1               dispatch_found:
00B0B7  1  8A               txa
00B0B8  1  0A               asl
00B0B9  1  AA               tax
00B0BA  1  BD 24 BF         lda cmd_addrs,x
00B0BD  1  85 C4            sta jmpvec
00B0BF  1  E8               inx
00B0C0  1  BD 24 BF         lda cmd_addrs,x
00B0C3  1  85 C5            sta jmpvec+1
00B0C5  1  6C C4 00         jmp (jmpvec)
00B0C8  1               
00B0C8  1               dispatch_error:
00B0C8  1  4C 46 B2         jmp cmd_error
00B0CB  1               
00B0CB  1               ; ------------------------------------------------------------
00B0CB  1               ; RESET COMMAND
00B0CB  1               ; ------------------------------------------------------------
00B0CB  1               cmd_reset:
00B0CB  1  4C 00 B0     		jmp reset
00B0CE  1               
00B0CE  1               ; ------------------------------------------------------------
00B0CE  1               ; MEMORY DUMP COMMAND
00B0CE  1               ; Syntax:
00B0CE  1               ;   M
00B0CE  1               ;   M start
00B0CE  1               ;   M start end
00B0CE  1               ;
00B0CE  1               ; Default start is MEM.
00B0CE  1               ; Default length is 12 lines * 8 bytes = 96 bytes.
00B0CE  1               ; MEM is updated to the next address after the dump.
00B0CE  1               ; ------------------------------------------------------------
00B0CE  1               cmd_mem:
00B0CE  1  20 38 B4     	jsr advance_lineptr
00B0D1  1               
00B0D1  1  20 CB B2         jsr next_token
00B0D4  1  90 14            bcc mem_default
00B0D6  1               
00B0D6  1  20 1C B3         jsr parse_word
00B0D9  1  20 62 B4         jsr copy_T0_R0
00B0DC  1               
00B0DC  1  20 CB B2         jsr next_token
00B0DF  1  90 0C            bcc mem_one_param
00B0E1  1               
00B0E1  1  20 1C B3         jsr parse_word
00B0E4  1  20 6B B4         jsr copy_T0_R1
00B0E7  1  4C F5 B0         jmp mem_prepare
00B0EA  1               
00B0EA  1               mem_default:
00B0EA  1  20 86 B4         jsr copy_MEM_R0
00B0ED  1               mem_one_param:
00B0ED  1  20 74 B4         jsr copy_R0_R1
00B0F0  1  A9 5F            lda #95
00B0F2  1  20 B5 B4         jsr add_R1_A
00B0F5  1               
00B0F5  1               mem_prepare:
00B0F5  1  20 CB B2         jsr next_token
00B0F8  1  90 03            bcc mem_prepare_ok
00B0FA  1  4C 46 B2         jmp cmd_error
00B0FD  1               
00B0FD  1               mem_prepare_ok:
00B0FD  1  20 7D B4         jsr copy_R0_R2
00B100  1               
00B100  1               mem_loop:
00B100  1  20 5D B5         jsr check_abort
00B103  1  B0 16            bcs mem_abort
00B105  1               
00B105  1  20 4B B2         jsr dump_line
00B108  1               
00B108  1  A9 08            lda #8
00B10A  1  20 C4 B4         jsr add_R2_A
00B10D  1  B0 07            bcs mem_ok
00B10F  1               
00B10F  1  20 E1 B4         jsr cmp_R2_R1
00B112  1  90 EC            bcc mem_loop
00B114  1  F0 EA            beq mem_loop
00B116  1               
00B116  1               mem_ok:
00B116  1  20 8F B4         jsr copy_R2_MEM
00B119  1  18               clc
00B11A  1  60           	rts
00B11B  1               
00B11B  1               mem_abort:
00B11B  1  4C 46 B2         jmp cmd_error
00B11E  1               
00B11E  1               ; ------------------------------------------------------------
00B11E  1               ; MEMORY EDIT COMMAND
00B11E  1               ; Syntax:
00B11E  1               ;   > addr byte...
00B11E  1               ; Writes 1..8 bytes.
00B11E  1               ; Updates MEM to the next address after the last write.
00B11E  1               ; ------------------------------------------------------------
00B11E  1               cmd_memedit:
00B11E  1  20 38 B4     	jsr advance_lineptr
00B121  1  20 1C B3         jsr parse_word
00B124  1  20 62 B4         jsr copy_T0_R0				; init ptr
00B127  1               
00B127  1  64 D4            stz parm_count				; first of 8
00B129  1               
00B129  1               write_loop:
00B129  1  A5 D4            lda parm_count
00B12B  1  C9 08            cmp #8
00B12D  1  B0 16            bcs write_done				; >= 7
00B12F  1               
00B12F  1  20 CB B2         jsr next_token
00B132  1  90 11            bcc write_done				; no more
00B134  1               
00B134  1  20 0F B3         jsr parse_byte
00B137  1               
00B137  1  A0 00            ldy #0
00B139  1  A5 CE            lda T0L
00B13B  1  91 C6            sta (R0L),y						; store it
00B13D  1               
00B13D  1  20 98 B4         jsr inc_R0						; next location
00B140  1  E6 D4            inc parm_count				; next param
00B142  1  4C 29 B1         jmp write_loop				; loop
00B145  1               
00B145  1               write_done:
00B145  1  A5 D4            lda parm_count
00B147  1  F0 0A            beq write_error				; no locations given
00B149  1               
00B149  1  A5 C6            lda R0L								; advance mem ptr
00B14B  1  85 D2            sta MEML
00B14D  1  A5 C7            lda R0H
00B14F  1  85 D3            sta MEMH
00B151  1  18               clc
00B152  1  60           	rts
00B153  1               
00B153  1               write_error:
00B153  1  4C 46 B2         jmp cmd_error
00B156  1               
00B156  1               
00B156  1               ; ------------------------------------------------------------
00B156  1               ; REGISTER DISPLAY COMMAND
00B156  1               ; Explicit register display on user request.
00B156  1               ; ------------------------------------------------------------
00B156  1               cmd_regs:
00B156  1               show_registers:
00B156  1  A9 46            lda #<reg_header
00B158  1  A2 BF            ldx #>reg_header
00B15A  1  20 7F B2         jsr print_str
00B15D  1               
00B15D  1               print_reg_line:
00B15D  1  A9 3B            lda #';'							; in sync with command table
00B15F  1  20 5A B5         jsr putchar
00B162  1  20 20 B5         jsr print_space
00B165  1               
00B165  1  AD 28 02         lda reg_pch
00B168  1  AE 29 02         ldx reg_pcl
00B16B  1  20 07 B5         jsr print_hex16
00B16E  1  20 20 B5         jsr print_space
00B171  1               
00B171  1  AD 2B 02         lda reg_a
00B174  1  20 EC B4         jsr print_hex8
00B177  1  20 20 B5         jsr print_space
00B17A  1               
00B17A  1  AD 2C 02         lda reg_x
00B17D  1  20 EC B4         jsr print_hex8
00B180  1  20 20 B5         jsr print_space
00B183  1               
00B183  1  AD 2D 02         lda reg_y
00B186  1  20 EC B4         jsr print_hex8
00B189  1  20 20 B5         jsr print_space
00B18C  1               
00B18C  1  AD 2E 02         lda reg_sp
00B18F  1  20 EC B4         jsr print_hex8
00B192  1  20 20 B5         jsr print_space
00B195  1               
00B195  1  A9 25            lda #'%'
00B197  1  20 5A B5     		jsr putchar
00B19A  1  AD 2A 02         lda reg_sr
00B19D  1  20 97 B2         jsr print_status_bits
00B1A0  1  20 25 B5         jsr newline
00B1A3  1  18           	clc
00B1A4  1  60           	rts
00B1A5  1               
00B1A5  1               ; ------------------------------------------------------------
00B1A5  1               ; REGISTER EDIT COMMAND
00B1A5  1               ; Editable line format:
00B1A5  1               ;   ; <PC> [A [X [Y [SP [SR]]]]]
00B1A5  1               ;
00B1A5  1               ; At least PC must be supplied.
00B1A5  1               ; Missing trailing operands leave saved registers unchanged.
00B1A5  1               ; ------------------------------------------------------------
00B1A5  1               cmd_regedit:
00B1A5  1  20 38 B4     	jsr advance_lineptr
00B1A8  1               
00B1A8  1  20 CB B2         jsr next_token
00B1AB  1  90 56            bcc regedit_error
00B1AD  1               
00B1AD  1  20 1C B3         jsr parse_word
00B1B0  1  A5 CE            lda T0L
00B1B2  1  8D 29 02         sta reg_pcl
00B1B5  1  A5 CF            lda T0H
00B1B7  1  8D 28 02         sta reg_pch
00B1BA  1               
00B1BA  1  20 CB B2         jsr next_token
00B1BD  1  90 3F            bcc regedit_done
00B1BF  1               
00B1BF  1  20 0F B3         jsr parse_byte
00B1C2  1  A5 CE            lda T0L
00B1C4  1  8D 2B 02         sta reg_a
00B1C7  1               
00B1C7  1  20 CB B2         jsr next_token
00B1CA  1  90 32            bcc regedit_done
00B1CC  1               
00B1CC  1  20 0F B3         jsr parse_byte
00B1CF  1  A5 CE            lda T0L
00B1D1  1  8D 2C 02         sta reg_x
00B1D4  1               
00B1D4  1  20 CB B2         jsr next_token
00B1D7  1  90 25            bcc regedit_done
00B1D9  1               
00B1D9  1  20 0F B3         jsr parse_byte
00B1DC  1  A5 CE            lda T0L
00B1DE  1  8D 2D 02         sta reg_y
00B1E1  1               
00B1E1  1  20 CB B2         jsr next_token
00B1E4  1  90 18            bcc regedit_done
00B1E6  1               
00B1E6  1  20 0F B3         jsr parse_byte
00B1E9  1  A5 CE            lda T0L
00B1EB  1  8D 2E 02         sta reg_sp
00B1EE  1               
00B1EE  1  20 CB B2         jsr next_token
00B1F1  1  90 0B            bcc regedit_done
00B1F3  1               
00B1F3  1  20 0F B3         jsr parse_byte
00B1F6  1  A5 CE            lda T0L
00B1F8  1  8D 2A 02         sta reg_sr
00B1FB  1               
00B1FB  1  20 CB B2         jsr next_token
00B1FE  1               
00B1FE  1               regedit_done:
00B1FE  1  20 56 B1     	jsr show_registers
00B201  1  18           	clc
00B202  1  60               rts
00B203  1               
00B203  1               regedit_error:
00B203  1  4C 46 B2         jmp cmd_error
00B206  1               
00B206  1               ; ------------------------------------------------------------
00B206  1               ; GO COMMAND
00B206  1               ; Syntax:
00B206  1               ;   G
00B206  1               ;   G <PC>
00B206  1               ; Restores the saved CPU image and resumes execution with RTI.
00B206  1               ; ------------------------------------------------------------
00B206  1               cmd_go:
00B206  1  20 38 B4     	jsr advance_lineptr
00B209  1  20 CB B2         jsr next_token
00B20C  1  90 15            bcc go_now
00B20E  1               
00B20E  1  20 1C B3         jsr parse_word
00B211  1  A5 CE            lda T0L
00B213  1  8D 29 02         sta reg_pcl
00B216  1  A5 CF            lda T0H
00B218  1  8D 28 02         sta reg_pch
00B21B  1               
00B21B  1  20 CB B2         jsr next_token
00B21E  1  90 03            bcc go_now
00B220  1  4C 46 B2         jmp cmd_error
00B223  1               
00B223  1               go_now:
00B223  1  AE 2E 02         ldx reg_sp
00B226  1  9A               txs
00B227  1  AD 28 02         lda reg_pch
00B22A  1  48               pha
00B22B  1  AD 29 02         lda reg_pcl
00B22E  1  48               pha
00B22F  1  AD 2A 02         lda reg_sr
00B232  1  48               pha
00B233  1  AD 2B 02         lda reg_a
00B236  1  AE 2C 02         ldx reg_x
00B239  1  AC 2D 02         ldy reg_y
00B23C  1  40               rti
00B23D  1               
00B23D  1               ; ------------------------------------------------------------
00B23D  1               ; HELP COMMAND
00B23D  1               ; ------------------------------------------------------------
00B23D  1               cmd_help:
00B23D  1  A9 68            lda #<help_text
00B23F  1  A2 BF            ldx #>help_text
00B241  1  20 7F B2         jsr print_str
00B244  1  18           	clc
00B245  1  60           	rts
00B246  1               
00B246  1               ; ------------------------------------------------------------
00B246  1               ; ERROR HANDLER
00B246  1               ; ------------------------------------------------------------
00B246  1               cmd_error:
00B246  1  20 4F B5         jsr print_error
00B249  1  38           	sec
00B24A  1  60           	rts
00B24B  1               
00B24B  1               ; ------------------------------------------------------------
00B24B  1               ; MEMORY DUMP FORMATTERS
00B24B  1               ; ------------------------------------------------------------
00B24B  1               ; show 8 memory locs @R2
00B24B  1               dump_line:
00B24B  1  A9 3E            lda #'>'						; sync with command table
00B24D  1  20 5A B5         jsr putchar
00B250  1  20 20 B5         jsr print_space
00B253  1               
00B253  1  A5 CA            lda R2L
00B255  1  85 CE            sta T0L
00B257  1  A5 CB            lda R2H
00B259  1  85 CF            sta T0H
00B25B  1  20 C1 B2         jsr print_address_T0
00B25E  1               
00B25E  1  A0 00            ldy #0
00B260  1               dump_hex_loop:
00B260  1  B1 CA            lda (R2L),y
00B262  1  20 EC B4         jsr print_hex8
00B265  1  20 20 B5         jsr print_space
00B268  1  C8               iny
00B269  1  C0 08            cpy #8
00B26B  1  D0 F3            bne dump_hex_loop
00B26D  1               
00B26D  1  20 20 B5         jsr print_space
00B270  1               
00B270  1  A0 00            ldy #0
00B272  1               dump_ascii_loop:
00B272  1  B1 CA            lda (R2L),y
00B274  1  20 10 B5         jsr print_ascii
00B277  1  C8               iny
00B278  1  C0 08            cpy #8
00B27A  1  D0 F6            bne dump_ascii_loop
00B27C  1  4C 25 B5         jmp newline
00B27F  1               
00B27F  1               ; ------------------------------------------------------------
00B27F  1               ; OUTPUT HELPERS
00B27F  1               ; ------------------------------------------------------------
00B27F  1               
00B27F  1               ; ------------------------------------------------------------
00B27F  1               ; STRING OUTPUT
00B27F  1               ; A = low byte, X = high byte of zero-terminated string.
00B27F  1               ; Uses T0 as the temporary string pointer.
00B27F  1               ; ------------------------------------------------------------
00B27F  1               print_str:
00B27F  1  5A               phy
00B280  1  85 CE            sta T0L
00B282  1  86 CF            stx T0H
00B284  1  A0 00            ldy #0
00B286  1               
00B286  1               print_str_loop:
00B286  1  B1 CE            lda (T0L),y
00B288  1  F0 0B            beq print_str_done
00B28A  1  20 5A B5         jsr putchar
00B28D  1  C8               iny
00B28E  1  D0 F6            bne print_str_loop
00B290  1  E6 CF            inc T0H
00B292  1  4C 86 B2         jmp print_str_loop
00B295  1               
00B295  1               print_str_done:
00B295  1  7A               ply
00B296  1  60           	rts
00B297  1               
00B297  1               ; ------------------------------------------------------------
00B297  1               ; PRINT_STATUS_BITS
00B297  1               ; Print processor status as:
00B297  1               ;   NV-BDIZC
00B297  1               ; using '1' for set bits and '0' for clear bits.
00B297  1               ;
00B297  1               ; Input
00B297  1               ;   A = status byte
00B297  1               ;
00B297  1               ; Clobbers
00B297  1               ;   A, X
00B297  1               ; ------------------------------------------------------------
00B297  1               print_status_bits:
00B297  1  85 D6            sta tmp
00B299  1               
00B299  1  06 D6            asl tmp              ; N -> C
00B29B  1  20 B5 B2         jsr print_bit_c
00B29E  1               
00B29E  1  06 D6            asl tmp              ; V -> C
00B2A0  1  20 B5 B2         jsr print_bit_c
00B2A3  1               
00B2A3  1  A9 2D            lda #'-'						 ; mmmhhhh
00B2A5  1  20 5A B5         jsr putchar
00B2A8  1               
00B2A8  1  06 D6            asl tmp              ; skip bit 5
00B2AA  1               
00B2AA  1  A2 05            ldx #5               ; B D I Z C
00B2AC  1               ps_loop:
00B2AC  1  06 D6            asl tmp              ; next bit -> C
00B2AE  1  20 B5 B2         jsr print_bit_c
00B2B1  1  CA               dex
00B2B2  1  D0 F8            bne ps_loop
00B2B4  1  60               rts
00B2B5  1               
00B2B5  1               ; ------------------------------------------------------------
00B2B5  1               ; PRINT_BIT_C
00B2B5  1               ; Print '1' if Carry set, else '0'.
00B2B5  1               ; ------------------------------------------------------------
00B2B5  1               print_bit_c:
00B2B5  1  90 05            bcc ps_zero
00B2B7  1  A9 31            lda #'1'
00B2B9  1  4C 5A B5         jmp putchar
00B2BC  1               ps_zero:
00B2BC  1  A9 30            lda #'0'
00B2BE  1  4C 5A B5         jmp putchar
00B2C1  1               
00B2C1  1               ; ------------------------------------------------------------
00B2C1  1               ; PRINT ADDRESS IN T0 + one trailing space
00B2C1  1               ; ------------------------------------------------------------
00B2C1  1               print_address_T0:
00B2C1  1  A5 CF            lda T0H
00B2C3  1  A6 CE            ldx T0L
00B2C5  1  20 07 B5         jsr print_hex16
00B2C8  1  4C 20 B5         jmp print_space
00B2CB  1               
00B2CB  1               ; ------------------------------------------------------------
00B2CB  1               ; TOKENIZER
00B2CB  1               ; Carry set   = token exists
00B2CB  1               ; Carry clear = end of line
00B2CB  1               ; ------------------------------------------------------------
00B2CB  1               next_token:
00B2CB  1  20 3F B4         jsr skip_spaces
00B2CE  1  A0 00            ldy #0
00B2D0  1  B1 C2            lda (lineptr),y
00B2D2  1  F0 02            beq token_eol
00B2D4  1  38               sec
00B2D5  1  60               rts
00B2D6  1               
00B2D6  1               token_eol:
00B2D6  1  18               clc
00B2D7  1  60               rts
00B2D8  1               
00B2D8  1               ; ------------------------------------------------------------
00B2D8  1               ; PARAMETER PARSER
00B2D8  1               ; Default base is hex.
00B2D8  1               ; Supported prefixes:
00B2D8  1               ;   $ hex
00B2D8  1               ;   + decimal
00B2D8  1               ;   % binary   (byte only)
00B2D8  1               ;   ' ASCII    (byte only)
00B2D8  1               ; Result is returned in T0, size in value_size.
00B2D8  1               ; ------------------------------------------------------------
00B2D8  1               parse_param:
00B2D8  1  20 3F B4         jsr skip_spaces
00B2DB  1  A0 00            ldy #0
00B2DD  1  B1 C2            lda (lineptr),y
00B2DF  1  F0 2B            beq param_error
00B2E1  1               
00B2E1  1  C9 24            cmp #'$'
00B2E3  1  F0 0F            beq parse_hex_pref
00B2E5  1  C9 2B            cmp #'+'
00B2E7  1  F0 11            beq parse_dec
00B2E9  1  C9 25            cmp #'%'
00B2EB  1  F0 13            beq parse_bin
00B2ED  1  C9 27            cmp #$27
00B2EF  1  F0 15            beq parse_ascii
00B2F1  1               
00B2F1  1  4C 7A B3         jmp parse_hex
00B2F4  1               
00B2F4  1               parse_hex_pref:
00B2F4  1  20 38 B4         jsr advance_lineptr
00B2F7  1  4C 7A B3         jmp parse_hex
00B2FA  1               
00B2FA  1               parse_dec:
00B2FA  1  20 38 B4         jsr advance_lineptr
00B2FD  1  4C C1 B3         jmp parse_decimal
00B300  1               
00B300  1               parse_bin:
00B300  1  20 38 B4         jsr advance_lineptr
00B303  1  4C 33 B3         jmp parse_binary
00B306  1               
00B306  1               parse_ascii:
00B306  1  20 38 B4         jsr advance_lineptr
00B309  1  4C 1F B3         jmp parse_ascii_char
00B30C  1               
00B30C  1               param_error:
00B30C  1  4C 46 B2         jmp cmd_error
00B30F  1               
00B30F  1               parse_byte:
00B30F  1  20 D8 B2         jsr parse_param
00B312  1  A5 D5            lda value_size
00B314  1  C9 01            cmp #1
00B316  1  F0 03            beq parse_byte_ok
00B318  1  4C 46 B2         jmp cmd_error
00B31B  1               parse_byte_ok:
00B31B  1  60               rts
00B31C  1               
00B31C  1               parse_word:
00B31C  1  4C D8 B2         jmp parse_param
00B31F  1               
00B31F  1               ; ------------------------------------------------------------
00B31F  1               ; ASCII PARSER
00B31F  1               ; Syntax: 'A
00B31F  1               ; ------------------------------------------------------------
00B31F  1               parse_ascii_char:
00B31F  1  A0 00            ldy #0
00B321  1  B1 C2            lda (lineptr),y
00B323  1  F0 0B            beq ascii_error
00B325  1  85 CE            sta T0L
00B327  1  64 CF            stz T0H
00B329  1  A9 01            lda #1
00B32B  1  85 D5            sta value_size
00B32D  1  4C 38 B4         jmp advance_lineptr
00B330  1               
00B330  1               ascii_error:
00B330  1  4C 46 B2         jmp cmd_error
00B333  1               
00B333  1               ; ------------------------------------------------------------
00B333  1               ; BINARY PARSER
00B333  1               ; Syntax: %10101010
00B333  1               ; Binary values are byte sized only.
00B333  1               ; ------------------------------------------------------------
00B333  1               parse_binary:
00B333  1  64 CE            stz T0L
00B335  1  64 CF            stz T0H
00B337  1  64 D6            stz tmp
00B339  1               
00B339  1               bin_loop:
00B339  1  A0 00            ldy #0
00B33B  1  B1 C2            lda (lineptr),y
00B33D  1  C9 30            cmp #'0'
00B33F  1  F0 0B            beq bin_zero
00B341  1  C9 31            cmp #'1'
00B343  1  F0 17            beq bin_one
00B345  1  C9 2D            cmp #'-'				; special case for S-register
00B347  1  F0 13            beq bin_one
00B349  1  4C 6E B3         jmp bin_done
00B34C  1               
00B34C  1               bin_zero:
00B34C  1  A5 D6            lda tmp
00B34E  1  C9 08            cmp #8
00B350  1  B0 25            bcs bin_error
00B352  1  06 CE            asl T0L
00B354  1  20 38 B4         jsr advance_lineptr
00B357  1  E6 D6            inc tmp
00B359  1  4C 39 B3         jmp bin_loop
00B35C  1               
00B35C  1               bin_one:
00B35C  1  A5 D6            lda tmp
00B35E  1  C9 08            cmp #8
00B360  1  B0 15            bcs bin_error
00B362  1  06 CE            asl T0L
00B364  1  E6 CE            inc T0L
00B366  1  20 38 B4         jsr advance_lineptr
00B369  1  E6 D6            inc tmp
00B36B  1  4C 39 B3         jmp bin_loop
00B36E  1               
00B36E  1               bin_done:
00B36E  1  A5 D6            lda tmp
00B370  1  F0 05            beq bin_error
00B372  1  A9 01            lda #1
00B374  1  85 D5            sta value_size
00B376  1  60               rts
00B377  1               
00B377  1               bin_error:
00B377  1  4C 46 B2         jmp cmd_error
00B37A  1               
00B37A  1               ; ------------------------------------------------------------
00B37A  1               ; HEX PARSER
00B37A  1               ; 1-2 digits => byte, 3-4 digits => word.
00B37A  1               ; ------------------------------------------------------------
00B37A  1               parse_hex:
00B37A  1  64 CE            stz T0L
00B37C  1  64 CF            stz T0H
00B37E  1  64 D6            stz tmp
00B380  1               
00B380  1               hex_loop:
00B380  1  A0 00            ldy #0
00B382  1  B1 C2            lda (lineptr),y
00B384  1  20 0F B4         jsr hex_digit
00B387  1  B0 1C            bcs hex_done
00B389  1               
00B389  1  06 CE            asl T0L
00B38B  1  26 CF            rol T0H
00B38D  1  06 CE            asl T0L
00B38F  1  26 CF            rol T0H
00B391  1  06 CE            asl T0L
00B393  1  26 CF            rol T0H
00B395  1  06 CE            asl T0L
00B397  1  26 CF            rol T0H
00B399  1               
00B399  1  05 CE            ora T0L
00B39B  1  85 CE            sta T0L
00B39D  1               
00B39D  1  20 38 B4         jsr advance_lineptr
00B3A0  1  E6 D6            inc tmp
00B3A2  1  4C 80 B3         jmp hex_loop
00B3A5  1               
00B3A5  1               hex_done:
00B3A5  1  A5 D6            lda tmp
00B3A7  1  F0 15            beq hex_error
00B3A9  1  C9 03            cmp #3
00B3AB  1  90 07            bcc hex_byte
00B3AD  1  C9 05            cmp #5
00B3AF  1  90 08            bcc hex_word
00B3B1  1  4C 46 B2         jmp cmd_error
00B3B4  1               
00B3B4  1               hex_byte:
00B3B4  1  A9 01            lda #1
00B3B6  1  85 D5            sta value_size
00B3B8  1  60               rts
00B3B9  1               
00B3B9  1               hex_word:
00B3B9  1  A9 02            lda #2
00B3BB  1  85 D5            sta value_size
00B3BD  1  60               rts
00B3BE  1               
00B3BE  1               hex_error:
00B3BE  1  4C 46 B2         jmp cmd_error
00B3C1  1               
00B3C1  1               ; ------------------------------------------------------------
00B3C1  1               ; DECIMAL PARSER
00B3C1  1               ; Syntax: +1234
00B3C1  1               ; Uses repeated 16-bit add:
00B3C1  1               ;   T0 = T0 * 10 + digit
00B3C1  1               ; ------------------------------------------------------------
00B3C1  1               parse_decimal:
00B3C1  1  64 CE            stz T0L
00B3C3  1  64 CF            stz T0H
00B3C5  1  64 D5            stz value_size
00B3C7  1               
00B3C7  1               dec_loop:
00B3C7  1  A0 00            ldy #0
00B3C9  1  B1 C2            lda (lineptr),y
00B3CB  1  C9 30            cmp #'0'
00B3CD  1  90 2B            bcc dec_done
00B3CF  1  C9 3A            cmp #'9'+1
00B3D1  1  B0 27            bcs dec_done
00B3D3  1               
00B3D3  1  38               sec
00B3D4  1  E9 30            sbc #'0'
00B3D6  1  85 D6            sta tmp
00B3D8  1               
00B3D8  1  20 59 B4         jsr copy_T0_T1
00B3DB  1               
00B3DB  1  64 CE            stz T0L
00B3DD  1  64 CF            stz T0H
00B3DF  1  A2 0A            ldx #10
00B3E1  1               
00B3E1  1               dec_mul_loop:
00B3E1  1  20 D3 B4         jsr add_T1_T0
00B3E4  1  CA               dex
00B3E5  1  D0 FA            bne dec_mul_loop
00B3E7  1               
00B3E7  1  18               clc
00B3E8  1  A5 CE            lda T0L
00B3EA  1  65 D6            adc tmp
00B3EC  1  85 CE            sta T0L
00B3EE  1  90 02            bcc dec_next
00B3F0  1  E6 CF            inc T0H
00B3F2  1               
00B3F2  1               dec_next:
00B3F2  1  20 38 B4         jsr advance_lineptr
00B3F5  1  E6 D5            inc value_size
00B3F7  1  4C C7 B3         jmp dec_loop
00B3FA  1               
00B3FA  1               dec_done:
00B3FA  1  A5 D5            lda value_size
00B3FC  1  F0 0E            beq dec_error
00B3FE  1  A5 CF            lda T0H
00B400  1  F0 05            beq dec_byte
00B402  1  A9 02            lda #2
00B404  1  85 D5            sta value_size
00B406  1  60               rts
00B407  1               
00B407  1               dec_byte:
00B407  1  A9 01            lda #1
00B409  1  85 D5            sta value_size
00B40B  1  60               rts
00B40C  1               
00B40C  1               dec_error:
00B40C  1  4C 46 B2         jmp cmd_error
00B40F  1               
00B40F  1               ; ------------------------------------------------------------
00B40F  1               ; HEX_DIGIT
00B40F  1               ; Convert ASCII hex digit to value 0..15.
00B40F  1               ;
00B40F  1               ; Input
00B40F  1               ;   A = ASCII character
00B40F  1               ;
00B40F  1               ; Output
00B40F  1               ;   A = digit value
00B40F  1               ;   C = 0 valid digit
00B40F  1               ;   C = 1 invalid digit
00B40F  1               ; ------------------------------------------------------------
00B40F  1               hex_digit:
00B40F  1  C9 30            cmp #'0'
00B411  1  90 23            bcc hex_bad
00B413  1  C9 3A            cmp #'9'+1
00B415  1  90 1A            bcc hex_num
00B417  1               
00B417  1  C9 41            cmp #'A'
00B419  1  90 04            bcc hex_lower
00B41B  1  C9 47            cmp #'F'+1
00B41D  1  90 0D            bcc hex_upper
00B41F  1               
00B41F  1               hex_lower:
00B41F  1  C9 61            cmp #'a'
00B421  1  90 13            bcc hex_bad
00B423  1  C9 67            cmp #'f'+1
00B425  1  B0 0F            bcs hex_bad
00B427  1  38               sec
00B428  1  E9 57            sbc #'a'-10
00B42A  1  18               clc
00B42B  1  60               rts
00B42C  1               
00B42C  1               hex_upper:
00B42C  1  38               sec
00B42D  1  E9 37            sbc #'A'-10
00B42F  1  18               clc
00B430  1  60               rts
00B431  1               
00B431  1               hex_num:
00B431  1  38               sec
00B432  1  E9 30            sbc #'0'
00B434  1  18               clc
00B435  1  60               rts
00B436  1               
00B436  1               hex_bad:
00B436  1  38               sec
00B437  1  60               rts
00B438  1               
00B438  1               ; ------------------------------------------------------------
00B438  1               ; TEXT POINTER HELPERS
00B438  1               ; ------------------------------------------------------------
00B438  1               advance_lineptr:
00B438  1  E6 C2            inc lineptr
00B43A  1  D0 02            bne ptr_done
00B43C  1  E6 C3            inc lineptr+1
00B43E  1               ptr_done:
00B43E  1  60               rts
00B43F  1               
00B43F  1               skip_spaces:
00B43F  1  A0 00            ldy #0
00B441  1  B1 C2            lda (lineptr),y
00B443  1  C9 20            cmp #' '
00B445  1  D0 06            bne skip_done
00B447  1  20 38 B4         jsr advance_lineptr
00B44A  1  4C 3F B4         jmp skip_spaces
00B44D  1               
00B44D  1               skip_done:
00B44D  1  60               rts
00B44E  1               
00B44E  1               toupper:
00B44E  1  C9 61            cmp #'a'
00B450  1  90 06            bcc upper_done
00B452  1  C9 7B            cmp #'z'+1
00B454  1  B0 02            bcs upper_done
00B456  1  29 DF            and #%11011111
00B458  1               upper_done:
00B458  1  60               rts
00B459  1               
00B459  1               ; ------------------------------------------------------------
00B459  1               ; 16-bit register / monitor pointer primitives
00B459  1               ; ------------------------------------------------------------
00B459  1               copy_T0_T1:
00B459  1  A5 CE            lda T0L
00B45B  1  85 D0            sta T1L
00B45D  1  A5 CF            lda T0H
00B45F  1  85 D1            sta T1H
00B461  1  60               rts
00B462  1               
00B462  1               copy_T0_R0:
00B462  1  A5 CE            lda T0L
00B464  1  85 C6            sta R0L
00B466  1  A5 CF            lda T0H
00B468  1  85 C7            sta R0H
00B46A  1  60               rts
00B46B  1               
00B46B  1               copy_T0_R1:
00B46B  1  A5 CE            lda T0L
00B46D  1  85 C8            sta R1L
00B46F  1  A5 CF            lda T0H
00B471  1  85 C9            sta R1H
00B473  1  60               rts
00B474  1               
00B474  1               copy_R0_R1:
00B474  1  A5 C6            lda R0L
00B476  1  85 C8            sta R1L
00B478  1  A5 C7            lda R0H
00B47A  1  85 C9            sta R1H
00B47C  1  60               rts
00B47D  1               
00B47D  1               copy_R0_R2:
00B47D  1  A5 C6            lda R0L
00B47F  1  85 CA            sta R2L
00B481  1  A5 C7            lda R0H
00B483  1  85 CB            sta R2H
00B485  1  60               rts
00B486  1               
00B486  1               copy_MEM_R0:
00B486  1  A5 D2            lda MEML
00B488  1  85 C6            sta R0L
00B48A  1  A5 D3            lda MEMH
00B48C  1  85 C7            sta R0H
00B48E  1  60               rts
00B48F  1               
00B48F  1               copy_R2_MEM:
00B48F  1  A5 CA            lda R2L
00B491  1  85 D2            sta MEML
00B493  1  A5 CB            lda R2H
00B495  1  85 D3            sta MEMH
00B497  1  60               rts
00B498  1               
00B498  1               inc_R0:
00B498  1  E6 C6            inc R0L
00B49A  1  D0 02            bne inc_r0_done
00B49C  1  E6 C7            inc R0H
00B49E  1               inc_r0_done:
00B49E  1  60               rts
00B49F  1               
00B49F  1               inc_R2:
00B49F  1  E6 CA            inc R2L
00B4A1  1  D0 02            bne inc_r2_done
00B4A3  1  E6 CB            inc R2H
00B4A5  1               inc_r2_done:
00B4A5  1  60               rts
00B4A6  1               
00B4A6  1               add_R0_A:
00B4A6  1  18               clc
00B4A7  1  65 C6            adc R0L
00B4A9  1  85 C6            sta R0L
00B4AB  1  90 04            bcc add_r0_no_wrap
00B4AD  1  E6 C7            inc R0H
00B4AF  1  F0 02            beq add_r0_wrap
00B4B1  1               add_r0_no_wrap:
00B4B1  1  18               clc
00B4B2  1  60               rts
00B4B3  1               add_r0_wrap:
00B4B3  1  38               sec
00B4B4  1  60               rts
00B4B5  1               
00B4B5  1               add_R1_A:
00B4B5  1  18               clc
00B4B6  1  65 C8            adc R1L
00B4B8  1  85 C8            sta R1L
00B4BA  1  90 04            bcc add_r1_no_wrap
00B4BC  1  E6 C9            inc R1H
00B4BE  1  F0 02            beq add_r1_wrap
00B4C0  1               add_r1_no_wrap:
00B4C0  1  18               clc

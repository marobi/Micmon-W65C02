00E7AD  1               
00E7AD  1               .include "asm.asm"
00E7AD  2               ; ------------------------------------------------------------
00E7AD  2               ; SIMPLE ASSEMBLER COMMAND
00E7AD  2               ; Syntax:
00E7AD  2               ;   A [addr] mnemonic [operand]
00E7AD  2               ;
00E7AD  2               ; If addr is omitted, MEM is used.
00E7AD  2               ; On success MEM is updated to the next address.
00E7AD  2               ; ------------------------------------------------------------
00E7AD  2               cmd_asm:
00E7AD  2  20 17 E4         jsr advance_lineptr
00E7B0  2  20 AA E2         jsr next_token
00E7B3  2  B0 03            bcs ca_have_first
00E7B5  2  4C 28 E2         jmp cmd_error
00E7B8  2               
00E7B8  2               ca_have_first:
00E7B8  2  A0 00            ldy #0
00E7BA  2  B1 C2            lda (lineptr),y
00E7BC  2  20 2D E4         jsr toupper
00E7BF  2  C9 41            cmp #'A'
00E7C1  2  90 04            bcc ca_with_addr
00E7C3  2  C9 5B            cmp #'Z'+1
00E7C5  2  90 0E            bcc ca_default_addr
00E7C7  2               
00E7C7  2               ca_with_addr:
00E7C7  2  20 FB E2         jsr parse_word
00E7CA  2  20 41 E4         jsr copy_T0_R0
00E7CD  2  20 AA E2         jsr next_token
00E7D0  2  B0 06            bcs ca_mnemonic
00E7D2  2  4C 28 E2         jmp cmd_error
00E7D5  2               
00E7D5  2               ca_default_addr:
00E7D5  2  20 65 E4         jsr copy_MEM_R0
00E7D8  2               
00E7D8  2               ca_mnemonic:
00E7D8  2  20 5C E4         jsr copy_R0_R2
00E7DB  2  20 F4 E7         jsr parse_mnemonic
00E7DE  2  20 59 E8         jsr parse_asm_operand
00E7E1  2  20 AA E2         jsr next_token
00E7E4  2  90 03            bcc ca_find
00E7E6  2  4C 28 E2         jmp cmd_error
00E7E9  2               
00E7E9  2               ca_find:
00E7E9  2  20 7F E9         jsr find_opcode
00E7EC  2  B0 03            bcs ca_emit
00E7EE  2  4C 28 E2         jmp cmd_error
00E7F1  2               
00E7F1  2               ca_emit:
00E7F1  2  4C 02 EA         jmp emit_instruction
00E7F4  2               
00E7F4  2               ; ------------------------------------------------------------
00E7F4  2               ; PARSE MNEMONIC
00E7F4  2               ; lineptr must point at the first mnemonic character.
00E7F4  2               ; Saves start pointer in R1 and length in mnem_len.
00E7F4  2               ; Advances lineptr to the first character after the mnemonic.
00E7F4  2               ; ------------------------------------------------------------
00E7F4  2               parse_mnemonic:
00E7F4  2  20 1E E4         jsr skip_spaces
00E7F7  2  A5 C2            lda lineptr
00E7F9  2  85 C8            sta R1L
00E7FB  2  A5 C3            lda lineptr+1
00E7FD  2  85 C9            sta R1H
00E7FF  2  64 D9            stz mnem_len
00E801  2               
00E801  2               pm_loop:
00E801  2  A0 00            ldy #0
00E803  2  B1 C2            lda (lineptr),y
00E805  2  F0 0C            beq pm_done
00E807  2  C9 20            cmp #' '
00E809  2  F0 08            beq pm_done
00E80B  2  E6 D9            inc mnem_len
00E80D  2  20 17 E4         jsr advance_lineptr
00E810  2  4C 01 E8         jmp pm_loop
00E813  2               
00E813  2               pm_done:
00E813  2  A5 D9            lda mnem_len
00E815  2  D0 03            bne pm_ok
00E817  2  4C 28 E2         jmp cmd_error
00E81A  2               
00E81A  2               pm_ok:
00E81A  2  60               rts
00E81B  2               
00E81B  2               ; ------------------------------------------------------------
00E81B  2               ; COMPARE INPUT MNEMONIC AGAINST CANDIDATE STRING
00E81B  2               ; Input:
00E81B  2               ;   R1 = input mnemonic start
00E81B  2               ;   mnem_len = input mnemonic length
00E81B  2               ;   T1 = candidate zero-terminated mnemonic pointer
00E81B  2               ;
00E81B  2               ; Output:
00E81B  2               ;   C = 1 match
00E81B  2               ;   C = 0 no match
00E81B  2               ; ------------------------------------------------------------
00E81B  2               compare_mnemonic:
00E81B  2  A0 00            ldy #0
00E81D  2               
00E81D  2               cm_loop:
00E81D  2  C4 D9            cpy mnem_len
00E81F  2  F0 13            beq cm_end_input
00E821  2               
00E821  2  B1 C8            lda (R1L),y
00E823  2  20 2D E4         jsr toupper
00E826  2  85 D6            sta tmp
00E828  2               
00E828  2  B1 D0            lda (T1L),y
00E82A  2  F0 0C            beq cm_no
00E82C  2  C5 D6            cmp tmp
00E82E  2  D0 08            bne cm_no
00E830  2               
00E830  2  C8               iny
00E831  2  4C 1D E8         jmp cm_loop
00E834  2               
00E834  2               cm_end_input:
00E834  2  B1 D0            lda (T1L),y
00E836  2  F0 02            beq cm_yes
00E838  2               
00E838  2               cm_no:
00E838  2  18               clc
00E839  2  60               rts
00E83A  2               
00E83A  2               cm_yes:
00E83A  2  38               sec
00E83B  2  60               rts
00E83C  2               
00E83C  2               
00E83C  2               ; ------------------------------------------------------------
00E83C  2               ; FETCH MNEMONIC ID FOR OPCODE IN X
00E83C  2               ; Uses mnemonic_id_table as a 256-byte table.
00E83C  2               ;
00E83C  2               ; Output:
00E83C  2               ;   A = mnemonic ID
00E83C  2               ; Preserves X
00E83C  2               ; ------------------------------------------------------------
00E83C  2               get_mnemonic_id_x:
00E83C  2  BD F9 ED         lda mnemonic_id_table,x
00E83F  2  60               rts
00E840  2               
00E840  2               ; ------------------------------------------------------------
00E840  2               ; FETCH MNEMONIC POINTER FOR MNEMONIC ID IN A
00E840  2               ; Uses mnemonic_text_ptrs as a compact unique-pointer table.
00E840  2               ;
00E840  2               ; Input:
00E840  2               ;   A = mnemonic ID
00E840  2               ;
00E840  2               ; Output:
00E840  2               ;   T1 = pointer to zero-terminated mnemonic string
00E840  2               ; Preserves X
00E840  2               ; ------------------------------------------------------------
00E840  2               get_mnemonic_ptr_id:
00E840  2  DA               phx
00E841  2               
00E841  2  85 D6            sta tmp
00E843  2  0A               asl
00E844  2  AA               tax
00E845  2               
00E845  2  BD 33 ED         lda mnemonic_text_ptrs,x
00E848  2  85 D0            sta T1L
00E84A  2  E8               inx
00E84B  2  BD 33 ED         lda mnemonic_text_ptrs,x
00E84E  2  85 D1            sta T1H
00E850  2               
00E850  2  FA               plx
00E851  2  60               rts
00E852  2               
00E852  2               ; ------------------------------------------------------------
00E852  2               ; GET INSTRUCTION LENGTH FROM ADDRESSING MODE
00E852  2               ;
00E852  2               ; Input:
00E852  2               ;   A = addressing mode
00E852  2               ;
00E852  2               ; Output:
00E852  2               ;   A = instruction length
00E852  2               ;
00E852  2               ; Notes:
00E852  2               ;   AM_IMP, AM_ACC, AM_ILL      -> 1
00E852  2               ;   AM_IMM, AM_ZP, AM_ZPX,
00E852  2               ;   AM_ZPY, AM_INDX, AM_INDY,
00E852  2               ;   AM_ZPIND, AM_REL            -> 2
00E852  2               ;   AM_ABS, AM_ABSX, AM_ABSY,
00E852  2               ;   AM_IND, AM_ZPREL, AM_AIX    -> 3
00E852  2               ; ------------------------------------------------------------
00E852  2               get_oplen_from_mode:
00E852  2  DA               phx
00E853  2  AA               tax
00E854  2  BD 22 ED         lda mode_len_table,x
00E857  2  FA               plx
00E858  2  60           		rts
00E859  2               
00E859  2               ; ------------------------------------------------------------
00E859  2               ; PARSE ASSEMBLER OPERAND
00E859  2               ;
00E859  2               ; Output:
00E859  2               ;   asm_mode = parsed addressing mode
00E859  2               ;   T0       = primary operand value
00E859  2               ;   T1L      = zp byte for ZPREL
00E859  2               ;
00E859  2               ; Supported:
00E859  2               ;   implied
00E859  2               ;   A
00E859  2               ;   #imm
00E859  2               ;   zp / abs
00E859  2               ;   zp,X / abs,X
00E859  2               ;   zp,Y / abs,Y
00E859  2               ;   (zp)
00E859  2               ;   (abs)
00E859  2               ;   (zp,X)
00E859  2               ;   (abs,X)
00E859  2               ;   (zp),Y
00E859  2               ;   zp,target   (for BBR/BBS)
00E859  2               ; ------------------------------------------------------------
00E859  2               parse_asm_operand:
00E859  2  20 AA E2         jsr next_token
00E85C  2  B0 05            bcs pa_have_operand
00E85E  2  A9 00            lda #AM_IMP
00E860  2  85 D7            sta asm_mode
00E862  2  60               rts
00E863  2               
00E863  2               pa_have_operand:
00E863  2  A0 00            ldy #0
00E865  2  B1 C2            lda (lineptr),y
00E867  2  C9 23            cmp #'#'
00E869  2  F0 2B            beq pa_imm
00E86B  2  C9 28            cmp #'('
00E86D  2  F0 32            beq pa_paren
00E86F  2               
00E86F  2                   ; bare A can mean accumulator, but only if it is exactly "A"
00E86F  2  20 2D E4         jsr toupper
00E872  2  C9 41            cmp #'A'
00E874  2  F0 03            beq pa_have_a
00E876  2  4C 1F E9     		jmp pa_value
00E879  2               
00E879  2               pa_have_a:
00E879  2  A0 01            ldy #1
00E87B  2  B1 C2            lda (lineptr),y
00E87D  2  F0 07            beq pa_try_acc
00E87F  2  C9 20            cmp #' '
00E881  2  F0 03            beq pa_try_acc
00E883  2  4C 1F E9         jmp pa_value
00E886  2               
00E886  2               pa_try_acc:
00E886  2  20 17 E4         jsr advance_lineptr
00E889  2  20 AA E2         jsr next_token
00E88C  2  90 03            bcc pa_acc
00E88E  2  4C 28 E2         jmp cmd_error
00E891  2               
00E891  2               pa_acc:
00E891  2  A9 01            lda #AM_ACC
00E893  2  85 D7            sta asm_mode
00E895  2  60               rts
00E896  2               
00E896  2               pa_imm:
00E896  2  20 17 E4         jsr advance_lineptr
00E899  2  20 EE E2         jsr parse_byte
00E89C  2  A9 02            lda #AM_IMM
00E89E  2  85 D7            sta asm_mode
00E8A0  2  60               rts
00E8A1  2               
00E8A1  2               pa_paren:
00E8A1  2  20 17 E4         jsr advance_lineptr
00E8A4  2  20 FB E2         jsr parse_word
00E8A7  2               
00E8A7  2  A0 00            ldy #0
00E8A9  2  B1 C2            lda (lineptr),y
00E8AB  2  C9 2C            cmp #','
00E8AD  2  F0 07            beq pa_paren_comma
00E8AF  2  C9 29            cmp #')'
00E8B1  2  F0 33            beq pa_paren_close
00E8B3  2  4C 28 E2         jmp cmd_error
00E8B6  2               
00E8B6  2               pa_paren_comma:
00E8B6  2  20 17 E4         jsr advance_lineptr
00E8B9  2  A0 00            ldy #0
00E8BB  2  B1 C2            lda (lineptr),y
00E8BD  2  20 2D E4         jsr toupper
00E8C0  2  C9 58            cmp #'X'
00E8C2  2  F0 03            beq pa_paren_x
00E8C4  2  4C 28 E2         jmp cmd_error
00E8C7  2               
00E8C7  2               pa_paren_x:
00E8C7  2  20 17 E4         jsr advance_lineptr
00E8CA  2  A0 00            ldy #0
00E8CC  2  B1 C2            lda (lineptr),y
00E8CE  2  C9 29            cmp #')'
00E8D0  2  F0 03            beq pa_paren_x_close
00E8D2  2  4C 28 E2         jmp cmd_error
00E8D5  2               
00E8D5  2               pa_paren_x_close:
00E8D5  2  20 17 E4         jsr advance_lineptr
00E8D8  2  A5 CF            lda T0H
00E8DA  2  F0 05            beq pa_indx
00E8DC  2  A9 0F            lda #AM_AIX
00E8DE  2  85 D7            sta asm_mode
00E8E0  2  60               rts
00E8E1  2               
00E8E1  2               pa_indx:
00E8E1  2  A9 0A            lda #AM_INDX
00E8E3  2  85 D7            sta asm_mode
00E8E5  2  60               rts
00E8E6  2               
00E8E6  2               pa_paren_close:
00E8E6  2  20 17 E4         jsr advance_lineptr
00E8E9  2  A0 00            ldy #0
00E8EB  2  B1 C2            lda (lineptr),y
00E8ED  2  C9 2C            cmp #','
00E8EF  2  F0 0E            beq pa_paren_close_comma
00E8F1  2               
00E8F1  2  A5 CF            lda T0H
00E8F3  2  F0 05            beq pa_zpind
00E8F5  2  A9 09            lda #AM_IND

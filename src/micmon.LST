00B9A0  2               ; FIND OPCODE
00B9A0  2               ;
00B9A0  2               ; Input:
00B9A0  2               ;   mnemonic in R1/mnem_len
00B9A0  2               ;   asm_mode
00B9A0  2               ;
00B9A0  2               ; Output:
00B9A0  2               ;   C = 1 found
00B9A0  2               ;   asm_opcode = opcode
00B9A0  2               ;   C = 0 not found
00B9A0  2               ;
00B9A0  2               ; Special case:
00B9A0  2               ;   branch mnemonics accept AM_REL when operand parsed as ZP or ABS
00B9A0  2               ; ------------------------------------------------------------
00B9A0  2               find_opcode:
00B9A0  2  A2 00            ldx #0
00B9A2  2               
00B9A2  2               fo_loop:
00B9A2  2  BD 43 BC         lda mode_table,x
00B9A5  2  C5 D7            cmp asm_mode
00B9A7  2  F0 11            beq fo_check_mnemonic_direct
00B9A9  2               
00B9A9  2  C9 0D            cmp #AM_REL
00B9AB  2  D0 35            bne fo_next
00B9AD  2               
00B9AD  2  A5 D7            lda asm_mode
00B9AF  2  C9 03            cmp #AM_ZP
00B9B1  2  F0 15            beq fo_check_mnemonic_rel
00B9B3  2  C9 06            cmp #AM_ABS
00B9B5  2  F0 11            beq fo_check_mnemonic_rel
00B9B7  2  4C E2 B9         jmp fo_next

00BAF0  2  43 50 59 00  mn_CPY:  .byte "CPY",0
00BAF4  2  44 45 43 00  mn_DEC:  .byte "DEC",0
00BAF8  2  44 45 58 00  mn_DEX:  .byte "DEX",0
00BAFC  2  44 45 59 00  mn_DEY:  .byte "DEY",0
00BB00  2  45 4F 52 00  mn_EOR:  .byte "EOR",0

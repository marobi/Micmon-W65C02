00B55A  1               ; I/O
00B55A  1               ; ------------------------------------------------------------
00B55A  1               .proc getchar
00B55A  1  20 00 F0     	jsr BIOS_GETCHAR
00B55D  1  F0 FB        	beq getchar
00B55F  1  60           	rts
00B560  1               .endproc
00B560  1               
00B560  1               .proc putchar
00B560  1  4C 03 F0         jmp BIOS_PUTCHAR
00B563  1               .endproc

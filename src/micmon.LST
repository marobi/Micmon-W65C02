00B1A8  1               ; ------------------------------------------------------------
00B1A8  1               ; REGISTER EDIT COMMAND
00B1A8  1               ; Editable line format:
00B1A8  1               ;   ; <PC> [A [X [Y [SP [SR]]]]]
00B1A8  1               ;
00B1A8  1               ; At least PC must be supplied.
00B1A8  1               ; Missing trailing operands leave saved registers unchanged.
00B1A8  1               ; ------------------------------------------------------------
00B1A8  1               cmd_regedit:
00B1A8  1  20 3B B4     	jsr advance_lineptr
00B1AB  1               
00B1AB  1  20 CE B2         jsr next_token
00B1AE  1  90 56            bcc regedit_error
00B1B0  1               
00B1B0  1  20 1F B3         jsr parse_word
00B1B3  1  A5 CE            lda T0L
00B1B5  1  8D 41 02         sta reg_pcl
00B1B8  1  A5 CF            lda T0H
00B1BA  1  8D 40 02         sta reg_pch
00B1BD  1               
00B1BD  1  20 CE B2         jsr next_token
00B1C0  1  90 3F            bcc regedit_done
00B1C2  1               
00B1C2  1  20 12 B3         jsr parse_byte
00B1C5  1  A5 CE            lda T0L
00B1C7  1  8D 43 02         sta reg_a
00B1CA  1               
00B1CA  1  20 CE B2         jsr next_token
00B1CD  1  90 32            bcc regedit_done
00B1CF  1               
00B1CF  1  20 12 B3         jsr parse_byte
00B1D2  1  A5 CE            lda T0L
00B1D4  1  8D 44 02         sta reg_x
00B1D7  1               
00B1D7  1  20 CE B2         jsr next_token
00B1DA  1  90 25            bcc regedit_done
00B1DC  1               
00B1DC  1  20 12 B3         jsr parse_byte
00B1DF  1  A5 CE            lda T0L
00B1E1  1  8D 45 02         sta reg_y
00B1E4  1               
00B1E4  1  20 CE B2         jsr next_token
00B1E7  1  90 18            bcc regedit_done
00B1E9  1               
00B1E9  1  20 12 B3         jsr parse_byte
00B1EC  1  A5 CE            lda T0L
00B1EE  1  8D 46 02         sta reg_sp
00B1F1  1               
00B1F1  1  20 CE B2         jsr next_token
00B1F4  1  90 0B            bcc regedit_done
00B1F6  1               
00B1F6  1  20 12 B3         jsr parse_byte
00B1F9  1  A5 CE            lda T0L
00B1FB  1  8D 42 02         sta reg_sr
00B1FE  1               
00B1FE  1  20 CE B2         jsr next_token
00B201  1               
00B201  1               regedit_done:
00B201  1  20 59 B1     	jsr show_registers
00B204  1  18           	clc
00B205  1  60               rts
00B206  1               
00B206  1               regedit_error:
00B206  1  4C 49 B2         jmp cmd_error
00B209  1               
00B209  1               ; ------------------------------------------------------------
00B209  1               ; GO COMMAND
00B209  1               ; Syntax:
00B209  1               ;   G
00B209  1               ;   G <PC>
00B209  1               ; Restores the saved CPU image and resumes execution with RTI.
00B209  1               ; ------------------------------------------------------------
00B209  1               cmd_go:
00B209  1  20 3B B4     	jsr advance_lineptr
00B20C  1  20 CE B2         jsr next_token
00B20F  1  90 15            bcc go_now
00B211  1               
00B211  1  20 1F B3         jsr parse_word
00B214  1  A5 CE            lda T0L
00B216  1  8D 41 02         sta reg_pcl
00B219  1  A5 CF            lda T0H
00B21B  1  8D 40 02         sta reg_pch
00B21E  1               
00B21E  1  20 CE B2         jsr next_token
00B221  1  90 03            bcc go_now
00B223  1  4C 49 B2         jmp cmd_error
00B226  1               
00B226  1               go_now:
00B226  1  AE 46 02         ldx reg_sp
00B229  1  9A               txs
00B22A  1  AD 40 02         lda reg_pch
00B22D  1  48               pha
00B22E  1  AD 41 02         lda reg_pcl
00B231  1  48               pha
00B232  1  AD 42 02         lda reg_sr
00B235  1  48               pha
00B236  1  AD 43 02         lda reg_a
00B239  1  AE 44 02         ldx reg_x
00B23C  1  AC 45 02         ldy reg_y
00B23F  1  40               rti
00B240  1               
00B240  1               ; ------------------------------------------------------------
00B240  1               ; HELP COMMAND
00B240  1               ; ------------------------------------------------------------
00B240  1               cmd_help:
00B240  1  A9 6D            lda #<help_text
00B242  1  A2 BF            ldx #>help_text
00B244  1  20 82 B2         jsr print_str
00B247  1  18           	clc
00B248  1  60           	rts
00B249  1               
00B249  1               ; ------------------------------------------------------------
00B249  1               ; ERROR HANDLER
00B249  1               ; ------------------------------------------------------------
00B249  1               cmd_error:
00B249  1  20 52 B5         jsr print_error
00B24C  1  38           	sec
00B24D  1  60           	rts
00B24E  1               
00B24E  1               ; ------------------------------------------------------------
00B24E  1               ; MEMORY DUMP FORMATTERS
00B24E  1               ; ------------------------------------------------------------
00B24E  1               ; show 8 memory locs @R2
00B24E  1               .proc dump_line
00B24E  1  A9 3E            lda #'>'						; sync with command table
00B250  1  20 60 B5         jsr putchar
00B253  1  20 23 B5         jsr print_space
00B256  1               
00B256  1  A5 CA            lda R2L
00B258  1  85 CE            sta T0L
00B25A  1  A5 CB            lda R2H
00B25C  1  85 CF            sta T0H
00B25E  1  20 C4 B2         jsr print_address_T0
00B261  1               
00B261  1  A0 00            ldy #0
00B263  1               dump_hex_loop:
00B263  1  B1 CA            lda (R2L),y
00B265  1  20 EF B4         jsr print_hex8
00B268  1  20 23 B5         jsr print_space
00B26B  1  C8               iny
00B26C  1  C0 08            cpy #8
00B26E  1  D0 F3            bne dump_hex_loop
00B270  1               
00B270  1  20 23 B5         jsr print_space
00B273  1               
00B273  1  A0 00            ldy #0
00B275  1               dump_ascii_loop:
00B275  1  B1 CA            lda (R2L),y
00B277  1  20 13 B5         jsr print_ascii
00B27A  1  C8               iny
00B27B  1  C0 08            cpy #8
00B27D  1  D0 F6            bne dump_ascii_loop
00B27F  1  4C 28 B5         jmp newline
00B282  1               .endproc
00B282  1               
00B282  1               ; ------------------------------------------------------------
00B282  1               ; OUTPUT HELPERS
00B282  1               ; ------------------------------------------------------------
00B282  1               
00B282  1               ; ------------------------------------------------------------
00B282  1               ; STRING OUTPUT
00B282  1               ; A = low byte, X = high byte of zero-terminated string.
00B282  1               ; Uses T0 as the temporary string pointer.
00B282  1               ; ------------------------------------------------------------
00B282  1               .proc print_str
00B282  1  5A               phy
00B283  1  85 CE            sta T0L
00B285  1  86 CF            stx T0H
00B287  1  A0 00            ldy #0
00B289  1               
00B289  1               print_str_loop:
00B289  1  B1 CE            lda (T0L),y
00B28B  1  F0 0B            beq print_str_done
00B28D  1  20 60 B5         jsr putchar
00B290  1  C8               iny
00B291  1  D0 F6            bne print_str_loop
00B293  1  E6 CF            inc T0H
00B295  1  4C 89 B2         jmp print_str_loop
00B298  1               
00B298  1               print_str_done:
00B298  1  7A               ply
00B299  1  60           	rts
00B29A  1               .endproc
00B29A  1               
00B29A  1               ; ------------------------------------------------------------
00B29A  1               ; PRINT_STATUS_BITS
00B29A  1               ; Print processor status as:
00B29A  1               ;   NV-BDIZC
00B29A  1               ; using '1' for set bits and '0' for clear bits.
00B29A  1               ;
00B29A  1               ; Input
00B29A  1               ;   A = status byte
00B29A  1               ;
00B29A  1               ; Clobbers
00B29A  1               ;   A, X
00B29A  1               ; ------------------------------------------------------------
00B29A  1               .proc print_status_bits
00B29A  1  85 D6            sta tmp
00B29C  1               
00B29C  1  06 D6            asl tmp              ; N -> C
00B29E  1  20 B8 B2         jsr print_bit_c
00B2A1  1               
00B2A1  1  06 D6            asl tmp              ; V -> C
00B2A3  1  20 B8 B2         jsr print_bit_c
00B2A6  1               
00B2A6  1  A9 2D            lda #'-'						 ; mmmhhhh
00B2A8  1  20 60 B5         jsr putchar
00B2AB  1               
00B2AB  1  06 D6            asl tmp              ; skip bit 5
00B2AD  1               
00B2AD  1  A2 05            ldx #5               ; B D I Z C
00B2AF  1               ps_loop:
00B2AF  1  06 D6            asl tmp              ; next bit -> C
00B2B1  1  20 B8 B2         jsr print_bit_c
00B2B4  1  CA               dex
00B2B5  1  D0 F8            bne ps_loop
00B2B7  1  60               rts
00B2B8  1               .endproc
00B2B8  1               
00B2B8  1               ; ------------------------------------------------------------
00B2B8  1               ; PRINT_BIT_C
00B2B8  1               ; Print '1' if Carry set, else '0'.
00B2B8  1               ; ------------------------------------------------------------
00B2B8  1               .proc print_bit_c
00B2B8  1  90 05            bcc ps_zero
00B2BA  1  A9 31            lda #'1'
00B2BC  1  4C 60 B5         jmp putchar
00B2BF  1               ps_zero:
00B2BF  1  A9 30            lda #'0'
00B2C1  1  4C 60 B5         jmp putchar
00B2C4  1               .endproc
00B2C4  1               
00B2C4  1               ; ------------------------------------------------------------
00B2C4  1               ; PRINT ADDRESS IN T0 + one trailing space
00B2C4  1               ; ------------------------------------------------------------
00B2C4  1               .proc print_address_T0
00B2C4  1  A5 CF            lda T0H
00B2C6  1  A6 CE            ldx T0L
00B2C8  1  20 0A B5         jsr print_hex16
00B2CB  1  4C 23 B5         jmp print_space
00B2CE  1               .endproc
00B2CE  1               
00B2CE  1               ; ------------------------------------------------------------
00B2CE  1               ; TOKENIZER
00B2CE  1               ; Carry set   = token exists
00B2CE  1               ; Carry clear = end of line
00B2CE  1               ; ------------------------------------------------------------
00B2CE  1               .proc next_token
00B2CE  1  20 42 B4         jsr skip_spaces
00B2D1  1  A0 00            ldy #0
00B2D3  1  B1 C2            lda (lineptr),y
00B2D5  1  F0 02            beq token_eol
00B2D7  1  38               sec
00B2D8  1  60               rts
00B2D9  1               
00B2D9  1               token_eol:
00B2D9  1  18               clc
00B2DA  1  60               rts
00B2DB  1               .endproc
00B2DB  1               
00B2DB  1               ; ------------------------------------------------------------
00B2DB  1               ; PARAMETER PARSER
00B2DB  1               ; Default base is hex.
00B2DB  1               ; Supported prefixes:
00B2DB  1               ;   $ hex
00B2DB  1               ;   + decimal
00B2DB  1               ;   % binary   (byte only)
00B2DB  1               ;   ' ASCII    (byte only)
00B2DB  1               ; Result is returned in T0, size in value_size.
00B2DB  1               ; ------------------------------------------------------------
00B2DB  1               .proc parse_param
00B2DB  1  20 42 B4         jsr skip_spaces
00B2DE  1  A0 00            ldy #0
00B2E0  1  B1 C2            lda (lineptr),y
00B2E2  1  F0 2B            beq param_error
00B2E4  1               
00B2E4  1  C9 24            cmp #'$'
00B2E6  1  F0 0F            beq parse_hex_pref
00B2E8  1  C9 2B            cmp #'+'
00B2EA  1  F0 11            beq parse_dec
00B2EC  1  C9 25            cmp #'%'
00B2EE  1  F0 13            beq parse_bin
00B2F0  1  C9 27            cmp #$27
00B2F2  1  F0 15            beq parse_ascii
00B2F4  1               
00B2F4  1  4C 7D B3         jmp parse_hex
00B2F7  1               
00B2F7  1               parse_hex_pref:
00B2F7  1  20 3B B4         jsr advance_lineptr
00B2FA  1  4C 7D B3         jmp parse_hex
00B2FD  1               
00B2FD  1               parse_dec:
00B2FD  1  20 3B B4         jsr advance_lineptr
00B300  1  4C C4 B3         jmp parse_decimal
00B303  1               
00B303  1               parse_bin:
00B303  1  20 3B B4         jsr advance_lineptr
00B306  1  4C 36 B3         jmp parse_binary
00B309  1               
00B309  1               parse_ascii:
00B309  1  20 3B B4         jsr advance_lineptr
00B30C  1  4C 22 B3         jmp parse_ascii_char
00B30F  1               
00B30F  1               param_error:
00B30F  1  4C 49 B2         jmp cmd_error
00B312  1               .endproc
00B312  1               
00B312  1               .proc parse_byte
00B312  1  20 DB B2         jsr parse_param
00B315  1  A5 D5            lda value_size
00B317  1  C9 01            cmp #1
00B319  1  F0 03            beq parse_byte_ok
00B31B  1  4C 49 B2         jmp cmd_error
00B31E  1               parse_byte_ok:
00B31E  1  60               rts
00B31F  1               .endproc
00B31F  1               
00B31F  1               .proc parse_word
00B31F  1  4C DB B2         jmp parse_param
00B322  1               .endproc
00B322  1               
00B322  1               ; ------------------------------------------------------------
00B322  1               ; ASCII PARSER
00B322  1               ; Syntax: 'A
00B322  1               ; ------------------------------------------------------------
00B322  1               .proc parse_ascii_char
00B322  1  A0 00            ldy #0
00B324  1  B1 C2            lda (lineptr),y
00B326  1  F0 0B            beq ascii_error
00B328  1  85 CE            sta T0L
00B32A  1  64 CF            stz T0H
00B32C  1  A9 01            lda #1
00B32E  1  85 D5            sta value_size
00B330  1  4C 3B B4         jmp advance_lineptr
00B333  1               
00B333  1               ascii_error:
00B333  1  4C 49 B2         jmp cmd_error
00B336  1               .endproc
00B336  1               
00B336  1               ; ------------------------------------------------------------
00B336  1               ; BINARY PARSER
00B336  1               ; Syntax: %10101010
00B336  1               ; Binary values are byte sized only.
00B336  1               ; ------------------------------------------------------------
00B336  1               .proc parse_binary
00B336  1  64 CE            stz T0L
00B338  1  64 CF            stz T0H
00B33A  1  64 D6            stz tmp
00B33C  1               
00B33C  1               bin_loop:
00B33C  1  A0 00            ldy #0
00B33E  1  B1 C2            lda (lineptr),y
00B340  1  C9 30            cmp #'0'
00B342  1  F0 0B            beq bin_zero
00B344  1  C9 31            cmp #'1'
00B346  1  F0 17            beq bin_one
00B348  1  C9 2D            cmp #'-'				; special case for S-register
00B34A  1  F0 13            beq bin_one
00B34C  1  4C 71 B3         jmp bin_done
00B34F  1               
00B34F  1               bin_zero:
00B34F  1  A5 D6            lda tmp
00B351  1  C9 08            cmp #8
00B353  1  B0 25            bcs bin_error
00B355  1  06 CE            asl T0L
00B357  1  20 3B B4         jsr advance_lineptr
00B35A  1  E6 D6            inc tmp
00B35C  1  4C 3C B3         jmp bin_loop
00B35F  1               
00B35F  1               bin_one:
00B35F  1  A5 D6            lda tmp
00B361  1  C9 08            cmp #8
00B363  1  B0 15            bcs bin_error
00B365  1  06 CE            asl T0L
00B367  1  E6 CE            inc T0L
00B369  1  20 3B B4         jsr advance_lineptr
00B36C  1  E6 D6            inc tmp
00B36E  1  4C 3C B3         jmp bin_loop
00B371  1               
00B371  1               bin_done:
00B371  1  A5 D6            lda tmp
00B373  1  F0 05            beq bin_error
00B375  1  A9 01            lda #1
00B377  1  85 D5            sta value_size
00B379  1  60               rts
00B37A  1               
00B37A  1               bin_error:
00B37A  1  4C 49 B2         jmp cmd_error
00B37D  1               .endproc
00B37D  1               
00B37D  1               ; ------------------------------------------------------------
00B37D  1               ; HEX PARSER
00B37D  1               ; 1-2 digits => byte, 3-4 digits => word.
00B37D  1               ; ------------------------------------------------------------
00B37D  1               .proc parse_hex
00B37D  1  64 CE            stz T0L
00B37F  1  64 CF            stz T0H
00B381  1  64 D6            stz tmp
00B383  1               
00B383  1               hex_loop:
00B383  1  A0 00            ldy #0
00B385  1  B1 C2            lda (lineptr),y
00B387  1  20 12 B4         jsr hex_digit
00B38A  1  B0 1C            bcs hex_done
00B38C  1               
00B38C  1  06 CE            asl T0L
00B38E  1  26 CF            rol T0H
00B390  1  06 CE            asl T0L
00B392  1  26 CF            rol T0H
00B394  1  06 CE            asl T0L
00B396  1  26 CF            rol T0H
00B398  1  06 CE            asl T0L
00B39A  1  26 CF            rol T0H
00B39C  1               
00B39C  1  05 CE            ora T0L
00B39E  1  85 CE            sta T0L
00B3A0  1               
00B3A0  1  20 3B B4         jsr advance_lineptr
00B3A3  1  E6 D6            inc tmp
00B3A5  1  4C 83 B3         jmp hex_loop
00B3A8  1               
00B3A8  1               hex_done:
00B3A8  1  A5 D6            lda tmp
00B3AA  1  F0 15            beq hex_error
00B3AC  1  C9 03            cmp #3
00B3AE  1  90 07            bcc hex_byte
00B3B0  1  C9 05            cmp #5
00B3B2  1  90 08            bcc hex_word
00B3B4  1  4C 49 B2         jmp cmd_error
00B3B7  1               
00B3B7  1               hex_byte:
00B3B7  1  A9 01            lda #1
00B3B9  1  85 D5            sta value_size
00B3BB  1  60               rts
00B3BC  1               
00B3BC  1               hex_word:
00B3BC  1  A9 02            lda #2
00B3BE  1  85 D5            sta value_size
00B3C0  1  60               rts
00B3C1  1               
00B3C1  1               hex_error:
00B3C1  1  4C 49 B2         jmp cmd_error
00B3C4  1               .endproc
00B3C4  1               
00B3C4  1               ; ------------------------------------------------------------
00B3C4  1               ; DECIMAL PARSER
00B3C4  1               ; Syntax: +1234
00B3C4  1               ; Uses repeated 16-bit add:
00B3C4  1               ;   T0 = T0 * 10 + digit
00B3C4  1               ; ------------------------------------------------------------
00B3C4  1               .proc parse_decimal
00B3C4  1  64 CE            stz T0L
00B3C6  1  64 CF            stz T0H
00B3C8  1  64 D5            stz value_size
00B3CA  1               
00B3CA  1               dec_loop:
00B3CA  1  A0 00            ldy #0
00B3CC  1  B1 C2            lda (lineptr),y
00B3CE  1  C9 30            cmp #'0'
00B3D0  1  90 2B            bcc dec_done
00B3D2  1  C9 3A            cmp #'9'+1
00B3D4  1  B0 27            bcs dec_done
00B3D6  1               
00B3D6  1  38               sec
00B3D7  1  E9 30            sbc #'0'
00B3D9  1  85 D6            sta tmp
00B3DB  1               
00B3DB  1  20 5C B4         jsr copy_T0_T1
00B3DE  1               
00B3DE  1  64 CE            stz T0L
00B3E0  1  64 CF            stz T0H
00B3E2  1  A2 0A            ldx #10
00B3E4  1               
00B3E4  1               dec_mul_loop:
00B3E4  1  20 D6 B4         jsr add_T1_T0
00B3E7  1  CA               dex
00B3E8  1  D0 FA            bne dec_mul_loop
00B3EA  1               
00B3EA  1  18               clc

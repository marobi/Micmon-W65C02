00B7D3  2               ; ------------------------------------------------------------
00B7D3  2               ; SIMPLE ASSEMBLER COMMAND
00B7D3  2               ; Syntax:
00B7D3  2               ;   A [addr] mnemonic [operand]
00B7D3  2               ;
00B7D3  2               ; If addr is omitted, MEM is used.
00B7D3  2               ; On success MEM is updated to the next address.
00B7D3  2               ; ------------------------------------------------------------
00B7D3  2               cmd_asm:
00B7D3  2  20 3B B4         jsr advance_lineptr
00B7D6  2  20 CE B2         jsr next_token
00B7D9  2  B0 03            bcs ca_have_first
00B7DB  2  4C 49 B2         jmp cmd_error
00B7DE  2               
00B7DE  2               ca_have_first:
00B7DE  2  A0 00            ldy #0
00B7E0  2  B1 C2            lda (lineptr),y
00B7E2  2  20 51 B4         jsr toupper
00B7E5  2  C9 41            cmp #'A'
00B7E7  2  90 04            bcc ca_with_addr
00B7E9  2  C9 5B            cmp #'Z'+1
00B7EB  2  90 0E            bcc ca_default_addr
00B7ED  2               
00B7ED  2               ca_with_addr:
00B7ED  2  20 1F B3         jsr parse_word
00B7F0  2  20 65 B4         jsr copy_T0_R0
00B7F3  2  20 CE B2         jsr next_token
00B7F6  2  B0 06            bcs ca_mnemonic
00B7F8  2  4C 49 B2         jmp cmd_error
00B7FB  2               
00B7FB  2               ca_default_addr:
00B7FB  2  20 89 B4         jsr copy_MEM_R0
00B7FE  2               
00B7FE  2               ca_mnemonic:
00B7FE  2  20 80 B4         jsr copy_R0_R2
00B801  2  20 1A B8         jsr parse_mnemonic
00B804  2  20 7F B8         jsr parse_asm_operand
00B807  2  20 CE B2         jsr next_token
00B80A  2  90 03            bcc ca_find
00B80C  2  4C 49 B2         jmp cmd_error
00B80F  2               
00B80F  2               ca_find:
00B80F  2  20 A5 B9         jsr find_opcode
00B812  2  B0 03            bcs ca_emit
00B814  2  4C 49 B2         jmp cmd_error
00B817  2               
00B817  2               ca_emit:
00B817  2  4C 28 BA         jmp emit_instruction
00B81A  2               
00B81A  2               ; ------------------------------------------------------------
00B81A  2               ; PARSE MNEMONIC
00B81A  2               ; lineptr must point at the first mnemonic character.
00B81A  2               ; Saves start pointer in R1 and length in mnem_len.
00B81A  2               ; Advances lineptr to the first character after the mnemonic.
00B81A  2               ; ------------------------------------------------------------
00B81A  2               parse_mnemonic:
00B81A  2  20 42 B4         jsr skip_spaces
00B81D  2  A5 C2            lda lineptr
00B81F  2  85 C8            sta R1L
00B821  2  A5 C3            lda lineptr+1
00B823  2  85 C9            sta R1H
00B825  2  64 D9            stz mnem_len
00B827  2               
00B827  2               pm_loop:
00B827  2  A0 00            ldy #0
00B829  2  B1 C2            lda (lineptr),y
00B82B  2  F0 0C            beq pm_done
00B82D  2  C9 20            cmp #' '
00B82F  2  F0 08            beq pm_done
00B831  2  E6 D9            inc mnem_len
00B833  2  20 3B B4         jsr advance_lineptr
00B836  2  4C 27 B8         jmp pm_loop
00B839  2               
00B839  2               pm_done:
00B839  2  A5 D9            lda mnem_len
00B83B  2  D0 03            bne pm_ok
00B83D  2  4C 49 B2         jmp cmd_error
00B840  2               
00B840  2               pm_ok:
00B840  2  60               rts
00B841  2               
00B841  2               ; ------------------------------------------------------------
00B841  2               ; COMPARE INPUT MNEMONIC AGAINST CANDIDATE STRING
00B841  2               ; Input:
00B841  2               ;   R1 = input mnemonic start
00B841  2               ;   mnem_len = input mnemonic length
00B841  2               ;   T1 = candidate zero-terminated mnemonic pointer
00B841  2               ;
00B841  2               ; Output:
00B841  2               ;   C = 1 match
00B841  2               ;   C = 0 no match
00B841  2               ; ------------------------------------------------------------
00B841  2               compare_mnemonic:
00B841  2  A0 00            ldy #0
00B843  2               
00B843  2               cm_loop:
00B843  2  C4 D9            cpy mnem_len
00B845  2  F0 13            beq cm_end_input
00B847  2               
00B847  2  B1 C8            lda (R1L),y
00B849  2  20 51 B4         jsr toupper
00B84C  2  85 D6            sta tmp
00B84E  2               
00B84E  2  B1 D0            lda (T1L),y
00B850  2  F0 0C            beq cm_no
00B852  2  C5 D6            cmp tmp
00B854  2  D0 08            bne cm_no
00B856  2               
00B856  2  C8               iny
00B857  2  4C 43 B8         jmp cm_loop
00B85A  2               
00B85A  2               cm_end_input:
00B85A  2  B1 D0            lda (T1L),y
00B85C  2  F0 02            beq cm_yes
00B85E  2               
00B85E  2               cm_no:
00B85E  2  18               clc
00B85F  2  60               rts
00B860  2               
00B860  2               cm_yes:
00B860  2  38               sec
00B861  2  60               rts
00B862  2               
00B862  2               
00B862  2               ; ------------------------------------------------------------
00B862  2               ; FETCH MNEMONIC ID FOR OPCODE IN X
00B862  2               ; Uses mnemonic_id_table as a 256-byte table.
00B862  2               ;
00B862  2               ; Output:
00B862  2               ;   A = mnemonic ID
00B862  2               ; Preserves X
00B862  2               ; ------------------------------------------------------------
00B862  2               get_mnemonic_id_x:
00B862  2  BD 1F BE         lda mnemonic_id_table,x
00B865  2  60               rts
00B866  2               
00B866  2               ; ------------------------------------------------------------
00B866  2               ; FETCH MNEMONIC POINTER FOR MNEMONIC ID IN A
00B866  2               ; Uses mnemonic_text_ptrs as a compact unique-pointer table.
00B866  2               ;
00B866  2               ; Input:
00B866  2               ;   A = mnemonic ID
00B866  2               ;
00B866  2               ; Output:
00B866  2               ;   T1 = pointer to zero-terminated mnemonic string
00B866  2               ; Preserves X
00B866  2               ; ------------------------------------------------------------
00B866  2               get_mnemonic_ptr_id:
00B866  2  DA               phx
00B867  2               
00B867  2  85 D6            sta tmp
00B869  2  0A               asl
00B86A  2  AA               tax
00B86B  2               
00B86B  2  BD 59 BD         lda mnemonic_text_ptrs,x
00B86E  2  85 D0            sta T1L
00B870  2  E8               inx
00B871  2  BD 59 BD         lda mnemonic_text_ptrs,x
00B874  2  85 D1            sta T1H
00B876  2               
00B876  2  FA               plx
00B877  2  60               rts
00B878  2               
00B878  2               ; ------------------------------------------------------------
00B878  2               ; GET INSTRUCTION LENGTH FROM ADDRESSING MODE
00B878  2               ;
00B878  2               ; Input:
00B878  2               ;   A = addressing mode
00B878  2               ;
00B878  2               ; Output:
00B878  2               ;   A = instruction length
00B878  2               ;
00B878  2               ; Notes:
00B878  2               ;   AM_IMP, AM_ACC, AM_ILL      -> 1
00B878  2               ;   AM_IMM, AM_ZP, AM_ZPX,
00B878  2               ;   AM_ZPY, AM_INDX, AM_INDY,
00B878  2               ;   AM_ZPIND, AM_REL            -> 2
00B878  2               ;   AM_ABS, AM_ABSX, AM_ABSY,
00B878  2               ;   AM_IND, AM_ZPREL, AM_AIX    -> 3
00B878  2               ; ------------------------------------------------------------
00B878  2               get_oplen_from_mode:
00B878  2  DA               phx
00B879  2  AA               tax
00B87A  2  BD 48 BD         lda mode_len_table,x
00B87D  2  FA               plx
00B87E  2  60           		rts
00B87F  2               
00B87F  2               ; ------------------------------------------------------------
00B87F  2               ; PARSE ASSEMBLER OPERAND
00B87F  2               ;
00B87F  2               ; Output:
00B87F  2               ;   asm_mode = parsed addressing mode
00B87F  2               ;   T0       = primary operand value
00B87F  2               ;   T1L      = zp byte for ZPREL
00B87F  2               ;
00B87F  2               ; Supported:
00B87F  2               ;   implied
00B87F  2               ;   A
00B87F  2               ;   #imm
00B87F  2               ;   zp / abs
00B87F  2               ;   zp,X / abs,X
00B87F  2               ;   zp,Y / abs,Y
00B87F  2               ;   (zp)
00B87F  2               ;   (abs)
00B87F  2               ;   (zp,X)
00B87F  2               ;   (abs,X)
00B87F  2               ;   (zp),Y
00B87F  2               ;   zp,target   (for BBR/BBS)
00B87F  2               ; ------------------------------------------------------------
00B87F  2               parse_asm_operand:
00B87F  2  20 CE B2         jsr next_token
00B882  2  B0 05            bcs pa_have_operand
00B884  2  A9 00            lda #AM_IMP
00B886  2  85 D7            sta asm_mode
00B888  2  60               rts
00B889  2               
00B889  2               pa_have_operand:
00B889  2  A0 00            ldy #0
00B88B  2  B1 C2            lda (lineptr),y
00B88D  2  C9 23            cmp #'#'
00B88F  2  F0 2B            beq pa_imm
00B891  2  C9 28            cmp #'('
00B893  2  F0 32            beq pa_paren
00B895  2               

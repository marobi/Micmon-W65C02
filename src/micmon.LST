00EA01  2               ; ------------------------------------------------------------
00EA01  2               ; COMPUTE_REL_OFFSET
00EA01  2               ;
00EA01  2               ; Input:
00EA01  2               ;   A  = instruction length (2 or 3)
00EA01  2               ;   R0 = instruction address
00EA01  2               ;   T0 = target address
00EA01  2               ;
00EA01  2               ; Output:
00EA01  2               ;   A  = signed 8-bit relative offset
00EA01  2               ;
00EA01  2               ; Error:
00EA01  2               ;   jumps to cmd_error if target is out of range
00EA01  2               ; ------------------------------------------------------------
00EA01  2               compute_rel_offset:
00EA01  2  85 D2            sta parm_count
00EA03  2               
00EA03  2                   ; R3 = base = R0 + instruction length
00EA03  2  A5 C4            lda R0L
00EA05  2  18               clc
00EA06  2  65 D2            adc parm_count
00EA08  2  85 CA            sta R3L
00EA0A  2  A5 C5            lda R0H
00EA0C  2  69 00            adc #0
00EA0E  2  85 CB            sta R3H
00EA10  2               
00EA10  2                   ; diff = target - base   (wrapped 16-bit subtraction)
00EA10  2  38               sec
00EA11  2  A5 CC            lda T0L
00EA13  2  E5 CA            sbc R3L
00EA15  2  85 CE            sta T1L
00EA17  2  A5 CD            lda T0H
00EA19  2  E5 CB            sbc R3H
00EA1B  2  85 CF            sta T1H
00EA1D  2               
00EA1D  2                   ; valid if:
00EA1D  2                   ;   T1 = 00:00..00:7F   (+0 .. +127)
00EA1D  2                   ;   T1 = FF:80..FF:FF   (-128 .. -1)
00EA1D  2               
00EA1D  2  A5 CF            lda T1H
00EA1F  2  F0 07            beq cro_pos
00EA21  2  C9 FF            cmp #$FF
00EA23  2  F0 0C            beq cro_neg
00EA25  2  4C 2C E2         jmp cmd_error
00EA28  2               
00EA28  2               cro_pos:
00EA28  2  A5 CE            lda T1L
00EA2A  2  C9 80            cmp #$80
00EA2C  2  90 0C            bcc cro_ok
00EA2E  2  4C 2C E2         jmp cmd_error
00EA31  2               
00EA31  2               cro_neg:
00EA31  2  A5 CE            lda T1L
00EA33  2  C9 80            cmp #$80
00EA35  2  B0 03            bcs cro_ok
00EA37  2  4C 2C E2         jmp cmd_error
00EA3A  2               
00EA3A  2               cro_ok:
00EA3A  2  A5 CE            lda T1L
00EA3C  2  60               rts
00EA3D  2               
00EA3D  2               ; ------------------------------------------------------------
00EA3D  2               ; EMIT INSTRUCTION
00EA3D  2               ; Uses asm_opcode, asm_mode and operand value(s).
00EA3D  2               ; Updates MEM to next address.
00EA3D  2               ; Writes nothing if relative offset is out of range.
00EA3D  2               ; ------------------------------------------------------------
00EA3D  2               emit_instruction:
00EA3D  2  A5 D5            lda asm_mode
00EA3F  2  20 5F E8         jsr get_oplen_from_mode
00EA42  2  85 D4            sta tmp
00EA44  2               
00EA44  2                   ; for relative forms, validate offset before storing opcode
00EA44  2  A5 D5            lda asm_mode
00EA46  2  C9 0D            cmp #AM_REL
00EA48  2  F0 07            beq ei_prep_rel
00EA4A  2  C9 0E            cmp #AM_ZPREL
00EA4C  2  F0 0D            beq ei_prep_zprel
00EA4E  2  4C 65 EA         jmp ei_store
00EA51  2               
00EA51  2               ei_prep_rel:
00EA51  2  A9 02            lda #2
00EA53  2  20 01 EA         jsr compute_rel_offset
00EA56  2  85 CF            sta T1H
00EA58  2  4C 65 EA         jmp ei_store
00EA5B  2               
00EA5B  2               ei_prep_zprel:
00EA5B  2  A9 03            lda #3
00EA5D  2  20 01 EA         jsr compute_rel_offset
00EA60  2  85 CF            sta T1H
00EA62  2  4C 65 EA         jmp ei_store
00EA65  2               
00EA65  2               ei_store:
00EA65  2  A0 00            ldy #0
00EA67  2  A5 D6            lda asm_opcode
00EA69  2  91 C4            sta (R0L),y
00EA6B  2               
00EA6B  2  A5 D4            lda tmp
00EA6D  2  C9 01            cmp #1
00EA6F  2  F0 32            beq ei_finish
00EA71  2               
00EA71  2  A5 D5            lda asm_mode
00EA73  2  C9 0D            cmp #AM_REL
00EA75  2  F0 18            beq ei_rel
00EA77  2  C9 0E            cmp #AM_ZPREL
00EA79  2  F0 1D            beq ei_zprel
00EA7B  2               
00EA7B  2  A0 01            ldy #1
00EA7D  2  A5 CC            lda T0L
00EA7F  2  91 C4            sta (R0L),y
00EA81  2               
00EA81  2  A5 D4            lda tmp
00EA83  2  C9 02            cmp #2
00EA85  2  F0 1C            beq ei_finish
00EA87  2               
00EA87  2  C8               iny
00EA88  2  A5 CD            lda T0H
00EA8A  2  91 C4            sta (R0L),y
00EA8C  2  4C A3 EA         jmp ei_finish
00EA8F  2               
00EA8F  2               ei_rel:
00EA8F  2  A0 01            ldy #1
00EA91  2  A5 CF            lda T1H
00EA93  2  91 C4            sta (R0L),y
00EA95  2  4C A3 EA         jmp ei_finish
00EA98  2               
00EA98  2               ei_zprel:
00EA98  2  A0 01            ldy #1
00EA9A  2  A5 CE            lda T1L
00EA9C  2  91 C4            sta (R0L),y
00EA9E  2  C8               iny
00EA9F  2  A5 CF            lda T1H
00EAA1  2  91 C4            sta (R0L),y
00EAA3  2               
00EAA3  2               ei_finish:
00EAA3  2  A5 D4            lda tmp
00EAA5  2  20 87 E4         jsr add_R0_A
00EAA8  2  A5 C4            lda R0L
00EAAA  2  85 D0            sta MEML
00EAAC  2  A5 C5            lda R0H
00EAAE  2  85 D1            sta MEMH
00EAB0  2  60               rts

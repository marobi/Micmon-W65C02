00B7F8  2               ; ------------------------------------------------------------
00B7F8  2               ; PARSE MNEMONIC
00B7F8  2               ; lineptr must point at the first mnemonic character.
00B7F8  2               ; Saves start pointer in R1 and length in mnem_len.
00B7F8  2               ; Advances lineptr to the first character after the mnemonic.
00B7F8  2               ; ------------------------------------------------------------
00B7F8  2               parse_mnemonic:
00B7F8  2  20 20 B4         jsr skip_spaces
00B7FB  2  A5 C2            lda lineptr
00B7FD  2  85 C8            sta R1L
00B7FF  2  A5 C3            lda lineptr+1
00B801  2  85 C9            sta R1H
00B803  2  64 D9            stz mnem_len
00B805  2               
00B805  2               pm_loop:
00B805  2  A0 00            ldy #0
00B807  2  B1 C2            lda (lineptr),y
00B809  2  F0 0C            beq pm_done
00B80B  2  C9 20            cmp #' '
00B80D  2  F0 08            beq pm_done
00B80F  2  E6 D9            inc mnem_len
00B811  2  20 19 B4         jsr advance_lineptr
00B814  2  4C 05 B8         jmp pm_loop
00B817  2               
00B817  2               pm_done:
00B817  2  A5 D9            lda mnem_len
00B819  2  D0 03            bne pm_ok
00B81B  2  4C 27 B2         jmp cmd_error
00B81E  2               
00B81E  2               pm_ok:
00B81E  2  60               rts
00B81F  2               
00B81F  2               ; ------------------------------------------------------------
00B81F  2               ; COMPARE INPUT MNEMONIC AGAINST CANDIDATE STRING
00B81F  2               ; Input:
00B81F  2               ;   R1 = input mnemonic start
00B81F  2               ;   mnem_len = input mnemonic length
00B81F  2               ;   T1 = candidate zero-terminated mnemonic pointer
00B81F  2               ;
00B81F  2               ; Output:
00B81F  2               ;   C = 1 match
00B81F  2               ;   C = 0 no match
00B81F  2               ; ------------------------------------------------------------
00B81F  2               compare_mnemonic:
00B81F  2  A0 00            ldy #0
00B821  2               
00B821  2               cm_loop:
00B821  2  C4 D9            cpy mnem_len
00B823  2  F0 13            beq cm_end_input
00B825  2               
00B825  2  B1 C8            lda (R1L),y
00B827  2  20 2F B4         jsr toupper
00B82A  2  85 D6            sta tmp
00B82C  2               
00B82C  2  B1 D0            lda (T1L),y
00B82E  2  F0 0C            beq cm_no
00B830  2  C5 D6            cmp tmp
00B832  2  D0 08            bne cm_no
00B834  2               
00B834  2  C8               iny
00B835  2  4C 21 B8         jmp cm_loop
00B838  2               
00B838  2               cm_end_input:
00B838  2  B1 D0            lda (T1L),y
00B83A  2  F0 02            beq cm_yes
00B83C  2               
00B83C  2               cm_no:
00B83C  2  18               clc
00B83D  2  60               rts
00B83E  2               
00B83E  2               cm_yes:
00B83E  2  38               sec
00B83F  2  60               rts

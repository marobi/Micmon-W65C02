00B512  1               ; ------------------------------------------------------------
00B512  1               ; GETLINE
00B512  1               ; Read a line from input into linebuf.
00B512  1               ;
00B512  1               ; Assumptions
00B512  1               ; - host terminal performs line editing
00B512  1               ; - CR (0x0D) terminates the line
00B512  1               ; - line is zero terminated
00B512  1               ; - max length = 127 characters
00B512  1               ; ------------------------------------------------------------
00B512  1               .proc getline
00B512  1  A2 00            ldx #0
00B514  1               
00B514  1               getline_loop:
00B514  1  20 38 B5         jsr getchar
00B517  1  C9 0D            cmp #$0D
00B519  1  F0 0F            beq getline_done
00B51B  1  C9 0A            cmp #$0A
00B51D  1  F0 0B            beq getline_done
00B51F  1               
00B51F  1  E0 3B            cpx #59
00B521  1  B0 F1            bcs getline_loop
00B523  1               
00B523  1  9D 00 02         sta linebuf,x
00B526  1  E8               inx
00B527  1  4C 14 B5         jmp getline_loop
00B52A  1               
00B52A  1               getline_done:
00B52A  1  A9 00            lda #0
00B52C  1  9D 00 02         sta linebuf,x
00B52F  1  60               rts
00B530  1               .endproc
00B530  1               
00B530  1               .proc print_error
00B530  1  A9 3F        	lda #'?'
00B532  1  20 3E B5     	jsr putchar
00B535  1  4C 06 B5     	jmp newline
00B538  1               .endproc
00B538  1               
00B538  1               ; ------------------------------------------------------------
00B538  1               ; I/O
00B538  1               ; ------------------------------------------------------------
00B538  1               .proc getchar
00B538  1  20 00 F0     	jsr BIOS_GETCHAR
00B53B  1  F0 FB        	beq getchar
00B53D  1  60           	rts
00B53E  1               .endproc
00B53E  1               
00B53E  1               .proc putchar
00B53E  1  4C 03 F0         jmp BIOS_PUTCHAR
00B541  1               .endproc
00B541  1               
00B541  1               ; ------------------------------------------------------------
00B541  1               ; CHECK_ABORT
00B541  1               ; Test if the user pressed ^C.
00B541  1               ;
00B541  1               ; Returns
00B541  1               ;   C = 1  abort requested
00B541  1               ;   C = 0  continue
00B541  1               ;
00B541  1               ; Wrapper around BIOS_STPKEY so the monitor depends only on
00B541  1               ; this primitive instead of calling the BIOS everywhere.
00B541  1               ; ------------------------------------------------------------
00B541  1               check_abort:
00B541  1  18               clc
00B542  1  60               rts
00B543  1               
00B543  1               ; command implementations
00B543  1               .include "disasm.asm"
00B543  2               ; ------------------------------------------------------------
00B543  2               ; DISASSEMBLER COMMAND
00B543  2               ; Syntax:
00B543  2               ;   D
00B543  2               ;   D start
00B543  2               ;   D start end
00B543  2               ;
00B543  2               ; Default start is MEM.
00B543  2               ; Default length is 12 instructions.
00B543  2               ; MEM is updated to the next address after the disassembly.
00B543  2               ; ------------------------------------------------------------
00B543  2               cmd_disasm:
00B543  2  20 19 B4         jsr advance_lineptr
00B546  2  20 AC B2         jsr next_token
00B549  2  90 14            bcc dis_default
00B54B  2               
00B54B  2  20 FD B2         jsr parse_word
00B54E  2  20 43 B4         jsr copy_T0_R0
00B551  2               
00B551  2  20 AC B2         jsr next_token
00B554  2  90 0C            bcc dis_one_param
00B556  2               
00B556  2  20 FD B2         jsr parse_word
00B559  2  20 4C B4         jsr copy_T0_R1
00B55C  2  4C 6C B5         jmp dis_prepare_range
00B55F  2               
00B55F  2               dis_default:
00B55F  2  20 67 B4         jsr copy_MEM_R0
00B562  2               
00B562  2               dis_one_param:
00B562  2  20 55 B4         jsr copy_R0_R1
00B565  2  A9 0C            lda #12
00B567  2  85 D4            sta parm_count
00B569  2  4C 74 B5         jmp dis_prepare_count
00B56C  2               
00B56C  2               dis_prepare_range:
00B56C  2  20 AC B2         jsr next_token
00B56F  2  90 21            bcc dis_range_ok
00B571  2  4C 27 B2         jmp cmd_error
00B574  2               
00B574  2               dis_prepare_count:
00B574  2  20 AC B2         jsr next_token
00B577  2  90 03            bcc dis_count_ok
00B579  2  4C 27 B2         jmp cmd_error
00B57C  2               
00B57C  2               dis_count_ok:
00B57C  2  20 5E B4         jsr copy_R0_R2
00B57F  2               
00B57F  2               dis_loop_count:
00B57F  2  20 41 B5         jsr check_abort
00B582  2  B0 2D            bcs dis_abort
00B584  2  20 B4 B5         jsr disasm_line
00B587  2  B0 23            bcs dis_done
00B589  2  C6 D4            dec parm_count
00B58B  2  D0 F2            bne dis_loop_count
00B58D  2  20 70 B4         jsr copy_R2_MEM
00B590  2  18           		clc
00B591  2  60           		rts
00B592  2               
00B592  2               dis_range_ok:
00B592  2  20 5E B4         jsr copy_R0_R2
00B595  2               
00B595  2               dis_loop_range:
00B595  2  20 41 B5         jsr check_abort
00B598  2  B0 17            bcs dis_abort
00B59A  2               
00B59A  2  20 C2 B4         jsr cmp_R2_R1
00B59D  2  90 05            bcc dis_do_line
00B59F  2  F0 03            beq dis_do_line
00B5A1  2  4C AC B5         jmp dis_done
00B5A4  2               
00B5A4  2               dis_do_line:
00B5A4  2  20 B4 B5         jsr disasm_line
00B5A7  2  B0 03            bcs dis_done
00B5A9  2  4C 95 B5         jmp dis_loop_range
00B5AC  2               
00B5AC  2               dis_done:
00B5AC  2  20 70 B4         jsr copy_R2_MEM
00B5AF  2  18           		clc
00B5B0  2  60           		rts
00B5B1  2               
00B5B1  2               dis_abort:
00B5B1  2  4C 27 B2         jmp cmd_error
00B5B4  2               
00B5B4  2               ; ------------------------------------------------------------
00B5B4  2               ; DISASSEMBLE ONE LINE
00B5B4  2               ;
00B5B4  2               ; Input
00B5B4  2               ;   R2 = current PC
00B5B4  2               ;
00B5B4  2               ; Internal use
00B5B4  2               ;   T0L = opcode
00B5B4  2               ;   R3L = addressing mode
00B5B4  2               ;   R3H = instruction length
00B5B4  2               ;   T1  = pointer to mnemonic string
00B5B4  2               ;
00B5B4  2               ; Output
00B5B4  2               ;   prints one disassembly line
00B5B4  2               ;   advances R2 by instruction length
00B5B4  2               ; ------------------------------------------------------------
00B5B4  2               disasm_line:
00B5B4  2  20 E5 B5         jsr print_disasm_address
00B5B7  2               
00B5B7  2  A0 00            ldy #0
00B5B9  2  B1 CA            lda (R2L),y
00B5BB  2  85 CE            sta T0L
00B5BD  2  AA               tax
00B5BE  2               
00B5BE  2  BD 26 BC         lda mode_table,x
00B5C1  2  85 CC            sta R3L
00B5C3  2  20 56 B8         jsr get_oplen_from_mode
00B5C6  2  85 CD            sta R3H
00B5C8  2               
00B5C8  2  20 40 B8         jsr get_mnemonic_id_x
00B5CB  2  20 44 B8         jsr get_mnemonic_ptr_id
00B5CE  2               
00B5CE  2  20 F2 B5         jsr print_disasm_bytes
00B5D1  2  20 01 B5         jsr print_space
00B5D4  2  20 01 B5         jsr print_space
00B5D7  2  20 22 B6         jsr print_mnemonic
00B5DA  2  20 2C B6         jsr print_operand
00B5DD  2  20 06 B5         jsr newline
00B5E0  2               
00B5E0  2  A5 CD            lda R3H
00B5E2  2  4C A5 B4         jmp add_R2_A
00B5E5  2               
00B5E5  2               print_disasm_address:
00B5E5  2  A5 CB            lda R2H
00B5E7  2  A6 CA            ldx R2L
00B5E9  2  20 E8 B4         jsr print_hex16
00B5EC  2  20 01 B5         jsr print_space
00B5EF  2  4C 01 B5         jmp print_space
00B5F2  2               
00B5F2  2               ; ------------------------------------------------------------
00B5F2  2               ; PRINT RAW BYTES FIELD
00B5F2  2               ; Shows 1..3 actual instruction bytes and pads to fixed width.
00B5F2  2               ; R3H = instruction length
00B5F2  2               ; ------------------------------------------------------------
00B5F2  2               print_disasm_bytes:
00B5F2  2  A0 00            ldy #0
00B5F4  2               
00B5F4  2               pdb_real_loop:
00B5F4  2  C4 CD            cpy R3H
00B5F6  2  F0 0E            beq pdb_pad
00B5F8  2  B1 CA            lda (R2L),y
00B5FA  2  20 CD B4         jsr print_hex8
00B5FD  2  20 01 B5         jsr print_space
00B600  2  C8               iny
00B601  2  C0 03            cpy #3
00B603  2  D0 EF            bne pdb_real_loop
00B605  2  60               rts
00B606  2               
00B606  2               pdb_pad:
00B606  2  C0 03            cpy #3
00B608  2  F0 11            beq pdb_done
00B60A  2  A9 20            lda #' '
00B60C  2  20 3E B5         jsr putchar
00B60F  2  A9 20            lda #' '
00B611  2  20 3E B5         jsr putchar
00B614  2  20 01 B5         jsr print_space
00B617  2  C8               iny
00B618  2  4C 06 B6         jmp pdb_pad
00B61B  2               
00B61B  2               pdb_done:
00B61B  2  60               rts
00B61C  2               
00B61C  2               ; ------------------------------------------------------------
00B61C  2               ; GAP BETWEEN BYTE FIELD AND MNEMONIC
00B61C  2               ; ------------------------------------------------------------
00B61C  2               print_disasm_gap:
00B61C  2  20 01 B5         jsr print_space
00B61F  2  4C 01 B5         jmp print_space
00B622  2               
00B622  2               ; ------------------------------------------------------------
00B622  2               ; PRINT MNEMONIC
00B622  2               ; T1 = pointer to zero-terminated mnemonic string
00B622  2               ; ------------------------------------------------------------
00B622  2               print_mnemonic:
00B622  2  A5 D0            lda T1L

00BA23  2               ; EMIT INSTRUCTION
00BA23  2               ; Uses asm_opcode, asm_mode and operand value(s).
00BA23  2               ; Updates MEM to next address.
00BA23  2               ; Writes nothing if relative offset is out of range.
00BA23  2               ; ------------------------------------------------------------
00BA23  2               emit_instruction:
00BA23  2  A5 D7            lda asm_mode
00BA25  2  20 73 B8         jsr get_oplen_from_mode
00BA28  2  85 CD            sta R3H
00BA2A  2               
00BA2A  2                   ; for relative forms, validate offset before storing opcode
00BA2A  2  A5 D7            lda asm_mode
00BA2C  2  C9 0D            cmp #AM_REL
00BA2E  2  F0 07            beq ei_prep_rel
00BA30  2  C9 0E            cmp #AM_ZPREL
00BA32  2  F0 0D            beq ei_prep_zprel
00BA34  2  4C 4B BA         jmp ei_store
00BA37  2               

00E9F5  2               ; ------------------------------------------------------------
00E9F5  2               ; COMPUTE_REL_OFFSET
00E9F5  2               ;
00E9F5  2               ; Input:
00E9F5  2               ;   A  = instruction length (2 or 3)
00E9F5  2               ;   R0 = instruction address
00E9F5  2               ;   T0 = target address
00E9F5  2               ;
00E9F5  2               ; Output:
00E9F5  2               ;   A  = signed 8-bit relative offset
00E9F5  2               ;
00E9F5  2               ; Error:
00E9F5  2               ;   jumps to cmd_error if target is out of range
00E9F5  2               ; ------------------------------------------------------------
00E9F5  2               compute_rel_offset:
00E9F5  2  85 D4            sta parm_count
00E9F7  2               
00E9F7  2                   ; R3 = base = R0 + instruction length
00E9F7  2  A5 C6            lda R0L
00E9F9  2  18               clc
00E9FA  2  65 D4            adc parm_count
00E9FC  2  85 CC            sta R3L
00E9FE  2  A5 C7            lda R0H
00EA00  2  69 00            adc #0
00EA02  2  85 CD            sta R3H
00EA04  2               
00EA04  2                   ; diff = target - base   (wrapped 16-bit subtraction)
00EA04  2  38               sec
00EA05  2  A5 CE            lda T0L
00EA07  2  E5 CC            sbc R3L
00EA09  2  85 D0            sta T1L
00EA0B  2  A5 CF            lda T0H
00EA0D  2  E5 CD            sbc R3H
00EA0F  2  85 D1            sta T1H
00EA11  2               
00EA11  2                   ; valid if:
00EA11  2                   ;   T1 = 00:00..00:7F   (+0 .. +127)
00EA11  2                   ;   T1 = FF:80..FF:FF   (-128 .. -1)
00EA11  2               
00EA11  2  A5 D1            lda T1H
00EA13  2  F0 07            beq cro_pos
00EA15  2  C9 FF            cmp #$FF
00EA17  2  F0 0C            beq cro_neg
00EA19  2  4C 54 E2         jmp cmd_error
00EA1C  2               
00EA1C  2               cro_pos:
00EA1C  2  A5 D0            lda T1L
00EA1E  2  C9 80            cmp #$80
00EA20  2  90 0C            bcc cro_ok
00EA22  2  4C 54 E2         jmp cmd_error
00EA25  2               
00EA25  2               cro_neg:
00EA25  2  A5 D0            lda T1L
00EA27  2  C9 80            cmp #$80
00EA29  2  B0 03            bcs cro_ok
00EA2B  2  4C 54 E2         jmp cmd_error
00EA2E  2               
00EA2E  2               cro_ok:
00EA2E  2  A5 D0            lda T1L
00EA30  2  60               rts
00EA31  2               
00EA31  2               ; ------------------------------------------------------------
00EA31  2               ; EMIT INSTRUCTION
00EA31  2               ; Uses asm_opcode, asm_mode and operand value(s).
00EA31  2               ; Updates MEM to next address.
00EA31  2               ; Writes nothing if relative offset is out of range.
00EA31  2               ; ------------------------------------------------------------
00EA31  2               emit_instruction:
00EA31  2  A5 D7            lda asm_mode
00EA33  2  20 81 E8         jsr get_oplen_from_mode
00EA36  2  85 CD            sta R3H
00EA38  2               
00EA38  2                   ; for relative forms, validate offset before storing opcode
00EA38  2  A5 D7            lda asm_mode
00EA3A  2  C9 0D            cmp #AM_REL
00EA3C  2  F0 07            beq ei_prep_rel
00EA3E  2  C9 0E            cmp #AM_ZPREL
00EA40  2  F0 0D            beq ei_prep_zprel
00EA42  2  4C 59 EA         jmp ei_store
00EA45  2               
00EA45  2               ei_prep_rel:
00EA45  2  A9 02            lda #2
00EA47  2  20 F5 E9         jsr compute_rel_offset
00EA4A  2  85 D1            sta T1H
00EA4C  2  4C 59 EA         jmp ei_store
00EA4F  2               
00EA4F  2               ei_prep_zprel:
00EA4F  2  A9 03            lda #3
00EA51  2  20 F5 E9         jsr compute_rel_offset
00EA54  2  85 D1            sta T1H
00EA56  2  4C 59 EA         jmp ei_store
00EA59  2               
00EA59  2               ei_store:
00EA59  2  A0 00            ldy #0
00EA5B  2  A5 D8            lda asm_opcode
00EA5D  2  91 C6            sta (R0L),y
00EA5F  2               
00EA5F  2  A5 CD            lda R3H
00EA61  2  C9 01            cmp #1
00EA63  2  F0 32            beq ei_finish
00EA65  2               
00EA65  2  A5 D7            lda asm_mode
00EA67  2  C9 0D            cmp #AM_REL
00EA69  2  F0 18            beq ei_rel
00EA6B  2  C9 0E            cmp #AM_ZPREL
00EA6D  2  F0 1D            beq ei_zprel
00EA6F  2               
00EA6F  2  A0 01            ldy #1
00EA71  2  A5 CE            lda T0L
00EA73  2  91 C6            sta (R0L),y
00EA75  2               
00EA75  2  A5 CD            lda R3H
00EA77  2  C9 02            cmp #2
00EA79  2  F0 1C            beq ei_finish
00EA7B  2               
00EA7B  2  C8               iny
00EA7C  2  A5 CF            lda T0H
00EA7E  2  91 C6            sta (R0L),y
00EA80  2  4C 97 EA         jmp ei_finish
00EA83  2               
00EA83  2               ei_rel:
00EA83  2  A0 01            ldy #1
00EA85  2  A5 D1            lda T1H
00EA87  2  91 C6            sta (R0L),y
00EA89  2  4C 97 EA         jmp ei_finish
00EA8C  2               
00EA8C  2               ei_zprel:
00EA8C  2  A0 01            ldy #1
00EA8E  2  A5 D0            lda T1L
00EA90  2  91 C6            sta (R0L),y
00EA92  2  C8               iny
00EA93  2  A5 D1            lda T1H
00EA95  2  91 C6            sta (R0L),y
00EA97  2               
00EA97  2               ei_finish:
00EA97  2  A5 CD            lda R3H
00EA99  2  20 B4 E4         jsr add_R0_A
00EA9C  2  A5 C6            lda R0L
00EA9E  2  85 D2            sta MEML
00EAA0  2  A5 C7            lda R0H
00EAA2  2  85 D3            sta MEMH
00EAA4  2  60               rts

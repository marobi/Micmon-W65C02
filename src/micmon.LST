00B15B  1  A2 BF            ldx #>reg_header
00B15D  1  20 82 B2         jsr print_str
00B160  1               
00B160  1               print_reg_line:
00B160  1  A9 3B            lda #';'							; in sync with command table
00B162  1  20 60 B5         jsr putchar
00B165  1  20 23 B5         jsr print_space
00B168  1               
00B168  1  AD 40 02         lda reg_pch
00B16B  1  AE 41 02         ldx reg_pcl
00B16E  1  20 0A B5         jsr print_hex16
00B171  1  20 23 B5         jsr print_space
00B174  1               
00B174  1  AD 43 02         lda reg_a
00B177  1  20 EF B4         jsr print_hex8
00B17A  1  20 23 B5         jsr print_space
00B17D  1               
00B17D  1  AD 44 02         lda reg_x
00B180  1  20 EF B4         jsr print_hex8
00B183  1  20 23 B5         jsr print_space
00B186  1               
00B186  1  AD 45 02         lda reg_y
00B189  1  20 EF B4         jsr print_hex8
00B18C  1  20 23 B5         jsr print_space
00B18F  1               
00B18F  1  AD 46 02         lda reg_sp
00B192  1  20 EF B4         jsr print_hex8
00B195  1  20 23 B5         jsr print_space
00B198  1               
00B198  1  A9 25            lda #'%'
00B19A  1  20 60 B5     		jsr putchar
00B19D  1  AD 42 02         lda reg_sr
00B1A0  1  20 9A B2         jsr print_status_bits
00B1A3  1  20 28 B5         jsr newline
00B1A6  1  18           	clc
00B1A7  1  60           	rts

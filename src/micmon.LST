00B4C7  1               .proc add_R2_A
00B4C7  1  18               clc
00B4C8  1  65 CA            adc R2L
00B4CA  1  85 CA            sta R2L
00B4CC  1  90 04            bcc add_r2_no_wrap
00B4CE  1               
00B4CE  1  E6 CB            inc R2H
00B4D0  1  F0 02            beq add_r2_wrap

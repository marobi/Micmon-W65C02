00B563  1               ; ------------------------------------------------------------
00B563  1               ; CHECK_ABORT
00B563  1               ; Test if the user pressed ^C.
00B563  1               ;
00B563  1               ; Returns
00B563  1               ;   C = 1  abort requested
00B563  1               ;   C = 0  continue
00B563  1               ;
00B563  1               ; Wrapper around BIOS_STPKEY so the monitor depends only on
00B563  1               ; this primitive instead of calling the BIOS everywhere.
00B563  1               ; ------------------------------------------------------------
00B563  1               check_abort:
00B563  1  18               clc
00B564  1  60               rts
00B565  1               
00B565  1               ; command implementations
00B565  1               .include "disasm.asm"
00B565  2               ; ------------------------------------------------------------
00B565  2               ; DISASSEMBLER COMMAND
00B565  2               ; Syntax:
00B565  2               ;   D
00B565  2               ;   D start
00B565  2               ;   D start end
00B565  2               ;
00B565  2               ; Default start is MEM.
00B565  2               ; Default length is 12 instructions.
00B565  2               ; MEM is updated to the next address after the disassembly.
00B565  2               ; ------------------------------------------------------------
00B565  2               cmd_disasm:
00B565  2  20 3B B4         jsr advance_lineptr
00B568  2  20 CE B2         jsr next_token
00B56B  2  90 14            bcc dis_default
00B56D  2               
00B56D  2  20 1F B3         jsr parse_word
00B570  2  20 65 B4         jsr copy_T0_R0
00B573  2               
00B573  2  20 CE B2         jsr next_token
00B576  2  90 0C            bcc dis_one_param
00B578  2               
00B578  2  20 1F B3         jsr parse_word
00B57B  2  20 6E B4         jsr copy_T0_R1
00B57E  2  4C 8E B5         jmp dis_prepare_range
00B581  2               
00B581  2               dis_default:
00B581  2  20 89 B4         jsr copy_MEM_R0
00B584  2               
00B584  2               dis_one_param:
00B584  2  20 77 B4         jsr copy_R0_R1
00B587  2  A9 0C            lda #12
00B589  2  85 D4            sta parm_count
00B58B  2  4C 96 B5         jmp dis_prepare_count
00B58E  2               
00B58E  2               dis_prepare_range:
00B58E  2  20 CE B2         jsr next_token
00B591  2  90 21            bcc dis_range_ok
00B593  2  4C 49 B2         jmp cmd_error
00B596  2               
00B596  2               dis_prepare_count:
00B596  2  20 CE B2         jsr next_token
00B599  2  90 03            bcc dis_count_ok
00B59B  2  4C 49 B2         jmp cmd_error
00B59E  2               
00B59E  2               dis_count_ok:
00B59E  2  20 80 B4         jsr copy_R0_R2
00B5A1  2               
00B5A1  2               dis_loop_count:
00B5A1  2  20 63 B5         jsr check_abort
00B5A4  2  B0 2D            bcs dis_abort
00B5A6  2  20 D6 B5         jsr disasm_line
00B5A9  2  B0 23            bcs dis_done
00B5AB  2  C6 D4            dec parm_count
00B5AD  2  D0 F2            bne dis_loop_count
00B5AF  2  20 92 B4         jsr copy_R2_MEM
00B5B2  2  18           		clc
00B5B3  2  60           		rts
00B5B4  2               
00B5B4  2               dis_range_ok:
00B5B4  2  20 80 B4         jsr copy_R0_R2
00B5B7  2               
00B5B7  2               dis_loop_range:
00B5B7  2  20 63 B5         jsr check_abort
00B5BA  2  B0 17            bcs dis_abort
00B5BC  2               
00B5BC  2  20 E4 B4         jsr cmp_R2_R1
00B5BF  2  90 05            bcc dis_do_line
00B5C1  2  F0 03            beq dis_do_line
00B5C3  2  4C CE B5         jmp dis_done
00B5C6  2               
00B5C6  2               dis_do_line:
00B5C6  2  20 D6 B5         jsr disasm_line
00B5C9  2  B0 03            bcs dis_done
00B5CB  2  4C B7 B5         jmp dis_loop_range
00B5CE  2               
00B5CE  2               dis_done:
00B5CE  2  20 92 B4         jsr copy_R2_MEM
00B5D1  2  18           		clc
00B5D2  2  60           		rts
00B5D3  2               
00B5D3  2               dis_abort:
00B5D3  2  4C 49 B2         jmp cmd_error
00B5D6  2               
00B5D6  2               ; ------------------------------------------------------------
00B5D6  2               ; DISASSEMBLE ONE LINE
00B5D6  2               ;
00B5D6  2               ; Input
00B5D6  2               ;   R2 = current PC
00B5D6  2               ;
00B5D6  2               ; Internal use
00B5D6  2               ;   T0L = opcode
00B5D6  2               ;   R3L = addressing mode
00B5D6  2               ;   R3H = instruction length
00B5D6  2               ;   T1  = pointer to mnemonic string
00B5D6  2               ;
00B5D6  2               ; Output
00B5D6  2               ;   prints one disassembly line
00B5D6  2               ;   advances R2 by instruction length
00B5D6  2               ; ------------------------------------------------------------
00B5D6  2               disasm_line:
00B5D6  2  20 07 B6         jsr print_disasm_address
00B5D9  2               
00B5D9  2  A0 00            ldy #0
00B5DB  2  B1 CA            lda (R2L),y
00B5DD  2  85 CE            sta T0L
00B5DF  2  AA               tax
00B5E0  2               
00B5E0  2  BD 48 BC         lda mode_table,x
00B5E3  2  85 CC            sta R3L
00B5E5  2  20 78 B8         jsr get_oplen_from_mode
00B5E8  2  85 CD            sta R3H
00B5EA  2               
00B5EA  2  20 62 B8         jsr get_mnemonic_id_x
00B5ED  2  20 66 B8         jsr get_mnemonic_ptr_id
00B5F0  2               
00B5F0  2  20 14 B6         jsr print_disasm_bytes
00B5F3  2  20 23 B5         jsr print_space
00B5F6  2  20 23 B5         jsr print_space
00B5F9  2  20 44 B6         jsr print_mnemonic
00B5FC  2  20 4E B6         jsr print_operand
00B5FF  2  20 28 B5         jsr newline
00B602  2               
00B602  2  A5 CD            lda R3H
00B604  2  4C C7 B4         jmp add_R2_A
00B607  2               
00B607  2               print_disasm_address:
00B607  2  A5 CB            lda R2H
00B609  2  A6 CA            ldx R2L
00B60B  2  20 0A B5         jsr print_hex16
00B60E  2  20 23 B5         jsr print_space
00B611  2  4C 23 B5         jmp print_space
00B614  2               
00B614  2               ; ------------------------------------------------------------
00B614  2               ; PRINT RAW BYTES FIELD
00B614  2               ; Shows 1..3 actual instruction bytes and pads to fixed width.
00B614  2               ; R3H = instruction length
00B614  2               ; ------------------------------------------------------------

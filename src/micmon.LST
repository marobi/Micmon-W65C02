00E4C6  1  D0 04            bne cmp_r2_r1_done
00E4C8  1  A5 C8            lda R2L
00E4CA  1  C5 C6            cmp R1L
00E4CC  1               cmp_r2_r1_done:
00E4CC  1  60               rts

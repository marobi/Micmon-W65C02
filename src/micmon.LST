000000r 1               ; ---------------------------------------------------------------------------
000000r 1               ; MICMON – Minimal Interactive Command Monitor for the W65C02
000000r 1               ; (c) 2026 Rien Matthijsse
000000r 1               ; ---------------------------------------------------------------------------
000000r 1               .include "readme.asm"
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; MICMON – Minimal Interactive Command Monitor for the W65C02
000000r 2               ; (c) 2026 Rien Matthijsse
000000r 2               ;
000000r 2               ; Overview
000000r 2               ; --------
000000r 2               ; Micmon is a compact machine-level monitor for the W65C02, designed to fit
000000r 2               ; within a 4 KB ROM. It provides essential debugging, inspection and control
000000r 2               ; facilities while remaining small, deterministic, and fully self-hosting.
000000r 2               ;
000000r 2               ; The monitor follows a strict "round-trip" philosophy: all output is valid
000000r 2               ; input. Any command output (e.g. memory dumps) can be edited and fed back
000000r 2               ; into the monitor for execution. This enables interactive workflows using
000000r 2               ; external terminals or VDUs with line editing capabilities.
000000r 2               ;
000000r 2               ; Design Goals
000000r 2               ; ------------
000000r 2               ; - Minimal footprint (fits in 4 KB ROM)
000000r 2               ; - Deterministic behaviour (no hidden state, no dynamic allocation)
000000r 2               ; - Table-driven architecture (command dispatch, disassembler, assembler)
000000r 2               ; - Round-trip capable output (monitor output is executable input)
000000r 2               ; - Tight integration with external VDU/GDU systems
000000r 2               ;
000000r 2               ; Functional Scope
000000r 2               ; ----------------
000000r 2               ; - Memory inspection and modification
000000r 2               ; - CPU register inspection and editing
000000r 2               ; - Program execution control (GO)
000000r 2               ; - Disassembler (W65C02 complete)
000000r 2               ; - Inline assembler (single-line, immediate emission)
000000r 2               ; - Command-driven interface with single-character dispatch
000000r 2               ;
000000r 2               ; Command Summary
000000r 2               ; ---------------
000000r 2               ;   H          Help / command overview
000000r 2               ;   M addr     Dump memory
000000r 2               ;   > addr     Modify memory (hex byte stream)
000000r 2               ;   R          Show CPU registers
000000r 2               ;   ;          Modify CPU registers
000000r 2               ;   G [addr]   Execute code at address
000000r 2               ;   D [addr]   Disassembler
000000r 2               ;   A [addr]   Assemble single instruction at address
000000r 2               ;
000000r 2               ; Notes:
000000r 2               ; - Default address is MEM unless explicitly provided
000000r 2               ; - Commands are line-oriented and CR-terminated
000000r 2               ; - Where possible: output format is compatible with monitor input (round-trip)
000000r 2               ;
000000r 2               ; Execution Model
000000r 2               ; ---------------
000000r 2               ; - RESET:
000000r 2               ;     Initializes CPU state and monitor environment
000000r 2               ;     Enters monitor via BRK vector
000000r 2               ;
000000r 2               ; - BRK handler:
000000r 2               ;     Saves full CPU context (A, X, Y, P, SP, PC)
000000r 2               ;     Transfers control to command interpreter
000000r 2               ;
000000r 2               ; - Command loop:
000000r 2               ;     Line-oriented input
000000r 2               ;     Single-character command dispatch via table
000000r 2               ;     Commands operate directly on memory and CPU image
000000r 2               ;
000000r 2               ; Interaction Model
000000r 2               ; -----------------
000000r 2               ; Micmon assumes the host terminal or VDU performs line editing.
000000r 2               ; Input is processed per line (CR-terminated).
000000r 2               ;
000000r 2               ; Output is formatted to be re-consumable:
000000r 2               ;
000000r 2               ;     M 0200 020F
000000r 2               ;     > 0200 A9 01 8D 00 02 ...
000000r 2               ;
000000r 2               ; Can be edited into:
000000r 2               ;
000000r 2               ;     > 0200 A9 FF 8D 00 02
000000r 2               ;
000000r 2               ; and executed directly by the monitor.
000000r 2               ;
000000r 2               ; Parameter Formats
000000r 2               ; -----------------
000000r 2               ; All numeric parameters support multiple input formats. The parser auto-
000000r 2               ; detects the format based on prefix or content.
000000r 2               ;
000000r 2               ; Supported formats:
000000r 2               ;
000000r 2               ;   Hexadecimal (default)
000000r 2               ;     0200      $0200
000000r 2               ;
000000r 2               ;   Decimal
000000r 2               ;     +123
000000r 2               ;
000000r 2               ;   Binary
000000r 2               ;     %10101010
000000r 2               ;
000000r 2               ;   ASCII
000000r 2               ;     'A        -> $41
000000r 2               ;
000000r 2               ; Rules:
000000r 2               ; - Hex is assumed if no prefix is present
000000r 2               ;       $   = hex (optional, since default)
000000r 2               ;       %   = binary
000000r 2               ;       +   = decimal
000000r 2               ;       '   = ASCII single byte
000000r 2               ;
000000r 2               ; - All parsed values result in:
000000r 2               ;       T0 = value (byte or word)
000000r 2               ;       value_size >= 1 indicates success
000000r 2               ;
000000r 2               ; - Commands are literal
000000r 2               ;
000000r 2               ; Examples:
000000r 2               ;   M $C000
000000r 2               ;   M %1100000000000000
000000r 2               ;   M +49152
000000r 2               ;
000000r 2               ;   > 0200 'A $42 %01000011
000000r 2               ;
000000r 2               ;   A 0300 LDA #'A
000000r 2               ;   A 0302 LDA #$41
000000r 2               ;
000000r 2               ; Architecture Notes
000000r 2               ; ------------------
000000r 2               ; - All decoding (disassembler/assembler) is table-driven
000000r 2               ; - Opcode metadata shared between assembler and disassembler
000000r 2               ; - Zero-page used from $00C0-$00DF
000000r 2               ; - Strict separation between parsing, decoding and execution
000000r 2               ;
000000r 2               ; Extensibility
000000r 2               ; -------------
000000r 2               ; Micmon is intentionally designed for easy extension:
000000r 2               ;
000000r 2               ; - New commands can be added by inserting entries in:
000000r 2               ;       cmd_chars / cmd_addrs tables
000000r 2               ;
000000r 2               ; - No central switch-case logic: dispatch is fully table-driven
000000r 2               ; - Parsing helpers (parse_word, next_token, etc.) are reusable
000000r 2               ; - Disassembler and assembler share data tables, reducing duplication
000000r 2               ; - New addressing modes or instructions require only table updates
000000r 2               ;
000000r 2               ; This allows incremental growth without restructuring the monitor core.
000000r 2               ;
000000r 2               ; Limitations
000000r 2               ; -----------
000000r 2               ; - No multi-line assembly or label resolution
000000r 2               ; - No expression evaluator
000000r 2               ; - Branch range limited to signed 8-bit (hardware constraint)
000000r 2               ;
000000r 2               ; Target
000000r 2               ; ------
000000r 2               ; WDC W65C02 (fully supported instruction set)
000000r 2               ;
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               
000000r 1               
000000r 1               	.setcpu "65C02"
000000r 1               
000000r 1               .include "bios.inc"
000000r 2               ;
000000r 2               ; BIOS jumptable + ...
000000r 2               ;
000000r 2               .ifndef __BIOS_INC__
000000r 2               __BIOS_INC__ = 1
000000r 2               
000000r 2               BIOS_CMD_PORT   =   $D002
000000r 2               BIOS_STAT_PORT  =   $D003
000000r 2               BIOS_SYNC_PORT  =   $D004
000000r 2               
000000r 2               BIOS_BASE       =  	$F000
000000r 2               BIOS_GETCHAR    =   BIOS_BASE
000000r 2               BIOS_PUTCHAR    =   BIOS_BASE+3
000000r 2               BIOS_INKEY      =   BIOS_BASE+6
000000r 2               BIOS_STPKEY		=	BIOS_BASE+9
000000r 2               BIOS_CONTEXT    =   BIOS_BASE+12
000000r 2               BIOS_GETLINE    =   BIOS_BASE+15
000000r 2               
000000r 2               ;
000000r 2               ;
000000r 2               ;
000000r 2               .macro BIOS_SETRBUF buf, len
000000r 2               	ldx #<buf
000000r 2               	ldy #>buf
000000r 2               	lda #len
000000r 2               .endmacro
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               
000000r 1               	.segment "ZEROPAGE"
000000r 1               	.org $00C0					; nicer listing
0000C0  1               
0000C0  1               ; IRQ hander vector
0000C0  1  xx           irq_vecL:   .res 1
0000C1  1  xx           irq_vecH:   .res 1
0000C2  1               
0000C2  1               ; parser / dispatcher pointers
0000C2  1  xx xx        lineptr:    .res 2
0000C4  1  xx xx        jmpvec:     .res 2
0000C6  1               
0000C6  1               ; 16-bit working registers for commands
0000C6  1  xx           R0L:        .res 1
0000C7  1  xx           R0H:        .res 1
0000C8  1  xx           R1L:        .res 1
0000C9  1  xx           R1H:        .res 1
0000CA  1  xx           R2L:        .res 1
0000CB  1  xx           R2H:        .res 1
0000CC  1  xx           R3L:        .res 1
0000CD  1  xx           R3H:        .res 1
0000CE  1               
0000CE  1               ; temporary registers used by parser and utility routines
0000CE  1  xx           T0L:        .res 1
0000CF  1  xx           T0H:        .res 1
0000D0  1  xx           T1L:        .res 1
0000D1  1  xx           T1H:        .res 1
0000D2  1               
0000D2  1               ; monitor remembers last referenced memory address
0000D2  1  xx           MEML:       .res 1
0000D3  1  xx           MEMH:       .res 1
0000D4  1               
0000D4  1               ; parser state
0000D4  1  xx           parm_count: .res 1
0000D5  1  xx           value_size: .res 1
0000D6  1  xx           tmp:        .res 1
0000D7  1               
0000D7  1  xx           asm_mode:   .res 1
0000D8  1  xx           asm_opcode: .res 1
0000D9  1  xx           mnem_len:   .res 1
0000DA  1               
0000DA  1               ; context
0000DA  1  xx           save_sp:	.res 1
0000DB  1               
0000DB  1               	.segment "BSS"
0000DB  1               	.org $0200				; nicer listing
000200  1               
000200  1               ; input buffer
000200  1  xx xx xx xx  linebuf:    .res 64
000204  1  xx xx xx xx  
000208  1  xx xx xx xx  
000240  1               
000240  1               ; saved CPU image
000240  1  xx           reg_pch:    .res 1
000241  1  xx           reg_pcl:    .res 1
000242  1  xx           reg_sr:     .res 1
000243  1  xx           reg_a:      .res 1
000244  1  xx           reg_x:      .res 1
000245  1  xx           reg_y:      .res 1
000246  1  xx           reg_sp:     .res 1
000247  1               
000247  1               	.segment "CODE"
000247  1               	.org $B000				; nicer listing
00B000  1               
00B000  1               ; ------------------------------------------------------------
00B000  1               ; RESET
00B000  1               ; Basic CPU setup, monitor state initialization, then enter
00B000  1               ; the monitor through BRK so startup uses the normal entry path.
00B000  1               ; ------------------------------------------------------------
00B000  1               	.export reset
00B000  1               reset:
00B000  1  78               sei						; disable interrupts
00B001  1  D8               cld
00B002  1  A2 FF            ldx #$FF
00B004  1  9A               txs						; init stack
00B005  1               
00B005  1  64 D2            stz MEML
00B007  1  64 D3            stz MEMH
00B009  1  A9 2C        	lda #<context_switch	; set interrupt vector
00B00B  1  85 C0            sta irq_vecL
00B00D  1  A9 B0        	lda #>context_switch
00B00F  1  85 C1            sta irq_vecH
00B011  1               
00B011  1  20 29 E0     	jsr $E029				; temp clutch!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
00B014  1               
00B014  1  A9 3B            lda #<welcome_text		; say hello
00B016  1  A2 BF            ldx #>welcome_text
00B018  1  20 82 B2         jsr print_str
00B01B  1               
00B01B  1  00           	brk						; enter monitor
00B01C  1               
00B01C  1               ; ------------------------------------------------------------
00B01C  1               ; IRQ / BRK ENTRY
00B01C  1               ; Shared entry for hardware IRQ and BRK.
00B01C  1               ;
00B01C  1               ; BRK enters the monitor.
00B01C  1               ; IRQ dispatches through irq_vec
00B01C  1               ; ------------------------------------------------------------
00B01C  1               	.export irq_entry
00B01C  1               irq_entry:
00B01C  1  48               pha						; save rest of context
00B01D  1  DA               phx
00B01E  1  5A               phy
00B01F  1               
00B01F  1  BA               tsx
00B020  1  86 DA        	stx save_sp				; save current SP
00B022  1  BD 04 01         lda $0104,x             ; stacked SR after PHA/PHX/PHY
00B025  1  29 10            and #$10
00B027  1  D0 23            bne brk_entry			; BREAK
00B029  1               
00B029  1               irq_dispatch:				; IRQ
00B029  1  6C C0 00         jmp (irq_vecL)
00B02C  1               
00B02C  1               ; ------------------------------------------------------------
00B02C  1               ; expects the full context to be saved on stack
00B02C  1               ; micmon must be shared between all contexts and loaded last
00B02C  1               ;
00B02C  1               context_switch:				; for now default irq vector
00B02C  1  AD 04 D0     	lda BIOS_SYNC_PORT
00B02F  1  F0 FB        	beq context_switch		; wait for prev release, should not happen
00B031  1               							; now 1
00B031  1  9C 04 D0     	stz BIOS_SYNC_PORT		; arm
00B034  1               							; now 0
00B034  1               wait_ack:					; rp2350 will perform context switch
00B034  1  AD 04 D0     	lda BIOS_SYNC_PORT
00B037  1  F0 FB        	beq wait_ack			; wait for completion
00B039  1               							; now 1
00B039  1  AD 03 D0     	lda BIOS_STAT_PORT		; what to do?
00B03C  1  C9 01        	cmp #$01				; when 1
00B03E  1  F0 03        	beq irq_restore			; restore context
00B040  1  6C FC FF     	jmp ($FFFC)				; else exec reset
00B043  1               
00B043  1               irq_restore:				; context switched
00B043  1  A6 DA        	ldx save_sp
00B045  1  9A           	txs						; restore SP
00B046  1  7A               ply						; restore context
00B047  1  FA               plx
00B048  1  68               pla
00B049  1  40               rti						; and continue
00B04A  1               
00B04A  1               	.export nmi_entry
00B04A  1               nmi_entry:
00B04A  1  40               rti						; stub
00B04B  1               
00B04B  1               print_context:
00B04B  1  BA               tsx
00B04C  1               
00B04C  1               ; ------------------------------------------------------------
00B04C  1               ; BRK ENTRY
00B04C  1               ; Save CPU state into monitor RAM and discard interrupt frame.
00B04C  1               ; BRK pushes PC+2, so saved PC is corrected back to BRK opcode.
00B04C  1               ; ------------------------------------------------------------
00B04C  1               brk_entry:
00B04C  1  68               pla						; save context
00B04D  1  8D 45 02         sta reg_y
00B050  1  68               pla
00B051  1  8D 44 02         sta reg_x
00B054  1  68               pla
00B055  1  8D 43 02         sta reg_a
00B058  1  68               pla
00B059  1  8D 42 02         sta reg_sr
00B05C  1  68               pla
00B05D  1  8D 41 02         sta reg_pcl
00B060  1  68               pla
00B061  1  8D 40 02         sta reg_pch
00B064  1               
00B064  1  BA               tsx
00B065  1  8E 46 02         stx reg_sp
00B068  1               
00B068  1  D8               cld
00B069  1  38               sec						; correct PC =-2
00B06A  1  AD 41 02         lda reg_pcl
00B06D  1  E9 02            sbc #2
00B06F  1  8D 41 02         sta reg_pcl
00B072  1  AD 40 02         lda reg_pch
00B075  1  E9 00            sbc #0
00B077  1  8D 40 02         sta reg_pch
00B07A  1               
00B07A  1               ; ------------------------------------------------------------
00B07A  1               ; MONITOR ENTRY
00B07A  1               ; Every BRK entry shows the saved registers, then drops into
00B07A  1               ; the command loop.
00B07A  1               ; ------------------------------------------------------------
00B07A  1               monitor_entry:
00B07A  1  58           	cli					; enable interrupts
00B07B  1  20 59 B1         jsr show_registers	; show regs and fall through
00B07E  1  20 2D B5     	jsr print_prompt
00B081  1               
00B081  1               ; ------------------------------------------------------------
00B081  1               ; MAIN MONITOR LOOP
00B081  1               ; Read one full line, execute it
00B081  1               ; ------------------------------------------------------------
00B081  1               monitor_loop:
00B081  1  20 34 B5         jsr getline					; read line
00B084  1  A9 00            lda #<linebuf
00B086  1  85 C2            sta lineptr
00B088  1  A9 02            lda #>linebuf
00B08A  1  85 C3            sta lineptr+1
00B08C  1               
00B08C  1               execute_line:
00B08C  1  20 42 B4         jsr skip_spaces
00B08F  1  A0 00            ldy #0
00B091  1  B1 C2            lda (lineptr),y			; get cmd
00B093  1  F0 0A            beq exec_done
00B095  1  20 51 B4         jsr toupper
00B098  1  91 C2            sta (lineptr),y			; save uppercase
00B09A  1  20 A5 B0         jsr dispatch_command
00B09D  1  B0 03        	bcs exec_nopr
00B09F  1               exec_done:
00B09F  1  20 2D B5     	jsr print_prompt
00B0A2  1               
00B0A2  1               exec_nopr:
00B0A2  1  4C 81 B0         jmp monitor_loop
00B0A5  1               
00B0A5  1               ; ------------------------------------------------------------
00B0A5  1               ; COMMAND DISPATCH
00B0A5  1               ; ------------------------------------------------------------
00B0A5  1               dispatch_command:
00B0A5  1  A0 00            ldy #0
00B0A7  1  B1 C2            lda (lineptr),y
00B0A9  1  85 D6            sta tmp
00B0AB  1               
00B0AB  1  A2 00            ldx #0
00B0AD  1               dispatch_loop:
00B0AD  1  BD 1F BF         lda cmd_chars,x
00B0B0  1  F0 19            beq dispatch_error
00B0B2  1  C5 D6            cmp tmp
00B0B4  1  F0 04            beq dispatch_found
00B0B6  1  E8               inx
00B0B7  1  4C AD B0         jmp dispatch_loop
00B0BA  1               
00B0BA  1               dispatch_found:
00B0BA  1  8A               txa
00B0BB  1  0A               asl
00B0BC  1  AA               tax
00B0BD  1  BD 29 BF         lda cmd_addrs,x
00B0C0  1  85 C4            sta jmpvec
00B0C2  1  E8               inx
00B0C3  1  BD 29 BF         lda cmd_addrs,x
00B0C6  1  85 C5            sta jmpvec+1
00B0C8  1  6C C4 00         jmp (jmpvec)
00B0CB  1               
00B0CB  1               dispatch_error:
00B0CB  1  4C 49 B2         jmp cmd_error
00B0CE  1               
00B0CE  1               ; ------------------------------------------------------------
00B0CE  1               ; RESET COMMAND
00B0CE  1               ; ------------------------------------------------------------
00B0CE  1               cmd_reset:
00B0CE  1  4C 00 B0     		jmp reset
00B0D1  1               
00B0D1  1               ; ------------------------------------------------------------
00B0D1  1               ; MEMORY DUMP COMMAND
00B0D1  1               ; Syntax:
00B0D1  1               ;   M
00B0D1  1               ;   M start
00B0D1  1               ;   M start end
00B0D1  1               ;
00B0D1  1               ; Default start is MEM.
00B0D1  1               ; Default length is 12 lines * 8 bytes = 96 bytes.
00B0D1  1               ; MEM is updated to the next address after the dump.
00B0D1  1               ; ------------------------------------------------------------
00B0D1  1               cmd_mem:
00B0D1  1  20 3B B4     	jsr advance_lineptr
00B0D4  1               
00B0D4  1  20 CE B2         jsr next_token
00B0D7  1  90 14            bcc mem_default
00B0D9  1               
00B0D9  1  20 1F B3         jsr parse_word
00B0DC  1  20 65 B4         jsr copy_T0_R0
00B0DF  1               
00B0DF  1  20 CE B2         jsr next_token
00B0E2  1  90 0C            bcc mem_one_param
00B0E4  1               
00B0E4  1  20 1F B3         jsr parse_word
00B0E7  1  20 6E B4         jsr copy_T0_R1
00B0EA  1  4C F8 B0         jmp mem_prepare
00B0ED  1               
00B0ED  1               mem_default:
00B0ED  1  20 89 B4         jsr copy_MEM_R0
00B0F0  1               mem_one_param:
00B0F0  1  20 77 B4         jsr copy_R0_R1
00B0F3  1  A9 5F            lda #95
00B0F5  1  20 B8 B4         jsr add_R1_A
00B0F8  1               
00B0F8  1               mem_prepare:
00B0F8  1  20 CE B2         jsr next_token
00B0FB  1  90 03            bcc mem_prepare_ok
00B0FD  1  4C 49 B2         jmp cmd_error
00B100  1               
00B100  1               mem_prepare_ok:
00B100  1  20 80 B4         jsr copy_R0_R2
00B103  1               
00B103  1               mem_loop:
00B103  1  20 63 B5         jsr check_abort
00B106  1  B0 16            bcs mem_abort
00B108  1               
00B108  1  20 4E B2         jsr dump_line
00B10B  1               
00B10B  1  A9 08            lda #8
00B10D  1  20 C7 B4         jsr add_R2_A
00B110  1  B0 07            bcs mem_ok
00B112  1               
00B112  1  20 E4 B4         jsr cmp_R2_R1
00B115  1  90 EC            bcc mem_loop
00B117  1  F0 EA            beq mem_loop
00B119  1               
00B119  1               mem_ok:
00B119  1  20 92 B4         jsr copy_R2_MEM
00B11C  1  18               clc
00B11D  1  60           	rts
00B11E  1               
00B11E  1               mem_abort:
00B11E  1  4C 49 B2         jmp cmd_error
00B121  1               
00B121  1               ; ------------------------------------------------------------
00B121  1               ; MEMORY EDIT COMMAND
00B121  1               ; Syntax:
00B121  1               ;   > addr byte...
00B121  1               ; Writes 1..8 bytes.
00B121  1               ; Updates MEM to the next address after the last write.
00B121  1               ; ------------------------------------------------------------
00B121  1               cmd_memedit:
00B121  1  20 3B B4     	jsr advance_lineptr
00B124  1  20 1F B3         jsr parse_word
00B127  1  20 65 B4         jsr copy_T0_R0				; init ptr
00B12A  1               
00B12A  1  64 D4            stz parm_count				; first of 8
00B12C  1               
00B12C  1               write_loop:
00B12C  1  A5 D4            lda parm_count
00B12E  1  C9 08            cmp #8
00B130  1  B0 16            bcs write_done				; >= 7
00B132  1               
00B132  1  20 CE B2         jsr next_token
00B135  1  90 11            bcc write_done				; no more
00B137  1               
00B137  1  20 12 B3         jsr parse_byte
00B13A  1               
00B13A  1  A0 00            ldy #0
00B13C  1  A5 CE            lda T0L
00B13E  1  91 C6            sta (R0L),y						; store it
00B140  1               
00B140  1  20 9B B4         jsr inc_R0						; next location
00B143  1  E6 D4            inc parm_count				; next param
00B145  1  4C 2C B1         jmp write_loop				; loop
00B148  1               
00B148  1               write_done:
00B148  1  A5 D4            lda parm_count
00B14A  1  F0 0A            beq write_error				; no locations given
00B14C  1               
00B14C  1  A5 C6            lda R0L								; advance mem ptr
00B14E  1  85 D2            sta MEML
00B150  1  A5 C7            lda R0H
00B152  1  85 D3            sta MEMH
00B154  1  18               clc
00B155  1  60           	rts
00B156  1               
00B156  1               write_error:
00B156  1  4C 49 B2         jmp cmd_error

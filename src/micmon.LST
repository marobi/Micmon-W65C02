00E795  1               .include "asm.asm"
00E795  2               ; ------------------------------------------------------------
00E795  2               ; SIMPLE ASSEMBLER COMMAND
00E795  2               ; Syntax:
00E795  2               ;   A [addr] mnemonic [operand]
00E795  2               ;
00E795  2               ; If addr is omitted, MEM is used.
00E795  2               ; On success MEM is updated to the next address.
00E795  2               ; ------------------------------------------------------------
00E795  2               cmd_asm:
00E795  2  20 1C E4         jsr advance_lineptr
00E798  2  20 AF E2         jsr next_token
00E79B  2  B0 03            bcs ca_have_first
00E79D  2  4C 2B E2         jmp cmd_error
00E7A0  2               
00E7A0  2               ca_have_first:
00E7A0  2  A0 00            ldy #0
00E7A2  2  B1 C0            lda (lineptr),y
00E7A4  2  20 32 E4         jsr toupper
00E7A7  2  C9 41            cmp #'A'
00E7A9  2  90 04            bcc ca_with_addr
00E7AB  2  C9 5B            cmp #'Z'+1
00E7AD  2  90 0E            bcc ca_default_addr
00E7AF  2               
00E7AF  2               ca_with_addr:
00E7AF  2  20 00 E3         jsr parse_word
00E7B2  2  20 46 E4         jsr copy_T0_R0
00E7B5  2  20 AF E2         jsr next_token
00E7B8  2  B0 06            bcs ca_mnemonic
00E7BA  2  4C 2B E2         jmp cmd_error
00E7BD  2               
00E7BD  2               ca_default_addr:
00E7BD  2  20 6A E4         jsr copy_MEM_R0
00E7C0  2               
00E7C0  2               ca_mnemonic:
00E7C0  2  20 61 E4         jsr copy_R0_R2
00E7C3  2  20 DC E7         jsr parse_mnemonic
00E7C6  2  20 6F E8         jsr parse_asm_operand
00E7C9  2  20 AF E2         jsr next_token
00E7CC  2  90 03            bcc ca_find
00E7CE  2  4C 2B E2         jmp cmd_error
00E7D1  2               
00E7D1  2               ca_find:
00E7D1  2  20 95 E9         jsr find_opcode
00E7D4  2  B0 03            bcs ca_emit
00E7D6  2  4C 2B E2         jmp cmd_error
00E7D9  2               
00E7D9  2               ca_emit:
00E7D9  2  4C 18 EA         jmp emit_instruction
00E7DC  2               
00E7DC  2               ; ------------------------------------------------------------
00E7DC  2               ; PARSE MNEMONIC
00E7DC  2               ; lineptr must point at the first mnemonic character.
00E7DC  2               ; Saves start pointer in R1 and length in mnem_len.
00E7DC  2               ; Advances lineptr to the first character after the mnemonic.
00E7DC  2               ; ------------------------------------------------------------
00E7DC  2               parse_mnemonic:
00E7DC  2  20 23 E4         jsr skip_spaces
00E7DF  2  A5 C0            lda lineptr
00E7E1  2  85 C6            sta R1L
00E7E3  2  A5 C1            lda lineptr+1
00E7E5  2  85 C7            sta R1H
00E7E7  2  64 D7            stz mnem_len
00E7E9  2               
00E7E9  2               pm_loop:
00E7E9  2  A0 00            ldy #0
00E7EB  2  B1 C0            lda (lineptr),y
00E7ED  2  F0 0C            beq pm_done
00E7EF  2  C9 20            cmp #' '
00E7F1  2  F0 08            beq pm_done
00E7F3  2  E6 D7            inc mnem_len
00E7F5  2  20 1C E4         jsr advance_lineptr
00E7F8  2  4C E9 E7         jmp pm_loop
00E7FB  2               
00E7FB  2               pm_done:
00E7FB  2  A5 D7            lda mnem_len
00E7FD  2  D0 03            bne pm_ok
00E7FF  2  4C 2B E2         jmp cmd_error
00E802  2               
00E802  2               pm_ok:
00E802  2  60               rts
00E803  2               
00E803  2               ; ------------------------------------------------------------
00E803  2               ; COMPARE INPUT MNEMONIC AGAINST CANDIDATE STRING
00E803  2               ; Input:
00E803  2               ;   R1 = input mnemonic start
00E803  2               ;   mnem_len = input mnemonic length
00E803  2               ;   T1 = candidate zero-terminated mnemonic pointer
00E803  2               ;
00E803  2               ; Output:
00E803  2               ;   C = 1 match
00E803  2               ;   C = 0 no match
00E803  2               ; ------------------------------------------------------------
00E803  2               compare_mnemonic:
00E803  2  A0 00            ldy #0
00E805  2               
00E805  2               cm_loop:
00E805  2  C4 D7            cpy mnem_len
00E807  2  F0 13            beq cm_end_input
00E809  2               
00E809  2  B1 C6            lda (R1L),y
00E80B  2  20 32 E4         jsr toupper
00E80E  2  85 D4            sta tmp
00E810  2               
00E810  2  B1 CE            lda (T1L),y
00E812  2  F0 0C            beq cm_no
00E814  2  C5 D4            cmp tmp
00E816  2  D0 08            bne cm_no
00E818  2               
00E818  2  C8               iny
00E819  2  4C 05 E8         jmp cm_loop
00E81C  2               
00E81C  2               cm_end_input:
00E81C  2  B1 CE            lda (T1L),y
00E81E  2  F0 02            beq cm_yes
00E820  2               
00E820  2               cm_no:
00E820  2  18               clc
00E821  2  60               rts
00E822  2               
00E822  2               cm_yes:
00E822  2  38               sec
00E823  2  60               rts
00E824  2               
00E824  2               
00E824  2               ; ------------------------------------------------------------
00E824  2               ; FETCH MNEMONIC ID FOR OPCODE IN X
00E824  2               ; Uses mnemonic_id_table as a 256-byte table.
00E824  2               ;
00E824  2               ; Output:
00E824  2               ;   A = mnemonic ID
00E824  2               ; Preserves X
00E824  2               ; ------------------------------------------------------------
00E824  2               get_mnemonic_id_x:
00E824  2  BD FE ED         lda mnemonic_id_table,x
00E827  2  60               rts
00E828  2               
00E828  2               ; ------------------------------------------------------------
00E828  2               ; FETCH MNEMONIC POINTER FOR MNEMONIC ID IN A
00E828  2               ; Uses mnemonic_text_ptrs as a compact unique-pointer table.
00E828  2               ;
00E828  2               ; Input:
00E828  2               ;   A = mnemonic ID
00E828  2               ;
00E828  2               ; Output:
00E828  2               ;   T1 = pointer to zero-terminated mnemonic string
00E828  2               ; Preserves X
00E828  2               ; ------------------------------------------------------------
00E828  2               get_mnemonic_ptr_id:
00E828  2  DA               phx
00E829  2               
00E829  2  85 D4            sta tmp
00E82B  2  0A               asl
00E82C  2  AA               tax
00E82D  2               
00E82D  2  BD 38 ED         lda mnemonic_text_ptrs,x
00E830  2  85 CE            sta T1L
00E832  2  E8               inx
00E833  2  BD 38 ED         lda mnemonic_text_ptrs,x
00E836  2  85 CF            sta T1H
00E838  2               
00E838  2  FA               plx
00E839  2  60               rts
00E83A  2               
00E83A  2               ; ------------------------------------------------------------
00E83A  2               ; GET INSTRUCTION LENGTH FROM ADDRESSING MODE
00E83A  2               ;
00E83A  2               ; Input:
00E83A  2               ;   A = addressing mode
00E83A  2               ;
00E83A  2               ; Output:
00E83A  2               ;   A = instruction length
00E83A  2               ;
00E83A  2               ; Notes:
00E83A  2               ;   AM_IMP, AM_ACC, AM_ILL      -> 1
00E83A  2               ;   AM_IMM, AM_ZP, AM_ZPX,
00E83A  2               ;   AM_ZPY, AM_INDX, AM_INDY,
00E83A  2               ;   AM_ZPIND, AM_REL            -> 2
00E83A  2               ;   AM_ABS, AM_ABSX, AM_ABSY,
00E83A  2               ;   AM_IND, AM_ZPREL, AM_AIX    -> 3
00E83A  2               ; ------------------------------------------------------------
00E83A  2               get_oplen_from_mode:
00E83A  2  C9 00            cmp #AM_IMP
00E83C  2  F0 2E            beq gol_len1
00E83E  2  C9 01            cmp #AM_ACC
00E840  2  F0 2A            beq gol_len1
00E842  2  C9 10            cmp #AM_ILL
00E844  2  F0 26            beq gol_len1
00E846  2               
00E846  2  C9 02            cmp #AM_IMM
00E848  2  F0 1F            beq gol_len2
00E84A  2  C9 03            cmp #AM_ZP
00E84C  2  F0 1B            beq gol_len2
00E84E  2  C9 04            cmp #AM_ZPX
00E850  2  F0 17            beq gol_len2
00E852  2  C9 05            cmp #AM_ZPY
00E854  2  F0 13            beq gol_len2
00E856  2  C9 0A            cmp #AM_INDX
00E858  2  F0 0F            beq gol_len2
00E85A  2  C9 0B            cmp #AM_INDY
00E85C  2  F0 0B            beq gol_len2
00E85E  2  C9 0C            cmp #AM_ZPIND
00E860  2  F0 07            beq gol_len2
00E862  2  C9 0D            cmp #AM_REL
00E864  2  F0 03            beq gol_len2
00E866  2               
00E866  2  A9 03            lda #3
00E868  2  60               rts
00E869  2               
00E869  2               gol_len2:
00E869  2  A9 02            lda #2
00E86B  2  60               rts
00E86C  2               
00E86C  2               gol_len1:
00E86C  2  A9 01            lda #1
00E86E  2  60               rts
00E86F  2               
00E86F  2               ; ------------------------------------------------------------
00E86F  2               ; PARSE ASSEMBLER OPERAND
00E86F  2               ;
00E86F  2               ; Output:
00E86F  2               ;   asm_mode = parsed addressing mode
00E86F  2               ;   T0       = primary operand value
00E86F  2               ;   T1L      = zp byte for ZPREL
00E86F  2               ;
00E86F  2               ; Supported:
00E86F  2               ;   implied
00E86F  2               ;   A
00E86F  2               ;   #imm
00E86F  2               ;   zp / abs
00E86F  2               ;   zp,X / abs,X
00E86F  2               ;   zp,Y / abs,Y
00E86F  2               ;   (zp)
00E86F  2               ;   (abs)
00E86F  2               ;   (zp,X)
00E86F  2               ;   (abs,X)
00E86F  2               ;   (zp),Y
00E86F  2               ;   zp,target   (for BBR/BBS)
00E86F  2               ; ------------------------------------------------------------
00E86F  2               parse_asm_operand:
00E86F  2  20 AF E2         jsr next_token
00E872  2  B0 05            bcs pa_have_operand
00E874  2  A9 00            lda #AM_IMP
00E876  2  85 D5            sta asm_mode
00E878  2  60               rts
00E879  2               
00E879  2               pa_have_operand:
00E879  2  A0 00            ldy #0
00E87B  2  B1 C0            lda (lineptr),y
00E87D  2  C9 23            cmp #'#'
00E87F  2  F0 2B            beq pa_imm
00E881  2  C9 28            cmp #'('
00E883  2  F0 32            beq pa_paren
00E885  2               
00E885  2                   ; bare A can mean accumulator, but only if it is exactly "A"
00E885  2  20 32 E4         jsr toupper
00E888  2  C9 41            cmp #'A'
00E88A  2  F0 03            beq pa_have_a
00E88C  2  4C 35 E9     		jmp pa_value
00E88F  2               
00E88F  2               pa_have_a:
00E88F  2  A0 01            ldy #1
00E891  2  B1 C0            lda (lineptr),y
00E893  2  F0 07            beq pa_try_acc
00E895  2  C9 20            cmp #' '
00E897  2  F0 03            beq pa_try_acc
00E899  2  4C 35 E9         jmp pa_value
00E89C  2               
00E89C  2               pa_try_acc:
00E89C  2  20 1C E4         jsr advance_lineptr
00E89F  2  20 AF E2         jsr next_token
00E8A2  2  90 03            bcc pa_acc
00E8A4  2  4C 2B E2         jmp cmd_error
00E8A7  2               
00E8A7  2               pa_acc:
00E8A7  2  A9 01            lda #AM_ACC
00E8A9  2  85 D5            sta asm_mode
00E8AB  2  60               rts
00E8AC  2               
00E8AC  2               pa_imm:
00E8AC  2  20 1C E4         jsr advance_lineptr
00E8AF  2  20 F3 E2         jsr parse_byte
00E8B2  2  A9 02            lda #AM_IMM
00E8B4  2  85 D5            sta asm_mode
00E8B6  2  60               rts
00E8B7  2               
00E8B7  2               pa_paren:
00E8B7  2  20 1C E4         jsr advance_lineptr
00E8BA  2  20 00 E3         jsr parse_word
00E8BD  2               
00E8BD  2  A0 00            ldy #0
00E8BF  2  B1 C0            lda (lineptr),y
00E8C1  2  C9 2C            cmp #','
00E8C3  2  F0 07            beq pa_paren_comma
00E8C5  2  C9 29            cmp #')'
00E8C7  2  F0 33            beq pa_paren_close
00E8C9  2  4C 2B E2         jmp cmd_error
00E8CC  2               
00E8CC  2               pa_paren_comma:
00E8CC  2  20 1C E4         jsr advance_lineptr
00E8CF  2  A0 00            ldy #0
00E8D1  2  B1 C0            lda (lineptr),y
00E8D3  2  20 32 E4         jsr toupper
00E8D6  2  C9 58            cmp #'X'
00E8D8  2  F0 03            beq pa_paren_x
00E8DA  2  4C 2B E2         jmp cmd_error
00E8DD  2               
00E8DD  2               pa_paren_x:
00E8DD  2  20 1C E4         jsr advance_lineptr
00E8E0  2  A0 00            ldy #0
00E8E2  2  B1 C0            lda (lineptr),y
00E8E4  2  C9 29            cmp #')'
00E8E6  2  F0 03            beq pa_paren_x_close
00E8E8  2  4C 2B E2         jmp cmd_error
00E8EB  2               
00E8EB  2               pa_paren_x_close:
00E8EB  2  20 1C E4         jsr advance_lineptr

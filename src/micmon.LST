00B983  2               ; ------------------------------------------------------------
00B983  2               ; FIND OPCODE
00B983  2               ;
00B983  2               ; Input:
00B983  2               ;   mnemonic in R1/mnem_len
00B983  2               ;   asm_mode
00B983  2               ;
00B983  2               ; Output:
00B983  2               ;   C = 1 found
00B983  2               ;   asm_opcode = opcode
00B983  2               ;   C = 0 not found
00B983  2               ;
00B983  2               ; Special case:
00B983  2               ;   branch mnemonics accept AM_REL when operand parsed as ZP or ABS
00B983  2               ; ------------------------------------------------------------
00B983  2               find_opcode:
00B983  2  A2 00            ldx #0
00B985  2               
00B985  2               fo_loop:
00B985  2  BD 26 BC         lda mode_table,x
00B988  2  C5 D7            cmp asm_mode
00B98A  2  F0 11            beq fo_check_mnemonic_direct
00B98C  2               
00B98C  2  C9 0D            cmp #AM_REL
00B98E  2  D0 35            bne fo_next
00B990  2               
00B990  2  A5 D7            lda asm_mode
00B992  2  C9 03            cmp #AM_ZP
00B994  2  F0 15            beq fo_check_mnemonic_rel
00B996  2  C9 06            cmp #AM_ABS
00B998  2  F0 11            beq fo_check_mnemonic_rel
00B99A  2  4C C5 B9         jmp fo_next

00E78B  2  2E E6            .word fmt_acc
00E78D  2  33 E6            .word fmt_imm
00E78F  2  44 E6            .word fmt_zp
00E791  2  50 E6            .word fmt_zpx
00E793  2  5D E6            .word fmt_zpy
00E795  2  6A E6            .word fmt_abs
00E797  2  7A E6            .word fmt_absx
00E799  2  87 E6            .word fmt_absy
00E79B  2  94 E6            .word fmt_ind

00E9AB  2               ; FIND OPCODE
00E9AB  2               ;
00E9AB  2               ; Input:
00E9AB  2               ;   mnemonic in R1/mnem_len
00E9AB  2               ;   asm_mode
00E9AB  2               ;
00E9AB  2               ; Output:
00E9AB  2               ;   C = 1 found
00E9AB  2               ;   asm_opcode = opcode
00E9AB  2               ;   C = 0 not found
00E9AB  2               ;
00E9AB  2               ; Special case:
00E9AB  2               ;   branch mnemonics accept AM_REL when operand parsed as ZP or ABS
00E9AB  2               ; ------------------------------------------------------------
00E9AB  2               find_opcode:
00E9AB  2  A2 00            ldx #0
00E9AD  2               
00E9AD  2               fo_loop:
00E9AD  2  BD 4E EC         lda mode_table,x
00E9B0  2  C5 D5            cmp asm_mode
00E9B2  2  F0 11            beq fo_check_mnemonic_direct
00E9B4  2               
00E9B4  2  C9 0D            cmp #AM_REL
00E9B6  2  D0 35            bne fo_next
00E9B8  2               
00E9B8  2  A5 D5            lda asm_mode
00E9BA  2  C9 03            cmp #AM_ZP
00E9BC  2  F0 15            beq fo_check_mnemonic_rel
00E9BE  2  C9 06            cmp #AM_ABS
00E9C0  2  F0 11            beq fo_check_mnemonic_rel
00E9C2  2  4C ED E9         jmp fo_next
00E9C5  2               

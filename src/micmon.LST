00E4AA  1  A5 CC            lda T0L
00E4AC  1  65 CE            adc T1L
00E4AE  1  85 CC            sta T0L
00E4B0  1  A5 CD            lda T0H
00E4B2  1  65 CF            adc T1H
00E4B4  1  85 CD            sta T0H
00E4B6  1  60               rts
00E4B7  1               
00E4B7  1               cmp_R2_R1:
00E4B7  1  A5 C9            lda R2H
00E4B9  1  C5 C7            cmp R1H
00E4BB  1  D0 04            bne cmp_r2_r1_done
00E4BD  1  A5 C8            lda R2L
00E4BF  1  C5 C6            cmp R1L
00E4C1  1               cmp_r2_r1_done:
00E4C1  1  60               rts
00E4C2  1               
00E4C2  1               ;------------------------------------------------
00E4C2  1               print_hex8:
00E4C2  1  48               pha
00E4C3  1  4A               lsr
00E4C4  1  4A               lsr
00E4C5  1  4A               lsr
00E4C6  1  4A               lsr
00E4C7  1  20 CD E4         jsr print_hex_digit
00E4CA  1  68               pla
00E4CB  1  29 0F            and #$0F
00E4CD  1               ;    jsr print_hex_digit
00E4CD  1               ;    rts
00E4CD  1               
00E4CD  1               print_hex_digit:
00E4CD  1  C9 0A            cmp #10
00E4CF  1  90 06            bcc print_hex_num
00E4D1  1  18               clc
00E4D2  1  69 37            adc #'A'-10
00E4D4  1  4C 0A E5         jmp putchar
00E4D7  1               
00E4D7  1               print_hex_num:
00E4D7  1  18               clc
00E4D8  1  69 30            adc #'0'
00E4DA  1  4C 0A E5         jmp putchar
00E4DD  1               
00E4DD  1               ; ------------------------------------------------------------
00E4DD  1               ; PRINT_HEX16
00E4DD  1               ; Print 16-bit value in hexadecimal.
00E4DD  1               ;
00E4DD  1               ; Input
00E4DD  1               ;   A = high byte
00E4DD  1               ;   X = low byte
00E4DD  1               ; ------------------------------------------------------------
00E4DD  1               print_hex16:
00E4DD  1  DA               phx
00E4DE  1  20 C2 E4         jsr print_hex8
00E4E1  1  FA               plx
00E4E2  1  8A               txa
00E4E3  1  4C C2 E4         jmp print_hex8
00E4E6  1               
00E4E6  1               
00E4E6  1               print_ascii:
00E4E6  1  C9 20            cmp #$20
00E4E8  1  90 07            bcc ascii_dot
00E4EA  1  C9 7F            cmp #$7F
00E4EC  1  B0 03            bcs ascii_dot
00E4EE  1  4C 0A E5         jmp putchar
00E4F1  1               
00E4F1  1               
00E4F1  1               ascii_dot:
00E4F1  1  A9 2E            lda #'.'

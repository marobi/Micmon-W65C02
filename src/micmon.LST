000000r 1               ; ---------------------------------------------------------------------------
000000r 1               ; MICMON – Minimal Interactive Command Monitor for the W65C02
000000r 1               ; (c) 2026 Rien Matthijsse
000000r 1               
000000r 1               .include "readme.asm"
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; MICMON – Minimal Interactive Command Monitor for the W65C02
000000r 2               ; (c) 2026 Rien Matthijsse
000000r 2               ;
000000r 2               ; Overview
000000r 2               ; --------
000000r 2               ; Micmon is a compact machine-level monitor for the W65C02, designed to fit
000000r 2               ; within a 4 KB ROM. It provides essential debugging, inspection and control
000000r 2               ; facilities while remaining small, deterministic, and fully self-hosting.
000000r 2               ;
000000r 2               ; The monitor follows a strict "round-trip" philosophy: all output is valid
000000r 2               ; input. Any command output (e.g. memory dumps) can be edited and fed back
000000r 2               ; into the monitor for execution. This enables interactive workflows using
000000r 2               ; external terminals or VDUs with line editing capabilities.
000000r 2               ;
000000r 2               ; Design Goals
000000r 2               ; ------------
000000r 2               ; - Minimal footprint (fits in 4 KB ROM)
000000r 2               ; - Deterministic behaviour (no hidden state, no dynamic allocation)
000000r 2               ; - Table-driven architecture (command dispatch, disassembler, assembler)
000000r 2               ; - Round-trip capable output (monitor output is executable input)
000000r 2               ; - Tight integration with external VDU/GDU systems
000000r 2               ;
000000r 2               ; Functional Scope
000000r 2               ; ----------------
000000r 2               ; - Memory inspection and modification
000000r 2               ; - CPU register inspection and editing
000000r 2               ; - Program execution control (GO)
000000r 2               ; - Disassembler (W65C02 complete)
000000r 2               ; - Inline assembler (single-line, immediate emission)
000000r 2               ; - Command-driven interface with single-character dispatch
000000r 2               ;
000000r 2               ; Command Summary
000000r 2               ; ---------------
000000r 2               ;   H          Help / command overview
000000r 2               ;   M addr     Dump memory
000000r 2               ;   > addr     Modify memory (hex byte stream)
000000r 2               ;   R          Show CPU registers
000000r 2               ;   ;          Modify CPU registers
000000r 2               ;   G [addr]   Execute code at address
000000r 2               ;   D [addr]   Disassembler
000000r 2               ;   A [addr]   Assemble single instruction at address
000000r 2               ;
000000r 2               ; Notes:
000000r 2               ; - Default address is MEM unless explicitly provided
000000r 2               ; - Commands are line-oriented and CR-terminated
000000r 2               ; - Where possible: output format is compatible with monitor input (round-trip)
000000r 2               ;
000000r 2               ; Execution Model
000000r 2               ; ---------------
000000r 2               ; - RESET:
000000r 2               ;     Initializes CPU state and monitor environment
000000r 2               ;     Enters monitor via BRK vector
000000r 2               ;
000000r 2               ; - BRK handler:
000000r 2               ;     Saves full CPU context (A, X, Y, P, SP, PC)
000000r 2               ;     Transfers control to command interpreter
000000r 2               ;
000000r 2               ; - Command loop:
000000r 2               ;     Line-oriented input
000000r 2               ;     Single-character command dispatch via table
000000r 2               ;     Commands operate directly on memory and CPU image
000000r 2               ;
000000r 2               ; Interaction Model
000000r 2               ; -----------------
000000r 2               ; Micmon assumes the host terminal or VDU performs line editing.
000000r 2               ; Input is processed per line (CR-terminated).
000000r 2               ;
000000r 2               ; Output is formatted to be re-consumable:
000000r 2               ;
000000r 2               ;     M 0200 020F
000000r 2               ;     > 0200 A9 01 8D 00 02 ...
000000r 2               ;
000000r 2               ; Can be edited into:
000000r 2               ;
000000r 2               ;     > 0200 A9 FF 8D 00 02
000000r 2               ;
000000r 2               ; and executed directly by the monitor.
000000r 2               ;
000000r 2               ; Parameter Formats
000000r 2               ; -----------------
000000r 2               ; All numeric parameters support multiple input formats. The parser auto-
000000r 2               ; detects the format based on prefix or content.
000000r 2               ;
000000r 2               ; Supported formats:
000000r 2               ;
000000r 2               ;   Hexadecimal (default)
000000r 2               ;     0200      $0200
000000r 2               ;
000000r 2               ;   Decimal
000000r 2               ;     +123
000000r 2               ;
000000r 2               ;   Binary
000000r 2               ;     %10101010
000000r 2               ;
000000r 2               ;   ASCII
000000r 2               ;     'A        -> $41
000000r 2               ;
000000r 2               ; Rules:
000000r 2               ; - Hex is assumed if no prefix is present
000000r 2               ;       $   = hex (optional, since default)
000000r 2               ;       %   = binary
000000r 2               ;       +   = decimal
000000r 2               ;       '   = ASCII single byte
000000r 2               ;
000000r 2               ; - All parsed values result in:
000000r 2               ;       T0 = value (byte or word)
000000r 2               ;       value_size >= 1 indicates success
000000r 2               ;
000000r 2               ; - Commands are literal
000000r 2               ;
000000r 2               ; Examples:
000000r 2               ;   M $C000
000000r 2               ;   M %1100000000000000
000000r 2               ;   M +49152
000000r 2               ;
000000r 2               ;   > 0200 'A $42 %01000011
000000r 2               ;
000000r 2               ;   A 0300 LDA #'A
000000r 2               ;   A 0302 LDA #$41
000000r 2               ;
000000r 2               ; Architecture Notes
000000r 2               ; ------------------
000000r 2               ; - All decoding (disassembler/assembler) is table-driven
000000r 2               ; - Opcode metadata shared between assembler and disassembler
000000r 2               ; - Zero-page used from $00C0-$00DF
000000r 2               ; - Strict separation between parsing, decoding and execution
000000r 2               ;
000000r 2               ; Extensibility
000000r 2               ; -------------
000000r 2               ; Micmon is intentionally designed for easy extension:
000000r 2               ;
000000r 2               ; - New commands can be added by inserting entries in:
000000r 2               ;       cmd_chars / cmd_addrs tables
000000r 2               ;
000000r 2               ; - No central switch-case logic: dispatch is fully table-driven
000000r 2               ; - Parsing helpers (parse_word, next_token, etc.) are reusable
000000r 2               ; - Disassembler and assembler share data tables, reducing duplication
000000r 2               ; - New addressing modes or instructions require only table updates
000000r 2               ;
000000r 2               ; This allows incremental growth without restructuring the monitor core.
000000r 2               ;
000000r 2               ; Limitations
000000r 2               ; -----------
000000r 2               ; - No multi-line assembly or label resolution
000000r 2               ; - No expression evaluator
000000r 2               ; - Branch range limited to signed 8-bit (hardware constraint)
000000r 2               ;
000000r 2               ; Target
000000r 2               ; ------
000000r 2               ; WDC W65C02 (fully supported instruction set)
000000r 2               ;
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               
000000r 1               
000000r 1               .setcpu "65C02"
000000r 1               
000000r 1               .include "../bios_mmu/bios.h"
000000r 2               ;
000000r 2               ;
000000r 2               ;
000000r 2               BIOS_BASE        =     $FE00
000000r 2               BIOS_INCHAR      =     BIOS_BASE
000000r 2               BIOS_OUTCHAR     =     BIOS_BASE+3
000000r 2               BIOS_INKEY       =     BIOS_BASE+6
000000r 2               BIOS_STPKEY			 =		 BIOS_BASE+9
000000r 2               
000000r 1               
000000r 1               .segment "ZEROPAGE"
000000r 1               .org $00C0								; nicer listing
0000C0  1               
0000C0  1               ; parser / dispatcher pointers
0000C0  1  xx xx        lineptr:    .res 2
0000C2  1  xx xx        jmpvec:     .res 2
0000C4  1               
0000C4  1               ; 16-bit working registers for commands
0000C4  1  xx           R0L:        .res 1
0000C5  1  xx           R0H:        .res 1
0000C6  1  xx           R1L:        .res 1
0000C7  1  xx           R1H:        .res 1
0000C8  1  xx           R2L:        .res 1
0000C9  1  xx           R2H:        .res 1
0000CA  1  xx           R3L:        .res 1
0000CB  1  xx           R3H:        .res 1
0000CC  1               
0000CC  1               ; temporary registers used by parser and utility routines
0000CC  1  xx           T0L:        .res 1
0000CD  1  xx           T0H:        .res 1
0000CE  1  xx           T1L:        .res 1
0000CF  1  xx           T1H:        .res 1
0000D0  1               
0000D0  1               ; monitor remembers last referenced memory address
0000D0  1  xx           MEML:       .res 1
0000D1  1  xx           MEMH:       .res 1
0000D2  1               
0000D2  1               ; parser state
0000D2  1  xx           parm_count: .res 1
0000D3  1  xx           value_size: .res 1
0000D4  1  xx           tmp:        .res 1
0000D5  1               
0000D5  1  xx           asm_mode:   .res 1
0000D6  1  xx           asm_opcode: .res 1
0000D7  1  xx           mnem_len:   .res 1
0000D8  1               
0000D8  1               
0000D8  1               .segment "BSS"
0000D8  1               .org $0200							; nicer listing
000200  1               
000200  1               ; input buffer
000200  1  xx xx xx xx  linebuf:    .res 40
000204  1  xx xx xx xx  
000208  1  xx xx xx xx  
000228  1               
000228  1               ; saved CPU image
000228  1  xx           reg_pch:    .res 1
000229  1  xx           reg_pcl:    .res 1
00022A  1  xx           reg_sr:     .res 1
00022B  1  xx           reg_a:      .res 1
00022C  1  xx           reg_x:      .res 1
00022D  1  xx           reg_y:      .res 1
00022E  1  xx           reg_sp:     .res 1
00022F  1               
00022F  1               .segment "CODE"
00022F  1               .org $E000							; nicer listing
00E000  1               
00E000  1               ; ------------------------------------------------------------
00E000  1               ; RESET
00E000  1               ; Basic CPU setup, monitor state initialization, then enter
00E000  1               ; the monitor through BRK so startup uses the normal entry path.
00E000  1               ; ------------------------------------------------------------
00E000  1               		.export reset
00E000  1               reset:
00E000  1  78               sei
00E001  1  D8               cld
00E002  1  A2 FF            ldx #$FF
00E004  1  9A               txs
00E005  1  20 09 E0         jsr monitor_init
00E008  1  00               brk
00E009  1               
00E009  1               monitor_init:
00E009  1  64 D0            stz MEML
00E00B  1  64 D1            stz MEMH
00E00D  1  A9 17        		lda #<welcome_text
00E00F  1  A2 EF            ldx #>welcome_text
00E011  1  4C 5F E2         jmp print_str
00E014  1               
00E014  1               ; ------------------------------------------------------------
00E014  1               ; IRQ / BRK ENTRY
00E014  1               ; The common IRQ vector saves A/X/Y, then distinguishes IRQ
00E014  1               ; from BRK by testing bit 4 of the stacked status byte.
00E014  1               ; IRQ returns immediately. BRK enters the monitor.
00E014  1               ; ------------------------------------------------------------
00E014  1               		.export irq_entry
00E014  1               irq_entry:
00E014  1  48               pha
00E015  1  8A               txa
00E016  1  48               pha
00E017  1  98               tya
00E018  1  48               pha
00E019  1               
00E019  1  BA               tsx
00E01A  1  BD 04 01         lda $0104,x
00E01D  1  29 10            and #$10
00E01F  1  D0 07            bne brk_entry
00E021  1               
00E021  1               irq_restore:
00E021  1  68               pla
00E022  1  A8               tay
00E023  1  68               pla
00E024  1  AA               tax
00E025  1  68               pla
00E026  1  40               rti
00E027  1               
00E027  1               		.export nmi_entry
00E027  1               nmi_entry:
00E027  1  40               rti
00E028  1               
00E028  1               ; ------------------------------------------------------------
00E028  1               ; BRK ENTRY
00E028  1               ; Save the CPU state into monitor RAM.
00E028  1               ; BRK pushes PC+2, so the saved PC is adjusted back to the
00E028  1               ; BRK opcode address for display and resume semantics.
00E028  1               ; ------------------------------------------------------------
00E028  1               brk_entry:
00E028  1  68               pla
00E029  1  8D 2D 02         sta reg_y
00E02C  1  68               pla
00E02D  1  8D 2C 02         sta reg_x
00E030  1  68               pla
00E031  1  8D 2B 02         sta reg_a
00E034  1  68               pla
00E035  1  8D 2A 02         sta reg_sr
00E038  1  68               pla
00E039  1  8D 29 02         sta reg_pcl
00E03C  1  68               pla
00E03D  1  8D 28 02         sta reg_pch
00E040  1               
00E040  1  D8               cld
00E041  1  38               sec						; correct PC by -2
00E042  1  AD 29 02         lda reg_pcl
00E045  1  E9 02            sbc #2
00E047  1  8D 29 02         sta reg_pcl
00E04A  1  AD 28 02         lda reg_pch
00E04D  1  E9 00            sbc #0
00E04F  1  8D 28 02         sta reg_pch
00E052  1               
00E052  1  BA               tsx
00E053  1  8E 2E 02         stx reg_sp
00E056  1  4C 59 E0         jmp monitor_entry
00E059  1               
00E059  1               ; ------------------------------------------------------------
00E059  1               ; MONITOR ENTRY
00E059  1               ; Every BRK entry shows the saved registers, then drops into
00E059  1               ; the command loop.
00E059  1               ; ------------------------------------------------------------
00E059  1               monitor_entry:
00E059  1  58           		cli
00E05A  1  20 41 E1         jsr show_registers	; show regs and fall through
00E05D  1               
00E05D  1               ; ------------------------------------------------------------
00E05D  1               ; MAIN MONITOR LOOP
00E05D  1               ; Read one full line, execute it
00E05D  1               ; ------------------------------------------------------------
00E05D  1               monitor_loop:
00E05D  1  20 0F E5         jsr getline					; read line
00E060  1  A9 00            lda #<linebuf
00E062  1  85 C0            sta lineptr
00E064  1  A9 02            lda #>linebuf
00E066  1  85 C1            sta lineptr+1
00E068  1               
00E068  1               execute_line:
00E068  1  20 23 E4         jsr skip_spaces
00E06B  1  A0 00            ldy #0
00E06D  1  B1 C0            lda (lineptr),y			; get cmd
00E06F  1  F0 08            beq exec_done
00E071  1  20 32 E4         jsr toupper
00E074  1  91 C0            sta (lineptr),y			; save uppercase
00E076  1  20 7F E0         jsr dispatch_command
00E079  1               
00E079  1               exec_done:
00E079  1  20 FF E4     		jsr print_prompt
00E07C  1  4C 5D E0         jmp monitor_loop
00E07F  1               
00E07F  1               ; ------------------------------------------------------------
00E07F  1               ; COMMAND DISPATCH
00E07F  1               ; Table format: command byte, handler low, handler high.
00E07F  1               ; ------------------------------------------------------------
00E07F  1               dispatch_command:
00E07F  1  A0 00            ldy #0
00E081  1  B1 C0            lda (lineptr),y
00E083  1  85 D4            sta tmp
00E085  1               
00E085  1  A2 00            ldx #0
00E087  1               dispatch_loop:
00E087  1  BD FE EE         lda cmd_chars,x
00E08A  1  F0 19            beq dispatch_error
00E08C  1  C5 D4            cmp tmp
00E08E  1  F0 04            beq dispatch_found
00E090  1  E8               inx
00E091  1  4C 87 E0         jmp dispatch_loop
00E094  1               
00E094  1               dispatch_found:
00E094  1  8A               txa
00E095  1  0A               asl
00E096  1  AA               tax
00E097  1  BD 07 EF         lda cmd_addrs,x
00E09A  1  85 C2            sta jmpvec
00E09C  1  E8               inx
00E09D  1  BD 07 EF         lda cmd_addrs,x
00E0A0  1  85 C3            sta jmpvec+1
00E0A2  1  6C C2 00         jmp (jmpvec)
00E0A5  1               
00E0A5  1               dispatch_error:
00E0A5  1  4C 2B E2         jmp cmd_error
00E0A8  1               
00E0A8  1               ; ------------------------------------------------------------
00E0A8  1               ; MEMORY DUMP COMMAND
00E0A8  1               ; Syntax:
00E0A8  1               ;   M
00E0A8  1               ;   M start
00E0A8  1               ;   M start end
00E0A8  1               ;
00E0A8  1               ; Default start is MEM.
00E0A8  1               ; Default length is 12 lines * 8 bytes = 96 bytes.
00E0A8  1               ; MEM is updated to the next address after the dump.
00E0A8  1               ; ------------------------------------------------------------
00E0A8  1               cmd_mem:
00E0A8  1  20 1C E4     		jsr advance_lineptr
00E0AB  1               
00E0AB  1  20 AF E2         jsr next_token
00E0AE  1  90 1F            bcc mem_default
00E0B0  1               
00E0B0  1  20 00 E3         jsr parse_word
00E0B3  1  20 46 E4         jsr copy_T0_R0
00E0B6  1               
00E0B6  1  20 AF E2         jsr next_token
00E0B9  1  90 09            bcc mem_one_param
00E0BB  1               
00E0BB  1  20 00 E3         jsr parse_word
00E0BE  1  20 4F E4         jsr copy_T0_R1
00E0C1  1  4C DA E0         jmp mem_prepare
00E0C4  1               
00E0C4  1               mem_one_param:
00E0C4  1  20 58 E4         jsr copy_R0_R1
00E0C7  1  A9 5F            lda #95
00E0C9  1  20 94 E4         jsr add_R1_A
00E0CC  1  4C DA E0         jmp mem_prepare
00E0CF  1               
00E0CF  1               mem_default:
00E0CF  1  20 6A E4         jsr copy_MEM_R0
00E0D2  1  20 58 E4         jsr copy_R0_R1
00E0D5  1  A9 5F            lda #95
00E0D7  1  20 94 E4         jsr add_R1_A
00E0DA  1               
00E0DA  1               mem_prepare:
00E0DA  1  20 AF E2         jsr next_token
00E0DD  1  90 03            bcc mem_prepare_ok
00E0DF  1  4C 2B E2         jmp cmd_error
00E0E2  1               
00E0E2  1               mem_prepare_ok:
00E0E2  1  20 61 E4         jsr copy_R0_R2
00E0E5  1               
00E0E5  1               mem_loop:
00E0E5  1  20 0C E5         jsr check_abort
00E0E8  1  B0 1D            bcs mem_abort
00E0EA  1               
00E0EA  1  20 2E E2         jsr dump_line
00E0ED  1               
00E0ED  1  18               clc
00E0EE  1  A5 C8            lda R2L
00E0F0  1  69 08            adc #8
00E0F2  1  85 C8            sta R2L
00E0F4  1  A5 C9            lda R2H
00E0F6  1  69 00            adc #0
00E0F8  1  85 C9            sta R2H
00E0FA  1  B0 07            bcs mem_ok          ; wrapped past $FFFF, stop
00E0FC  1               
00E0FC  1  20 B6 E4         jsr cmp_R2_R1
00E0FF  1  90 E4            bcc mem_loop
00E101  1  F0 E2            beq mem_loop
00E103  1               
00E103  1               mem_ok:
00E103  1  20 73 E4         jsr copy_R2_MEM
00E106  1  60               rts
00E107  1               
00E107  1               mem_abort:
00E107  1  4C 2B E2         jmp cmd_error
00E10A  1               
00E10A  1               ; ------------------------------------------------------------
00E10A  1               ; MEMORY EDIT COMMAND
00E10A  1               ; Syntax:
00E10A  1               ;   : addr byte...
00E10A  1               ; Writes 1..8 bytes.
00E10A  1               ; Updates MEM to the next address after the last write.
00E10A  1               ; ------------------------------------------------------------
00E10A  1               cmd_memedit:
00E10A  1  20 1C E4     		jsr advance_lineptr
00E10D  1  20 00 E3         jsr parse_word
00E110  1  20 46 E4         jsr copy_T0_R0				; init ptr
00E113  1               
00E113  1  64 D2            stz parm_count				; first of 8
00E115  1               
00E115  1               write_loop:
00E115  1  A5 D2            lda parm_count
00E117  1  C9 08            cmp #8
00E119  1  B0 16            bcs write_done				; >= 7
00E11B  1               
00E11B  1  20 AF E2         jsr next_token
00E11E  1  90 11            bcc write_done				; no more
00E120  1               
00E120  1  20 F3 E2         jsr parse_byte
00E123  1               
00E123  1  A0 00            ldy #0
00E125  1  A5 CC            lda T0L
00E127  1  91 C4            sta (R0L),y						; store it
00E129  1               
00E129  1  20 7C E4         jsr inc_R0						; next location
00E12C  1  E6 D2            inc parm_count				; next param
00E12E  1  4C 15 E1         jmp write_loop				; loop
00E131  1               
00E131  1               write_done:
00E131  1  A5 D2            lda parm_count
00E133  1  F0 09            beq write_error				; no locations given
00E135  1               
00E135  1               ;    jsr next_token
00E135  1               ;    bcs write_error
00E135  1               
00E135  1  A5 C4            lda R0L								; advance mem ptr
00E137  1  85 D0            sta MEML
00E139  1  A5 C5            lda R0H
00E13B  1  85 D1            sta MEMH
00E13D  1  60               rts
00E13E  1               
00E13E  1               write_error:
00E13E  1  4C 2B E2         jmp cmd_error
00E141  1               
00E141  1               
00E141  1               ; ------------------------------------------------------------
00E141  1               ; REGISTER DISPLAY COMMAND
00E141  1               ; Explicit register display on user request.
00E141  1               ; ------------------------------------------------------------
00E141  1               cmd_regs:
00E141  1               show_registers:
00E141  1  A9 2F            lda #<reg_header
00E143  1  A2 EF            ldx #>reg_header
00E145  1  20 5F E2         jsr print_str
00E148  1               
00E148  1               print_reg_line:
00E148  1  A9 3B            lda #';'
00E14A  1  20 09 E5         jsr putchar
00E14D  1  20 F5 E4         jsr print_space
00E150  1               
00E150  1  AD 28 02         lda reg_pch
00E153  1  AE 29 02         ldx reg_pcl
00E156  1  20 DC E4         jsr print_hex16
00E159  1  20 F5 E4         jsr print_space
00E15C  1               
00E15C  1  AD 2B 02         lda reg_a
00E15F  1  20 C1 E4         jsr print_hex8
00E162  1  20 F5 E4         jsr print_space
00E165  1               
00E165  1  AD 2C 02         lda reg_x
00E168  1  20 C1 E4         jsr print_hex8
00E16B  1  20 F5 E4         jsr print_space
00E16E  1               
00E16E  1  AD 2D 02         lda reg_y
00E171  1  20 C1 E4         jsr print_hex8
00E174  1  20 F5 E4         jsr print_space
00E177  1               
00E177  1  AD 2E 02         lda reg_sp
00E17A  1  20 C1 E4         jsr print_hex8
00E17D  1  20 F5 E4         jsr print_space
00E180  1               
00E180  1               ;    lda reg_sr
00E180  1               ;    jsr print_hex8
00E180  1               ;    jsr print_space
00E180  1               
00E180  1  A9 25            lda #'%'
00E182  1  20 09 E5     		jsr putchar
00E185  1  AD 2A 02         lda reg_sr
00E188  1  20 75 E2         jsr print_status_bits
00E18B  1  4C FA E4         jmp newline
00E18E  1               
00E18E  1               ; ------------------------------------------------------------
00E18E  1               ; REGISTER EDIT COMMAND
00E18E  1               ; Editable line format:
00E18E  1               ;   . <PC> [A [X [Y [SP [SR]]]]]
00E18E  1               ;
00E18E  1               ; At least PC must be supplied.
00E18E  1               ; Missing trailing operands leave saved registers unchanged.
00E18E  1               ; ------------------------------------------------------------
00E18E  1               cmd_regedit:
00E18E  1  20 1C E4     		jsr advance_lineptr
00E191  1               
00E191  1  20 AF E2         jsr next_token
00E194  1  90 54            bcc regedit_error
00E196  1               
00E196  1  20 00 E3         jsr parse_word
00E199  1  A5 CC            lda T0L
00E19B  1  8D 29 02         sta reg_pcl
00E19E  1  A5 CD            lda T0H
00E1A0  1  8D 28 02         sta reg_pch
00E1A3  1               
00E1A3  1  20 AF E2         jsr next_token
00E1A6  1  90 3F            bcc regedit_done
00E1A8  1               
00E1A8  1  20 F3 E2         jsr parse_byte
00E1AB  1  A5 CC            lda T0L
00E1AD  1  8D 2B 02         sta reg_a
00E1B0  1               
00E1B0  1  20 AF E2         jsr next_token
00E1B3  1  90 32            bcc regedit_done
00E1B5  1               
00E1B5  1  20 F3 E2         jsr parse_byte
00E1B8  1  A5 CC            lda T0L
00E1BA  1  8D 2C 02         sta reg_x
00E1BD  1               
00E1BD  1  20 AF E2         jsr next_token
00E1C0  1  90 25            bcc regedit_done
00E1C2  1               
00E1C2  1  20 F3 E2         jsr parse_byte
00E1C5  1  A5 CC            lda T0L
00E1C7  1  8D 2D 02         sta reg_y
00E1CA  1               
00E1CA  1  20 AF E2         jsr next_token
00E1CD  1  90 18            bcc regedit_done
00E1CF  1               
00E1CF  1  20 F3 E2         jsr parse_byte
00E1D2  1  A5 CC            lda T0L
00E1D4  1  8D 2E 02         sta reg_sp
00E1D7  1               
00E1D7  1  20 AF E2         jsr next_token
00E1DA  1  90 0B            bcc regedit_done
00E1DC  1               
00E1DC  1  20 F3 E2         jsr parse_byte
00E1DF  1  A5 CC            lda T0L
00E1E1  1  8D 2A 02         sta reg_sr
00E1E4  1               
00E1E4  1  20 AF E2         jsr next_token
00E1E7  1               ;    bcc regedit_done
00E1E7  1               
00E1E7  1               regedit_done:
00E1E7  1               ;    jsr next_token
00E1E7  1               ;    bcs regedit_error
00E1E7  1  4C 41 E1     		jmp show_registers
00E1EA  1               ;    rts
00E1EA  1               
00E1EA  1               regedit_error:
00E1EA  1  4C 2B E2         jmp cmd_error
00E1ED  1               
00E1ED  1               
00E1ED  1               ; ------------------------------------------------------------
00E1ED  1               ; GO COMMAND
00E1ED  1               ; Syntax:
00E1ED  1               ;   G
00E1ED  1               ;   G <PC>
00E1ED  1               ; Restores the saved CPU image and resumes execution with RTI.
00E1ED  1               ; ------------------------------------------------------------
00E1ED  1               cmd_go:
00E1ED  1  20 1C E4     		jsr advance_lineptr
00E1F0  1  20 AF E2         jsr next_token
00E1F3  1  90 15            bcc go_now
00E1F5  1               
00E1F5  1  20 00 E3         jsr parse_word
00E1F8  1  A5 CC            lda T0L
00E1FA  1  8D 29 02         sta reg_pcl
00E1FD  1  A5 CD            lda T0H
00E1FF  1  8D 28 02         sta reg_pch
00E202  1               
00E202  1  20 AF E2         jsr next_token
00E205  1  90 03            bcc go_now
00E207  1  4C 2B E2         jmp cmd_error
00E20A  1               
00E20A  1               go_now:
00E20A  1  AE 2E 02         ldx reg_sp
00E20D  1  9A               txs
00E20E  1  AD 28 02         lda reg_pch
00E211  1  48               pha
00E212  1  AD 29 02         lda reg_pcl
00E215  1  48               pha
00E216  1  AD 2A 02         lda reg_sr
00E219  1  48               pha
00E21A  1  AD 2B 02         lda reg_a
00E21D  1  AE 2C 02         ldx reg_x
00E220  1  AC 2D 02         ldy reg_y
00E223  1  40               rti
00E224  1               
00E224  1               ; ------------------------------------------------------------
00E224  1               ; HELP COMMAND
00E224  1               ; ------------------------------------------------------------
00E224  1               cmd_help:
00E224  1  A9 51            lda #<help_text
00E226  1  A2 EF            ldx #>help_text
00E228  1  4C 5F E2         jmp print_str
00E22B  1               
00E22B  1               ; ------------------------------------------------------------
00E22B  1               ; ERROR HANDLER
00E22B  1               ; ------------------------------------------------------------
00E22B  1               cmd_error:
00E22B  1  4C 2D E5         jmp print_error
00E22E  1               
00E22E  1               ; ------------------------------------------------------------
00E22E  1               ; MEMORY DUMP FORMATTERS
00E22E  1               ; ------------------------------------------------------------
00E22E  1               ; show 8 memory locs @R2
00E22E  1               dump_line:
00E22E  1  A9 3E            lda #'>'
00E230  1  20 09 E5         jsr putchar
00E233  1               
00E233  1  A5 C8            lda R2L
00E235  1  85 CC            sta T0L
00E237  1  A5 C9            lda R2H
00E239  1  85 CD            sta T0H
00E23B  1  20 9F E2         jsr print_address_T0
00E23E  1               
00E23E  1  A0 00            ldy #0
00E240  1               dump_hex_loop:
00E240  1  B1 C8            lda (R2L),y
00E242  1  20 C1 E4         jsr print_hex8
00E245  1  20 F5 E4         jsr print_space
00E248  1  C8               iny
00E249  1  C0 08            cpy #8
00E24B  1  D0 F3            bne dump_hex_loop
00E24D  1               
00E24D  1  20 F5 E4         jsr print_space
00E250  1               
00E250  1  A0 00            ldy #0
00E252  1               dump_ascii_loop:
00E252  1  B1 C8            lda (R2L),y
00E254  1  20 E5 E4         jsr print_ascii
00E257  1  C8               iny
00E258  1  C0 08            cpy #8
00E25A  1  D0 F6            bne dump_ascii_loop
00E25C  1  4C FA E4         jmp newline
00E25F  1               
00E25F  1               ; ------------------------------------------------------------
00E25F  1               ; OUTPUT HELPERS
00E25F  1               ; ------------------------------------------------------------
00E25F  1               
00E25F  1               ; ------------------------------------------------------------
00E25F  1               ; STRING OUTPUT
00E25F  1               ; A = low byte, X = high byte of zero-terminated string.
00E25F  1               ; Uses T0 as the temporary string pointer.
00E25F  1               ; ------------------------------------------------------------
00E25F  1               print_str:
00E25F  1  85 CC            sta T0L
00E261  1  86 CD            stx T0H
00E263  1  A0 00            ldy #0
00E265  1               
00E265  1               print_str_loop:
00E265  1  B1 CC            lda (T0L),y
00E267  1  F0 0B            beq print_str_done
00E269  1  20 09 E5         jsr putchar
00E26C  1  C8               iny
00E26D  1  D0 F6            bne print_str_loop
00E26F  1  E6 CD            inc T0H
00E271  1  4C 65 E2         jmp print_str_loop
00E274  1               
00E274  1               print_str_done:
00E274  1  60               rts
00E275  1               
00E275  1               ; ------------------------------------------------------------
00E275  1               ; PRINT_STATUS_BITS
00E275  1               ; Print processor status as:
00E275  1               ;   NV-BDIZC
00E275  1               ; using '1' for set bits and '0' for clear bits.
00E275  1               ;
00E275  1               ; Input
00E275  1               ;   A = status byte
00E275  1               ;
00E275  1               ; Clobbers
00E275  1               ;   A,X
00E275  1               ; ------------------------------------------------------------
00E275  1               print_status_bits:
00E275  1  85 D4            sta tmp
00E277  1               
00E277  1  06 D4            asl tmp              ; N -> C
00E279  1  20 93 E2         jsr print_bit_c
00E27C  1               
00E27C  1  06 D4            asl tmp              ; V -> C
00E27E  1  20 93 E2         jsr print_bit_c
00E281  1               
00E281  1  A9 2D            lda #'-'
00E283  1  20 09 E5         jsr putchar
00E286  1               
00E286  1  06 D4            asl tmp              ; skip bit 5
00E288  1               
00E288  1  A2 05            ldx #5               ; B D I Z C
00E28A  1               ps_loop:
00E28A  1  06 D4            asl tmp              ; next bit -> C
00E28C  1  20 93 E2         jsr print_bit_c
00E28F  1  CA               dex
00E290  1  D0 F8            bne ps_loop
00E292  1  60               rts
00E293  1               
00E293  1               ; ------------------------------------------------------------
00E293  1               ; PRINT_BIT_C
00E293  1               ; Print '1' if Carry set, else '0'.
00E293  1               ; ------------------------------------------------------------
00E293  1               print_bit_c:
00E293  1  90 05            bcc ps_zero
00E295  1  A9 31            lda #'1'
00E297  1  4C 09 E5         jmp putchar
00E29A  1               ps_zero:
00E29A  1  A9 30            lda #'0'
00E29C  1  4C 09 E5         jmp putchar
00E29F  1               
00E29F  1               ; ------------------------------------------------------------
00E29F  1               ; PRINT ADDRESS IN T0 + one trailing space
00E29F  1               ; ------------------------------------------------------------
00E29F  1               print_address_T0:
00E29F  1  A5 CD            lda T0H
00E2A1  1  A6 CC            ldx T0L
00E2A3  1  20 DC E4         jsr print_hex16
00E2A6  1  4C F5 E4         jmp print_space
00E2A9  1               
00E2A9  1               ; ------------------------------------------------------------
00E2A9  1               ; PRINT ADDRESS IN T0 + two trailing spaces
00E2A9  1               ; Used by disassembly line prefix.
00E2A9  1               ; ------------------------------------------------------------
00E2A9  1               print_address_T0_2spaces:
00E2A9  1  20 9F E2         jsr print_address_T0
00E2AC  1  4C F5 E4         jmp print_space
00E2AF  1               
00E2AF  1               
00E2AF  1               ; ------------------------------------------------------------
00E2AF  1               ; TOKENIZER
00E2AF  1               ; Carry set   = token exists
00E2AF  1               ; Carry clear = end of line
00E2AF  1               ; ------------------------------------------------------------
00E2AF  1               next_token:
00E2AF  1  20 23 E4         jsr skip_spaces
00E2B2  1  A0 00            ldy #0
00E2B4  1  B1 C0            lda (lineptr),y
00E2B6  1  F0 02            beq token_eol
00E2B8  1  38               sec
00E2B9  1  60               rts
00E2BA  1               
00E2BA  1               token_eol:
00E2BA  1  18               clc
00E2BB  1  60               rts
00E2BC  1               
00E2BC  1               ; ------------------------------------------------------------
00E2BC  1               ; PARAMETER PARSER
00E2BC  1               ; Default base is hex.
00E2BC  1               ; Supported prefixes:
00E2BC  1               ;   $ hex
00E2BC  1               ;   + decimal
00E2BC  1               ;   % binary   (byte only)
00E2BC  1               ;   ' ASCII    (byte only)
00E2BC  1               ; Result is returned in T0, size in value_size.
00E2BC  1               ; ------------------------------------------------------------
00E2BC  1               parse_param:
00E2BC  1  20 23 E4         jsr skip_spaces
00E2BF  1  A0 00            ldy #0
00E2C1  1  B1 C0            lda (lineptr),y
00E2C3  1  F0 2B            beq param_error
00E2C5  1               
00E2C5  1  C9 24            cmp #'$'
00E2C7  1  F0 0F            beq parse_hex_pref
00E2C9  1  C9 2B            cmp #'+'
00E2CB  1  F0 11            beq parse_dec
00E2CD  1  C9 25            cmp #'%'
00E2CF  1  F0 13            beq parse_bin
00E2D1  1  C9 27            cmp #$27
00E2D3  1  F0 15            beq parse_ascii
00E2D5  1               
00E2D5  1  4C 5E E3         jmp parse_hex
00E2D8  1               
00E2D8  1               parse_hex_pref:
00E2D8  1  20 1C E4         jsr advance_lineptr
00E2DB  1  4C 5E E3         jmp parse_hex
00E2DE  1               
00E2DE  1               parse_dec:
00E2DE  1  20 1C E4         jsr advance_lineptr
00E2E1  1  4C A5 E3         jmp parse_decimal
00E2E4  1               
00E2E4  1               parse_bin:
00E2E4  1  20 1C E4         jsr advance_lineptr
00E2E7  1  4C 17 E3         jmp parse_binary
00E2EA  1               
00E2EA  1               parse_ascii:
00E2EA  1  20 1C E4         jsr advance_lineptr
00E2ED  1  4C 03 E3         jmp parse_ascii_char
00E2F0  1               
00E2F0  1               param_error:
00E2F0  1  4C 2B E2         jmp cmd_error
00E2F3  1               
00E2F3  1               parse_byte:
00E2F3  1  20 BC E2         jsr parse_param
00E2F6  1  A5 D3            lda value_size
00E2F8  1  C9 01            cmp #1
00E2FA  1  F0 03            beq parse_byte_ok
00E2FC  1  4C 2B E2         jmp cmd_error
00E2FF  1               parse_byte_ok:
00E2FF  1  60               rts
00E300  1               
00E300  1               parse_word:
00E300  1  4C BC E2         jmp parse_param
00E303  1               ;    lda value_size
00E303  1               ;    cmp #2
00E303  1               ;    bne parse_word_ok
00E303  1               ;    jmp cmd_error
00E303  1               ;parse_word_ok:
00E303  1               ;    rts
00E303  1               
00E303  1               ; ------------------------------------------------------------
00E303  1               ; ASCII PARSER
00E303  1               ; Syntax: 'A
00E303  1               ; ------------------------------------------------------------
00E303  1               parse_ascii_char:
00E303  1  A0 00            ldy #0
00E305  1  B1 C0            lda (lineptr),y
00E307  1  F0 0B            beq ascii_error
00E309  1  85 CC            sta T0L
00E30B  1  64 CD            stz T0H
00E30D  1  A9 01            lda #1
00E30F  1  85 D3            sta value_size
00E311  1  4C 1C E4         jmp advance_lineptr
00E314  1               
00E314  1               ascii_error:
00E314  1  4C 2B E2         jmp cmd_error
00E317  1               
00E317  1               ; ------------------------------------------------------------
00E317  1               ; BINARY PARSER
00E317  1               ; Syntax: %10101010
00E317  1               ; Binary values are byte sized only.
00E317  1               ; ------------------------------------------------------------
00E317  1               parse_binary:
00E317  1  64 CC            stz T0L
00E319  1  64 CD            stz T0H
00E31B  1  64 D4            stz tmp
00E31D  1               
00E31D  1               bin_loop:
00E31D  1  A0 00            ldy #0
00E31F  1  B1 C0            lda (lineptr),y
00E321  1  C9 30            cmp #'0'
00E323  1  F0 0B            beq bin_zero
00E325  1  C9 31            cmp #'1'
00E327  1  F0 17            beq bin_one
00E329  1  C9 2D            cmp #'-'				; special case for S-register
00E32B  1  F0 13            beq bin_one
00E32D  1  4C 52 E3         jmp bin_done
00E330  1               
00E330  1               bin_zero:
00E330  1  A5 D4            lda tmp
00E332  1  C9 08            cmp #8
00E334  1  B0 25            bcs bin_error
00E336  1  06 CC            asl T0L
00E338  1  20 1C E4         jsr advance_lineptr
00E33B  1  E6 D4            inc tmp
00E33D  1  4C 1D E3         jmp bin_loop
00E340  1               
00E340  1               bin_one:
00E340  1  A5 D4            lda tmp
00E342  1  C9 08            cmp #8
00E344  1  B0 15            bcs bin_error
00E346  1  06 CC            asl T0L
00E348  1  E6 CC            inc T0L
00E34A  1  20 1C E4         jsr advance_lineptr
00E34D  1  E6 D4            inc tmp
00E34F  1  4C 1D E3         jmp bin_loop
00E352  1               
00E352  1               bin_done:
00E352  1  A5 D4            lda tmp
00E354  1  F0 05            beq bin_error2
00E356  1  A9 01            lda #1
00E358  1  85 D3            sta value_size
00E35A  1  60               rts
00E35B  1               
00E35B  1               bin_error:
00E35B  1               bin_error2:
00E35B  1  4C 2B E2         jmp cmd_error
00E35E  1               
00E35E  1               ; ------------------------------------------------------------
00E35E  1               ; HEX PARSER
00E35E  1               ; 1-2 digits => byte, 3-4 digits => word.
00E35E  1               ; ------------------------------------------------------------
00E35E  1               parse_hex:
00E35E  1  64 CC            stz T0L
00E360  1  64 CD            stz T0H
00E362  1  64 D4            stz tmp
00E364  1               
00E364  1               hex_loop:
00E364  1  A0 00            ldy #0
00E366  1  B1 C0            lda (lineptr),y
00E368  1  20 F3 E3         jsr hex_digit
00E36B  1  B0 1C            bcs hex_done
00E36D  1               
00E36D  1  06 CC            asl T0L
00E36F  1  26 CD            rol T0H
00E371  1  06 CC            asl T0L
00E373  1  26 CD            rol T0H
00E375  1  06 CC            asl T0L
00E377  1  26 CD            rol T0H
00E379  1  06 CC            asl T0L
00E37B  1  26 CD            rol T0H
00E37D  1               
00E37D  1  05 CC            ora T0L
00E37F  1  85 CC            sta T0L
00E381  1               
00E381  1  20 1C E4         jsr advance_lineptr
00E384  1  E6 D4            inc tmp
00E386  1  4C 64 E3         jmp hex_loop
00E389  1               
00E389  1               hex_done:
00E389  1  A5 D4            lda tmp
00E38B  1  F0 15            beq hex_error
00E38D  1  C9 03            cmp #3
00E38F  1  90 07            bcc hex_byte
00E391  1  C9 05            cmp #5
00E393  1  90 08            bcc hex_word
00E395  1  4C 2B E2         jmp cmd_error
00E398  1               
00E398  1               hex_byte:
00E398  1  A9 01            lda #1
00E39A  1  85 D3            sta value_size
00E39C  1  60               rts
00E39D  1               
00E39D  1               hex_word:
00E39D  1  A9 02            lda #2
00E39F  1  85 D3            sta value_size
00E3A1  1  60               rts
00E3A2  1               
00E3A2  1               hex_error:
00E3A2  1  4C 2B E2         jmp cmd_error
00E3A5  1               
00E3A5  1               ; ------------------------------------------------------------
00E3A5  1               ; DECIMAL PARSER
00E3A5  1               ; Syntax: +1234
00E3A5  1               ; Uses repeated 16-bit add:
00E3A5  1               ;   T0 = T0 * 10 + digit
00E3A5  1               ; ------------------------------------------------------------
00E3A5  1               parse_decimal:
00E3A5  1  64 CC            stz T0L
00E3A7  1  64 CD            stz T0H
00E3A9  1  64 D3            stz value_size
00E3AB  1               
00E3AB  1               dec_loop:
00E3AB  1  A0 00            ldy #0
00E3AD  1  B1 C0            lda (lineptr),y
00E3AF  1  C9 30            cmp #'0'
00E3B1  1  90 2B            bcc dec_done
00E3B3  1  C9 3A            cmp #'9'+1
00E3B5  1  B0 27            bcs dec_done
00E3B7  1               
00E3B7  1  38               sec
00E3B8  1  E9 30            sbc #'0'
00E3BA  1  85 D4            sta tmp
00E3BC  1               
00E3BC  1  20 3D E4         jsr copy_T0_T1
00E3BF  1               
00E3BF  1  64 CC            stz T0L
00E3C1  1  64 CD            stz T0H
00E3C3  1  A2 0A            ldx #10
00E3C5  1               
00E3C5  1               dec_mul_loop:
00E3C5  1  20 9E E4         jsr add_T1_T0
00E3C8  1  CA               dex
00E3C9  1  D0 FA            bne dec_mul_loop
00E3CB  1               
00E3CB  1  18               clc
00E3CC  1  A5 CC            lda T0L
00E3CE  1  65 D4            adc tmp
00E3D0  1  85 CC            sta T0L
00E3D2  1  90 02            bcc dec_next
00E3D4  1  E6 CD            inc T0H
00E3D6  1               
00E3D6  1               dec_next:
00E3D6  1  20 1C E4         jsr advance_lineptr
00E3D9  1  E6 D3            inc value_size
00E3DB  1  4C AB E3         jmp dec_loop
00E3DE  1               
00E3DE  1               dec_done:
00E3DE  1  A5 D3            lda value_size
00E3E0  1  F0 0E            beq dec_error
00E3E2  1  A5 CD            lda T0H
00E3E4  1  F0 05            beq dec_byte
00E3E6  1  A9 02            lda #2
00E3E8  1  85 D3            sta value_size
00E3EA  1  60               rts
00E3EB  1               
00E3EB  1               dec_byte:
00E3EB  1  A9 01            lda #1
00E3ED  1  85 D3            sta value_size
00E3EF  1  60               rts
00E3F0  1               
00E3F0  1               dec_error:
00E3F0  1  4C 2B E2         jmp cmd_error
00E3F3  1               
00E3F3  1               ; ------------------------------------------------------------
00E3F3  1               ; HEX_DIGIT
00E3F3  1               ; Convert ASCII hex digit to value 0..15.
00E3F3  1               ;
00E3F3  1               ; Input
00E3F3  1               ;   A = ASCII character
00E3F3  1               ;
00E3F3  1               ; Output
00E3F3  1               ;   A = digit value
00E3F3  1               ;   C = 0 valid digit
00E3F3  1               ;   C = 1 invalid digit
00E3F3  1               ; ------------------------------------------------------------
00E3F3  1               hex_digit:
00E3F3  1  C9 30            cmp #'0'
00E3F5  1  90 23            bcc hex_bad
00E3F7  1  C9 3A            cmp #'9'+1
00E3F9  1  90 1A            bcc hex_num
00E3FB  1               
00E3FB  1  C9 41            cmp #'A'
00E3FD  1  90 04            bcc hex_lower
00E3FF  1  C9 47            cmp #'F'+1
00E401  1  90 0D            bcc hex_upper
00E403  1               
00E403  1               hex_lower:
00E403  1  C9 61            cmp #'a'
00E405  1  90 13            bcc hex_bad
00E407  1  C9 67            cmp #'f'+1
00E409  1  B0 0F            bcs hex_bad
00E40B  1  38               sec
00E40C  1  E9 57            sbc #'a'-10
00E40E  1  18               clc
00E40F  1  60               rts

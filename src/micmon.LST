00E44E  1  60               rts
00E44F  1               
00E44F  1               copy_T0_R1:
00E44F  1  A5 CC            lda T0L
00E451  1  85 C6            sta R1L
00E453  1  A5 CD            lda T0H
00E455  1  85 C7            sta R1H
00E457  1  60               rts
00E458  1               
00E458  1               copy_R0_R1:
00E458  1  A5 C4            lda R0L
00E45A  1  85 C6            sta R1L
00E45C  1  A5 C5            lda R0H
00E45E  1  85 C7            sta R1H
00E460  1  60               rts
00E461  1               
00E461  1               copy_R0_R2:

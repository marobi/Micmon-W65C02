00B7CE  1               .include "asm.asm"
00B7CE  2               ; ------------------------------------------------------------
00B7CE  2               ; SIMPLE ASSEMBLER COMMAND
00B7CE  2               ; Syntax:
00B7CE  2               ;   A [addr] mnemonic [operand]
00B7CE  2               ;
00B7CE  2               ; If addr is omitted, MEM is used.
00B7CE  2               ; On success MEM is updated to the next address.
00B7CE  2               ; ------------------------------------------------------------
00B7CE  2               cmd_asm:
00B7CE  2  20 38 B4         jsr advance_lineptr
00B7D1  2  20 CB B2         jsr next_token
00B7D4  2  B0 03            bcs ca_have_first
00B7D6  2  4C 46 B2         jmp cmd_error
00B7D9  2               
00B7D9  2               ca_have_first:
00B7D9  2  A0 00            ldy #0
00B7DB  2  B1 C2            lda (lineptr),y
00B7DD  2  20 4E B4         jsr toupper
00B7E0  2  C9 41            cmp #'A'
00B7E2  2  90 04            bcc ca_with_addr
00B7E4  2  C9 5B            cmp #'Z'+1
00B7E6  2  90 0E            bcc ca_default_addr
00B7E8  2               
00B7E8  2               ca_with_addr:
00B7E8  2  20 1C B3         jsr parse_word
00B7EB  2  20 62 B4         jsr copy_T0_R0
00B7EE  2  20 CB B2         jsr next_token
00B7F1  2  B0 06            bcs ca_mnemonic
00B7F3  2  4C 46 B2         jmp cmd_error
00B7F6  2               
00B7F6  2               ca_default_addr:
00B7F6  2  20 86 B4         jsr copy_MEM_R0
00B7F9  2               
00B7F9  2               ca_mnemonic:
00B7F9  2  20 7D B4         jsr copy_R0_R2
00B7FC  2  20 15 B8         jsr parse_mnemonic
00B7FF  2  20 7A B8         jsr parse_asm_operand
00B802  2  20 CB B2         jsr next_token
00B805  2  90 03            bcc ca_find
00B807  2  4C 46 B2         jmp cmd_error
00B80A  2               
00B80A  2               ca_find:
00B80A  2  20 A0 B9         jsr find_opcode
00B80D  2  B0 03            bcs ca_emit
00B80F  2  4C 46 B2         jmp cmd_error
00B812  2               
00B812  2               ca_emit:
00B812  2  4C 23 BA         jmp emit_instruction
00B815  2               
00B815  2               ; ------------------------------------------------------------
00B815  2               ; PARSE MNEMONIC
00B815  2               ; lineptr must point at the first mnemonic character.
00B815  2               ; Saves start pointer in R1 and length in mnem_len.
00B815  2               ; Advances lineptr to the first character after the mnemonic.
00B815  2               ; ------------------------------------------------------------
00B815  2               parse_mnemonic:
00B815  2  20 3F B4         jsr skip_spaces
00B818  2  A5 C2            lda lineptr
00B81A  2  85 C8            sta R1L
00B81C  2  A5 C3            lda lineptr+1
00B81E  2  85 C9            sta R1H
00B820  2  64 D9            stz mnem_len
00B822  2               
00B822  2               pm_loop:
00B822  2  A0 00            ldy #0
00B824  2  B1 C2            lda (lineptr),y
00B826  2  F0 0C            beq pm_done
00B828  2  C9 20            cmp #' '
00B82A  2  F0 08            beq pm_done
00B82C  2  E6 D9            inc mnem_len
00B82E  2  20 38 B4         jsr advance_lineptr
00B831  2  4C 22 B8         jmp pm_loop
00B834  2               
00B834  2               pm_done:
00B834  2  A5 D9            lda mnem_len
00B836  2  D0 03            bne pm_ok
00B838  2  4C 46 B2         jmp cmd_error
00B83B  2               
00B83B  2               pm_ok:
00B83B  2  60               rts
00B83C  2               
00B83C  2               ; ------------------------------------------------------------
00B83C  2               ; COMPARE INPUT MNEMONIC AGAINST CANDIDATE STRING
00B83C  2               ; Input:
00B83C  2               ;   R1 = input mnemonic start
00B83C  2               ;   mnem_len = input mnemonic length
00B83C  2               ;   T1 = candidate zero-terminated mnemonic pointer
00B83C  2               ;
00B83C  2               ; Output:
00B83C  2               ;   C = 1 match
00B83C  2               ;   C = 0 no match
00B83C  2               ; ------------------------------------------------------------
00B83C  2               compare_mnemonic:
00B83C  2  A0 00            ldy #0
00B83E  2               
00B83E  2               cm_loop:
00B83E  2  C4 D9            cpy mnem_len
00B840  2  F0 13            beq cm_end_input
00B842  2               
00B842  2  B1 C8            lda (R1L),y
00B844  2  20 4E B4         jsr toupper
00B847  2  85 D6            sta tmp
00B849  2               
00B849  2  B1 D0            lda (T1L),y
00B84B  2  F0 0C            beq cm_no
00B84D  2  C5 D6            cmp tmp
00B84F  2  D0 08            bne cm_no
00B851  2               
00B851  2  C8               iny
00B852  2  4C 3E B8         jmp cm_loop
00B855  2               
00B855  2               cm_end_input:
00B855  2  B1 D0            lda (T1L),y
00B857  2  F0 02            beq cm_yes
00B859  2               
00B859  2               cm_no:
00B859  2  18               clc
00B85A  2  60               rts
00B85B  2               
00B85B  2               cm_yes:
00B85B  2  38               sec
00B85C  2  60               rts
00B85D  2               
00B85D  2               
00B85D  2               ; ------------------------------------------------------------
00B85D  2               ; FETCH MNEMONIC ID FOR OPCODE IN X
00B85D  2               ; Uses mnemonic_id_table as a 256-byte table.
00B85D  2               ;
00B85D  2               ; Output:
00B85D  2               ;   A = mnemonic ID
00B85D  2               ; Preserves X
00B85D  2               ; ------------------------------------------------------------
00B85D  2               get_mnemonic_id_x:
00B85D  2  BD 1A BE         lda mnemonic_id_table,x
00B860  2  60               rts
00B861  2               
00B861  2               ; ------------------------------------------------------------
00B861  2               ; FETCH MNEMONIC POINTER FOR MNEMONIC ID IN A
00B861  2               ; Uses mnemonic_text_ptrs as a compact unique-pointer table.
00B861  2               ;
00B861  2               ; Input:
00B861  2               ;   A = mnemonic ID
00B861  2               ;
00B861  2               ; Output:
00B861  2               ;   T1 = pointer to zero-terminated mnemonic string
00B861  2               ; Preserves X
00B861  2               ; ------------------------------------------------------------
00B861  2               get_mnemonic_ptr_id:
00B861  2  DA               phx
00B862  2               
00B862  2  85 D6            sta tmp
00B864  2  0A               asl
00B865  2  AA               tax
00B866  2               
00B866  2  BD 54 BD         lda mnemonic_text_ptrs,x
00B869  2  85 D0            sta T1L
00B86B  2  E8               inx
00B86C  2  BD 54 BD         lda mnemonic_text_ptrs,x
00B86F  2  85 D1            sta T1H
00B871  2               
00B871  2  FA               plx
00B872  2  60               rts
00B873  2               
00B873  2               ; ------------------------------------------------------------
00B873  2               ; GET INSTRUCTION LENGTH FROM ADDRESSING MODE
00B873  2               ;
00B873  2               ; Input:
00B873  2               ;   A = addressing mode
00B873  2               ;
00B873  2               ; Output:
00B873  2               ;   A = instruction length
00B873  2               ;
00B873  2               ; Notes:
00B873  2               ;   AM_IMP, AM_ACC, AM_ILL      -> 1
00B873  2               ;   AM_IMM, AM_ZP, AM_ZPX,
00B873  2               ;   AM_ZPY, AM_INDX, AM_INDY,
00B873  2               ;   AM_ZPIND, AM_REL            -> 2
00B873  2               ;   AM_ABS, AM_ABSX, AM_ABSY,
00B873  2               ;   AM_IND, AM_ZPREL, AM_AIX    -> 3
00B873  2               ; ------------------------------------------------------------
00B873  2               get_oplen_from_mode:
00B873  2  DA               phx
00B874  2  AA               tax
00B875  2  BD 43 BD         lda mode_len_table,x
00B878  2  FA               plx
00B879  2  60           		rts
00B87A  2               
00B87A  2               ; ------------------------------------------------------------
00B87A  2               ; PARSE ASSEMBLER OPERAND
00B87A  2               ;
00B87A  2               ; Output:
00B87A  2               ;   asm_mode = parsed addressing mode
00B87A  2               ;   T0       = primary operand value
00B87A  2               ;   T1L      = zp byte for ZPREL
00B87A  2               ;
00B87A  2               ; Supported:
00B87A  2               ;   implied
00B87A  2               ;   A
00B87A  2               ;   #imm
00B87A  2               ;   zp / abs
00B87A  2               ;   zp,X / abs,X
00B87A  2               ;   zp,Y / abs,Y
00B87A  2               ;   (zp)
00B87A  2               ;   (abs)
00B87A  2               ;   (zp,X)
00B87A  2               ;   (abs,X)
00B87A  2               ;   (zp),Y
00B87A  2               ;   zp,target   (for BBR/BBS)
00B87A  2               ; ------------------------------------------------------------
00B87A  2               parse_asm_operand:
00B87A  2  20 CB B2         jsr next_token
00B87D  2  B0 05            bcs pa_have_operand
00B87F  2  A9 00            lda #AM_IMP
00B881  2  85 D7            sta asm_mode
00B883  2  60               rts
00B884  2               
00B884  2               pa_have_operand:
00B884  2  A0 00            ldy #0
00B886  2  B1 C2            lda (lineptr),y
00B888  2  C9 23            cmp #'#'
00B88A  2  F0 2B            beq pa_imm
00B88C  2  C9 28            cmp #'('
00B88E  2  F0 32            beq pa_paren
00B890  2               
00B890  2                   ; bare A can mean accumulator, but only if it is exactly "A"
00B890  2  20 4E B4         jsr toupper
00B893  2  C9 41            cmp #'A'
00B895  2  F0 03            beq pa_have_a
00B897  2  4C 40 B9     		jmp pa_value
00B89A  2               
00B89A  2               pa_have_a:
00B89A  2  A0 01            ldy #1
00B89C  2  B1 C2            lda (lineptr),y
00B89E  2  F0 07            beq pa_try_acc
00B8A0  2  C9 20            cmp #' '
00B8A2  2  F0 03            beq pa_try_acc
00B8A4  2  4C 40 B9         jmp pa_value
00B8A7  2               
00B8A7  2               pa_try_acc:
00B8A7  2  20 38 B4         jsr advance_lineptr
00B8AA  2  20 CB B2         jsr next_token
00B8AD  2  90 03            bcc pa_acc
00B8AF  2  4C 46 B2         jmp cmd_error
00B8B2  2               
00B8B2  2               pa_acc:
00B8B2  2  A9 01            lda #AM_ACC
00B8B4  2  85 D7            sta asm_mode
00B8B6  2  60               rts
00B8B7  2               
00B8B7  2               pa_imm:
00B8B7  2  20 38 B4         jsr advance_lineptr
00B8BA  2  20 0F B3         jsr parse_byte
00B8BD  2  A9 02            lda #AM_IMM
00B8BF  2  85 D7            sta asm_mode
00B8C1  2  60               rts
00B8C2  2               
00B8C2  2               pa_paren:
00B8C2  2  20 38 B4         jsr advance_lineptr
00B8C5  2  20 1C B3         jsr parse_word
00B8C8  2               
00B8C8  2  A0 00            ldy #0
00B8CA  2  B1 C2            lda (lineptr),y

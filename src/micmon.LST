00EAB1  2               ; asm_data.asm
00EAB1  2               ; W65C02S (dis)assembler tables
00EAB1  2               ;
00EAB1  2               ; Data source:
00EAB1  2               ; - WDC W65C02S opcode matrix
00EAB1  2               ; - 16 addressing modes, 212 defined opcodes
00EAB1  2               ;
00EAB1  2               ; Undefined / blank matrix cells are mapped to:
00EAB1  2               ;   mn_ILL / AM_ILL / length 1
00EAB1  2               
00EAB1  2               ; ------------------------------------------------------------
00EAB1  2               ; Addressing mode IDs
00EAB1  2               ; ------------------------------------------------------------
00EAB1  2               
00EAB1  2               AM_IMP   = 0      ; implied / stack
00EAB1  2               AM_ACC   = 1      ; accumulator
00EAB1  2               AM_IMM   = 2      ; immediate
00EAB1  2               AM_ZP    = 3      ; zero page
00EAB1  2               AM_ZPX   = 4      ; zero page,X
00EAB1  2               AM_ZPY   = 5      ; zero page,Y
00EAB1  2               AM_ABS   = 6      ; absolute
00EAB1  2               AM_ABSX  = 7      ; absolute,X
00EAB1  2               AM_ABSY  = 8      ; absolute,Y
00EAB1  2               AM_IND   = 9      ; (absolute)
00EAB1  2               AM_INDX  = 10     ; (zp,X)
00EAB1  2               AM_INDY  = 11     ; (zp),Y
00EAB1  2               AM_ZPIND = 12     ; (zp)
00EAB1  2               AM_REL   = 13     ; relative
00EAB1  2               AM_ZPREL = 14     ; zp,relative   (BBR/BBS)
00EAB1  2               AM_AIX   = 15     ; (absolute,X)
00EAB1  2               AM_ILL   = 16     ; undefined / reserved
00EAB1  2               
00EAB1  2               ; ------------------------------------------------------------
00EAB1  2               ; Unique mnemonic strings
00EAB1  2               ; ------------------------------------------------------------
00EAB1  2               

00E47C  1  18               clc
00E47D  1  65 C4            adc R0L
00E47F  1  85 C4            sta R0L
00E481  1  90 04            bcc add_r0_no_wrap
00E483  1  E6 C5            inc R0H
00E485  1  F0 02            beq add_r0_wrap
00E487  1               add_r0_no_wrap:
00E487  1  18               clc

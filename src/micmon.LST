00BA06  2               ; EMIT INSTRUCTION
00BA06  2               ; Uses asm_opcode, asm_mode and operand value(s).
00BA06  2               ; Updates MEM to next address.
00BA06  2               ; Writes nothing if relative offset is out of range.
00BA06  2               ; ------------------------------------------------------------
00BA06  2               emit_instruction:
00BA06  2  A5 D7            lda asm_mode
00BA08  2  20 56 B8         jsr get_oplen_from_mode
00BA0B  2  85 CD            sta R3H
00BA0D  2               
00BA0D  2                   ; for relative forms, validate offset before storing opcode
00BA0D  2  A5 D7            lda asm_mode
00BA0F  2  C9 0D            cmp #AM_REL
00BA11  2  F0 07            beq ei_prep_rel
00BA13  2  C9 0E            cmp #AM_ZPREL
00BA15  2  F0 0D            beq ei_prep_zprel
00BA17  2  4C 2E BA         jmp ei_store
00BA1A  2               
00BA1A  2               ei_prep_rel:
00BA1A  2  A9 02            lda #2
00BA1C  2  20 CA B9         jsr compute_rel_offset
00BA1F  2  85 D1            sta T1H
00BA21  2  4C 2E BA         jmp ei_store
00BA24  2               
00BA24  2               ei_prep_zprel:
00BA24  2  A9 03            lda #3
00BA26  2  20 CA B9         jsr compute_rel_offset
00BA29  2  85 D1            sta T1H
00BA2B  2  4C 2E BA         jmp ei_store
00BA2E  2               
00BA2E  2               ei_store:
00BA2E  2  A0 00            ldy #0
00BA30  2  A5 D8            lda asm_opcode
00BA32  2  91 C6            sta (R0L),y
00BA34  2               
00BA34  2  A5 CD            lda R3H
00BA36  2  C9 01            cmp #1
00BA38  2  F0 32            beq ei_finish
00BA3A  2               
00BA3A  2  A5 D7            lda asm_mode
00BA3C  2  C9 0D            cmp #AM_REL
00BA3E  2  F0 18            beq ei_rel
00BA40  2  C9 0E            cmp #AM_ZPREL
00BA42  2  F0 1D            beq ei_zprel
00BA44  2               
00BA44  2  A0 01            ldy #1
00BA46  2  A5 CE            lda T0L
00BA48  2  91 C6            sta (R0L),y
00BA4A  2               
00BA4A  2  A5 CD            lda R3H
00BA4C  2  C9 02            cmp #2
00BA4E  2  F0 1C            beq ei_finish
00BA50  2               
00BA50  2  C8               iny
00BA51  2  A5 CF            lda T0H
00BA53  2  91 C6            sta (R0L),y
00BA55  2  4C 6C BA         jmp ei_finish
00BA58  2               
00BA58  2               ei_rel:
00BA58  2  A0 01            ldy #1
00BA5A  2  A5 D1            lda T1H
00BA5C  2  91 C6            sta (R0L),y
00BA5E  2  4C 6C BA         jmp ei_finish
00BA61  2               
00BA61  2               ei_zprel:
00BA61  2  A0 01            ldy #1
00BA63  2  A5 D0            lda T1L
00BA65  2  91 C6            sta (R0L),y
00BA67  2  C8               iny
00BA68  2  A5 D1            lda T1H
00BA6A  2  91 C6            sta (R0L),y
00BA6C  2               
00BA6C  2               ei_finish:
00BA6C  2  A5 CD            lda R3H
00BA6E  2  20 87 B4         jsr add_R0_A
00BA71  2  A5 C6            lda R0L
00BA73  2  85 D2            sta MEML
00BA75  2  A5 C7            lda R0H
00BA77  2  85 D3            sta MEMH

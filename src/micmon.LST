00E9D5  2               ; ------------------------------------------------------------
00E9D5  2               ; COMPUTE_REL_OFFSET
00E9D5  2               ;
00E9D5  2               ; Input:
00E9D5  2               ;   A  = instruction length (2 or 3)
00E9D5  2               ;   R0 = instruction address
00E9D5  2               ;   T0 = target address
00E9D5  2               ;
00E9D5  2               ; Output:
00E9D5  2               ;   A  = signed 8-bit relative offset
00E9D5  2               ;
00E9D5  2               ; Error:
00E9D5  2               ;   jumps to cmd_error if target is out of range
00E9D5  2               ; ------------------------------------------------------------
00E9D5  2               compute_rel_offset:
00E9D5  2  85 D2            sta parm_count
00E9D7  2               
00E9D7  2                   ; R3 = base = R0 + instruction length
00E9D7  2  A5 C4            lda R0L
00E9D9  2  18               clc
00E9DA  2  65 D2            adc parm_count
00E9DC  2  85 CA            sta R3L
00E9DE  2  A5 C5            lda R0H
00E9E0  2  69 00            adc #0
00E9E2  2  85 CB            sta R3H
00E9E4  2               
00E9E4  2                   ; diff = target - base   (wrapped 16-bit subtraction)
00E9E4  2  38               sec
00E9E5  2  A5 CC            lda T0L
00E9E7  2  E5 CA            sbc R3L
00E9E9  2  85 CE            sta T1L
00E9EB  2  A5 CD            lda T0H
00E9ED  2  E5 CB            sbc R3H
00E9EF  2  85 CF            sta T1H
00E9F1  2               
00E9F1  2                   ; valid if:
00E9F1  2                   ;   T1 = 00:00..00:7F   (+0 .. +127)
00E9F1  2                   ;   T1 = FF:80..FF:FF   (-128 .. -1)
00E9F1  2               
00E9F1  2  A5 CF            lda T1H
00E9F3  2  F0 07            beq cro_pos
00E9F5  2  C9 FF            cmp #$FF
00E9F7  2  F0 0C            beq cro_neg
00E9F9  2  4C D7 E1         jmp cmd_error
00E9FC  2               
00E9FC  2               cro_pos:
00E9FC  2  A5 CE            lda T1L
00E9FE  2  C9 80            cmp #$80
00EA00  2  90 0C            bcc cro_ok
00EA02  2  4C D7 E1         jmp cmd_error
00EA05  2               
00EA05  2               cro_neg:
00EA05  2  A5 CE            lda T1L
00EA07  2  C9 80            cmp #$80
00EA09  2  B0 03            bcs cro_ok
00EA0B  2  4C D7 E1         jmp cmd_error
00EA0E  2               
00EA0E  2               cro_ok:
00EA0E  2  A5 CE            lda T1L
00EA10  2  60               rts

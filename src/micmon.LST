00EA2E  2               ; ------------------------------------------------------------
00EA2E  2               ; EMIT INSTRUCTION
00EA2E  2               ; Uses asm_opcode, asm_mode and operand value(s).
00EA2E  2               ; Updates MEM to next address.
00EA2E  2               ; Writes nothing if relative offset is out of range.
00EA2E  2               ; ------------------------------------------------------------
00EA2E  2               emit_instruction:
00EA2E  2  A5 D5            lda asm_mode
00EA30  2  20 50 E8         jsr get_oplen_from_mode
00EA33  2  85 D4            sta tmp
00EA35  2               
00EA35  2                   ; for relative forms, validate offset before storing opcode
00EA35  2  A5 D5            lda asm_mode
00EA37  2  C9 0D            cmp #AM_REL
00EA39  2  F0 07            beq ei_prep_rel
00EA3B  2  C9 0E            cmp #AM_ZPREL
00EA3D  2  F0 0D            beq ei_prep_zprel
00EA3F  2  4C 56 EA         jmp ei_store
00EA42  2               
00EA42  2               ei_prep_rel:
00EA42  2  A9 02            lda #2
00EA44  2  20 F2 E9         jsr compute_rel_offset
00EA47  2  85 CF            sta T1H
00EA49  2  4C 56 EA         jmp ei_store
00EA4C  2               
00EA4C  2               ei_prep_zprel:
00EA4C  2  A9 03            lda #3
00EA4E  2  20 F2 E9         jsr compute_rel_offset
00EA51  2  85 CF            sta T1H
00EA53  2  4C 56 EA         jmp ei_store
00EA56  2               
00EA56  2               ei_store:
00EA56  2  A0 00            ldy #0
00EA58  2  A5 D6            lda asm_opcode
00EA5A  2  91 C4            sta (R0L),y
00EA5C  2               
00EA5C  2  A5 D4            lda tmp
00EA5E  2  C9 01            cmp #1
00EA60  2  F0 32            beq ei_finish
00EA62  2               
00EA62  2  A5 D5            lda asm_mode
00EA64  2  C9 0D            cmp #AM_REL
00EA66  2  F0 18            beq ei_rel
00EA68  2  C9 0E            cmp #AM_ZPREL
00EA6A  2  F0 1D            beq ei_zprel
00EA6C  2               
00EA6C  2  A0 01            ldy #1
00EA6E  2  A5 CC            lda T0L
00EA70  2  91 C4            sta (R0L),y
00EA72  2               
00EA72  2  A5 D4            lda tmp
00EA74  2  C9 02            cmp #2
00EA76  2  F0 1C            beq ei_finish
00EA78  2               
00EA78  2  C8               iny
00EA79  2  A5 CD            lda T0H
00EA7B  2  91 C4            sta (R0L),y
00EA7D  2  4C 94 EA         jmp ei_finish
00EA80  2               
00EA80  2               ei_rel:
00EA80  2  A0 01            ldy #1
00EA82  2  A5 CF            lda T1H
00EA84  2  91 C4            sta (R0L),y
00EA86  2  4C 94 EA         jmp ei_finish
00EA89  2               
00EA89  2               ei_zprel:
00EA89  2  A0 01            ldy #1
00EA8B  2  A5 CE            lda T1L
00EA8D  2  91 C4            sta (R0L),y
00EA8F  2  C8               iny
00EA90  2  A5 CF            lda T1H
00EA92  2  91 C4            sta (R0L),y
00EA94  2               
00EA94  2               ei_finish:
00EA94  2  A5 D4            lda tmp
00EA96  2  20 7C E4         jsr add_R0_A
00EA99  2  A5 C4            lda R0L
00EA9B  2  85 D0            sta MEML
00EA9D  2  A5 C5            lda R0H
00EA9F  2  85 D1            sta MEMH

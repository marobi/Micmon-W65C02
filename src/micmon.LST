00E995  2               ; ------------------------------------------------------------
00E995  2               ; FIND OPCODE
00E995  2               ;
00E995  2               ; Input:
00E995  2               ;   mnemonic in R1/mnem_len
00E995  2               ;   asm_mode
00E995  2               ;
00E995  2               ; Output:
00E995  2               ;   C = 1 found
00E995  2               ;   asm_opcode = opcode
00E995  2               ;   C = 0 not found
00E995  2               ;
00E995  2               ; Special case:
00E995  2               ;   branch mnemonics accept AM_REL when operand parsed as ZP or ABS
00E995  2               ; ------------------------------------------------------------
00E995  2               find_opcode:
00E995  2  A2 00            ldx #0
00E997  2               
00E997  2               fo_loop:
00E997  2  BD 38 EC         lda mode_table,x
00E99A  2  C5 D5            cmp asm_mode
00E99C  2  F0 11            beq fo_check_mnemonic_direct
00E99E  2               
00E99E  2  C9 0D            cmp #AM_REL
00E9A0  2  D0 35            bne fo_next
00E9A2  2               
00E9A2  2  A5 D5            lda asm_mode
00E9A4  2  C9 03            cmp #AM_ZP
00E9A6  2  F0 15            beq fo_check_mnemonic_rel
00E9A8  2  C9 06            cmp #AM_ABS
00E9AA  2  F0 11            beq fo_check_mnemonic_rel
00E9AC  2  4C D7 E9         jmp fo_next
00E9AF  2               
00E9AF  2               fo_check_mnemonic_direct:
00E9AF  2  20 24 E8         jsr get_mnemonic_id_x
00E9B2  2  20 28 E8         jsr get_mnemonic_ptr_id
00E9B5  2  20 03 E8         jsr compare_mnemonic
00E9B8  2  B0 19            bcs fo_found_direct
00E9BA  2  4C D7 E9         jmp fo_next
00E9BD  2               
00E9BD  2               fo_check_mnemonic_rel:
00E9BD  2  20 24 E8         jsr get_mnemonic_id_x
00E9C0  2  20 28 E8         jsr get_mnemonic_ptr_id
00E9C3  2  20 03 E8         jsr compare_mnemonic
00E9C6  2  B0 03            bcs fo_found_rel
00E9C8  2  4C D7 E9         jmp fo_next
00E9CB  2               
00E9CB  2               fo_found_rel:
00E9CB  2  A9 0D            lda #AM_REL
00E9CD  2  85 D5            sta asm_mode
00E9CF  2  86 D6            stx asm_opcode
00E9D1  2  38               sec
00E9D2  2  60               rts
00E9D3  2               
00E9D3  2               fo_found_direct:
00E9D3  2  86 D6            stx asm_opcode
00E9D5  2  38               sec
00E9D6  2  60               rts
00E9D7  2               
00E9D7  2               fo_next:
00E9D7  2  E8               inx
00E9D8  2  D0 BD            bne fo_loop
00E9DA  2  18               clc
00E9DB  2  60               rts

00E97F  2               ; ------------------------------------------------------------
00E97F  2               ; FIND OPCODE
00E97F  2               ;
00E97F  2               ; Input:
00E97F  2               ;   mnemonic in R1/mnem_len
00E97F  2               ;   asm_mode
00E97F  2               ;
00E97F  2               ; Output:
00E97F  2               ;   C = 1 found
00E97F  2               ;   asm_opcode = opcode
00E97F  2               ;   C = 0 not found
00E97F  2               ;
00E97F  2               ; Special case:
00E97F  2               ;   branch mnemonics accept AM_REL when operand parsed as ZP or ABS
00E97F  2               ; ------------------------------------------------------------
00E97F  2               find_opcode:
00E97F  2  A2 00            ldx #0
00E981  2               
00E981  2               fo_loop:
00E981  2  BD 22 EC         lda mode_table,x
00E984  2  C5 D7            cmp asm_mode
00E986  2  F0 11            beq fo_check_mnemonic_direct
00E988  2               
00E988  2  C9 0D            cmp #AM_REL
00E98A  2  D0 35            bne fo_next
00E98C  2               
00E98C  2  A5 D7            lda asm_mode
00E98E  2  C9 03            cmp #AM_ZP
00E990  2  F0 15            beq fo_check_mnemonic_rel
00E992  2  C9 06            cmp #AM_ABS
00E994  2  F0 11            beq fo_check_mnemonic_rel
00E996  2  4C C1 E9         jmp fo_next
00E999  2               
00E999  2               fo_check_mnemonic_direct:
00E999  2  20 3C E8         jsr get_mnemonic_id_x
00E99C  2  20 40 E8         jsr get_mnemonic_ptr_id
00E99F  2  20 1B E8         jsr compare_mnemonic
00E9A2  2  B0 19            bcs fo_found_direct
00E9A4  2  4C C1 E9         jmp fo_next
00E9A7  2               
00E9A7  2               fo_check_mnemonic_rel:
00E9A7  2  20 3C E8         jsr get_mnemonic_id_x
00E9AA  2  20 40 E8         jsr get_mnemonic_ptr_id
00E9AD  2  20 1B E8         jsr compare_mnemonic
00E9B0  2  B0 03            bcs fo_found_rel
00E9B2  2  4C C1 E9         jmp fo_next
00E9B5  2               
00E9B5  2               fo_found_rel:
00E9B5  2  A9 0D            lda #AM_REL
00E9B7  2  85 D7            sta asm_mode
00E9B9  2  86 D8            stx asm_opcode
00E9BB  2  38               sec
00E9BC  2  60               rts
00E9BD  2               

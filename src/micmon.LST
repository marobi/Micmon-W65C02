00EAA5  2               ; asm_data.asm
00EAA5  2               ; W65C02S (dis)assembler tables
00EAA5  2               ;
00EAA5  2               ; Data source:
00EAA5  2               ; - WDC W65C02S opcode matrix
00EAA5  2               ; - 16 addressing modes, 212 defined opcodes
00EAA5  2               ;
00EAA5  2               ; Undefined / blank matrix cells are mapped to:
00EAA5  2               ;   mn_ILL / AM_ILL / length 1
00EAA5  2               
00EAA5  2               ; ------------------------------------------------------------
00EAA5  2               ; Addressing mode IDs
00EAA5  2               ; ------------------------------------------------------------
00EAA5  2               
00EAA5  2               AM_IMP   = 0      ; implied / stack
00EAA5  2               AM_ACC   = 1      ; accumulator
00EAA5  2               AM_IMM   = 2      ; immediate
00EAA5  2               AM_ZP    = 3      ; zero page
00EAA5  2               AM_ZPX   = 4      ; zero page,X
00EAA5  2               AM_ZPY   = 5      ; zero page,Y
00EAA5  2               AM_ABS   = 6      ; absolute
00EAA5  2               AM_ABSX  = 7      ; absolute,X
00EAA5  2               AM_ABSY  = 8      ; absolute,Y
00EAA5  2               AM_IND   = 9      ; (absolute)
00EAA5  2               AM_INDX  = 10     ; (zp,X)
00EAA5  2               AM_INDY  = 11     ; (zp),Y
00EAA5  2               AM_ZPIND = 12     ; (zp)
00EAA5  2               AM_REL   = 13     ; relative
00EAA5  2               AM_ZPREL = 14     ; zp,relative   (BBR/BBS)
00EAA5  2               AM_AIX   = 15     ; (absolute,X)
00EAA5  2               AM_ILL   = 16     ; undefined / reserved
00EAA5  2               
00EAA5  2               ; ------------------------------------------------------------
00EAA5  2               ; Unique mnemonic strings
00EAA5  2               ; ------------------------------------------------------------
00EAA5  2               
00EAA5  2  2E 44 42 00  mn_ILL:  .byte ".DB",0

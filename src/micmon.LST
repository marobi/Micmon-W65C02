00E9C5  2  20 3A E8         jsr get_mnemonic_id_x
00E9C8  2  20 3E E8         jsr get_mnemonic_ptr_id
00E9CB  2  20 19 E8         jsr compare_mnemonic
00E9CE  2  B0 19            bcs fo_found_direct
00E9D0  2  4C ED E9         jmp fo_next
00E9D3  2               
00E9D3  2               fo_check_mnemonic_rel:
00E9D3  2  20 3A E8         jsr get_mnemonic_id_x
00E9D6  2  20 3E E8         jsr get_mnemonic_ptr_id
00E9D9  2  20 19 E8         jsr compare_mnemonic
00E9DC  2  B0 03            bcs fo_found_rel
00E9DE  2  4C ED E9         jmp fo_next
00E9E1  2               

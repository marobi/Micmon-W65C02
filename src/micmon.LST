00EA02  2               ; ------------------------------------------------------------
00EA02  2               ; EMIT INSTRUCTION
00EA02  2               ; Uses asm_opcode, asm_mode and operand value(s).
00EA02  2               ; Updates MEM to next address.
00EA02  2               ; Writes nothing if relative offset is out of range.
00EA02  2               ; ------------------------------------------------------------
00EA02  2               emit_instruction:
00EA02  2  A5 D7            lda asm_mode
00EA04  2  20 52 E8         jsr get_oplen_from_mode
00EA07  2  85 CD            sta R3H
00EA09  2               
00EA09  2                   ; for relative forms, validate offset before storing opcode
00EA09  2  A5 D7            lda asm_mode
00EA0B  2  C9 0D            cmp #AM_REL
00EA0D  2  F0 07            beq ei_prep_rel
00EA0F  2  C9 0E            cmp #AM_ZPREL
00EA11  2  F0 0D            beq ei_prep_zprel
00EA13  2  4C 2A EA         jmp ei_store
00EA16  2               
00EA16  2               ei_prep_rel:
00EA16  2  A9 02            lda #2
00EA18  2  20 C6 E9         jsr compute_rel_offset
00EA1B  2  85 D1            sta T1H
00EA1D  2  4C 2A EA         jmp ei_store
00EA20  2               
00EA20  2               ei_prep_zprel:
00EA20  2  A9 03            lda #3
00EA22  2  20 C6 E9         jsr compute_rel_offset
00EA25  2  85 D1            sta T1H
00EA27  2  4C 2A EA         jmp ei_store
00EA2A  2               
00EA2A  2               ei_store:
00EA2A  2  A0 00            ldy #0
00EA2C  2  A5 D8            lda asm_opcode
00EA2E  2  91 C6            sta (R0L),y
00EA30  2               
00EA30  2  A5 CD            lda R3H
00EA32  2  C9 01            cmp #1
00EA34  2  F0 32            beq ei_finish
00EA36  2               
00EA36  2  A5 D7            lda asm_mode
00EA38  2  C9 0D            cmp #AM_REL
00EA3A  2  F0 18            beq ei_rel
00EA3C  2  C9 0E            cmp #AM_ZPREL
00EA3E  2  F0 1D            beq ei_zprel
00EA40  2               
00EA40  2  A0 01            ldy #1
00EA42  2  A5 CE            lda T0L
00EA44  2  91 C6            sta (R0L),y
00EA46  2               
00EA46  2  A5 CD            lda R3H
00EA48  2  C9 02            cmp #2
00EA4A  2  F0 1C            beq ei_finish
00EA4C  2               
00EA4C  2  C8               iny
00EA4D  2  A5 CF            lda T0H
00EA4F  2  91 C6            sta (R0L),y
00EA51  2  4C 68 EA         jmp ei_finish
00EA54  2               
00EA54  2               ei_rel:
00EA54  2  A0 01            ldy #1
00EA56  2  A5 D1            lda T1H
00EA58  2  91 C6            sta (R0L),y
00EA5A  2  4C 68 EA         jmp ei_finish
00EA5D  2               
00EA5D  2               ei_zprel:
00EA5D  2  A0 01            ldy #1
00EA5F  2  A5 D0            lda T1L
00EA61  2  91 C6            sta (R0L),y
00EA63  2  C8               iny
00EA64  2  A5 D1            lda T1H
00EA66  2  91 C6            sta (R0L),y
00EA68  2               
00EA68  2               ei_finish:
00EA68  2  A5 CD            lda R3H
00EA6A  2  20 85 E4         jsr add_R0_A
00EA6D  2  A5 C6            lda R0L
00EA6F  2  85 D2            sta MEML
00EA71  2  A5 C7            lda R0H
00EA73  2  85 D3            sta MEMH
00EA75  2  60               rts

00E4A5  1               ; ------------------------------------------------------------
00E4A5  1               ; ADD_R2_A
00E4A5  1               ; Add unsigned byte in A to 16-bit register R2.
00E4A5  1               ; ------------------------------------------------------------
00E4A5  1               add_R2_A:
00E4A5  1  18               clc
00E4A6  1  65 C8            adc R2L
00E4A8  1  85 C8            sta R2L

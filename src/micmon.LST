00E9AE  2               ; ------------------------------------------------------------
00E9AE  2               ; FIND OPCODE
00E9AE  2               ;
00E9AE  2               ; Input:
00E9AE  2               ;   mnemonic in R1/mnem_len
00E9AE  2               ;   asm_mode
00E9AE  2               ;
00E9AE  2               ; Output:
00E9AE  2               ;   C = 1 found
00E9AE  2               ;   asm_opcode = opcode
00E9AE  2               ;   C = 0 not found
00E9AE  2               ;
00E9AE  2               ; Special case:
00E9AE  2               ;   branch mnemonics accept AM_REL when operand parsed as ZP or ABS
00E9AE  2               ; ------------------------------------------------------------
00E9AE  2               find_opcode:
00E9AE  2  A2 00            ldx #0
00E9B0  2               
00E9B0  2               fo_loop:
00E9B0  2  BD 51 EC         lda mode_table,x
00E9B3  2  C5 D7            cmp asm_mode
00E9B5  2  F0 11            beq fo_check_mnemonic_direct
00E9B7  2               
00E9B7  2  C9 0D            cmp #AM_REL
00E9B9  2  D0 35            bne fo_next
00E9BB  2               
00E9BB  2  A5 D7            lda asm_mode
00E9BD  2  C9 03            cmp #AM_ZP
00E9BF  2  F0 15            beq fo_check_mnemonic_rel
00E9C1  2  C9 06            cmp #AM_ABS
00E9C3  2  F0 11            beq fo_check_mnemonic_rel
00E9C5  2  4C F0 E9         jmp fo_next
00E9C8  2               
00E9C8  2               fo_check_mnemonic_direct:
00E9C8  2  20 6B E8         jsr get_mnemonic_id_x
00E9CB  2  20 6F E8         jsr get_mnemonic_ptr_id
00E9CE  2  20 4A E8         jsr compare_mnemonic
00E9D1  2  B0 19            bcs fo_found_direct
00E9D3  2  4C F0 E9         jmp fo_next
00E9D6  2               
00E9D6  2               fo_check_mnemonic_rel:
00E9D6  2  20 6B E8         jsr get_mnemonic_id_x
00E9D9  2  20 6F E8         jsr get_mnemonic_ptr_id
00E9DC  2  20 4A E8         jsr compare_mnemonic
00E9DF  2  B0 03            bcs fo_found_rel
00E9E1  2  4C F0 E9         jmp fo_next
00E9E4  2               
00E9E4  2               fo_found_rel:
00E9E4  2  A9 0D            lda #AM_REL
00E9E6  2  85 D7            sta asm_mode
00E9E8  2  86 D8            stx asm_opcode
00E9EA  2  38               sec
00E9EB  2  60               rts
00E9EC  2               
00E9EC  2               fo_found_direct:

00E7DC  1               
00E7DC  1               .include "asm.asm"
00E7DC  2               ; ------------------------------------------------------------
00E7DC  2               ; SIMPLE ASSEMBLER COMMAND
00E7DC  2               ; Syntax:
00E7DC  2               ;   A [addr] mnemonic [operand]
00E7DC  2               ;
00E7DC  2               ; If addr is omitted, MEM is used.
00E7DC  2               ; On success MEM is updated to the next address.
00E7DC  2               ; ------------------------------------------------------------
00E7DC  2               cmd_asm:
00E7DC  2  20 46 E4         jsr advance_lineptr
00E7DF  2  20 D9 E2         jsr next_token
00E7E2  2  B0 03            bcs ca_have_first
00E7E4  2  4C 54 E2         jmp cmd_error
00E7E7  2               
00E7E7  2               ca_have_first:
00E7E7  2  A0 00            ldy #0
00E7E9  2  B1 C2            lda (lineptr),y
00E7EB  2  20 5C E4         jsr toupper
00E7EE  2  C9 41            cmp #'A'
00E7F0  2  90 04            bcc ca_with_addr
00E7F2  2  C9 5B            cmp #'Z'+1
00E7F4  2  90 0E            bcc ca_default_addr
00E7F6  2               
00E7F6  2               ca_with_addr:
00E7F6  2  20 2A E3         jsr parse_word
00E7F9  2  20 70 E4         jsr copy_T0_R0
00E7FC  2  20 D9 E2         jsr next_token
00E7FF  2  B0 06            bcs ca_mnemonic
00E801  2  4C 54 E2         jmp cmd_error
00E804  2               
00E804  2               ca_default_addr:
00E804  2  20 94 E4         jsr copy_MEM_R0
00E807  2               
00E807  2               ca_mnemonic:
00E807  2  20 8B E4         jsr copy_R0_R2
00E80A  2  20 23 E8         jsr parse_mnemonic
00E80D  2  20 88 E8         jsr parse_asm_operand
00E810  2  20 D9 E2         jsr next_token
00E813  2  90 03            bcc ca_find
00E815  2  4C 54 E2         jmp cmd_error
00E818  2               
00E818  2               ca_find:
00E818  2  20 AE E9         jsr find_opcode
00E81B  2  B0 03            bcs ca_emit
00E81D  2  4C 54 E2         jmp cmd_error
00E820  2               
00E820  2               ca_emit:
00E820  2  4C 31 EA         jmp emit_instruction
00E823  2               
00E823  2               ; ------------------------------------------------------------
00E823  2               ; PARSE MNEMONIC
00E823  2               ; lineptr must point at the first mnemonic character.
00E823  2               ; Saves start pointer in R1 and length in mnem_len.
00E823  2               ; Advances lineptr to the first character after the mnemonic.
00E823  2               ; ------------------------------------------------------------
00E823  2               parse_mnemonic:
00E823  2  20 4D E4         jsr skip_spaces
00E826  2  A5 C2            lda lineptr
00E828  2  85 C8            sta R1L
00E82A  2  A5 C3            lda lineptr+1
00E82C  2  85 C9            sta R1H
00E82E  2  64 D9            stz mnem_len
00E830  2               
00E830  2               pm_loop:
00E830  2  A0 00            ldy #0
00E832  2  B1 C2            lda (lineptr),y
00E834  2  F0 0C            beq pm_done
00E836  2  C9 20            cmp #' '
00E838  2  F0 08            beq pm_done
00E83A  2  E6 D9            inc mnem_len
00E83C  2  20 46 E4         jsr advance_lineptr
00E83F  2  4C 30 E8         jmp pm_loop
00E842  2               
00E842  2               pm_done:
00E842  2  A5 D9            lda mnem_len
00E844  2  D0 03            bne pm_ok
00E846  2  4C 54 E2         jmp cmd_error
00E849  2               
00E849  2               pm_ok:
00E849  2  60               rts
00E84A  2               
00E84A  2               ; ------------------------------------------------------------
00E84A  2               ; COMPARE INPUT MNEMONIC AGAINST CANDIDATE STRING
00E84A  2               ; Input:
00E84A  2               ;   R1 = input mnemonic start
00E84A  2               ;   mnem_len = input mnemonic length
00E84A  2               ;   T1 = candidate zero-terminated mnemonic pointer
00E84A  2               ;
00E84A  2               ; Output:
00E84A  2               ;   C = 1 match
00E84A  2               ;   C = 0 no match
00E84A  2               ; ------------------------------------------------------------
00E84A  2               compare_mnemonic:
00E84A  2  A0 00            ldy #0
00E84C  2               
00E84C  2               cm_loop:
00E84C  2  C4 D9            cpy mnem_len
00E84E  2  F0 13            beq cm_end_input
00E850  2               
00E850  2  B1 C8            lda (R1L),y
00E852  2  20 5C E4         jsr toupper
00E855  2  85 D6            sta tmp
00E857  2               
00E857  2  B1 D0            lda (T1L),y
00E859  2  F0 0C            beq cm_no
00E85B  2  C5 D6            cmp tmp
00E85D  2  D0 08            bne cm_no
00E85F  2               
00E85F  2  C8               iny
00E860  2  4C 4C E8         jmp cm_loop
00E863  2               
00E863  2               cm_end_input:
00E863  2  B1 D0            lda (T1L),y
00E865  2  F0 02            beq cm_yes
00E867  2               
00E867  2               cm_no:
00E867  2  18               clc
00E868  2  60               rts
00E869  2               
00E869  2               cm_yes:
00E869  2  38               sec
00E86A  2  60               rts
00E86B  2               
00E86B  2               
00E86B  2               ; ------------------------------------------------------------
00E86B  2               ; FETCH MNEMONIC ID FOR OPCODE IN X
00E86B  2               ; Uses mnemonic_id_table as a 256-byte table.
00E86B  2               ;
00E86B  2               ; Output:
00E86B  2               ;   A = mnemonic ID
00E86B  2               ; Preserves X
00E86B  2               ; ------------------------------------------------------------
00E86B  2               get_mnemonic_id_x:
00E86B  2  BD 28 EE         lda mnemonic_id_table,x
00E86E  2  60               rts
00E86F  2               
00E86F  2               ; ------------------------------------------------------------
00E86F  2               ; FETCH MNEMONIC POINTER FOR MNEMONIC ID IN A
00E86F  2               ; Uses mnemonic_text_ptrs as a compact unique-pointer table.
00E86F  2               ;
00E86F  2               ; Input:
00E86F  2               ;   A = mnemonic ID
00E86F  2               ;
00E86F  2               ; Output:
00E86F  2               ;   T1 = pointer to zero-terminated mnemonic string
00E86F  2               ; Preserves X
00E86F  2               ; ------------------------------------------------------------
00E86F  2               get_mnemonic_ptr_id:
00E86F  2  DA               phx
00E870  2               
00E870  2  85 D6            sta tmp
00E872  2  0A               asl
00E873  2  AA               tax
00E874  2               
00E874  2  BD 62 ED         lda mnemonic_text_ptrs,x
00E877  2  85 D0            sta T1L
00E879  2  E8               inx
00E87A  2  BD 62 ED         lda mnemonic_text_ptrs,x
00E87D  2  85 D1            sta T1H
00E87F  2               
00E87F  2  FA               plx
00E880  2  60               rts
00E881  2               
00E881  2               ; ------------------------------------------------------------
00E881  2               ; GET INSTRUCTION LENGTH FROM ADDRESSING MODE
00E881  2               ;
00E881  2               ; Input:
00E881  2               ;   A = addressing mode
00E881  2               ;
00E881  2               ; Output:
00E881  2               ;   A = instruction length
00E881  2               ;
00E881  2               ; Notes:
00E881  2               ;   AM_IMP, AM_ACC, AM_ILL      -> 1
00E881  2               ;   AM_IMM, AM_ZP, AM_ZPX,
00E881  2               ;   AM_ZPY, AM_INDX, AM_INDY,
00E881  2               ;   AM_ZPIND, AM_REL            -> 2
00E881  2               ;   AM_ABS, AM_ABSX, AM_ABSY,
00E881  2               ;   AM_IND, AM_ZPREL, AM_AIX    -> 3
00E881  2               ; ------------------------------------------------------------
00E881  2               get_oplen_from_mode:
00E881  2  DA               phx
00E882  2  AA               tax
00E883  2  BD 51 ED         lda mode_len_table,x
00E886  2  FA               plx
00E887  2  60           		rts
00E888  2               
00E888  2               ; ------------------------------------------------------------
00E888  2               ; PARSE ASSEMBLER OPERAND
00E888  2               ;
00E888  2               ; Output:
00E888  2               ;   asm_mode = parsed addressing mode
00E888  2               ;   T0       = primary operand value
00E888  2               ;   T1L      = zp byte for ZPREL
00E888  2               ;
00E888  2               ; Supported:
00E888  2               ;   implied
00E888  2               ;   A
00E888  2               ;   #imm
00E888  2               ;   zp / abs
00E888  2               ;   zp,X / abs,X
00E888  2               ;   zp,Y / abs,Y
00E888  2               ;   (zp)
00E888  2               ;   (abs)
00E888  2               ;   (zp,X)
00E888  2               ;   (abs,X)
00E888  2               ;   (zp),Y
00E888  2               ;   zp,target   (for BBR/BBS)
00E888  2               ; ------------------------------------------------------------
00E888  2               parse_asm_operand:
00E888  2  20 D9 E2         jsr next_token
00E88B  2  B0 05            bcs pa_have_operand
00E88D  2  A9 00            lda #AM_IMP
00E88F  2  85 D7            sta asm_mode
00E891  2  60               rts
00E892  2               
00E892  2               pa_have_operand:
00E892  2  A0 00            ldy #0
00E894  2  B1 C2            lda (lineptr),y
00E896  2  C9 23            cmp #'#'
00E898  2  F0 2B            beq pa_imm
00E89A  2  C9 28            cmp #'('
00E89C  2  F0 32            beq pa_paren
00E89E  2               
00E89E  2                   ; bare A can mean accumulator, but only if it is exactly "A"
00E89E  2  20 5C E4         jsr toupper
00E8A1  2  C9 41            cmp #'A'
00E8A3  2  F0 03            beq pa_have_a
00E8A5  2  4C 4E E9     		jmp pa_value
00E8A8  2               
00E8A8  2               pa_have_a:
00E8A8  2  A0 01            ldy #1
00E8AA  2  B1 C2            lda (lineptr),y
00E8AC  2  F0 07            beq pa_try_acc
00E8AE  2  C9 20            cmp #' '
00E8B0  2  F0 03            beq pa_try_acc
00E8B2  2  4C 4E E9         jmp pa_value
00E8B5  2               
00E8B5  2               pa_try_acc:
00E8B5  2  20 46 E4         jsr advance_lineptr
00E8B8  2  20 D9 E2         jsr next_token
00E8BB  2  90 03            bcc pa_acc
00E8BD  2  4C 54 E2         jmp cmd_error
00E8C0  2               
00E8C0  2               pa_acc:
00E8C0  2  A9 01            lda #AM_ACC
00E8C2  2  85 D7            sta asm_mode
00E8C4  2  60               rts
00E8C5  2               
00E8C5  2               pa_imm:
00E8C5  2  20 46 E4         jsr advance_lineptr
00E8C8  2  20 1D E3         jsr parse_byte
00E8CB  2  A9 02            lda #AM_IMM
00E8CD  2  85 D7            sta asm_mode
00E8CF  2  60               rts
00E8D0  2               
00E8D0  2               pa_paren:
00E8D0  2  20 46 E4         jsr advance_lineptr
00E8D3  2  20 2A E3         jsr parse_word
00E8D6  2               

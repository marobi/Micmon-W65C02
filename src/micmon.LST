00E9F2  2               ; ------------------------------------------------------------
00E9F2  2               ; COMPUTE_REL_OFFSET
00E9F2  2               ;
00E9F2  2               ; Input:
00E9F2  2               ;   A  = instruction length (2 or 3)
00E9F2  2               ;   R0 = instruction address
00E9F2  2               ;   T0 = target address
00E9F2  2               ;
00E9F2  2               ; Output:
00E9F2  2               ;   A  = signed 8-bit relative offset
00E9F2  2               ;
00E9F2  2               ; Error:
00E9F2  2               ;   jumps to cmd_error if target is out of range
00E9F2  2               ; ------------------------------------------------------------
00E9F2  2               compute_rel_offset:
00E9F2  2  85 D2            sta parm_count
00E9F4  2               
00E9F4  2                   ; R3 = base = R0 + instruction length
00E9F4  2  A5 C4            lda R0L
00E9F6  2  18               clc
00E9F7  2  65 D2            adc parm_count
00E9F9  2  85 CA            sta R3L
00E9FB  2  A5 C5            lda R0H
00E9FD  2  69 00            adc #0
00E9FF  2  85 CB            sta R3H
00EA01  2               
00EA01  2                   ; diff = target - base   (wrapped 16-bit subtraction)
00EA01  2  38               sec
00EA02  2  A5 CC            lda T0L
00EA04  2  E5 CA            sbc R3L
00EA06  2  85 CE            sta T1L
00EA08  2  A5 CD            lda T0H
00EA0A  2  E5 CB            sbc R3H
00EA0C  2  85 CF            sta T1H
00EA0E  2               
00EA0E  2                   ; valid if:
00EA0E  2                   ;   T1 = 00:00..00:7F   (+0 .. +127)
00EA0E  2                   ;   T1 = FF:80..FF:FF   (-128 .. -1)
00EA0E  2               
00EA0E  2  A5 CF            lda T1H
00EA10  2  F0 07            beq cro_pos
00EA12  2  C9 FF            cmp #$FF
00EA14  2  F0 0C            beq cro_neg
00EA16  2  4C 23 E2         jmp cmd_error
00EA19  2               
00EA19  2               cro_pos:
00EA19  2  A5 CE            lda T1L
00EA1B  2  C9 80            cmp #$80
00EA1D  2  90 0C            bcc cro_ok
00EA1F  2  4C 23 E2         jmp cmd_error
00EA22  2               
00EA22  2               cro_neg:
00EA22  2  A5 CE            lda T1L
00EA24  2  C9 80            cmp #$80
00EA26  2  B0 03            bcs cro_ok
00EA28  2  4C 23 E2         jmp cmd_error
00EA2B  2               
00EA2B  2               cro_ok:
00EA2B  2  A5 CE            lda T1L
00EA2D  2  60               rts

00B4C3  1  60               rts
00B4C4  1               
00B4C4  1               ; ------------------------------------------------------------
00B4C4  1               ; ADD_R2_A
00B4C4  1               ; Add unsigned byte in A to 16-bit register R2.
00B4C4  1               ;
00B4C4  1               ; Returns:
00B4C4  1               ;   C = 1 only if 16-bit wrap occurred ($FFFF -> $0000)
00B4C4  1               ;   C = 0 otherwise
00B4C4  1               ; ------------------------------------------------------------
00B4C4  1               add_R2_A:
00B4C4  1  18               clc
00B4C5  1  65 CA            adc R2L
00B4C7  1  85 CA            sta R2L
00B4C9  1  90 04            bcc add_r2_no_wrap
00B4CB  1               
00B4CB  1  E6 CB            inc R2H
00B4CD  1  F0 02            beq add_r2_wrap
00B4CF  1               
00B4CF  1               add_r2_no_wrap:
00B4CF  1  18               clc
00B4D0  1  60               rts
00B4D1  1               
00B4D1  1               add_r2_wrap:
00B4D1  1  38               sec
00B4D2  1  60               rts
00B4D3  1               
00B4D3  1               add_T1_T0:
00B4D3  1  18               clc
00B4D4  1  A5 CE            lda T0L
00B4D6  1  65 D0            adc T1L
00B4D8  1  85 CE            sta T0L
00B4DA  1  A5 CF            lda T0H
00B4DC  1  65 D1            adc T1H
00B4DE  1  85 CF            sta T0H
00B4E0  1  60               rts
00B4E1  1               
00B4E1  1               cmp_R2_R1:
00B4E1  1  A5 CB            lda R2H
00B4E3  1  C5 C9            cmp R1H
00B4E5  1  D0 04            bne cmp_r2_r1_done
00B4E7  1  A5 CA            lda R2L
00B4E9  1  C5 C8            cmp R1L
00B4EB  1               cmp_r2_r1_done:
00B4EB  1  60               rts
00B4EC  1               
00B4EC  1               ;------------------------------------------------
00B4EC  1               print_hex8:
00B4EC  1  48               pha
00B4ED  1  4A               lsr
00B4EE  1  4A               lsr
00B4EF  1  4A               lsr
00B4F0  1  4A               lsr
00B4F1  1  20 F7 B4         jsr print_hex_digit
00B4F4  1  68               pla
00B4F5  1  29 0F            and #$0F
00B4F7  1               
00B4F7  1               print_hex_digit:
00B4F7  1  C9 0A            cmp #10
00B4F9  1  90 06            bcc print_hex_num
00B4FB  1  18               clc
00B4FC  1  69 37            adc #'A'-10
00B4FE  1  4C 5A B5         jmp putchar
00B501  1               
00B501  1               print_hex_num:
00B501  1  18               clc
00B502  1  69 30            adc #'0'
00B504  1  4C 5A B5         jmp putchar
00B507  1               
00B507  1               ; ------------------------------------------------------------
00B507  1               ; PRINT_HEX16
00B507  1               ; Print 16-bit value in hexadecimal.
00B507  1               ;
00B507  1               ; Input
00B507  1               ;   A = high byte
00B507  1               ;   X = low byte
00B507  1               ; ------------------------------------------------------------
00B507  1               print_hex16:
00B507  1  DA               phx
00B508  1  20 EC B4         jsr print_hex8
00B50B  1  FA               plx
00B50C  1  8A               txa
00B50D  1  4C EC B4         jmp print_hex8
00B510  1               
00B510  1               
00B510  1               print_ascii:
00B510  1  C9 20            cmp #$20
00B512  1  90 07            bcc ascii_dot
00B514  1  C9 7F            cmp #$7F
00B516  1  B0 03            bcs ascii_dot
00B518  1  4C 5A B5         jmp putchar
00B51B  1               
00B51B  1               
00B51B  1               ascii_dot:
00B51B  1  A9 2E            lda #'.'
00B51D  1  4C 5A B5         jmp putchar
00B520  1               
00B520  1               print_space:
00B520  1  A9 20            lda #' '
00B522  1  4C 5A B5         jmp putchar
00B525  1               
00B525  1               newline:
00B525  1  A9 0D            lda #$0D
00B527  1  4C 5A B5         jmp putchar
00B52A  1               
00B52A  1               print_prompt:
00B52A  1  A9 64        		lda #<prompt_text
00B52C  1  A2 BF            ldx #>prompt_text
00B52E  1  4C 7F B2         jmp print_str
00B531  1               
00B531  1               ; ------------------------------------------------------------
00B531  1               ; GETLINE
00B531  1               ; Read a line from input into linebuf.
00B531  1               ;
00B531  1               ; Assumptions
00B531  1               ; - host terminal performs line editing
00B531  1               ; - CR (0x0D) terminates the line
00B531  1               ; - line is zero terminated
00B531  1               ; - max length = 127 characters
00B531  1               ; ------------------------------------------------------------
00B531  1               getline:
00B531  1  A2 00            ldx #0
00B533  1               
00B533  1               getline_loop:
00B533  1  20 57 B5         jsr getchar
00B536  1  C9 0D            cmp #$0D
00B538  1  F0 0F            beq getline_done
00B53A  1  C9 0A            cmp #$0A
00B53C  1  F0 0B            beq getline_done
00B53E  1               
00B53E  1  E0 3B            cpx #59
00B540  1  B0 F1            bcs getline_loop
00B542  1               
00B542  1  9D 00 02         sta linebuf,x
00B545  1  E8               inx
00B546  1  4C 33 B5         jmp getline_loop
00B549  1               
00B549  1               getline_done:
00B549  1  A9 00            lda #0
00B54B  1  9D 00 02         sta linebuf,x
00B54E  1  60               rts
00B54F  1               
00B54F  1               print_error:
00B54F  1  A9 3F        	lda #'?'
00B551  1  20 5A B5     	jsr putchar
00B554  1  4C 25 B5     	jmp newline
00B557  1               
00B557  1               ; ------------------------------------------------------------
00B557  1               ; I/O
00B557  1               ; ------------------------------------------------------------
00B557  1               getchar:
00B557  1  4C 00 F0     	jmp BIOS_INCHAR
00B55A  1               
00B55A  1               putchar:
00B55A  1  4C 03 F0         jmp BIOS_OUTCHAR
00B55D  1               
00B55D  1               ; ------------------------------------------------------------
00B55D  1               ; CHECK_ABORT
00B55D  1               ; Test if the user pressed ^C.
00B55D  1               ;
00B55D  1               ; Returns
00B55D  1               ;   C = 1  abort requested
00B55D  1               ;   C = 0  continue
00B55D  1               ;
00B55D  1               ; Wrapper around BIOS_STPKEY so the monitor depends only on
00B55D  1               ; this primitive instead of calling the BIOS everywhere.
00B55D  1               ; ------------------------------------------------------------
00B55D  1               check_abort:
00B55D  1  4C 09 F0         jmp BIOS_STPKEY
00B560  1               
00B560  1               ; command implementations
00B560  1               .include "disasm.asm"
00B560  2               ; ------------------------------------------------------------
00B560  2               ; DISASSEMBLER COMMAND
00B560  2               ; Syntax:
00B560  2               ;   D
00B560  2               ;   D start
00B560  2               ;   D start end
00B560  2               ;
00B560  2               ; Default start is MEM.
00B560  2               ; Default length is 12 instructions.
00B560  2               ; MEM is updated to the next address after the disassembly.
00B560  2               ; ------------------------------------------------------------
00B560  2               cmd_disasm:
00B560  2  20 38 B4         jsr advance_lineptr
00B563  2  20 CB B2         jsr next_token
00B566  2  90 14            bcc dis_default
00B568  2               
00B568  2  20 1C B3         jsr parse_word
00B56B  2  20 62 B4         jsr copy_T0_R0
00B56E  2               
00B56E  2  20 CB B2         jsr next_token
00B571  2  90 0C            bcc dis_one_param
00B573  2               
00B573  2  20 1C B3         jsr parse_word
00B576  2  20 6B B4         jsr copy_T0_R1
00B579  2  4C 89 B5         jmp dis_prepare_range
00B57C  2               
00B57C  2               dis_default:
00B57C  2  20 86 B4         jsr copy_MEM_R0
00B57F  2               
00B57F  2               dis_one_param:
00B57F  2  20 74 B4         jsr copy_R0_R1
00B582  2  A9 0C            lda #12
00B584  2  85 D4            sta parm_count
00B586  2  4C 91 B5         jmp dis_prepare_count
00B589  2               
00B589  2               dis_prepare_range:
00B589  2  20 CB B2         jsr next_token
00B58C  2  90 21            bcc dis_range_ok
00B58E  2  4C 46 B2         jmp cmd_error
00B591  2               
00B591  2               dis_prepare_count:
00B591  2  20 CB B2         jsr next_token
00B594  2  90 03            bcc dis_count_ok
00B596  2  4C 46 B2         jmp cmd_error
00B599  2               
00B599  2               dis_count_ok:
00B599  2  20 7D B4         jsr copy_R0_R2
00B59C  2               
00B59C  2               dis_loop_count:
00B59C  2  20 5D B5         jsr check_abort
00B59F  2  B0 2D            bcs dis_abort
00B5A1  2  20 D1 B5         jsr disasm_line
00B5A4  2  B0 23            bcs dis_done
00B5A6  2  C6 D4            dec parm_count
00B5A8  2  D0 F2            bne dis_loop_count
00B5AA  2  20 8F B4         jsr copy_R2_MEM
00B5AD  2  18           		clc
00B5AE  2  60           		rts
00B5AF  2               
00B5AF  2               dis_range_ok:
00B5AF  2  20 7D B4         jsr copy_R0_R2
00B5B2  2               
00B5B2  2               dis_loop_range:
00B5B2  2  20 5D B5         jsr check_abort
00B5B5  2  B0 17            bcs dis_abort
00B5B7  2               
00B5B7  2  20 E1 B4         jsr cmp_R2_R1
00B5BA  2  90 05            bcc dis_do_line
00B5BC  2  F0 03            beq dis_do_line
00B5BE  2  4C C9 B5         jmp dis_done
00B5C1  2               
00B5C1  2               dis_do_line:
00B5C1  2  20 D1 B5         jsr disasm_line
00B5C4  2  B0 03            bcs dis_done
00B5C6  2  4C B2 B5         jmp dis_loop_range
00B5C9  2               
00B5C9  2               dis_done:
00B5C9  2  20 8F B4         jsr copy_R2_MEM
00B5CC  2  18           		clc
00B5CD  2  60           		rts
00B5CE  2               
00B5CE  2               dis_abort:
00B5CE  2  4C 46 B2         jmp cmd_error
00B5D1  2               
00B5D1  2               ; ------------------------------------------------------------
00B5D1  2               ; DISASSEMBLE ONE LINE
00B5D1  2               ;
00B5D1  2               ; Input
00B5D1  2               ;   R2 = current PC
00B5D1  2               ;
00B5D1  2               ; Internal use
00B5D1  2               ;   T0L = opcode
00B5D1  2               ;   R3L = addressing mode
00B5D1  2               ;   R3H = instruction length
00B5D1  2               ;   T1  = pointer to mnemonic string
00B5D1  2               ;
00B5D1  2               ; Output
00B5D1  2               ;   prints one disassembly line
00B5D1  2               ;   advances R2 by instruction length
00B5D1  2               ; ------------------------------------------------------------
00B5D1  2               disasm_line:
00B5D1  2  20 02 B6         jsr print_disasm_address
00B5D4  2               
00B5D4  2  A0 00            ldy #0
00B5D6  2  B1 CA            lda (R2L),y
00B5D8  2  85 CE            sta T0L
00B5DA  2  AA               tax
00B5DB  2               
00B5DB  2  BD 43 BC         lda mode_table,x
00B5DE  2  85 CC            sta R3L
00B5E0  2  20 73 B8         jsr get_oplen_from_mode
00B5E3  2  85 CD            sta R3H
00B5E5  2               
00B5E5  2  20 5D B8         jsr get_mnemonic_id_x
00B5E8  2  20 61 B8         jsr get_mnemonic_ptr_id
00B5EB  2               
00B5EB  2  20 0F B6         jsr print_disasm_bytes
00B5EE  2  20 20 B5         jsr print_space
00B5F1  2  20 20 B5         jsr print_space
00B5F4  2  20 3F B6         jsr print_mnemonic
00B5F7  2  20 49 B6         jsr print_operand
00B5FA  2  20 25 B5         jsr newline
00B5FD  2               
00B5FD  2  A5 CD            lda R3H
00B5FF  2  4C C4 B4         jmp add_R2_A
00B602  2               
00B602  2               print_disasm_address:
00B602  2  A5 CB            lda R2H
00B604  2  A6 CA            ldx R2L
00B606  2  20 07 B5         jsr print_hex16
00B609  2  20 20 B5         jsr print_space
00B60C  2  4C 20 B5         jmp print_space
00B60F  2               
00B60F  2               ; ------------------------------------------------------------
00B60F  2               ; PRINT RAW BYTES FIELD
00B60F  2               ; Shows 1..3 actual instruction bytes and pads to fixed width.
00B60F  2               ; R3H = instruction length
00B60F  2               ; ------------------------------------------------------------
00B60F  2               print_disasm_bytes:
00B60F  2  A0 00            ldy #0
00B611  2               
00B611  2               pdb_real_loop:
00B611  2  C4 CD            cpy R3H
00B613  2  F0 0E            beq pdb_pad
00B615  2  B1 CA            lda (R2L),y
00B617  2  20 EC B4         jsr print_hex8
00B61A  2  20 20 B5         jsr print_space
00B61D  2  C8               iny
00B61E  2  C0 03            cpy #3
00B620  2  D0 EF            bne pdb_real_loop
00B622  2  60               rts
00B623  2               
00B623  2               pdb_pad:
00B623  2  C0 03            cpy #3
00B625  2  F0 11            beq pdb_done
00B627  2  A9 20            lda #' '
00B629  2  20 5A B5         jsr putchar
00B62C  2  A9 20            lda #' '
00B62E  2  20 5A B5         jsr putchar
00B631  2  20 20 B5         jsr print_space
00B634  2  C8               iny
00B635  2  4C 23 B6         jmp pdb_pad
00B638  2               
00B638  2               pdb_done:
00B638  2  60               rts
00B639  2               
00B639  2               ; ------------------------------------------------------------
00B639  2               ; GAP BETWEEN BYTE FIELD AND MNEMONIC
00B639  2               ; ------------------------------------------------------------
00B639  2               print_disasm_gap:
00B639  2  20 20 B5         jsr print_space
00B63C  2  4C 20 B5         jmp print_space
00B63F  2               
00B63F  2               ; ------------------------------------------------------------
00B63F  2               ; PRINT MNEMONIC
00B63F  2               ; T1 = pointer to zero-terminated mnemonic string
00B63F  2               ; ------------------------------------------------------------
00B63F  2               print_mnemonic:
00B63F  2  A5 D0            lda T1L
00B641  2  A6 D1            ldx T1H
00B643  2  20 7F B2         jsr print_str
00B646  2  4C 20 B5         jmp print_space

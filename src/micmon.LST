00B412  1               ;
00B412  1               ; Input
00B412  1               ;   A = ASCII character
00B412  1               ;
00B412  1               ; Output
00B412  1               ;   A = digit value
00B412  1               ;   C = 0 valid digit
00B412  1               ;   C = 1 invalid digit
00B412  1               ; ------------------------------------------------------------
00B412  1               hex_digit:
00B412  1  C9 30            cmp #'0'
00B414  1  90 23            bcc hex_bad
00B416  1  C9 3A            cmp #'9'+1
00B418  1  90 1A            bcc hex_num
00B41A  1               
00B41A  1  C9 41            cmp #'A'
00B41C  1  90 04            bcc hex_lower
00B41E  1  C9 47            cmp #'F'+1
00B420  1  90 0D            bcc hex_upper
00B422  1               

000000r 1               ; ---------------------------------------------------------------------------
000000r 1               ; MICMON – Minimal Interactive Command Monitor for the W65C02
000000r 1               ; (c) 2026 Rien Matthijsse
000000r 1               ; ---------------------------------------------------------------------------
000000r 1               .include "readme.asm"
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; MICMON – Minimal Interactive Command Monitor for the W65C02
000000r 2               ; (c) 2026 Rien Matthijsse
000000r 2               ;
000000r 2               ; Overview
000000r 2               ; --------
000000r 2               ; Micmon is a compact machine-level monitor for the W65C02, designed to fit
000000r 2               ; within a 4 KB ROM. It provides essential debugging, inspection and control
000000r 2               ; facilities while remaining small, deterministic, and fully self-hosting.
000000r 2               ;
000000r 2               ; The monitor follows a strict "round-trip" philosophy: all output is valid
000000r 2               ; input. Any command output (e.g. memory dumps) can be edited and fed back
000000r 2               ; into the monitor for execution. This enables interactive workflows using
000000r 2               ; external terminals or VDUs with line editing capabilities.
000000r 2               ;
000000r 2               ; Design Goals
000000r 2               ; ------------
000000r 2               ; - Minimal footprint (fits in 4 KB ROM)
000000r 2               ; - Deterministic behaviour (no hidden state, no dynamic allocation)
000000r 2               ; - Table-driven architecture (command dispatch, disassembler, assembler)
000000r 2               ; - Round-trip capable output (monitor output is executable input)
000000r 2               ; - Tight integration with external VDU/GDU systems
000000r 2               ;
000000r 2               ; Functional Scope
000000r 2               ; ----------------
000000r 2               ; - Memory inspection and modification
000000r 2               ; - CPU register inspection and editing
000000r 2               ; - Program execution control (GO)
000000r 2               ; - Disassembler (W65C02 complete)
000000r 2               ; - Inline assembler (single-line, immediate emission)
000000r 2               ; - Command-driven interface with single-character dispatch
000000r 2               ;
000000r 2               ; Command Summary
000000r 2               ; ---------------
000000r 2               ;   H          Help / command overview
000000r 2               ;   M addr     Dump memory
000000r 2               ;   > addr     Modify memory (hex byte stream)
000000r 2               ;   R          Show CPU registers
000000r 2               ;   ;          Modify CPU registers
000000r 2               ;   G [addr]   Execute code at address
000000r 2               ;   D [addr]   Disassembler
000000r 2               ;   A [addr]   Assemble single instruction at address
000000r 2               ;
000000r 2               ; Notes:
000000r 2               ; - Default address is MEM unless explicitly provided
000000r 2               ; - Commands are line-oriented and CR-terminated
000000r 2               ; - Where possible: output format is compatible with monitor input (round-trip)
000000r 2               ;
000000r 2               ; Execution Model
000000r 2               ; ---------------
000000r 2               ; - RESET:
000000r 2               ;     Initializes CPU state and monitor environment
000000r 2               ;     Enters monitor via BRK vector
000000r 2               ;
000000r 2               ; - BRK handler:
000000r 2               ;     Saves full CPU context (A, X, Y, P, SP, PC)
000000r 2               ;     Transfers control to command interpreter
000000r 2               ;
000000r 2               ; - Command loop:
000000r 2               ;     Line-oriented input
000000r 2               ;     Single-character command dispatch via table
000000r 2               ;     Commands operate directly on memory and CPU image
000000r 2               ;
000000r 2               ; Interaction Model
000000r 2               ; -----------------
000000r 2               ; Micmon assumes the host terminal or VDU performs line editing.
000000r 2               ; Input is processed per line (CR-terminated).
000000r 2               ;
000000r 2               ; Output is formatted to be re-consumable:
000000r 2               ;
000000r 2               ;     M 0200 020F
000000r 2               ;     > 0200 A9 01 8D 00 02 ...
000000r 2               ;
000000r 2               ; Can be edited into:
000000r 2               ;
000000r 2               ;     > 0200 A9 FF 8D 00 02
000000r 2               ;
000000r 2               ; and executed directly by the monitor.
000000r 2               ;
000000r 2               ; Parameter Formats
000000r 2               ; -----------------
000000r 2               ; All numeric parameters support multiple input formats. The parser auto-
000000r 2               ; detects the format based on prefix or content.
000000r 2               ;
000000r 2               ; Supported formats:
000000r 2               ;
000000r 2               ;   Hexadecimal (default)
000000r 2               ;     0200      $0200
000000r 2               ;
000000r 2               ;   Decimal
000000r 2               ;     +123
000000r 2               ;
000000r 2               ;   Binary
000000r 2               ;     %10101010
000000r 2               ;
000000r 2               ;   ASCII
000000r 2               ;     'A        -> $41
000000r 2               ;
000000r 2               ; Rules:
000000r 2               ; - Hex is assumed if no prefix is present
000000r 2               ;       $   = hex (optional, since default)
000000r 2               ;       %   = binary
000000r 2               ;       +   = decimal
000000r 2               ;       '   = ASCII single byte
000000r 2               ;
000000r 2               ; - All parsed values result in:
000000r 2               ;       T0 = value (byte or word)
000000r 2               ;       value_size >= 1 indicates success
000000r 2               ;
000000r 2               ; - Commands are literal
000000r 2               ;
000000r 2               ; Examples:
000000r 2               ;   M $C000
000000r 2               ;   M %1100000000000000
000000r 2               ;   M +49152
000000r 2               ;
000000r 2               ;   > 0200 'A $42 %01000011
000000r 2               ;
000000r 2               ;   A 0300 LDA #'A
000000r 2               ;   A 0302 LDA #$41
000000r 2               ;
000000r 2               ; Architecture Notes
000000r 2               ; ------------------
000000r 2               ; - All decoding (disassembler/assembler) is table-driven
000000r 2               ; - Opcode metadata shared between assembler and disassembler
000000r 2               ; - Zero-page used from $00C0-$00DF
000000r 2               ; - Strict separation between parsing, decoding and execution
000000r 2               ;
000000r 2               ; Extensibility
000000r 2               ; -------------
000000r 2               ; Micmon is intentionally designed for easy extension:
000000r 2               ;
000000r 2               ; - New commands can be added by inserting entries in:
000000r 2               ;       cmd_chars / cmd_addrs tables
000000r 2               ;
000000r 2               ; - No central switch-case logic: dispatch is fully table-driven
000000r 2               ; - Parsing helpers (parse_word, next_token, etc.) are reusable
000000r 2               ; - Disassembler and assembler share data tables, reducing duplication
000000r 2               ; - New addressing modes or instructions require only table updates
000000r 2               ;
000000r 2               ; This allows incremental growth without restructuring the monitor core.
000000r 2               ;
000000r 2               ; Limitations
000000r 2               ; -----------
000000r 2               ; - No multi-line assembly or label resolution
000000r 2               ; - No expression evaluator
000000r 2               ; - Branch range limited to signed 8-bit (hardware constraint)
000000r 2               ;
000000r 2               ; Target
000000r 2               ; ------
000000r 2               ; WDC W65C02 (fully supported instruction set)
000000r 2               ;
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               
000000r 1               
000000r 1               	.setcpu "65C02"
000000r 1               
000000r 1               .include "../bios/bios.h"
000000r 2               ;
000000r 2               ; BIOS jumptable + ...
000000r 2               ;
000000r 2               BIOS_CMD_PORT   =   $D002
000000r 2               BIOS_STAT_PORT  =   $D003
000000r 2               BIOS_SYNC_PORT  =   $D004
000000r 2               
000000r 2               BIOS_BASE       =  	$F000
000000r 2               BIOS_INCHAR     =   BIOS_BASE
000000r 2               BIOS_OUTCHAR    =   BIOS_BASE+3
000000r 2               BIOS_INKEY      =   BIOS_BASE+6
000000r 2               BIOS_STPKEY		=	BIOS_BASE+9
000000r 2               BIOS_CONTEXT    =   BIOS_BASE+12
000000r 2               
000000r 1               
000000r 1               	.segment "ZEROPAGE"
000000r 1               	.org $00C0								; nicer listing
0000C0  1               
0000C0  1               ; IRQ hander vector
0000C0  1  xx           irq_vecL:   .res 1
0000C1  1  xx           irq_vecH:   .res 1
0000C2  1               
0000C2  1               ; parser / dispatcher pointers
0000C2  1  xx xx        lineptr:    .res 2
0000C4  1  xx xx        jmpvec:     .res 2
0000C6  1               
0000C6  1               ; 16-bit working registers for commands
0000C6  1  xx           R0L:        .res 1
0000C7  1  xx           R0H:        .res 1
0000C8  1  xx           R1L:        .res 1
0000C9  1  xx           R1H:        .res 1
0000CA  1  xx           R2L:        .res 1
0000CB  1  xx           R2H:        .res 1
0000CC  1  xx           R3L:        .res 1
0000CD  1  xx           R3H:        .res 1
0000CE  1               
0000CE  1               ; temporary registers used by parser and utility routines
0000CE  1  xx           T0L:        .res 1
0000CF  1  xx           T0H:        .res 1
0000D0  1  xx           T1L:        .res 1
0000D1  1  xx           T1H:        .res 1
0000D2  1               
0000D2  1               ; monitor remembers last referenced memory address
0000D2  1  xx           MEML:       .res 1
0000D3  1  xx           MEMH:       .res 1
0000D4  1               
0000D4  1               ; parser state
0000D4  1  xx           parm_count: .res 1
0000D5  1  xx           value_size: .res 1
0000D6  1  xx           tmp:        .res 1
0000D7  1               
0000D7  1  xx           asm_mode:   .res 1
0000D8  1  xx           asm_opcode: .res 1
0000D9  1  xx           mnem_len:   .res 1
0000DA  1               
0000DA  1               	.segment "BSS"
0000DA  1               	.org $0200							; nicer listing
000200  1               
000200  1               ; input buffer
000200  1  xx xx xx xx  linebuf:    .res 40
000204  1  xx xx xx xx  
000208  1  xx xx xx xx  
000228  1               
000228  1               ; saved CPU image
000228  1  xx           reg_pch:    .res 1
000229  1  xx           reg_pcl:    .res 1
00022A  1  xx           reg_sr:     .res 1
00022B  1  xx           reg_a:      .res 1
00022C  1  xx           reg_x:      .res 1
00022D  1  xx           reg_y:      .res 1
00022E  1  xx           reg_sp:     .res 1
00022F  1               
00022F  1               	.segment "CODE"
00022F  1               	.org $E000				; nicer listing
00E000  1               
00E000  1               ; ------------------------------------------------------------
00E000  1               ; RESET
00E000  1               ; Basic CPU setup, monitor state initialization, then enter
00E000  1               ; the monitor through BRK so startup uses the normal entry path.
00E000  1               ; ------------------------------------------------------------
00E000  1               	.export reset
00E000  1               reset:
00E000  1  78               sei						; disable interrupts
00E001  1  D8               cld
00E002  1  A2 FF            ldx #$FF
00E004  1  9A               txs						; init stack
00E005  1               
00E005  1  64 D2            stz MEML
00E007  1  64 D3            stz MEMH
00E009  1  A9 2A        	lda #<context_switch	; set interrupt vector
00E00B  1  85 C0            sta irq_vecL
00E00D  1  A9 E0        	lda #>context_switch
00E00F  1  85 C1            sta irq_vecH
00E011  1               
00E011  1  A9 44            lda #<welcome_text		; say hello
00E013  1  A2 EF            ldx #>welcome_text
00E015  1  20 8D E2         jsr print_str
00E018  1               
00E018  1  00           	brk						; enter monitor
00E019  1               
00E019  1               ; ------------------------------------------------------------
00E019  1               ; IRQ / BRK ENTRY
00E019  1               ; Shared entry for hardware IRQ and BRK.
00E019  1               ;
00E019  1               ; BRK enters the monitor.
00E019  1               ; IRQ dispatches through irq_vec
00E019  1               ; ------------------------------------------------------------
00E019  1               	.export irq_entry
00E019  1               irq_entry:
00E019  1  48               pha						; save rest of context
00E01A  1  DA               phx
00E01B  1  5A               phy
00E01C  1               
00E01C  1  BA               tsx
00E01D  1  8E 00 01     	stx $0100				; save SP
00E020  1  BD 04 01         lda $0104,x             ; stacked SR after PHA/PHX/PHY
00E023  1  29 10            and #$10
00E025  1  D0 30            bne brk_entry			; BREAK
00E027  1               
00E027  1               irq_dispatch:				; IRQ
00E027  1  6C C0 00         jmp (irq_vecL)
00E02A  1               
00E02A  1               ; ------------------------------------------------------------
00E02A  1               ; expects the full context to be saved on stack
00E02A  1               ; micmon must be shared between all contexts and loaded last
00E02A  1               ;
00E02A  1               context_switch:				; for now default irq vector
00E02A  1  AD 04 D0     	lda BIOS_SYNC_PORT
00E02D  1  F0 FB        	beq context_switch		; wait for prev release, should not happen
00E02F  1               							; now 1
00E02F  1  9C 04 D0     	stz BIOS_SYNC_PORT		; arm
00E032  1               							; now 0
00E032  1               wait_ack:					; rp2350 will perform context switch
00E032  1  AD 04 D0     	lda BIOS_SYNC_PORT
00E035  1  F0 FB        	beq wait_ack			; wait for completion
00E037  1               							; now 1
00E037  1  AD 03 D0     	lda BIOS_STAT_PORT		; what to do?
00E03A  1  C9 01        	cmp #$01				; when 1
00E03C  1  F0 03        	beq irq_restore			; restore context
00E03E  1  6C FC FF     	jmp ($FFFC)				; else exec reset
00E041  1               
00E041  1               irq_restore:				; context switched
00E041  1  AE 00 01     	ldx $0100
00E044  1  9A           	txs						; restore SP
00E045  1  7A               ply						; restore context
00E046  1  FA               plx
00E047  1  68               pla
00E048  1  40               rti						; and continue
00E049  1               
00E049  1               	.export nmi_entry
00E049  1               nmi_entry:
00E049  1  40               rti						; stub
00E04A  1               
00E04A  1               print_context:
00E04A  1  BA               tsx
00E04B  1               
00E04B  1               
00E04B  1               switch_txt:
00E04B  1  0D 53 57 49  	.byte $0D, "SWITCHED:", $0D, 0
00E04F  1  54 43 48 45  
00E053  1  44 3A 0D 00  
00E057  1               
00E057  1               ; ------------------------------------------------------------
00E057  1               ; BRK ENTRY
00E057  1               ; Save CPU state into monitor RAM and discard interrupt frame.
00E057  1               ; BRK pushes PC+2, so saved PC is corrected back to BRK opcode.
00E057  1               ; ------------------------------------------------------------
00E057  1               brk_entry:
00E057  1  68               pla						; save context
00E058  1  8D 2D 02         sta reg_y
00E05B  1  68               pla
00E05C  1  8D 2C 02         sta reg_x
00E05F  1  68               pla
00E060  1  8D 2B 02         sta reg_a
00E063  1  68               pla
00E064  1  8D 2A 02         sta reg_sr
00E067  1  68               pla
00E068  1  8D 29 02         sta reg_pcl
00E06B  1  68               pla
00E06C  1  8D 28 02         sta reg_pch
00E06F  1               
00E06F  1  BA               tsx
00E070  1  8E 2E 02         stx reg_sp
00E073  1               
00E073  1  D8               cld
00E074  1  38               sec						; correct PC =-2
00E075  1  AD 29 02         lda reg_pcl
00E078  1  E9 02            sbc #2
00E07A  1  8D 29 02         sta reg_pcl
00E07D  1  AD 28 02         lda reg_pch
00E080  1  E9 00            sbc #0
00E082  1  8D 28 02         sta reg_pch
00E085  1               
00E085  1               ; ------------------------------------------------------------
00E085  1               ; MONITOR ENTRY
00E085  1               ; Every BRK entry shows the saved registers, then drops into
00E085  1               ; the command loop.
00E085  1               ; ------------------------------------------------------------
00E085  1               monitor_entry:
00E085  1  58           	cli					; enable interrupts
00E086  1  20 64 E1         jsr show_registers	; show regs and fall through
00E089  1  20 38 E5     	jsr print_prompt
00E08C  1               
00E08C  1               ; ------------------------------------------------------------
00E08C  1               ; MAIN MONITOR LOOP
00E08C  1               ; Read one full line, execute it
00E08C  1               ; ------------------------------------------------------------
00E08C  1               monitor_loop:
00E08C  1  20 3F E5         jsr getline					; read line
00E08F  1  A9 00            lda #<linebuf
00E091  1  85 C2            sta lineptr
00E093  1  A9 02            lda #>linebuf
00E095  1  85 C3            sta lineptr+1
00E097  1               
00E097  1               execute_line:
00E097  1  20 4D E4         jsr skip_spaces
00E09A  1  A0 00            ldy #0
00E09C  1  B1 C2            lda (lineptr),y			; get cmd
00E09E  1  F0 0A            beq exec_done
00E0A0  1  20 5C E4         jsr toupper
00E0A3  1  91 C2            sta (lineptr),y			; save uppercase
00E0A5  1  20 B0 E0         jsr dispatch_command
00E0A8  1  B0 03        	bcs exec_nopr
00E0AA  1               exec_done:
00E0AA  1  20 38 E5     	jsr print_prompt
00E0AD  1               
00E0AD  1               exec_nopr:
00E0AD  1  4C 8C E0         jmp monitor_loop
00E0B0  1               
00E0B0  1               ; ------------------------------------------------------------
00E0B0  1               ; COMMAND DISPATCH
00E0B0  1               ; ------------------------------------------------------------
00E0B0  1               dispatch_command:
00E0B0  1  A0 00            ldy #0
00E0B2  1  B1 C2            lda (lineptr),y
00E0B4  1  85 D6            sta tmp
00E0B6  1               
00E0B6  1  A2 00            ldx #0
00E0B8  1               dispatch_loop:
00E0B8  1  BD 28 EF         lda cmd_chars,x
00E0BB  1  F0 19            beq dispatch_error
00E0BD  1  C5 D6            cmp tmp
00E0BF  1  F0 04            beq dispatch_found
00E0C1  1  E8               inx
00E0C2  1  4C B8 E0         jmp dispatch_loop
00E0C5  1               
00E0C5  1               dispatch_found:
00E0C5  1  8A               txa
00E0C6  1  0A               asl
00E0C7  1  AA               tax
00E0C8  1  BD 32 EF         lda cmd_addrs,x
00E0CB  1  85 C4            sta jmpvec
00E0CD  1  E8               inx
00E0CE  1  BD 32 EF         lda cmd_addrs,x
00E0D1  1  85 C5            sta jmpvec+1
00E0D3  1  6C C4 00         jmp (jmpvec)
00E0D6  1               
00E0D6  1               dispatch_error:
00E0D6  1  4C 54 E2         jmp cmd_error
00E0D9  1               
00E0D9  1               ; ------------------------------------------------------------
00E0D9  1               ; RESET COMMAND
00E0D9  1               ; ------------------------------------------------------------
00E0D9  1               cmd_reset:
00E0D9  1  4C 00 E0     		jmp reset
00E0DC  1               
00E0DC  1               ; ------------------------------------------------------------
00E0DC  1               ; MEMORY DUMP COMMAND
00E0DC  1               ; Syntax:
00E0DC  1               ;   M
00E0DC  1               ;   M start
00E0DC  1               ;   M start end
00E0DC  1               ;
00E0DC  1               ; Default start is MEM.
00E0DC  1               ; Default length is 12 lines * 8 bytes = 96 bytes.
00E0DC  1               ; MEM is updated to the next address after the dump.
00E0DC  1               ; ------------------------------------------------------------
00E0DC  1               cmd_mem:
00E0DC  1  20 46 E4     	jsr advance_lineptr
00E0DF  1               
00E0DF  1  20 D9 E2         jsr next_token
00E0E2  1  90 14            bcc mem_default
00E0E4  1               
00E0E4  1  20 2A E3         jsr parse_word
00E0E7  1  20 70 E4         jsr copy_T0_R0
00E0EA  1               
00E0EA  1  20 D9 E2         jsr next_token
00E0ED  1  90 0C            bcc mem_one_param
00E0EF  1               
00E0EF  1  20 2A E3         jsr parse_word
00E0F2  1  20 79 E4         jsr copy_T0_R1
00E0F5  1  4C 03 E1         jmp mem_prepare
00E0F8  1               
00E0F8  1               mem_default:
00E0F8  1  20 94 E4         jsr copy_MEM_R0
00E0FB  1               mem_one_param:
00E0FB  1  20 82 E4         jsr copy_R0_R1
00E0FE  1  A9 5F            lda #95
00E100  1  20 C3 E4         jsr add_R1_A
00E103  1               
00E103  1               mem_prepare:
00E103  1  20 D9 E2         jsr next_token
00E106  1  90 03            bcc mem_prepare_ok
00E108  1  4C 54 E2         jmp cmd_error
00E10B  1               
00E10B  1               mem_prepare_ok:
00E10B  1  20 8B E4         jsr copy_R0_R2
00E10E  1               
00E10E  1               mem_loop:
00E10E  1  20 6B E5         jsr check_abort
00E111  1  B0 16            bcs mem_abort
00E113  1               
00E113  1  20 59 E2         jsr dump_line
00E116  1               
00E116  1  A9 08            lda #8
00E118  1  20 D2 E4         jsr add_R2_A
00E11B  1  B0 07            bcs mem_ok
00E11D  1               
00E11D  1  20 EF E4         jsr cmp_R2_R1
00E120  1  90 EC            bcc mem_loop
00E122  1  F0 EA            beq mem_loop
00E124  1               
00E124  1               mem_ok:
00E124  1  20 9D E4         jsr copy_R2_MEM
00E127  1  18               clc
00E128  1  60           	rts
00E129  1               
00E129  1               mem_abort:
00E129  1  4C 54 E2         jmp cmd_error
00E12C  1               
00E12C  1               ; ------------------------------------------------------------
00E12C  1               ; MEMORY EDIT COMMAND
00E12C  1               ; Syntax:
00E12C  1               ;   > addr byte...
00E12C  1               ; Writes 1..8 bytes.
00E12C  1               ; Updates MEM to the next address after the last write.
00E12C  1               ; ------------------------------------------------------------
00E12C  1               cmd_memedit:
00E12C  1  20 46 E4     	jsr advance_lineptr
00E12F  1  20 2A E3         jsr parse_word
00E132  1  20 70 E4         jsr copy_T0_R0				; init ptr
00E135  1               
00E135  1  64 D4            stz parm_count				; first of 8
00E137  1               
00E137  1               write_loop:
00E137  1  A5 D4            lda parm_count
00E139  1  C9 08            cmp #8
00E13B  1  B0 16            bcs write_done				; >= 7
00E13D  1               
00E13D  1  20 D9 E2         jsr next_token
00E140  1  90 11            bcc write_done				; no more
00E142  1               
00E142  1  20 1D E3         jsr parse_byte
00E145  1               
00E145  1  A0 00            ldy #0
00E147  1  A5 CE            lda T0L
00E149  1  91 C6            sta (R0L),y						; store it
00E14B  1               
00E14B  1  20 A6 E4         jsr inc_R0						; next location
00E14E  1  E6 D4            inc parm_count				; next param
00E150  1  4C 37 E1         jmp write_loop				; loop
00E153  1               
00E153  1               write_done:
00E153  1  A5 D4            lda parm_count
00E155  1  F0 0A            beq write_error				; no locations given
00E157  1               
00E157  1  A5 C6            lda R0L								; advance mem ptr
00E159  1  85 D2            sta MEML
00E15B  1  A5 C7            lda R0H
00E15D  1  85 D3            sta MEMH
00E15F  1  18               clc
00E160  1  60           	rts
00E161  1               
00E161  1               write_error:
00E161  1  4C 54 E2         jmp cmd_error
00E164  1               
00E164  1               
00E164  1               ; ------------------------------------------------------------
00E164  1               ; REGISTER DISPLAY COMMAND
00E164  1               ; Explicit register display on user request.
00E164  1               ; ------------------------------------------------------------
00E164  1               cmd_regs:
00E164  1               show_registers:
00E164  1  A9 54            lda #<reg_header
00E166  1  A2 EF            ldx #>reg_header
00E168  1  20 8D E2         jsr print_str
00E16B  1               
00E16B  1               print_reg_line:
00E16B  1  A9 3B            lda #';'							; in sync with command table
00E16D  1  20 68 E5         jsr putchar
00E170  1  20 2E E5         jsr print_space
00E173  1               
00E173  1  AD 28 02         lda reg_pch
00E176  1  AE 29 02         ldx reg_pcl
00E179  1  20 15 E5         jsr print_hex16
00E17C  1  20 2E E5         jsr print_space
00E17F  1               
00E17F  1  AD 2B 02         lda reg_a
00E182  1  20 FA E4         jsr print_hex8
00E185  1  20 2E E5         jsr print_space
00E188  1               
00E188  1  AD 2C 02         lda reg_x
00E18B  1  20 FA E4         jsr print_hex8
00E18E  1  20 2E E5         jsr print_space
00E191  1               
00E191  1  AD 2D 02         lda reg_y
00E194  1  20 FA E4         jsr print_hex8
00E197  1  20 2E E5         jsr print_space
00E19A  1               
00E19A  1  AD 2E 02         lda reg_sp
00E19D  1  20 FA E4         jsr print_hex8
00E1A0  1  20 2E E5         jsr print_space
00E1A3  1               
00E1A3  1  A9 25            lda #'%'
00E1A5  1  20 68 E5     		jsr putchar
00E1A8  1  AD 2A 02         lda reg_sr
00E1AB  1  20 A5 E2         jsr print_status_bits
00E1AE  1  20 33 E5         jsr newline
00E1B1  1  18           	clc
00E1B2  1  60           	rts
00E1B3  1               
00E1B3  1               ; ------------------------------------------------------------
00E1B3  1               ; REGISTER EDIT COMMAND
00E1B3  1               ; Editable line format:
00E1B3  1               ;   ; <PC> [A [X [Y [SP [SR]]]]]
00E1B3  1               ;
00E1B3  1               ; At least PC must be supplied.
00E1B3  1               ; Missing trailing operands leave saved registers unchanged.
00E1B3  1               ; ------------------------------------------------------------
00E1B3  1               cmd_regedit:
00E1B3  1  20 46 E4     	jsr advance_lineptr
00E1B6  1               
00E1B6  1  20 D9 E2         jsr next_token
00E1B9  1  90 56            bcc regedit_error
00E1BB  1               
00E1BB  1  20 2A E3         jsr parse_word
00E1BE  1  A5 CE            lda T0L
00E1C0  1  8D 29 02         sta reg_pcl
00E1C3  1  A5 CF            lda T0H
00E1C5  1  8D 28 02         sta reg_pch
00E1C8  1               
00E1C8  1  20 D9 E2         jsr next_token
00E1CB  1  90 3F            bcc regedit_done
00E1CD  1               
00E1CD  1  20 1D E3         jsr parse_byte
00E1D0  1  A5 CE            lda T0L
00E1D2  1  8D 2B 02         sta reg_a
00E1D5  1               
00E1D5  1  20 D9 E2         jsr next_token
00E1D8  1  90 32            bcc regedit_done
00E1DA  1               
00E1DA  1  20 1D E3         jsr parse_byte
00E1DD  1  A5 CE            lda T0L
00E1DF  1  8D 2C 02         sta reg_x
00E1E2  1               
00E1E2  1  20 D9 E2         jsr next_token
00E1E5  1  90 25            bcc regedit_done
00E1E7  1               
00E1E7  1  20 1D E3         jsr parse_byte
00E1EA  1  A5 CE            lda T0L
00E1EC  1  8D 2D 02         sta reg_y
00E1EF  1               
00E1EF  1  20 D9 E2         jsr next_token
00E1F2  1  90 18            bcc regedit_done
00E1F4  1               
00E1F4  1  20 1D E3         jsr parse_byte
00E1F7  1  A5 CE            lda T0L
00E1F9  1  8D 2E 02         sta reg_sp
00E1FC  1               
00E1FC  1  20 D9 E2         jsr next_token
00E1FF  1  90 0B            bcc regedit_done
00E201  1               
00E201  1  20 1D E3         jsr parse_byte
00E204  1  A5 CE            lda T0L
00E206  1  8D 2A 02         sta reg_sr
00E209  1               
00E209  1  20 D9 E2         jsr next_token
00E20C  1               
00E20C  1               regedit_done:
00E20C  1  20 64 E1     	jsr show_registers
00E20F  1  18           	clc
00E210  1  60               rts
00E211  1               
00E211  1               regedit_error:
00E211  1  4C 54 E2         jmp cmd_error
00E214  1               
00E214  1               ; ------------------------------------------------------------
00E214  1               ; GO COMMAND
00E214  1               ; Syntax:
00E214  1               ;   G
00E214  1               ;   G <PC>
00E214  1               ; Restores the saved CPU image and resumes execution with RTI.
00E214  1               ; ------------------------------------------------------------
00E214  1               cmd_go:
00E214  1  20 46 E4     	jsr advance_lineptr
00E217  1  20 D9 E2         jsr next_token
00E21A  1  90 15            bcc go_now
00E21C  1               
00E21C  1  20 2A E3         jsr parse_word
00E21F  1  A5 CE            lda T0L
00E221  1  8D 29 02         sta reg_pcl
00E224  1  A5 CF            lda T0H
00E226  1  8D 28 02         sta reg_pch
00E229  1               
00E229  1  20 D9 E2         jsr next_token
00E22C  1  90 03            bcc go_now
00E22E  1  4C 54 E2         jmp cmd_error
00E231  1               
00E231  1               go_now:
00E231  1  AE 2E 02         ldx reg_sp
00E234  1  9A               txs
00E235  1  AD 28 02         lda reg_pch
00E238  1  48               pha
00E239  1  AD 29 02         lda reg_pcl
00E23C  1  48               pha
00E23D  1  AD 2A 02         lda reg_sr
00E240  1  48               pha
00E241  1  AD 2B 02         lda reg_a
00E244  1  AE 2C 02         ldx reg_x
00E247  1  AC 2D 02         ldy reg_y
00E24A  1  40               rti
00E24B  1               
00E24B  1               ; ------------------------------------------------------------
00E24B  1               ; HELP COMMAND
00E24B  1               ; ------------------------------------------------------------
00E24B  1               cmd_help:
00E24B  1  A9 76            lda #<help_text
00E24D  1  A2 EF            ldx #>help_text
00E24F  1  20 8D E2         jsr print_str
00E252  1  18           	clc
00E253  1  60           	rts
00E254  1               
00E254  1               ; ------------------------------------------------------------
00E254  1               ; ERROR HANDLER
00E254  1               ; ------------------------------------------------------------
00E254  1               cmd_error:
00E254  1  20 5D E5         jsr print_error
00E257  1  38           	sec
00E258  1  60           	rts
00E259  1               
00E259  1               ; ------------------------------------------------------------
00E259  1               ; MEMORY DUMP FORMATTERS
00E259  1               ; ------------------------------------------------------------
00E259  1               ; show 8 memory locs @R2
00E259  1               dump_line:
00E259  1  A9 3E            lda #'>'						; sync with command table
00E25B  1  20 68 E5         jsr putchar
00E25E  1  20 2E E5         jsr print_space
00E261  1               
00E261  1  A5 CA            lda R2L
00E263  1  85 CE            sta T0L
00E265  1  A5 CB            lda R2H
00E267  1  85 CF            sta T0H
00E269  1  20 CF E2         jsr print_address_T0
00E26C  1               
00E26C  1  A0 00            ldy #0
00E26E  1               dump_hex_loop:
00E26E  1  B1 CA            lda (R2L),y
00E270  1  20 FA E4         jsr print_hex8
00E273  1  20 2E E5         jsr print_space
00E276  1  C8               iny
00E277  1  C0 08            cpy #8
00E279  1  D0 F3            bne dump_hex_loop
00E27B  1               
00E27B  1  20 2E E5         jsr print_space
00E27E  1               
00E27E  1  A0 00            ldy #0
00E280  1               dump_ascii_loop:
00E280  1  B1 CA            lda (R2L),y
00E282  1  20 1E E5         jsr print_ascii
00E285  1  C8               iny
00E286  1  C0 08            cpy #8
00E288  1  D0 F6            bne dump_ascii_loop
00E28A  1  4C 33 E5         jmp newline
00E28D  1               
00E28D  1               ; ------------------------------------------------------------
00E28D  1               ; OUTPUT HELPERS
00E28D  1               ; ------------------------------------------------------------
00E28D  1               
00E28D  1               ; ------------------------------------------------------------
00E28D  1               ; STRING OUTPUT
00E28D  1               ; A = low byte, X = high byte of zero-terminated string.
00E28D  1               ; Uses T0 as the temporary string pointer.
00E28D  1               ; ------------------------------------------------------------
00E28D  1               print_str:
00E28D  1  5A               phy
00E28E  1  85 CE            sta T0L
00E290  1  86 CF            stx T0H
00E292  1  A0 00            ldy #0
00E294  1               
00E294  1               print_str_loop:
00E294  1  B1 CE            lda (T0L),y
00E296  1  F0 0B            beq print_str_done
00E298  1  20 68 E5         jsr putchar
00E29B  1  C8               iny
00E29C  1  D0 F6            bne print_str_loop
00E29E  1  E6 CF            inc T0H
00E2A0  1  4C 94 E2         jmp print_str_loop
00E2A3  1               
00E2A3  1               print_str_done:
00E2A3  1  7A               ply
00E2A4  1  60           	rts
00E2A5  1               
00E2A5  1               ; ------------------------------------------------------------
00E2A5  1               ; PRINT_STATUS_BITS
00E2A5  1               ; Print processor status as:
00E2A5  1               ;   NV-BDIZC
00E2A5  1               ; using '1' for set bits and '0' for clear bits.
00E2A5  1               ;
00E2A5  1               ; Input
00E2A5  1               ;   A = status byte
00E2A5  1               ;
00E2A5  1               ; Clobbers
00E2A5  1               ;   A, X
00E2A5  1               ; ------------------------------------------------------------
00E2A5  1               print_status_bits:
00E2A5  1  85 D6            sta tmp
00E2A7  1               
00E2A7  1  06 D6            asl tmp              ; N -> C
00E2A9  1  20 C3 E2         jsr print_bit_c
00E2AC  1               
00E2AC  1  06 D6            asl tmp              ; V -> C
00E2AE  1  20 C3 E2         jsr print_bit_c
00E2B1  1               
00E2B1  1  A9 2D            lda #'-'						 ; mmmhhhh
00E2B3  1  20 68 E5         jsr putchar
00E2B6  1               
00E2B6  1  06 D6            asl tmp              ; skip bit 5
00E2B8  1               
00E2B8  1  A2 05            ldx #5               ; B D I Z C
00E2BA  1               ps_loop:
00E2BA  1  06 D6            asl tmp              ; next bit -> C
00E2BC  1  20 C3 E2         jsr print_bit_c
00E2BF  1  CA               dex
00E2C0  1  D0 F8            bne ps_loop
00E2C2  1  60               rts
00E2C3  1               
00E2C3  1               ; ------------------------------------------------------------
00E2C3  1               ; PRINT_BIT_C
00E2C3  1               ; Print '1' if Carry set, else '0'.
00E2C3  1               ; ------------------------------------------------------------
00E2C3  1               print_bit_c:
00E2C3  1  90 05            bcc ps_zero
00E2C5  1  A9 31            lda #'1'
00E2C7  1  4C 68 E5         jmp putchar
00E2CA  1               ps_zero:
00E2CA  1  A9 30            lda #'0'
00E2CC  1  4C 68 E5         jmp putchar
00E2CF  1               
00E2CF  1               ; ------------------------------------------------------------
00E2CF  1               ; PRINT ADDRESS IN T0 + one trailing space
00E2CF  1               ; ------------------------------------------------------------
00E2CF  1               print_address_T0:
00E2CF  1  A5 CF            lda T0H
00E2D1  1  A6 CE            ldx T0L
00E2D3  1  20 15 E5         jsr print_hex16
00E2D6  1  4C 2E E5         jmp print_space
00E2D9  1               
00E2D9  1               ; ------------------------------------------------------------
00E2D9  1               ; TOKENIZER
00E2D9  1               ; Carry set   = token exists
00E2D9  1               ; Carry clear = end of line
00E2D9  1               ; ------------------------------------------------------------
00E2D9  1               next_token:
00E2D9  1  20 4D E4         jsr skip_spaces
00E2DC  1  A0 00            ldy #0
00E2DE  1  B1 C2            lda (lineptr),y
00E2E0  1  F0 02            beq token_eol
00E2E2  1  38               sec
00E2E3  1  60               rts
00E2E4  1               
00E2E4  1               token_eol:
00E2E4  1  18               clc
00E2E5  1  60               rts
00E2E6  1               
00E2E6  1               ; ------------------------------------------------------------
00E2E6  1               ; PARAMETER PARSER
00E2E6  1               ; Default base is hex.
00E2E6  1               ; Supported prefixes:
00E2E6  1               ;   $ hex
00E2E6  1               ;   + decimal
00E2E6  1               ;   % binary   (byte only)
00E2E6  1               ;   ' ASCII    (byte only)
00E2E6  1               ; Result is returned in T0, size in value_size.
00E2E6  1               ; ------------------------------------------------------------
00E2E6  1               parse_param:
00E2E6  1  20 4D E4         jsr skip_spaces
00E2E9  1  A0 00            ldy #0
00E2EB  1  B1 C2            lda (lineptr),y
00E2ED  1  F0 2B            beq param_error
00E2EF  1               
00E2EF  1  C9 24            cmp #'$'
00E2F1  1  F0 0F            beq parse_hex_pref
00E2F3  1  C9 2B            cmp #'+'
00E2F5  1  F0 11            beq parse_dec
00E2F7  1  C9 25            cmp #'%'
00E2F9  1  F0 13            beq parse_bin
00E2FB  1  C9 27            cmp #$27
00E2FD  1  F0 15            beq parse_ascii
00E2FF  1               
00E2FF  1  4C 88 E3         jmp parse_hex
00E302  1               
00E302  1               parse_hex_pref:
00E302  1  20 46 E4         jsr advance_lineptr
00E305  1  4C 88 E3         jmp parse_hex
00E308  1               
00E308  1               parse_dec:
00E308  1  20 46 E4         jsr advance_lineptr
00E30B  1  4C CF E3         jmp parse_decimal
00E30E  1               
00E30E  1               parse_bin:
00E30E  1  20 46 E4         jsr advance_lineptr
00E311  1  4C 41 E3         jmp parse_binary
00E314  1               
00E314  1               parse_ascii:
00E314  1  20 46 E4         jsr advance_lineptr
00E317  1  4C 2D E3         jmp parse_ascii_char
00E31A  1               
00E31A  1               param_error:
00E31A  1  4C 54 E2         jmp cmd_error
00E31D  1               
00E31D  1               parse_byte:
00E31D  1  20 E6 E2         jsr parse_param
00E320  1  A5 D5            lda value_size
00E322  1  C9 01            cmp #1
00E324  1  F0 03            beq parse_byte_ok
00E326  1  4C 54 E2         jmp cmd_error
00E329  1               parse_byte_ok:
00E329  1  60               rts
00E32A  1               
00E32A  1               parse_word:
00E32A  1  4C E6 E2         jmp parse_param
00E32D  1               
00E32D  1               ; ------------------------------------------------------------
00E32D  1               ; ASCII PARSER
00E32D  1               ; Syntax: 'A
00E32D  1               ; ------------------------------------------------------------
00E32D  1               parse_ascii_char:
00E32D  1  A0 00            ldy #0
00E32F  1  B1 C2            lda (lineptr),y
00E331  1  F0 0B            beq ascii_error
00E333  1  85 CE            sta T0L
00E335  1  64 CF            stz T0H
00E337  1  A9 01            lda #1
00E339  1  85 D5            sta value_size
00E33B  1  4C 46 E4         jmp advance_lineptr
00E33E  1               
00E33E  1               ascii_error:
00E33E  1  4C 54 E2         jmp cmd_error
00E341  1               
00E341  1               ; ------------------------------------------------------------
00E341  1               ; BINARY PARSER
00E341  1               ; Syntax: %10101010
00E341  1               ; Binary values are byte sized only.
00E341  1               ; ------------------------------------------------------------
00E341  1               parse_binary:
00E341  1  64 CE            stz T0L
00E343  1  64 CF            stz T0H
00E345  1  64 D6            stz tmp
00E347  1               
00E347  1               bin_loop:
00E347  1  A0 00            ldy #0
00E349  1  B1 C2            lda (lineptr),y
00E34B  1  C9 30            cmp #'0'
00E34D  1  F0 0B            beq bin_zero
00E34F  1  C9 31            cmp #'1'
00E351  1  F0 17            beq bin_one
00E353  1  C9 2D            cmp #'-'				; special case for S-register
00E355  1  F0 13            beq bin_one
00E357  1  4C 7C E3         jmp bin_done
00E35A  1               
00E35A  1               bin_zero:
00E35A  1  A5 D6            lda tmp
00E35C  1  C9 08            cmp #8
00E35E  1  B0 25            bcs bin_error
00E360  1  06 CE            asl T0L
00E362  1  20 46 E4         jsr advance_lineptr
00E365  1  E6 D6            inc tmp
00E367  1  4C 47 E3         jmp bin_loop
00E36A  1               
00E36A  1               bin_one:
00E36A  1  A5 D6            lda tmp
00E36C  1  C9 08            cmp #8
00E36E  1  B0 15            bcs bin_error
00E370  1  06 CE            asl T0L
00E372  1  E6 CE            inc T0L
00E374  1  20 46 E4         jsr advance_lineptr
00E377  1  E6 D6            inc tmp
00E379  1  4C 47 E3         jmp bin_loop
00E37C  1               
00E37C  1               bin_done:
00E37C  1  A5 D6            lda tmp
00E37E  1  F0 05            beq bin_error
00E380  1  A9 01            lda #1
00E382  1  85 D5            sta value_size
00E384  1  60               rts
00E385  1               
00E385  1               bin_error:
00E385  1  4C 54 E2         jmp cmd_error
00E388  1               
00E388  1               ; ------------------------------------------------------------
00E388  1               ; HEX PARSER
00E388  1               ; 1-2 digits => byte, 3-4 digits => word.
00E388  1               ; ------------------------------------------------------------
00E388  1               parse_hex:
00E388  1  64 CE            stz T0L
00E38A  1  64 CF            stz T0H
00E38C  1  64 D6            stz tmp
00E38E  1               
00E38E  1               hex_loop:
00E38E  1  A0 00            ldy #0
00E390  1  B1 C2            lda (lineptr),y
00E392  1  20 1D E4         jsr hex_digit
00E395  1  B0 1C            bcs hex_done
00E397  1               
00E397  1  06 CE            asl T0L
00E399  1  26 CF            rol T0H
00E39B  1  06 CE            asl T0L
00E39D  1  26 CF            rol T0H
00E39F  1  06 CE            asl T0L
00E3A1  1  26 CF            rol T0H
00E3A3  1  06 CE            asl T0L
00E3A5  1  26 CF            rol T0H
00E3A7  1               
00E3A7  1  05 CE            ora T0L
00E3A9  1  85 CE            sta T0L
00E3AB  1               
00E3AB  1  20 46 E4         jsr advance_lineptr
00E3AE  1  E6 D6            inc tmp
00E3B0  1  4C 8E E3         jmp hex_loop
00E3B3  1               
00E3B3  1               hex_done:
00E3B3  1  A5 D6            lda tmp
00E3B5  1  F0 15            beq hex_error
00E3B7  1  C9 03            cmp #3
00E3B9  1  90 07            bcc hex_byte
00E3BB  1  C9 05            cmp #5
00E3BD  1  90 08            bcc hex_word
00E3BF  1  4C 54 E2         jmp cmd_error
00E3C2  1               
00E3C2  1               hex_byte:
00E3C2  1  A9 01            lda #1
00E3C4  1  85 D5            sta value_size
00E3C6  1  60               rts
00E3C7  1               
00E3C7  1               hex_word:
00E3C7  1  A9 02            lda #2
00E3C9  1  85 D5            sta value_size
00E3CB  1  60               rts
00E3CC  1               
00E3CC  1               hex_error:
00E3CC  1  4C 54 E2         jmp cmd_error
00E3CF  1               
00E3CF  1               ; ------------------------------------------------------------
00E3CF  1               ; DECIMAL PARSER
00E3CF  1               ; Syntax: +1234
00E3CF  1               ; Uses repeated 16-bit add:
00E3CF  1               ;   T0 = T0 * 10 + digit
00E3CF  1               ; ------------------------------------------------------------
00E3CF  1               parse_decimal:
00E3CF  1  64 CE            stz T0L
00E3D1  1  64 CF            stz T0H
00E3D3  1  64 D5            stz value_size
00E3D5  1               
00E3D5  1               dec_loop:
00E3D5  1  A0 00            ldy #0
00E3D7  1  B1 C2            lda (lineptr),y
00E3D9  1  C9 30            cmp #'0'
00E3DB  1  90 2B            bcc dec_done
00E3DD  1  C9 3A            cmp #'9'+1
00E3DF  1  B0 27            bcs dec_done
00E3E1  1               
00E3E1  1  38               sec
00E3E2  1  E9 30            sbc #'0'
00E3E4  1  85 D6            sta tmp
00E3E6  1               
00E3E6  1  20 67 E4         jsr copy_T0_T1
00E3E9  1               
00E3E9  1  64 CE            stz T0L
00E3EB  1  64 CF            stz T0H
00E3ED  1  A2 0A            ldx #10
00E3EF  1               
00E3EF  1               dec_mul_loop:
00E3EF  1  20 E1 E4         jsr add_T1_T0
00E3F2  1  CA               dex
00E3F3  1  D0 FA            bne dec_mul_loop
00E3F5  1               
00E3F5  1  18               clc
00E3F6  1  A5 CE            lda T0L
00E3F8  1  65 D6            adc tmp
00E3FA  1  85 CE            sta T0L
00E3FC  1  90 02            bcc dec_next
00E3FE  1  E6 CF            inc T0H
00E400  1               
00E400  1               dec_next:
00E400  1  20 46 E4         jsr advance_lineptr
00E403  1  E6 D5            inc value_size
00E405  1  4C D5 E3         jmp dec_loop
00E408  1               
00E408  1               dec_done:
00E408  1  A5 D5            lda value_size
00E40A  1  F0 0E            beq dec_error
00E40C  1  A5 CF            lda T0H
00E40E  1  F0 05            beq dec_byte
00E410  1  A9 02            lda #2
00E412  1  85 D5            sta value_size
00E414  1  60               rts
00E415  1               
00E415  1               dec_byte:
00E415  1  A9 01            lda #1
00E417  1  85 D5            sta value_size
00E419  1  60               rts
00E41A  1               
00E41A  1               dec_error:
00E41A  1  4C 54 E2         jmp cmd_error
00E41D  1               
00E41D  1               ; ------------------------------------------------------------
00E41D  1               ; HEX_DIGIT
00E41D  1               ; Convert ASCII hex digit to value 0..15.
00E41D  1               ;
00E41D  1               ; Input
00E41D  1               ;   A = ASCII character
00E41D  1               ;
00E41D  1               ; Output
00E41D  1               ;   A = digit value
00E41D  1               ;   C = 0 valid digit
00E41D  1               ;   C = 1 invalid digit
00E41D  1               ; ------------------------------------------------------------
00E41D  1               hex_digit:
00E41D  1  C9 30            cmp #'0'
00E41F  1  90 23            bcc hex_bad
00E421  1  C9 3A            cmp #'9'+1
00E423  1  90 1A            bcc hex_num
00E425  1               
00E425  1  C9 41            cmp #'A'
00E427  1  90 04            bcc hex_lower
00E429  1  C9 47            cmp #'F'+1
00E42B  1  90 0D            bcc hex_upper
00E42D  1               
00E42D  1               hex_lower:
00E42D  1  C9 61            cmp #'a'
00E42F  1  90 13            bcc hex_bad
00E431  1  C9 67            cmp #'f'+1
00E433  1  B0 0F            bcs hex_bad
00E435  1  38               sec
00E436  1  E9 57            sbc #'a'-10
00E438  1  18               clc
00E439  1  60               rts
00E43A  1               
00E43A  1               hex_upper:
00E43A  1  38               sec
00E43B  1  E9 37            sbc #'A'-10
00E43D  1  18               clc
00E43E  1  60               rts
00E43F  1               
00E43F  1               hex_num:
00E43F  1  38               sec
00E440  1  E9 30            sbc #'0'
00E442  1  18               clc
00E443  1  60               rts
00E444  1               
00E444  1               hex_bad:
00E444  1  38               sec
00E445  1  60               rts
00E446  1               
00E446  1               ; ------------------------------------------------------------
00E446  1               ; TEXT POINTER HELPERS
00E446  1               ; ------------------------------------------------------------
00E446  1               advance_lineptr:
00E446  1  E6 C2            inc lineptr
00E448  1  D0 02            bne ptr_done
00E44A  1  E6 C3            inc lineptr+1
00E44C  1               ptr_done:
00E44C  1  60               rts
00E44D  1               
00E44D  1               skip_spaces:
00E44D  1  A0 00            ldy #0
00E44F  1  B1 C2            lda (lineptr),y
00E451  1  C9 20            cmp #' '
00E453  1  D0 06            bne skip_done
00E455  1  20 46 E4         jsr advance_lineptr
00E458  1  4C 4D E4         jmp skip_spaces
00E45B  1               
00E45B  1               skip_done:
00E45B  1  60               rts
00E45C  1               
00E45C  1               toupper:
00E45C  1  C9 61            cmp #'a'
00E45E  1  90 06            bcc upper_done
00E460  1  C9 7B            cmp #'z'+1
00E462  1  B0 02            bcs upper_done
00E464  1  29 DF            and #%11011111
00E466  1               upper_done:
00E466  1  60               rts
00E467  1               
00E467  1               ; ------------------------------------------------------------
00E467  1               ; 16-bit register / monitor pointer primitives
00E467  1               ; ------------------------------------------------------------
00E467  1               copy_T0_T1:
00E467  1  A5 CE            lda T0L
00E469  1  85 D0            sta T1L
00E46B  1  A5 CF            lda T0H
00E46D  1  85 D1            sta T1H
00E46F  1  60               rts
00E470  1               
00E470  1               copy_T0_R0:
00E470  1  A5 CE            lda T0L
00E472  1  85 C6            sta R0L
00E474  1  A5 CF            lda T0H
00E476  1  85 C7            sta R0H
00E478  1  60               rts
00E479  1               
00E479  1               copy_T0_R1:
00E479  1  A5 CE            lda T0L
00E47B  1  85 C8            sta R1L
00E47D  1  A5 CF            lda T0H
00E47F  1  85 C9            sta R1H
00E481  1  60               rts
00E482  1               
00E482  1               copy_R0_R1:
00E482  1  A5 C6            lda R0L
00E484  1  85 C8            sta R1L
00E486  1  A5 C7            lda R0H
00E488  1  85 C9            sta R1H
00E48A  1  60               rts
00E48B  1               
00E48B  1               copy_R0_R2:
00E48B  1  A5 C6            lda R0L
00E48D  1  85 CA            sta R2L
00E48F  1  A5 C7            lda R0H
00E491  1  85 CB            sta R2H
00E493  1  60               rts
00E494  1               
00E494  1               copy_MEM_R0:
00E494  1  A5 D2            lda MEML
00E496  1  85 C6            sta R0L
00E498  1  A5 D3            lda MEMH
00E49A  1  85 C7            sta R0H
00E49C  1  60               rts
00E49D  1               
00E49D  1               copy_R2_MEM:
00E49D  1  A5 CA            lda R2L
00E49F  1  85 D2            sta MEML
00E4A1  1  A5 CB            lda R2H
00E4A3  1  85 D3            sta MEMH
00E4A5  1  60               rts
00E4A6  1               
00E4A6  1               inc_R0:
00E4A6  1  E6 C6            inc R0L
00E4A8  1  D0 02            bne inc_r0_done
00E4AA  1  E6 C7            inc R0H
00E4AC  1               inc_r0_done:
00E4AC  1  60               rts
00E4AD  1               
00E4AD  1               inc_R2:
00E4AD  1  E6 CA            inc R2L
00E4AF  1  D0 02            bne inc_r2_done
00E4B1  1  E6 CB            inc R2H
00E4B3  1               inc_r2_done:
00E4B3  1  60               rts
00E4B4  1               
00E4B4  1               add_R0_A:
00E4B4  1  18               clc
00E4B5  1  65 C6            adc R0L
00E4B7  1  85 C6            sta R0L
00E4B9  1  90 04            bcc add_r0_no_wrap
00E4BB  1  E6 C7            inc R0H
00E4BD  1  F0 02            beq add_r0_wrap
00E4BF  1               add_r0_no_wrap:
00E4BF  1  18               clc
00E4C0  1  60               rts
00E4C1  1               add_r0_wrap:
00E4C1  1  38               sec
00E4C2  1  60               rts
00E4C3  1               
00E4C3  1               add_R1_A:
00E4C3  1  18               clc
00E4C4  1  65 C8            adc R1L
00E4C6  1  85 C8            sta R1L
00E4C8  1  90 04            bcc add_r1_no_wrap
00E4CA  1  E6 C9            inc R1H
00E4CC  1  F0 02            beq add_r1_wrap
00E4CE  1               add_r1_no_wrap:
00E4CE  1  18               clc
00E4CF  1  60               rts
00E4D0  1               add_r1_wrap:
00E4D0  1  38               sec
00E4D1  1  60               rts
00E4D2  1               
00E4D2  1               ; ------------------------------------------------------------
00E4D2  1               ; ADD_R2_A
00E4D2  1               ; Add unsigned byte in A to 16-bit register R2.
00E4D2  1               ;
00E4D2  1               ; Returns:
00E4D2  1               ;   C = 1 only if 16-bit wrap occurred ($FFFF -> $0000)
00E4D2  1               ;   C = 0 otherwise
00E4D2  1               ; ------------------------------------------------------------
00E4D2  1               add_R2_A:
00E4D2  1  18               clc
00E4D3  1  65 CA            adc R2L
00E4D5  1  85 CA            sta R2L
00E4D7  1  90 04            bcc add_r2_no_wrap
00E4D9  1               
00E4D9  1  E6 CB            inc R2H
00E4DB  1  F0 02            beq add_r2_wrap
00E4DD  1               
00E4DD  1               add_r2_no_wrap:
00E4DD  1  18               clc
00E4DE  1  60               rts
00E4DF  1               
00E4DF  1               add_r2_wrap:
00E4DF  1  38               sec
00E4E0  1  60               rts
00E4E1  1               
00E4E1  1               add_T1_T0:
00E4E1  1  18               clc
00E4E2  1  A5 CE            lda T0L
00E4E4  1  65 D0            adc T1L
00E4E6  1  85 CE            sta T0L
00E4E8  1  A5 CF            lda T0H
00E4EA  1  65 D1            adc T1H
00E4EC  1  85 CF            sta T0H
00E4EE  1  60               rts
00E4EF  1               
00E4EF  1               cmp_R2_R1:
00E4EF  1  A5 CB            lda R2H
00E4F1  1  C5 C9            cmp R1H
00E4F3  1  D0 04            bne cmp_r2_r1_done
00E4F5  1  A5 CA            lda R2L
00E4F7  1  C5 C8            cmp R1L
00E4F9  1               cmp_r2_r1_done:
00E4F9  1  60               rts
00E4FA  1               
00E4FA  1               ;------------------------------------------------
00E4FA  1               print_hex8:
00E4FA  1  48               pha
00E4FB  1  4A               lsr
00E4FC  1  4A               lsr
00E4FD  1  4A               lsr
00E4FE  1  4A               lsr
00E4FF  1  20 05 E5         jsr print_hex_digit
00E502  1  68               pla
00E503  1  29 0F            and #$0F
00E505  1               
00E505  1               print_hex_digit:
00E505  1  C9 0A            cmp #10
00E507  1  90 06            bcc print_hex_num
00E509  1  18               clc
00E50A  1  69 37            adc #'A'-10
00E50C  1  4C 68 E5         jmp putchar
00E50F  1               
00E50F  1               print_hex_num:
00E50F  1  18               clc
00E510  1  69 30            adc #'0'
00E512  1  4C 68 E5         jmp putchar
00E515  1               
00E515  1               ; ------------------------------------------------------------
00E515  1               ; PRINT_HEX16
00E515  1               ; Print 16-bit value in hexadecimal.
00E515  1               ;
00E515  1               ; Input
00E515  1               ;   A = high byte
00E515  1               ;   X = low byte
00E515  1               ; ------------------------------------------------------------
00E515  1               print_hex16:
00E515  1  DA               phx
00E516  1  20 FA E4         jsr print_hex8
00E519  1  FA               plx
00E51A  1  8A               txa
00E51B  1  4C FA E4         jmp print_hex8
00E51E  1               
00E51E  1               
00E51E  1               print_ascii:
00E51E  1  C9 20            cmp #$20
00E520  1  90 07            bcc ascii_dot
00E522  1  C9 7F            cmp #$7F
00E524  1  B0 03            bcs ascii_dot
00E526  1  4C 68 E5         jmp putchar
00E529  1               
00E529  1               
00E529  1               ascii_dot:
00E529  1  A9 2E            lda #'.'
00E52B  1  4C 68 E5         jmp putchar
00E52E  1               
00E52E  1               print_space:
00E52E  1  A9 20            lda #' '
00E530  1  4C 68 E5         jmp putchar
00E533  1               
00E533  1               newline:
00E533  1  A9 0D            lda #$0D
00E535  1  4C 68 E5         jmp putchar
00E538  1               
00E538  1               print_prompt:
00E538  1  A9 72        		lda #<prompt_text
00E53A  1  A2 EF            ldx #>prompt_text
00E53C  1  4C 8D E2         jmp print_str
00E53F  1               
00E53F  1               ; ------------------------------------------------------------
00E53F  1               ; GETLINE
00E53F  1               ; Read a line from input into linebuf.
00E53F  1               ;
00E53F  1               ; Assumptions
00E53F  1               ; - host terminal performs line editing
00E53F  1               ; - CR (0x0D) terminates the line
00E53F  1               ; - line is zero terminated
00E53F  1               ; - max length = 127 characters
00E53F  1               ; ------------------------------------------------------------
00E53F  1               getline:
00E53F  1  A2 00            ldx #0
00E541  1               
00E541  1               getline_loop:
00E541  1  20 65 E5         jsr getchar
00E544  1  C9 0D            cmp #$0D
00E546  1  F0 0F            beq getline_done
00E548  1  C9 0A            cmp #$0A
00E54A  1  F0 0B            beq getline_done
00E54C  1               
00E54C  1  E0 3B            cpx #59
00E54E  1  B0 F1            bcs getline_loop
00E550  1               
00E550  1  9D 00 02         sta linebuf,x
00E553  1  E8               inx
00E554  1  4C 41 E5         jmp getline_loop
00E557  1               
00E557  1               getline_done:
00E557  1  A9 00            lda #0
00E559  1  9D 00 02         sta linebuf,x
00E55C  1  60               rts
00E55D  1               
00E55D  1               print_error:
00E55D  1  A9 3F        	lda #'?'
00E55F  1  20 68 E5     	jsr putchar
00E562  1  4C 33 E5     	jmp newline
00E565  1               
00E565  1               ; ------------------------------------------------------------
00E565  1               ; I/O
00E565  1               ; ------------------------------------------------------------
00E565  1               getchar:
00E565  1  4C 00 F0     	jmp BIOS_INCHAR
00E568  1               
00E568  1               putchar:
00E568  1  4C 03 F0         jmp BIOS_OUTCHAR
00E56B  1               
00E56B  1               ; ------------------------------------------------------------
00E56B  1               ; CHECK_ABORT
00E56B  1               ; Test if the user pressed ^C.
00E56B  1               ;
00E56B  1               ; Returns
00E56B  1               ;   C = 1  abort requested
00E56B  1               ;   C = 0  continue
00E56B  1               ;
00E56B  1               ; Wrapper around BIOS_STPKEY so the monitor depends only on
00E56B  1               ; this primitive instead of calling the BIOS everywhere.
00E56B  1               ; ------------------------------------------------------------
00E56B  1               check_abort:
00E56B  1  4C 09 F0         jmp BIOS_STPKEY
00E56E  1               
00E56E  1               ; command implementations
00E56E  1               .include "disasm.asm"
00E56E  2               ; ------------------------------------------------------------
00E56E  2               ; DISASSEMBLER COMMAND
00E56E  2               ; Syntax:
00E56E  2               ;   D
00E56E  2               ;   D start
00E56E  2               ;   D start end
00E56E  2               ;
00E56E  2               ; Default start is MEM.
00E56E  2               ; Default length is 12 instructions.
00E56E  2               ; MEM is updated to the next address after the disassembly.
00E56E  2               ; ------------------------------------------------------------
00E56E  2               cmd_disasm:
00E56E  2  20 46 E4         jsr advance_lineptr
00E571  2  20 D9 E2         jsr next_token
00E574  2  90 14            bcc dis_default
00E576  2               
00E576  2  20 2A E3         jsr parse_word
00E579  2  20 70 E4         jsr copy_T0_R0
00E57C  2               
00E57C  2  20 D9 E2         jsr next_token
00E57F  2  90 0C            bcc dis_one_param
00E581  2               
00E581  2  20 2A E3         jsr parse_word
00E584  2  20 79 E4         jsr copy_T0_R1
00E587  2  4C 97 E5         jmp dis_prepare_range
00E58A  2               
00E58A  2               dis_default:
00E58A  2  20 94 E4         jsr copy_MEM_R0
00E58D  2               
00E58D  2               dis_one_param:
00E58D  2  20 82 E4         jsr copy_R0_R1
00E590  2  A9 0C            lda #12
00E592  2  85 D4            sta parm_count
00E594  2  4C 9F E5         jmp dis_prepare_count
00E597  2               
00E597  2               dis_prepare_range:
00E597  2  20 D9 E2         jsr next_token
00E59A  2  90 21            bcc dis_range_ok
00E59C  2  4C 54 E2         jmp cmd_error
00E59F  2               
00E59F  2               dis_prepare_count:
00E59F  2  20 D9 E2         jsr next_token
00E5A2  2  90 03            bcc dis_count_ok
00E5A4  2  4C 54 E2         jmp cmd_error
00E5A7  2               
00E5A7  2               dis_count_ok:
00E5A7  2  20 8B E4         jsr copy_R0_R2
00E5AA  2               
00E5AA  2               dis_loop_count:
00E5AA  2  20 6B E5         jsr check_abort
00E5AD  2  B0 2D            bcs dis_abort
00E5AF  2  20 DF E5         jsr disasm_line
00E5B2  2  B0 23            bcs dis_done
00E5B4  2  C6 D4            dec parm_count
00E5B6  2  D0 F2            bne dis_loop_count
00E5B8  2  20 9D E4         jsr copy_R2_MEM
00E5BB  2  18           		clc
00E5BC  2  60           		rts
00E5BD  2               
00E5BD  2               dis_range_ok:
00E5BD  2  20 8B E4         jsr copy_R0_R2
00E5C0  2               
00E5C0  2               dis_loop_range:
00E5C0  2  20 6B E5         jsr check_abort
00E5C3  2  B0 17            bcs dis_abort
00E5C5  2               
00E5C5  2  20 EF E4         jsr cmp_R2_R1
00E5C8  2  90 05            bcc dis_do_line
00E5CA  2  F0 03            beq dis_do_line
00E5CC  2  4C D7 E5         jmp dis_done
00E5CF  2               
00E5CF  2               dis_do_line:
00E5CF  2  20 DF E5         jsr disasm_line
00E5D2  2  B0 03            bcs dis_done
00E5D4  2  4C C0 E5         jmp dis_loop_range
00E5D7  2               
00E5D7  2               dis_done:
00E5D7  2  20 9D E4         jsr copy_R2_MEM
00E5DA  2  18           		clc
00E5DB  2  60           		rts
00E5DC  2               
00E5DC  2               dis_abort:
00E5DC  2  4C 54 E2         jmp cmd_error
00E5DF  2               
00E5DF  2               ; ------------------------------------------------------------
00E5DF  2               ; DISASSEMBLE ONE LINE
00E5DF  2               ;
00E5DF  2               ; Input
00E5DF  2               ;   R2 = current PC
00E5DF  2               ;
00E5DF  2               ; Internal use
00E5DF  2               ;   T0L = opcode
00E5DF  2               ;   R3L = addressing mode
00E5DF  2               ;   R3H = instruction length
00E5DF  2               ;   T1  = pointer to mnemonic string
00E5DF  2               ;
00E5DF  2               ; Output
00E5DF  2               ;   prints one disassembly line
00E5DF  2               ;   advances R2 by instruction length
00E5DF  2               ; ------------------------------------------------------------
00E5DF  2               disasm_line:
00E5DF  2  20 10 E6         jsr print_disasm_address
00E5E2  2               
00E5E2  2  A0 00            ldy #0
00E5E4  2  B1 CA            lda (R2L),y
00E5E6  2  85 CE            sta T0L
00E5E8  2  AA               tax
00E5E9  2               
00E5E9  2  BD 51 EC         lda mode_table,x
00E5EC  2  85 CC            sta R3L
00E5EE  2  20 81 E8         jsr get_oplen_from_mode
00E5F1  2  85 CD            sta R3H
00E5F3  2               
00E5F3  2  20 6B E8         jsr get_mnemonic_id_x
00E5F6  2  20 6F E8         jsr get_mnemonic_ptr_id
00E5F9  2               
00E5F9  2  20 1D E6         jsr print_disasm_bytes
00E5FC  2  20 2E E5         jsr print_space
00E5FF  2  20 2E E5         jsr print_space
00E602  2  20 4D E6         jsr print_mnemonic
00E605  2  20 57 E6         jsr print_operand
00E608  2  20 33 E5         jsr newline
00E60B  2               
00E60B  2  A5 CD            lda R3H
00E60D  2  4C D2 E4         jmp add_R2_A
00E610  2               
00E610  2               print_disasm_address:
00E610  2  A5 CB            lda R2H
00E612  2  A6 CA            ldx R2L
00E614  2  20 15 E5         jsr print_hex16
00E617  2  20 2E E5         jsr print_space
00E61A  2  4C 2E E5         jmp print_space
00E61D  2               
00E61D  2               ; ------------------------------------------------------------
00E61D  2               ; PRINT RAW BYTES FIELD
00E61D  2               ; Shows 1..3 actual instruction bytes and pads to fixed width.
00E61D  2               ; R3H = instruction length
00E61D  2               ; ------------------------------------------------------------
00E61D  2               print_disasm_bytes:
00E61D  2  A0 00            ldy #0
00E61F  2               
00E61F  2               pdb_real_loop:
00E61F  2  C4 CD            cpy R3H
00E621  2  F0 0E            beq pdb_pad
00E623  2  B1 CA            lda (R2L),y
00E625  2  20 FA E4         jsr print_hex8
00E628  2  20 2E E5         jsr print_space
00E62B  2  C8               iny
00E62C  2  C0 03            cpy #3
00E62E  2  D0 EF            bne pdb_real_loop
00E630  2  60               rts
00E631  2               
00E631  2               pdb_pad:
00E631  2  C0 03            cpy #3
00E633  2  F0 11            beq pdb_done
00E635  2  A9 20            lda #' '
00E637  2  20 68 E5         jsr putchar
00E63A  2  A9 20            lda #' '
00E63C  2  20 68 E5         jsr putchar
00E63F  2  20 2E E5         jsr print_space
00E642  2  C8               iny
00E643  2  4C 31 E6         jmp pdb_pad
00E646  2               
00E646  2               pdb_done:
00E646  2  60               rts
00E647  2               
00E647  2               ; ------------------------------------------------------------
00E647  2               ; GAP BETWEEN BYTE FIELD AND MNEMONIC
00E647  2               ; ------------------------------------------------------------
00E647  2               print_disasm_gap:
00E647  2  20 2E E5         jsr print_space
00E64A  2  4C 2E E5         jmp print_space
00E64D  2               
00E64D  2               ; ------------------------------------------------------------
00E64D  2               ; PRINT MNEMONIC

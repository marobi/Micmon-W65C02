00E516  1               
00E516  1               ; ------------------------------------------------------------
00E516  1               ; CHECK_ABORT
00E516  1               ; Test if the user pressed ^C.
00E516  1               ;
00E516  1               ; Returns
00E516  1               ;   C = 1  abort requested
00E516  1               ;   C = 0  continue
00E516  1               ;
00E516  1               ; Wrapper around BIOS_STPKEY so the monitor depends only on
00E516  1               ; this primitive instead of calling the BIOS everywhere.
00E516  1               ; ------------------------------------------------------------
00E516  1               check_abort:
00E516  1  4C 09 F0         jmp BIOS_STPKEY
00E519  1               
00E519  1               ; ------------------------------------------------------------
00E519  1               ; GETLINE
00E519  1               ; Read a line from input into linebuf.
00E519  1               ;
00E519  1               ; Assumptions
00E519  1               ; - host terminal performs line editing
00E519  1               ; - CR (0x0D) terminates the line
00E519  1               ; - line is zero terminated
00E519  1               ; - max length = 127 characters
00E519  1               ; ------------------------------------------------------------
00E519  1               getline:
00E519  1  A2 00            ldx #0
00E51B  1               
00E51B  1               getline_loop:
00E51B  1  20 10 E5         jsr getchar
00E51E  1  C9 0D            cmp #$0D
00E520  1  F0 0F            beq getline_done
00E522  1  C9 0A            cmp #$0A
00E524  1  F0 0B            beq getline_done
00E526  1               
00E526  1  E0 3B            cpx #59
00E528  1  B0 F1            bcs getline_loop
00E52A  1               
00E52A  1  9D 00 02         sta linebuf,x
00E52D  1  E8               inx
00E52E  1  4C 1B E5         jmp getline_loop
00E531  1               
00E531  1               getline_done:
00E531  1  A9 00            lda #0
00E533  1  9D 00 02         sta linebuf,x
00E536  1  60               rts
00E537  1               
00E537  1               print_error:
00E537  1  A9 3F        		lda #'?'
00E539  1  20 13 E5     		jsr putchar
00E53C  1  4C 04 E5     		jmp newline
00E53F  1               
00E53F  1               ; command implementations
00E53F  1               .include "disasm.asm"
00E53F  2               ; ------------------------------------------------------------
00E53F  2               ; DISASSEMBLER COMMAND
00E53F  2               ; Syntax:
00E53F  2               ;   D
00E53F  2               ;   D start
00E53F  2               ;   D start end
00E53F  2               ;
00E53F  2               ; Default start is MEM.
00E53F  2               ; Default length is 12 instructions.
00E53F  2               ; MEM is updated to the next address after the disassembly.
00E53F  2               ; ------------------------------------------------------------
00E53F  2               cmd_disasm:
00E53F  2  20 17 E4         jsr advance_lineptr
00E542  2  20 AA E2         jsr next_token
00E545  2  90 14            bcc dis_default
00E547  2               
00E547  2  20 FB E2         jsr parse_word
00E54A  2  20 41 E4         jsr copy_T0_R0
00E54D  2               
00E54D  2  20 AA E2         jsr next_token
00E550  2  90 0C            bcc dis_one_param
00E552  2               
00E552  2  20 FB E2         jsr parse_word
00E555  2  20 4A E4         jsr copy_T0_R1
00E558  2  4C 68 E5         jmp dis_prepare_range
00E55B  2               
00E55B  2               dis_default:
00E55B  2  20 65 E4         jsr copy_MEM_R0
00E55E  2               
00E55E  2               dis_one_param:
00E55E  2  20 53 E4         jsr copy_R0_R1
00E561  2  A9 0C            lda #12
00E563  2  85 D4            sta parm_count
00E565  2  4C 70 E5         jmp dis_prepare_count
00E568  2               
00E568  2               dis_prepare_range:
00E568  2  20 AA E2         jsr next_token
00E56B  2  90 21            bcc dis_range_ok
00E56D  2  4C 28 E2         jmp cmd_error
00E570  2               
00E570  2               dis_prepare_count:
00E570  2  20 AA E2         jsr next_token
00E573  2  90 03            bcc dis_count_ok
00E575  2  4C 28 E2         jmp cmd_error
00E578  2               
00E578  2               dis_count_ok:
00E578  2  20 5C E4         jsr copy_R0_R2
00E57B  2               
00E57B  2               dis_loop_count:
00E57B  2  20 16 E5         jsr check_abort
00E57E  2  B0 2D            bcs dis_abort
00E580  2  20 B0 E5         jsr disasm_line
00E583  2  B0 23            bcs dis_done
00E585  2  C6 D4            dec parm_count
00E587  2  D0 F2            bne dis_loop_count
00E589  2  20 6E E4         jsr copy_R2_MEM
00E58C  2  18           		clc
00E58D  2  60           		rts
00E58E  2               
00E58E  2               dis_range_ok:
00E58E  2  20 5C E4         jsr copy_R0_R2
00E591  2               
00E591  2               dis_loop_range:
00E591  2  20 16 E5         jsr check_abort
00E594  2  B0 17            bcs dis_abort
00E596  2               
00E596  2  20 C0 E4         jsr cmp_R2_R1
00E599  2  90 05            bcc dis_do_line
00E59B  2  F0 03            beq dis_do_line
00E59D  2  4C A8 E5         jmp dis_done
00E5A0  2               
00E5A0  2               dis_do_line:
00E5A0  2  20 B0 E5         jsr disasm_line
00E5A3  2  B0 03            bcs dis_done
00E5A5  2  4C 91 E5         jmp dis_loop_range
00E5A8  2               
00E5A8  2               dis_done:
00E5A8  2  20 6E E4         jsr copy_R2_MEM
00E5AB  2  18           		clc
00E5AC  2  60           		rts
00E5AD  2               
00E5AD  2               dis_abort:
00E5AD  2  4C 28 E2         jmp cmd_error
00E5B0  2               
00E5B0  2               ; ------------------------------------------------------------
00E5B0  2               ; DISASSEMBLE ONE LINE
00E5B0  2               ;
00E5B0  2               ; Input
00E5B0  2               ;   R2 = current PC
00E5B0  2               ;
00E5B0  2               ; Internal use
00E5B0  2               ;   T0L = opcode
00E5B0  2               ;   R3L = addressing mode
00E5B0  2               ;   R3H = instruction length
00E5B0  2               ;   T1  = pointer to mnemonic string
00E5B0  2               ;
00E5B0  2               ; Output
00E5B0  2               ;   prints one disassembly line
00E5B0  2               ;   advances R2 by instruction length
00E5B0  2               ; ------------------------------------------------------------
00E5B0  2               disasm_line:
00E5B0  2  20 E1 E5         jsr print_disasm_address
00E5B3  2               
00E5B3  2  A0 00            ldy #0
00E5B5  2  B1 CA            lda (R2L),y
00E5B7  2  85 CE            sta T0L
00E5B9  2  AA               tax
00E5BA  2               
00E5BA  2  BD 22 EC         lda mode_table,x
00E5BD  2  85 CC            sta R3L
00E5BF  2  20 52 E8         jsr get_oplen_from_mode
00E5C2  2  85 CD            sta R3H
00E5C4  2               
00E5C4  2  20 3C E8         jsr get_mnemonic_id_x
00E5C7  2  20 40 E8         jsr get_mnemonic_ptr_id
00E5CA  2               
00E5CA  2  20 EE E5         jsr print_disasm_bytes
00E5CD  2  20 FF E4         jsr print_space
00E5D0  2  20 FF E4         jsr print_space
00E5D3  2  20 1E E6         jsr print_mnemonic
00E5D6  2  20 28 E6         jsr print_operand
00E5D9  2  20 04 E5         jsr newline
00E5DC  2               
00E5DC  2  A5 CD            lda R3H
00E5DE  2  4C A3 E4         jmp add_R2_A
00E5E1  2               
00E5E1  2               print_disasm_address:
00E5E1  2  A5 CB            lda R2H
00E5E3  2  A6 CA            ldx R2L
00E5E5  2  20 E6 E4         jsr print_hex16
00E5E8  2  20 FF E4         jsr print_space
00E5EB  2  4C FF E4         jmp print_space
00E5EE  2               
00E5EE  2               ; ------------------------------------------------------------
00E5EE  2               ; PRINT RAW BYTES FIELD
00E5EE  2               ; Shows 1..3 actual instruction bytes and pads to fixed width.
00E5EE  2               ; R3H = instruction length
00E5EE  2               ; ------------------------------------------------------------
00E5EE  2               print_disasm_bytes:
00E5EE  2  A0 00            ldy #0
00E5F0  2               
00E5F0  2               pdb_real_loop:
00E5F0  2  C4 CD            cpy R3H
00E5F2  2  F0 0E            beq pdb_pad
00E5F4  2  B1 CA            lda (R2L),y
00E5F6  2  20 CB E4         jsr print_hex8
00E5F9  2  20 FF E4         jsr print_space
00E5FC  2  C8               iny
00E5FD  2  C0 03            cpy #3
00E5FF  2  D0 EF            bne pdb_real_loop
00E601  2  60               rts
00E602  2               
00E602  2               pdb_pad:
00E602  2  C0 03            cpy #3
00E604  2  F0 11            beq pdb_done
00E606  2  A9 20            lda #' '
00E608  2  20 13 E5         jsr putchar
00E60B  2  A9 20            lda #' '
00E60D  2  20 13 E5         jsr putchar
00E610  2  20 FF E4         jsr print_space
00E613  2  C8               iny
00E614  2  4C 02 E6         jmp pdb_pad
00E617  2               
00E617  2               pdb_done:
00E617  2  60               rts
00E618  2               
00E618  2               ; ------------------------------------------------------------
00E618  2               ; GAP BETWEEN BYTE FIELD AND MNEMONIC
00E618  2               ; ------------------------------------------------------------
00E618  2               print_disasm_gap:
00E618  2  20 FF E4         jsr print_space
00E61B  2  4C FF E4         jmp print_space
00E61E  2               
00E61E  2               ; ------------------------------------------------------------
00E61E  2               ; PRINT MNEMONIC
00E61E  2               ; T1 = pointer to zero-terminated mnemonic string
00E61E  2               ; ------------------------------------------------------------
00E61E  2               print_mnemonic:
00E61E  2  A5 D0            lda T1L
00E620  2  A6 D1            ldx T1H
00E622  2  20 5E E2         jsr print_str
00E625  2  4C FF E4         jmp print_space
00E628  2               
00E628  2               ; ------------------------------------------------------------
00E628  2               ; PRINT OPERAND
00E628  2               ; R3L = addressing mode
00E628  2               ; R2  = current instruction address
00E628  2               ; ------------------------------------------------------------
00E628  2               print_operand:
00E628  2  A5 CC            lda R3L
00E62A  2  0A               asl
00E62B  2  AA               tax
00E62C  2  BD 8B E7         lda operand_vecs,x
00E62F  2  85 C4            sta jmpvec
00E631  2  E8               inx
00E632  2  BD 8B E7         lda operand_vecs,x
00E635  2  85 C5            sta jmpvec+1
00E637  2  6C C4 00         jmp (jmpvec)
00E63A  2               
00E63A  2               ; ------------------------------------------------------------
00E63A  2               ; ADDRESSING MODE FORMATTERS
00E63A  2               ; ------------------------------------------------------------
00E63A  2               fmt_imp:
00E63A  2  60               rts
00E63B  2               
00E63B  2               fmt_acc:
00E63B  2  20 FF E4         jsr print_space
00E63E  2  A9 41            lda #'A'
00E640  2  4C 13 E5         jmp putchar
00E643  2               
00E643  2               fmt_imm:
00E643  2  A9 23            lda #'#'
00E645  2  20 13 E5         jsr putchar
00E648  2  A9 24            lda #'$'
00E64A  2  20 13 E5         jsr putchar
00E64D  2  A0 01            ldy #1
00E64F  2  B1 CA            lda (R2L),y
00E651  2  4C CB E4         jmp print_hex8
00E654  2               
00E654  2               fmt_zp:
00E654  2  20 FF E4         jsr print_space
00E657  2               fmt_zp2:
00E657  2  A9 24            lda #'$'
00E659  2  20 13 E5         jsr putchar
00E65C  2  A0 01            ldy #1
00E65E  2  B1 CA            lda (R2L),y

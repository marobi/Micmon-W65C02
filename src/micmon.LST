00E4F0  1  4C 02 E5         jmp putchar
00E4F3  1               
00E4F3  1               newline:
00E4F3  1  A9 0D            lda #$0D
00E4F5  1               ;    jsr putchar
00E4F5  1               ;    lda #$0A
00E4F5  1  4C 02 E5         jmp putchar
00E4F8  1               
00E4F8  1               print_prompt:
00E4F8  1  A9 47        		lda #<prompt_text
00E4FA  1  A2 EF            ldx #>prompt_text
00E4FC  1  4C 5C E2         jmp print_str
00E4FF  1               
00E4FF  1               ; ------------------------------------------------------------
00E4FF  1               ; I/O
00E4FF  1               ; ------------------------------------------------------------
00E4FF  1               getchar
00E4FF  1  4C 00 FE     		jmp BIOS_INCHAR
00E502  1               
00E502  1               putchar:
00E502  1  4C 03 FE         jmp BIOS_OUTCHAR
00E505  1               
00E505  1               ; ------------------------------------------------------------
00E505  1               ; CHECK_ABORT
00E505  1               ; Test if the user pressed ^C.
00E505  1               ;
00E505  1               ; Returns
00E505  1               ;   C = 1  abort requested
00E505  1               ;   C = 0  continue
00E505  1               ;
00E505  1               ; Wrapper around BIOS_STPKEY so the monitor depends only on
00E505  1               ; this primitive instead of calling the BIOS everywhere.
00E505  1               ; ------------------------------------------------------------
00E505  1               check_abort:
00E505  1  4C 09 FE         jmp BIOS_STPKEY
00E508  1               
00E508  1               ; ------------------------------------------------------------
00E508  1               ; GETLINE
00E508  1               ; Read a line from input into linebuf.
00E508  1               ;
00E508  1               ; Assumptions
00E508  1               ; - host terminal performs line editing
00E508  1               ; - CR (0x0D) terminates the line
00E508  1               ; - line is zero terminated
00E508  1               ; - max length = 127 characters
00E508  1               ; ------------------------------------------------------------
00E508  1               getline:
00E508  1  A2 00            ldx #0
00E50A  1               
00E50A  1               getline_loop:
00E50A  1  20 FF E4         jsr getchar
00E50D  1  C9 0D            cmp #$0D
00E50F  1  F0 0F            beq getline_done
00E511  1  C9 0A            cmp #$0A
00E513  1  F0 0B            beq getline_done
00E515  1               
00E515  1  E0 3B            cpx #59
00E517  1  B0 F1            bcs getline_loop
00E519  1               
00E519  1  9D 00 02         sta linebuf,x
00E51C  1  E8               inx
00E51D  1  4C 0A E5         jmp getline_loop
00E520  1               
00E520  1               getline_done:
00E520  1  A9 00            lda #0
00E522  1  9D 00 02         sta linebuf,x
00E525  1  60               rts
00E526  1               
00E526  1               print_error:
00E526  1  A9 3F        		lda #'?'
00E528  1  20 02 E5     		jsr putchar
00E52B  1  4C F3 E4     		jmp newline
00E52E  1               
00E52E  1               ; command implementations
00E52E  1               .include "disasm.asm"
00E52E  2               ; ------------------------------------------------------------
00E52E  2               ; DISASSEMBLER COMMAND
00E52E  2               ; Syntax:
00E52E  2               ;   D
00E52E  2               ;   D start
00E52E  2               ;   D start end
00E52E  2               ;
00E52E  2               ; Default start is MEM.
00E52E  2               ; Default length is 12 instructions.
00E52E  2               ; MEM is updated to the next address after the disassembly.
00E52E  2               ; ------------------------------------------------------------
00E52E  2               cmd_disasm:
00E52E  2  20 15 E4         jsr advance_lineptr
00E531  2  20 AC E2         jsr next_token
00E534  2  90 19            bcc dis_default
00E536  2               
00E536  2  20 FD E2         jsr parse_word
00E539  2  20 3F E4         jsr copy_T0_R0
00E53C  2               
00E53C  2  20 AC E2         jsr next_token
00E53F  2  90 11            bcc dis_one_param
00E541  2               
00E541  2  20 FD E2         jsr parse_word
00E544  2  20 48 E4         jsr copy_T0_R1
00E547  2               
00E547  2               dis_prepare_range:
00E547  2  20 AC E2         jsr next_token
00E54A  2  90 27            bcc dis_range_ok
00E54C  2  4C D7 E1         jmp cmd_error
00E54F  2               
00E54F  2               dis_default:
00E54F  2  20 63 E4         jsr copy_MEM_R0
00E552  2               
00E552  2               dis_one_param:
00E552  2  20 51 E4         jsr copy_R0_R1
00E555  2  A9 0C            lda #12
00E557  2  85 D2            sta parm_count
00E559  2               
00E559  2               dis_prepare_count:
00E559  2  20 AC E2         jsr next_token
00E55C  2  90 03            bcc dis_count_ok
00E55E  2  4C D7 E1         jmp cmd_error
00E561  2               
00E561  2               dis_count_ok:
00E561  2  20 5A E4         jsr copy_R0_R2
00E564  2               
00E564  2               dis_loop_count:
00E564  2  20 05 E5         jsr check_abort
00E567  2  B0 1F            bcs dis_abort
00E569  2  20 8B E5         jsr disasm_line
00E56C  2  C6 D2            dec parm_count
00E56E  2  D0 F4            bne dis_loop_count
00E570  2  4C 6C E4         jmp copy_R2_MEM
00E573  2               
00E573  2               dis_range_ok:
00E573  2  20 5A E4         jsr copy_R0_R2
00E576  2               
00E576  2               dis_loop_range:
00E576  2  20 05 E5         jsr check_abort
00E579  2  B0 0D            bcs dis_abort
00E57B  2  20 8B E5         jsr disasm_line
00E57E  2  20 AF E4         jsr cmp_R2_R1
00E581  2  90 F3            bcc dis_loop_range
00E583  2  F0 F1            beq dis_loop_range
00E585  2  4C 6C E4         jmp copy_R2_MEM
00E588  2               
00E588  2               dis_abort:
00E588  2  4C D7 E1         jmp cmd_error
00E58B  2               
00E58B  2               ; ------------------------------------------------------------
00E58B  2               ; DISASSEMBLE ONE LINE
00E58B  2               ;
00E58B  2               ; Input
00E58B  2               ;   R2 = current PC
00E58B  2               ;
00E58B  2               ; Internal use
00E58B  2               ;   T0L = opcode
00E58B  2               ;   R3L = addressing mode
00E58B  2               ;   R3H = instruction length
00E58B  2               ;   T1  = pointer to mnemonic string
00E58B  2               ;
00E58B  2               ; Output
00E58B  2               ;   prints one disassembly line
00E58B  2               ;   advances R2 by instruction length
00E58B  2               ; ------------------------------------------------------------
00E58B  2               disasm_line:
00E58B  2  A5 C8            lda R2L
00E58D  2  85 CC            sta T0L
00E58F  2  A5 C9            lda R2H
00E591  2  85 CD            sta T0H
00E593  2  20 A6 E2         jsr print_address_T0_2spaces
00E596  2               
00E596  2  A0 00            ldy #0
00E598  2  B1 C8            lda (R2L),y
00E59A  2  85 CC            sta T0L
00E59C  2  AA               tax
00E59D  2               
00E59D  2  BD 31 EC         lda mode_table,x
00E5A0  2  85 CA            sta R3L
00E5A2  2  20 33 E8         jsr get_oplen_from_mode
00E5A5  2  85 CB            sta R3H
00E5A7  2               
00E5A7  2  20 1D E8         jsr get_mnemonic_id_x
00E5AA  2  20 21 E8         jsr get_mnemonic_ptr_id
00E5AD  2               
00E5AD  2  20 C4 E5         jsr print_disasm_bytes
00E5B0  2  20 EE E4         jsr print_space
00E5B3  2  20 EE E4         jsr print_space
00E5B6  2  20 F4 E5         jsr print_mnemonic
00E5B9  2  20 FE E5         jsr print_operand
00E5BC  2  20 F3 E4         jsr newline
00E5BF  2               
00E5BF  2  A5 CB            lda R3H
00E5C1  2  4C A5 E4         jmp add_R2_A
00E5C4  2               
00E5C4  2               
00E5C4  2               ; ------------------------------------------------------------
00E5C4  2               ; PRINT RAW BYTES FIELD
00E5C4  2               ; Shows 1..3 actual instruction bytes and pads to fixed width.
00E5C4  2               ; R3H = instruction length
00E5C4  2               ; ------------------------------------------------------------
00E5C4  2               print_disasm_bytes:
00E5C4  2  A0 00            ldy #0
00E5C6  2               
00E5C6  2               pdb_real_loop:
00E5C6  2  C4 CB            cpy R3H
00E5C8  2  F0 0E            beq pdb_pad
00E5CA  2  B1 C8            lda (R2L),y
00E5CC  2  20 BA E4         jsr print_hex8
00E5CF  2  20 EE E4         jsr print_space
00E5D2  2  C8               iny
00E5D3  2  C0 03            cpy #3
00E5D5  2  D0 EF            bne pdb_real_loop
00E5D7  2  60               rts
00E5D8  2               
00E5D8  2               pdb_pad:
00E5D8  2  C0 03            cpy #3
00E5DA  2  F0 11            beq pdb_done
00E5DC  2  A9 20            lda #' '
00E5DE  2  20 02 E5         jsr putchar
00E5E1  2  A9 20            lda #' '
00E5E3  2  20 02 E5         jsr putchar
00E5E6  2  20 EE E4         jsr print_space
00E5E9  2  C8               iny
00E5EA  2  4C D8 E5         jmp pdb_pad
00E5ED  2               
00E5ED  2               pdb_done:
00E5ED  2  60               rts
00E5EE  2               
00E5EE  2               ; ------------------------------------------------------------
00E5EE  2               ; GAP BETWEEN BYTE FIELD AND MNEMONIC
00E5EE  2               ; ------------------------------------------------------------
00E5EE  2               print_disasm_gap:
00E5EE  2  20 EE E4         jsr print_space
00E5F1  2  4C EE E4         jmp print_space
00E5F4  2               
00E5F4  2               ; ------------------------------------------------------------
00E5F4  2               ; PRINT MNEMONIC
00E5F4  2               ; T1 = pointer to zero-terminated mnemonic string
00E5F4  2               ; ------------------------------------------------------------
00E5F4  2               print_mnemonic:
00E5F4  2  A5 CE            lda T1L
00E5F6  2  A6 CF            ldx T1H
00E5F8  2  20 5C E2         jsr print_str
00E5FB  2  4C EE E4         jmp print_space
00E5FE  2               
00E5FE  2               ; ------------------------------------------------------------
00E5FE  2               ; PRINT OPERAND
00E5FE  2               ; R3L = addressing mode
00E5FE  2               ; R2  = current instruction address
00E5FE  2               ; ------------------------------------------------------------
00E5FE  2               print_operand:
00E5FE  2  A5 CA            lda R3L
00E600  2  0A               asl
00E601  2  AA               tax
00E602  2  BD 6C E7         lda operand_vecs,x
00E605  2  85 C2            sta jmpvec
00E607  2  E8               inx
00E608  2  BD 6C E7         lda operand_vecs,x
00E60B  2  85 C3            sta jmpvec+1
00E60D  2  6C C2 00         jmp (jmpvec)
00E610  2               
00E610  2               ; ------------------------------------------------------------
00E610  2               ; ADDRESSING MODE FORMATTERS
00E610  2               ; ------------------------------------------------------------
00E610  2               fmt_imp:
00E610  2  60               rts
00E611  2               
00E611  2               fmt_acc:
00E611  2  A9 41            lda #'A'
00E613  2  4C 02 E5         jmp putchar
00E616  2               
00E616  2               fmt_imm:
00E616  2  A9 23            lda #'#'
00E618  2  20 02 E5         jsr putchar
00E61B  2  A9 24            lda #'$'
00E61D  2  20 02 E5         jsr putchar
00E620  2  A0 01            ldy #1
00E622  2  B1 C8            lda (R2L),y
00E624  2  4C BA E4         jmp print_hex8
00E627  2               
00E627  2               fmt_zp:
00E627  2  A9 24            lda #'$'
00E629  2  20 02 E5         jsr putchar
00E62C  2  A0 01            ldy #1
00E62E  2  B1 C8            lda (R2L),y
00E630  2  4C BA E4         jmp print_hex8
00E633  2               
00E633  2               fmt_zpx:
00E633  2  20 27 E6         jsr fmt_zp
00E636  2  A9 2C            lda #','
00E638  2  20 02 E5         jsr putchar
00E63B  2  A9 58            lda #'X'
00E63D  2  4C 02 E5         jmp putchar
00E640  2               
00E640  2               fmt_zpy:
00E640  2  20 27 E6         jsr fmt_zp
00E643  2  A9 2C            lda #','
00E645  2  20 02 E5         jsr putchar
00E648  2  A9 59            lda #'Y'
00E64A  2  4C 02 E5         jmp putchar
00E64D  2               
00E64D  2               fmt_abs:
00E64D  2  A9 24            lda #'$'
00E64F  2  20 02 E5         jsr putchar
00E652  2  A0 01            ldy #1
00E654  2  B1 C8            lda (R2L),y
00E656  2  AA               tax

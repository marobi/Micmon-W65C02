000000r 1               ; ---------------------------------------------------------------------------
000000r 1               ; MICMON – Minimal Interactive Command Monitor for the W65C02
000000r 1               ; (c) 2026 Rien Matthijsse
000000r 1               ; ---------------------------------------------------------------------------
000000r 1               .include "readme.asm"
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; MICMON – Minimal Interactive Command Monitor for the W65C02
000000r 2               ; (c) 2026 Rien Matthijsse
000000r 2               ;
000000r 2               ; Overview
000000r 2               ; --------
000000r 2               ; Micmon is a compact machine-level monitor for the W65C02, designed to fit
000000r 2               ; within a 4 KB ROM. It provides essential debugging, inspection and control
000000r 2               ; facilities while remaining small, deterministic, and fully self-hosting.
000000r 2               ;
000000r 2               ; The monitor follows a strict "round-trip" philosophy: all output is valid
000000r 2               ; input. Any command output (e.g. memory dumps) can be edited and fed back
000000r 2               ; into the monitor for execution. This enables interactive workflows using
000000r 2               ; external terminals or VDUs with line editing capabilities.
000000r 2               ;
000000r 2               ; Design Goals
000000r 2               ; ------------
000000r 2               ; - Minimal footprint (fits in 4 KB ROM)
000000r 2               ; - Deterministic behaviour (no hidden state, no dynamic allocation)
000000r 2               ; - Table-driven architecture (command dispatch, disassembler, assembler)
000000r 2               ; - Round-trip capable output (monitor output is executable input)
000000r 2               ; - Tight integration with external VDU/GDU systems
000000r 2               ;
000000r 2               ; Functional Scope
000000r 2               ; ----------------
000000r 2               ; - Memory inspection and modification
000000r 2               ; - CPU register inspection and editing
000000r 2               ; - Program execution control (GO)
000000r 2               ; - Disassembler (W65C02 complete)
000000r 2               ; - Inline assembler (single-line, immediate emission)
000000r 2               ; - Command-driven interface with single-character dispatch
000000r 2               ;
000000r 2               ; Command Summary
000000r 2               ; ---------------
000000r 2               ;   H          Help / command overview
000000r 2               ;   M addr     Dump memory
000000r 2               ;   > addr     Modify memory (hex byte stream)
000000r 2               ;   R          Show CPU registers
000000r 2               ;   ;          Modify CPU registers
000000r 2               ;   G [addr]   Execute code at address
000000r 2               ;   D [addr]   Disassembler
000000r 2               ;   A [addr]   Assemble single instruction at address
000000r 2               ;
000000r 2               ; Notes:
000000r 2               ; - Default address is MEM unless explicitly provided
000000r 2               ; - Commands are line-oriented and CR-terminated
000000r 2               ; - Where possible: output format is compatible with monitor input (round-trip)
000000r 2               ;
000000r 2               ; Execution Model
000000r 2               ; ---------------
000000r 2               ; - RESET:
000000r 2               ;     Initializes CPU state and monitor environment
000000r 2               ;     Enters monitor via BRK vector
000000r 2               ;
000000r 2               ; - BRK handler:
000000r 2               ;     Saves full CPU context (A, X, Y, P, SP, PC)
000000r 2               ;     Transfers control to command interpreter
000000r 2               ;
000000r 2               ; - Command loop:
000000r 2               ;     Line-oriented input
000000r 2               ;     Single-character command dispatch via table
000000r 2               ;     Commands operate directly on memory and CPU image
000000r 2               ;
000000r 2               ; Interaction Model
000000r 2               ; -----------------
000000r 2               ; Micmon assumes the host terminal or VDU performs line editing.
000000r 2               ; Input is processed per line (CR-terminated).
000000r 2               ;
000000r 2               ; Output is formatted to be re-consumable:
000000r 2               ;
000000r 2               ;     M 0200 020F
000000r 2               ;     > 0200 A9 01 8D 00 02 ...
000000r 2               ;
000000r 2               ; Can be edited into:
000000r 2               ;
000000r 2               ;     > 0200 A9 FF 8D 00 02
000000r 2               ;
000000r 2               ; and executed directly by the monitor.
000000r 2               ;
000000r 2               ; Parameter Formats
000000r 2               ; -----------------
000000r 2               ; All numeric parameters support multiple input formats. The parser auto-
000000r 2               ; detects the format based on prefix or content.
000000r 2               ;
000000r 2               ; Supported formats:
000000r 2               ;
000000r 2               ;   Hexadecimal (default)
000000r 2               ;     0200      $0200
000000r 2               ;
000000r 2               ;   Decimal
000000r 2               ;     +123
000000r 2               ;
000000r 2               ;   Binary
000000r 2               ;     %10101010
000000r 2               ;
000000r 2               ;   ASCII
000000r 2               ;     'A        -> $41
000000r 2               ;
000000r 2               ; Rules:
000000r 2               ; - Hex is assumed if no prefix is present
000000r 2               ;       $   = hex (optional, since default)
000000r 2               ;       %   = binary
000000r 2               ;       +   = decimal
000000r 2               ;       '   = ASCII single byte
000000r 2               ;
000000r 2               ; - All parsed values result in:
000000r 2               ;       T0 = value (byte or word)
000000r 2               ;       value_size >= 1 indicates success
000000r 2               ;
000000r 2               ; - Commands are literal
000000r 2               ;
000000r 2               ; Examples:
000000r 2               ;   M $C000
000000r 2               ;   M %1100000000000000
000000r 2               ;   M +49152
000000r 2               ;
000000r 2               ;   > 0200 'A $42 %01000011
000000r 2               ;
000000r 2               ;   A 0300 LDA #'A
000000r 2               ;   A 0302 LDA #$41
000000r 2               ;
000000r 2               ; Architecture Notes
000000r 2               ; ------------------
000000r 2               ; - All decoding (disassembler/assembler) is table-driven
000000r 2               ; - Opcode metadata shared between assembler and disassembler
000000r 2               ; - Zero-page used from $00C0-$00DF
000000r 2               ; - Strict separation between parsing, decoding and execution
000000r 2               ;
000000r 2               ; Extensibility
000000r 2               ; -------------
000000r 2               ; Micmon is intentionally designed for easy extension:
000000r 2               ;
000000r 2               ; - New commands can be added by inserting entries in:
000000r 2               ;       cmd_chars / cmd_addrs tables
000000r 2               ;
000000r 2               ; - No central switch-case logic: dispatch is fully table-driven
000000r 2               ; - Parsing helpers (parse_word, next_token, etc.) are reusable
000000r 2               ; - Disassembler and assembler share data tables, reducing duplication
000000r 2               ; - New addressing modes or instructions require only table updates
000000r 2               ;
000000r 2               ; This allows incremental growth without restructuring the monitor core.
000000r 2               ;
000000r 2               ; Limitations
000000r 2               ; -----------
000000r 2               ; - No multi-line assembly or label resolution
000000r 2               ; - No expression evaluator
000000r 2               ; - Branch range limited to signed 8-bit (hardware constraint)
000000r 2               ;
000000r 2               ; Target
000000r 2               ; ------
000000r 2               ; WDC W65C02 (fully supported instruction set)
000000r 2               ;
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               
000000r 1               
000000r 1               	.setcpu "65C02"
000000r 1               
000000r 1               .include "bios.inc"
000000r 2               ;
000000r 2               ; BIOS jumptable + ...
000000r 2               ;
000000r 2               .ifndef __BIOS_INC__
000000r 2               __BIOS_INC__ = 1
000000r 2               
000000r 2               BIOS_CMD_PORT   =   $D002
000000r 2               BIOS_STAT_PORT  =   $D003
000000r 2               BIOS_SYNC_PORT  =   $D004
000000r 2               
000000r 2               BIOS_BASE       =  	$F000
000000r 2               BIOS_GETCHAR    =   BIOS_BASE
000000r 2               BIOS_PUTCHAR    =   BIOS_BASE+3
000000r 2               BIOS_INKEY      =   BIOS_BASE+6
000000r 2               BIOS_STPKEY		=	BIOS_BASE+9
000000r 2               BIOS_CONTEXT    =   BIOS_BASE+12
000000r 2               BIOS_GETLINE    =   BIOS_BASE+15
000000r 2               BIOS_ACK_IRQ    =   BIOS_BASE+18
000000r 2               
000000r 2               .endif
000000r 2               
000000r 1               
000000r 1               	.segment "ZEROPAGE"
000000r 1               	.org $00C0					; nicer listing
0000C0  1               
0000C0  1               ; IRQ hander vector
0000C0  1  xx           irq_vecL:   .res 1
0000C1  1  xx           irq_vecH:   .res 1
0000C2  1               
0000C2  1               ; parser / dispatcher pointers
0000C2  1  xx xx        lineptr:    .res 2
0000C4  1  xx xx        jmpvec:     .res 2
0000C6  1               
0000C6  1               ; 16-bit working registers for commands
0000C6  1  xx           R0L:        .res 1
0000C7  1  xx           R0H:        .res 1
0000C8  1  xx           R1L:        .res 1
0000C9  1  xx           R1H:        .res 1
0000CA  1  xx           R2L:        .res 1
0000CB  1  xx           R2H:        .res 1
0000CC  1  xx           R3L:        .res 1
0000CD  1  xx           R3H:        .res 1
0000CE  1               
0000CE  1               ; temporary registers used by parser and utility routines
0000CE  1  xx           T0L:        .res 1
0000CF  1  xx           T0H:        .res 1
0000D0  1  xx           T1L:        .res 1
0000D1  1  xx           T1H:        .res 1
0000D2  1               
0000D2  1               ; monitor remembers last referenced memory address
0000D2  1  xx           MEML:       .res 1
0000D3  1  xx           MEMH:       .res 1
0000D4  1               
0000D4  1               ; parser state
0000D4  1  xx           parm_count: .res 1
0000D5  1  xx           value_size: .res 1
0000D6  1  xx           tmp:        .res 1
0000D7  1               
0000D7  1  xx           asm_mode:   .res 1
0000D8  1  xx           asm_opcode: .res 1
0000D9  1  xx           mnem_len:   .res 1
0000DA  1               
0000DA  1               	.segment "BSS"
0000DA  1               	.org $0200				; nicer listing
000200  1               
000200  1               ; input buffer
000200  1  xx xx xx xx  linebuf:    .res 64
000204  1  xx xx xx xx  
000208  1  xx xx xx xx  
000240  1               
000240  1               ; saved CPU image
000240  1  xx           reg_pch:    .res 1
000241  1  xx           reg_pcl:    .res 1
000242  1  xx           reg_sr:     .res 1
000243  1  xx           reg_a:      .res 1
000244  1  xx           reg_x:      .res 1
000245  1  xx           reg_y:      .res 1
000246  1  xx           reg_sp:     .res 1
000247  1               
000247  1               	.segment "CODE"
000247  1               	.org $B000				; nicer listing
00B000  1               
00B000  1               ; ------------------------------------------------------------
00B000  1               ; RESET
00B000  1               ; Basic CPU setup, monitor state initialization, then enter
00B000  1               ; the monitor through BRK so startup uses the normal entry path.
00B000  1               ; ------------------------------------------------------------
00B000  1               	.export reset
00B000  1               reset:
00B000  1  78               sei						; disable interrupts
00B001  1  D8               cld
00B002  1  A2 FF            ldx #$FF
00B004  1  9A               txs						; init stack
00B005  1               
00B005  1  64 D2            stz MEML
00B007  1  64 D3            stz MEMH
00B009  1               
00B009  1  20 30 E0     	jsr $E030				; temp fix
00B00C  1               
00B00C  1  A9 19            lda #<welcome_text		; say hello
00B00E  1  A2 BF            ldx #>welcome_text
00B010  1  20 60 B2         jsr print_str
00B013  1               
00B013  1  00           	brk						; enter monitor
00B014  1               
00B014  1               ; ------------------------------------------------------------
00B014  1               ; IRQ / BRK ENTRY
00B014  1               ; The common IRQ vector saves A/X/Y, then distinguishes IRQ
00B014  1               ; from BRK by testing bit 4 of the stacked status byte.
00B014  1               ; IRQ returns immediately. BRK enters the monitor.
00B014  1               ; ------------------------------------------------------------
00B014  1               	.export irq_entry
00B014  1               irq_entry:
00B014  1  48               pha
00B015  1  8A               txa
00B016  1  48               pha
00B017  1  98               tya
00B018  1  48               pha
00B019  1               
00B019  1  BA               tsx
00B01A  1  BD 04 01         lda $0104,x
00B01D  1  29 10            and #$10
00B01F  1  D0 09            bne brk_entry
00B021  1               
00B021  1               irq_restore:
00B021  1  20 12 F0     	jsr BIOS_ACK_IRQ
00B024  1  7A               ply
00B025  1  FA               plx
00B026  1  68               pla
00B027  1  40               rti
00B028  1               
00B028  1               	.export nmi_entry
00B028  1               nmi_entry:
00B028  1  40               rti						; stub
00B029  1               
00B029  1               print_context:
00B029  1  BA               tsx
00B02A  1               
00B02A  1               ; ------------------------------------------------------------
00B02A  1               ; BRK ENTRY
00B02A  1               ; Save CPU state into monitor RAM and discard interrupt frame.
00B02A  1               ; BRK pushes PC+2, so saved PC is corrected back to BRK opcode.
00B02A  1               ; ------------------------------------------------------------
00B02A  1               brk_entry:
00B02A  1  68               pla						; save context
00B02B  1  8D 45 02         sta reg_y
00B02E  1  68               pla
00B02F  1  8D 44 02         sta reg_x
00B032  1  68               pla
00B033  1  8D 43 02         sta reg_a
00B036  1  68               pla
00B037  1  8D 42 02         sta reg_sr
00B03A  1  68               pla
00B03B  1  8D 41 02         sta reg_pcl
00B03E  1  68               pla
00B03F  1  8D 40 02         sta reg_pch
00B042  1               
00B042  1  BA               tsx
00B043  1  8E 46 02         stx reg_sp
00B046  1               
00B046  1  D8               cld
00B047  1  38               sec						; correct PC =-2
00B048  1  AD 41 02         lda reg_pcl
00B04B  1  E9 02            sbc #2
00B04D  1  8D 41 02         sta reg_pcl
00B050  1  AD 40 02         lda reg_pch
00B053  1  E9 00            sbc #0
00B055  1  8D 40 02         sta reg_pch
00B058  1               
00B058  1               ; ------------------------------------------------------------
00B058  1               ; MONITOR ENTRY
00B058  1               ; Every BRK entry shows the saved registers, then drops into
00B058  1               ; the command loop.
00B058  1               ; ------------------------------------------------------------
00B058  1               monitor_entry:
00B058  1  58           	cli					; enable interrupts
00B059  1  20 37 B1         jsr show_registers	; show regs and fall through
00B05C  1  20 0B B5     	jsr print_prompt
00B05F  1               
00B05F  1               ; ------------------------------------------------------------
00B05F  1               ; MAIN MONITOR LOOP
00B05F  1               ; Read one full line, execute it
00B05F  1               ; ------------------------------------------------------------
00B05F  1               monitor_loop:
00B05F  1  20 12 B5         jsr getline					; read line
00B062  1  A9 00            lda #<linebuf
00B064  1  85 C2            sta lineptr
00B066  1  A9 02            lda #>linebuf
00B068  1  85 C3            sta lineptr+1
00B06A  1               
00B06A  1               execute_line:
00B06A  1  20 20 B4         jsr skip_spaces
00B06D  1  A0 00            ldy #0
00B06F  1  B1 C2            lda (lineptr),y			; get cmd
00B071  1  F0 0A            beq exec_done
00B073  1  20 2F B4         jsr toupper
00B076  1  91 C2            sta (lineptr),y			; save uppercase
00B078  1  20 83 B0         jsr dispatch_command
00B07B  1  B0 03        	bcs exec_nopr
00B07D  1               exec_done:
00B07D  1  20 0B B5     	jsr print_prompt
00B080  1               
00B080  1               exec_nopr:
00B080  1  4C 5F B0         jmp monitor_loop
00B083  1               
00B083  1               ; ------------------------------------------------------------
00B083  1               ; COMMAND DISPATCH
00B083  1               ; ------------------------------------------------------------
00B083  1               dispatch_command:
00B083  1  A0 00            ldy #0
00B085  1  B1 C2            lda (lineptr),y
00B087  1  85 D6            sta tmp
00B089  1               
00B089  1  A2 00            ldx #0
00B08B  1               dispatch_loop:
00B08B  1  BD FD BE         lda cmd_chars,x
00B08E  1  F0 19            beq dispatch_error
00B090  1  C5 D6            cmp tmp
00B092  1  F0 04            beq dispatch_found
00B094  1  E8               inx
00B095  1  4C 8B B0         jmp dispatch_loop
00B098  1               
00B098  1               dispatch_found:
00B098  1  8A               txa
00B099  1  0A               asl
00B09A  1  AA               tax
00B09B  1  BD 07 BF         lda cmd_addrs,x
00B09E  1  85 C4            sta jmpvec
00B0A0  1  E8               inx
00B0A1  1  BD 07 BF         lda cmd_addrs,x
00B0A4  1  85 C5            sta jmpvec+1
00B0A6  1  6C C4 00         jmp (jmpvec)
00B0A9  1               
00B0A9  1               dispatch_error:
00B0A9  1  4C 27 B2         jmp cmd_error
00B0AC  1               
00B0AC  1               ; ------------------------------------------------------------
00B0AC  1               ; RESET COMMAND
00B0AC  1               ; ------------------------------------------------------------
00B0AC  1               cmd_reset:
00B0AC  1  4C 00 B0     		jmp reset
00B0AF  1               
00B0AF  1               ; ------------------------------------------------------------
00B0AF  1               ; MEMORY DUMP COMMAND
00B0AF  1               ; Syntax:
00B0AF  1               ;   M
00B0AF  1               ;   M start
00B0AF  1               ;   M start end
00B0AF  1               ;
00B0AF  1               ; Default start is MEM.
00B0AF  1               ; Default length is 12 lines * 8 bytes = 96 bytes.
00B0AF  1               ; MEM is updated to the next address after the dump.
00B0AF  1               ; ------------------------------------------------------------
00B0AF  1               cmd_mem:
00B0AF  1  20 19 B4     	jsr advance_lineptr
00B0B2  1               
00B0B2  1  20 AC B2         jsr next_token
00B0B5  1  90 14            bcc mem_default
00B0B7  1               
00B0B7  1  20 FD B2         jsr parse_word
00B0BA  1  20 43 B4         jsr copy_T0_R0
00B0BD  1               
00B0BD  1  20 AC B2         jsr next_token
00B0C0  1  90 0C            bcc mem_one_param
00B0C2  1               
00B0C2  1  20 FD B2         jsr parse_word
00B0C5  1  20 4C B4         jsr copy_T0_R1
00B0C8  1  4C D6 B0         jmp mem_prepare
00B0CB  1               
00B0CB  1               mem_default:
00B0CB  1  20 67 B4         jsr copy_MEM_R0
00B0CE  1               mem_one_param:
00B0CE  1  20 55 B4         jsr copy_R0_R1
00B0D1  1  A9 5F            lda #95
00B0D3  1  20 96 B4         jsr add_R1_A
00B0D6  1               
00B0D6  1               mem_prepare:
00B0D6  1  20 AC B2         jsr next_token
00B0D9  1  90 03            bcc mem_prepare_ok
00B0DB  1  4C 27 B2         jmp cmd_error
00B0DE  1               
00B0DE  1               mem_prepare_ok:
00B0DE  1  20 5E B4         jsr copy_R0_R2
00B0E1  1               
00B0E1  1               mem_loop:
00B0E1  1  20 41 B5         jsr check_abort
00B0E4  1  B0 16            bcs mem_abort
00B0E6  1               
00B0E6  1  20 2C B2         jsr dump_line
00B0E9  1               
00B0E9  1  A9 08            lda #8
00B0EB  1  20 A5 B4         jsr add_R2_A
00B0EE  1  B0 07            bcs mem_ok
00B0F0  1               
00B0F0  1  20 C2 B4         jsr cmp_R2_R1
00B0F3  1  90 EC            bcc mem_loop
00B0F5  1  F0 EA            beq mem_loop
00B0F7  1               
00B0F7  1               mem_ok:
00B0F7  1  20 70 B4         jsr copy_R2_MEM
00B0FA  1  18               clc
00B0FB  1  60           	rts
00B0FC  1               
00B0FC  1               mem_abort:
00B0FC  1  4C 27 B2         jmp cmd_error
00B0FF  1               
00B0FF  1               ; ------------------------------------------------------------
00B0FF  1               ; MEMORY EDIT COMMAND
00B0FF  1               ; Syntax:
00B0FF  1               ;   > addr byte...
00B0FF  1               ; Writes 1..8 bytes.
00B0FF  1               ; Updates MEM to the next address after the last write.
00B0FF  1               ; ------------------------------------------------------------
00B0FF  1               cmd_memedit:
00B0FF  1  20 19 B4     	jsr advance_lineptr
00B102  1  20 FD B2         jsr parse_word
00B105  1  20 43 B4         jsr copy_T0_R0				; init ptr
00B108  1               
00B108  1  64 D4            stz parm_count				; first of 8
00B10A  1               
00B10A  1               write_loop:
00B10A  1  A5 D4            lda parm_count
00B10C  1  C9 08            cmp #8
00B10E  1  B0 16            bcs write_done				; >= 7
00B110  1               
00B110  1  20 AC B2         jsr next_token
00B113  1  90 11            bcc write_done				; no more
00B115  1               
00B115  1  20 F0 B2         jsr parse_byte
00B118  1               
00B118  1  A0 00            ldy #0
00B11A  1  A5 CE            lda T0L
00B11C  1  91 C6            sta (R0L),y						; store it
00B11E  1               
00B11E  1  20 79 B4         jsr inc_R0						; next location
00B121  1  E6 D4            inc parm_count				; next param
00B123  1  4C 0A B1         jmp write_loop				; loop
00B126  1               
00B126  1               write_done:
00B126  1  A5 D4            lda parm_count
00B128  1  F0 0A            beq write_error				; no locations given
00B12A  1               
00B12A  1  A5 C6            lda R0L								; advance mem ptr
00B12C  1  85 D2            sta MEML
00B12E  1  A5 C7            lda R0H
00B130  1  85 D3            sta MEMH
00B132  1  18               clc
00B133  1  60           	rts
00B134  1               
00B134  1               write_error:
00B134  1  4C 27 B2         jmp cmd_error
00B137  1               
00B137  1               
00B137  1               ; ------------------------------------------------------------
00B137  1               ; REGISTER DISPLAY COMMAND
00B137  1               ; Explicit register display on user request.
00B137  1               ; ------------------------------------------------------------
00B137  1               cmd_regs:
00B137  1               show_registers:
00B137  1  A9 29            lda #<reg_header
00B139  1  A2 BF            ldx #>reg_header
00B13B  1  20 60 B2         jsr print_str
00B13E  1               
00B13E  1               print_reg_line:
00B13E  1  A9 3B            lda #';'							; in sync with command table
00B140  1  20 3E B5         jsr putchar
00B143  1  20 01 B5         jsr print_space
00B146  1               
00B146  1  AD 40 02         lda reg_pch
00B149  1  AE 41 02         ldx reg_pcl
00B14C  1  20 E8 B4         jsr print_hex16
00B14F  1  20 01 B5         jsr print_space
00B152  1               
00B152  1  AD 43 02         lda reg_a
00B155  1  20 CD B4         jsr print_hex8
00B158  1  20 01 B5         jsr print_space
00B15B  1               
00B15B  1  AD 44 02         lda reg_x
00B15E  1  20 CD B4         jsr print_hex8
00B161  1  20 01 B5         jsr print_space
00B164  1               
00B164  1  AD 45 02         lda reg_y
00B167  1  20 CD B4         jsr print_hex8
00B16A  1  20 01 B5         jsr print_space
00B16D  1               
00B16D  1  AD 46 02         lda reg_sp
00B170  1  20 CD B4         jsr print_hex8
00B173  1  20 01 B5         jsr print_space
00B176  1               
00B176  1  A9 25            lda #'%'
00B178  1  20 3E B5     		jsr putchar
00B17B  1  AD 42 02         lda reg_sr
00B17E  1  20 78 B2         jsr print_status_bits
00B181  1  20 06 B5         jsr newline
00B184  1  18           	clc
00B185  1  60           	rts
00B186  1               
00B186  1               ; ------------------------------------------------------------
00B186  1               ; REGISTER EDIT COMMAND
00B186  1               ; Editable line format:
00B186  1               ;   ; <PC> [A [X [Y [SP [SR]]]]]
00B186  1               ;
00B186  1               ; At least PC must be supplied.
00B186  1               ; Missing trailing operands leave saved registers unchanged.
00B186  1               ; ------------------------------------------------------------
00B186  1               cmd_regedit:
00B186  1  20 19 B4     	jsr advance_lineptr
00B189  1               
00B189  1  20 AC B2         jsr next_token
00B18C  1  90 56            bcc regedit_error
00B18E  1               
00B18E  1  20 FD B2         jsr parse_word
00B191  1  A5 CE            lda T0L
00B193  1  8D 41 02         sta reg_pcl
00B196  1  A5 CF            lda T0H
00B198  1  8D 40 02         sta reg_pch
00B19B  1               
00B19B  1  20 AC B2         jsr next_token
00B19E  1  90 3F            bcc regedit_done
00B1A0  1               
00B1A0  1  20 F0 B2         jsr parse_byte
00B1A3  1  A5 CE            lda T0L
00B1A5  1  8D 43 02         sta reg_a
00B1A8  1               
00B1A8  1  20 AC B2         jsr next_token
00B1AB  1  90 32            bcc regedit_done
00B1AD  1               
00B1AD  1  20 F0 B2         jsr parse_byte
00B1B0  1  A5 CE            lda T0L
00B1B2  1  8D 44 02         sta reg_x
00B1B5  1               
00B1B5  1  20 AC B2         jsr next_token
00B1B8  1  90 25            bcc regedit_done
00B1BA  1               
00B1BA  1  20 F0 B2         jsr parse_byte
00B1BD  1  A5 CE            lda T0L
00B1BF  1  8D 45 02         sta reg_y
00B1C2  1               
00B1C2  1  20 AC B2         jsr next_token
00B1C5  1  90 18            bcc regedit_done
00B1C7  1               
00B1C7  1  20 F0 B2         jsr parse_byte
00B1CA  1  A5 CE            lda T0L
00B1CC  1  8D 46 02         sta reg_sp
00B1CF  1               
00B1CF  1  20 AC B2         jsr next_token
00B1D2  1  90 0B            bcc regedit_done
00B1D4  1               
00B1D4  1  20 F0 B2         jsr parse_byte
00B1D7  1  A5 CE            lda T0L
00B1D9  1  8D 42 02         sta reg_sr
00B1DC  1               
00B1DC  1  20 AC B2         jsr next_token
00B1DF  1               
00B1DF  1               regedit_done:
00B1DF  1  20 37 B1     	jsr show_registers
00B1E2  1  18           	clc
00B1E3  1  60               rts
00B1E4  1               
00B1E4  1               regedit_error:
00B1E4  1  4C 27 B2         jmp cmd_error
00B1E7  1               
00B1E7  1               ; ------------------------------------------------------------
00B1E7  1               ; GO COMMAND
00B1E7  1               ; Syntax:
00B1E7  1               ;   G
00B1E7  1               ;   G <PC>
00B1E7  1               ; Restores the saved CPU image and resumes execution with RTI.
00B1E7  1               ; ------------------------------------------------------------
00B1E7  1               cmd_go:
00B1E7  1  20 19 B4     	jsr advance_lineptr
00B1EA  1  20 AC B2         jsr next_token
00B1ED  1  90 15            bcc go_now
00B1EF  1               
00B1EF  1  20 FD B2         jsr parse_word
00B1F2  1  A5 CE            lda T0L
00B1F4  1  8D 41 02         sta reg_pcl
00B1F7  1  A5 CF            lda T0H
00B1F9  1  8D 40 02         sta reg_pch
00B1FC  1               
00B1FC  1  20 AC B2         jsr next_token
00B1FF  1  90 03            bcc go_now
00B201  1  4C 27 B2         jmp cmd_error
00B204  1               
00B204  1               go_now:
00B204  1  AE 46 02         ldx reg_sp
00B207  1  9A               txs
00B208  1  AD 40 02         lda reg_pch
00B20B  1  48               pha
00B20C  1  AD 41 02         lda reg_pcl
00B20F  1  48               pha
00B210  1  AD 42 02         lda reg_sr
00B213  1  48               pha
00B214  1  AD 43 02         lda reg_a
00B217  1  AE 44 02         ldx reg_x
00B21A  1  AC 45 02         ldy reg_y
00B21D  1  40               rti
00B21E  1               
00B21E  1               ; ------------------------------------------------------------
00B21E  1               ; HELP COMMAND
00B21E  1               ; ------------------------------------------------------------
00B21E  1               cmd_help:
00B21E  1  A9 4B            lda #<help_text
00B220  1  A2 BF            ldx #>help_text
00B222  1  20 60 B2         jsr print_str
00B225  1  18           	clc
00B226  1  60           	rts
00B227  1               
00B227  1               ; ------------------------------------------------------------
00B227  1               ; ERROR HANDLER
00B227  1               ; ------------------------------------------------------------
00B227  1               cmd_error:
00B227  1  20 30 B5         jsr print_error
00B22A  1  38           	sec
00B22B  1  60           	rts
00B22C  1               
00B22C  1               ; ------------------------------------------------------------
00B22C  1               ; MEMORY DUMP FORMATTERS
00B22C  1               ; ------------------------------------------------------------
00B22C  1               ; show 8 memory locs @R2
00B22C  1               .proc dump_line
00B22C  1  A9 3E            lda #'>'						; sync with command table
00B22E  1  20 3E B5         jsr putchar
00B231  1  20 01 B5         jsr print_space
00B234  1               
00B234  1  A5 CA            lda R2L
00B236  1  85 CE            sta T0L
00B238  1  A5 CB            lda R2H
00B23A  1  85 CF            sta T0H
00B23C  1  20 A2 B2         jsr print_address_T0
00B23F  1               
00B23F  1  A0 00            ldy #0
00B241  1               dump_hex_loop:
00B241  1  B1 CA            lda (R2L),y
00B243  1  20 CD B4         jsr print_hex8
00B246  1  20 01 B5         jsr print_space
00B249  1  C8               iny
00B24A  1  C0 08            cpy #8
00B24C  1  D0 F3            bne dump_hex_loop
00B24E  1               
00B24E  1  20 01 B5         jsr print_space
00B251  1               
00B251  1  A0 00            ldy #0
00B253  1               dump_ascii_loop:
00B253  1  B1 CA            lda (R2L),y
00B255  1  20 F1 B4         jsr print_ascii
00B258  1  C8               iny
00B259  1  C0 08            cpy #8
00B25B  1  D0 F6            bne dump_ascii_loop
00B25D  1  4C 06 B5         jmp newline
00B260  1               .endproc
00B260  1               
00B260  1               ; ------------------------------------------------------------
00B260  1               ; OUTPUT HELPERS
00B260  1               ; ------------------------------------------------------------
00B260  1               
00B260  1               ; ------------------------------------------------------------
00B260  1               ; STRING OUTPUT
00B260  1               ; A = low byte, X = high byte of zero-terminated string.
00B260  1               ; Uses T0 as the temporary string pointer.
00B260  1               ; ------------------------------------------------------------
00B260  1               .proc print_str
00B260  1  5A               phy
00B261  1  85 CE            sta T0L
00B263  1  86 CF            stx T0H
00B265  1  A0 00            ldy #0
00B267  1               
00B267  1               print_str_loop:
00B267  1  B1 CE            lda (T0L),y
00B269  1  F0 0B            beq print_str_done
00B26B  1  20 3E B5         jsr putchar
00B26E  1  C8               iny
00B26F  1  D0 F6            bne print_str_loop
00B271  1  E6 CF            inc T0H
00B273  1  4C 67 B2         jmp print_str_loop
00B276  1               
00B276  1               print_str_done:
00B276  1  7A               ply
00B277  1  60           	rts
00B278  1               .endproc
00B278  1               
00B278  1               ; ------------------------------------------------------------
00B278  1               ; PRINT_STATUS_BITS
00B278  1               ; Print processor status as:
00B278  1               ;   NV-BDIZC
00B278  1               ; using '1' for set bits and '0' for clear bits.
00B278  1               ;
00B278  1               ; Input
00B278  1               ;   A = status byte
00B278  1               ;
00B278  1               ; Clobbers
00B278  1               ;   A, X
00B278  1               ; ------------------------------------------------------------
00B278  1               .proc print_status_bits
00B278  1  85 D6            sta tmp
00B27A  1               
00B27A  1  06 D6            asl tmp              ; N -> C
00B27C  1  20 96 B2         jsr print_bit_c
00B27F  1               
00B27F  1  06 D6            asl tmp              ; V -> C
00B281  1  20 96 B2         jsr print_bit_c
00B284  1               
00B284  1  A9 2D            lda #'-'						 ; mmmhhhh
00B286  1  20 3E B5         jsr putchar
00B289  1               
00B289  1  06 D6            asl tmp              ; skip bit 5
00B28B  1               
00B28B  1  A2 05            ldx #5               ; B D I Z C
00B28D  1               ps_loop:
00B28D  1  06 D6            asl tmp              ; next bit -> C
00B28F  1  20 96 B2         jsr print_bit_c
00B292  1  CA               dex
00B293  1  D0 F8            bne ps_loop
00B295  1  60               rts
00B296  1               .endproc
00B296  1               
00B296  1               ; ------------------------------------------------------------
00B296  1               ; PRINT_BIT_C
00B296  1               ; Print '1' if Carry set, else '0'.
00B296  1               ; ------------------------------------------------------------
00B296  1               .proc print_bit_c
00B296  1  90 05            bcc ps_zero
00B298  1  A9 31            lda #'1'
00B29A  1  4C 3E B5         jmp putchar
00B29D  1               ps_zero:
00B29D  1  A9 30            lda #'0'
00B29F  1  4C 3E B5         jmp putchar
00B2A2  1               .endproc
00B2A2  1               
00B2A2  1               ; ------------------------------------------------------------
00B2A2  1               ; PRINT ADDRESS IN T0 + one trailing space
00B2A2  1               ; ------------------------------------------------------------
00B2A2  1               .proc print_address_T0
00B2A2  1  A5 CF            lda T0H
00B2A4  1  A6 CE            ldx T0L
00B2A6  1  20 E8 B4         jsr print_hex16
00B2A9  1  4C 01 B5         jmp print_space
00B2AC  1               .endproc
00B2AC  1               
00B2AC  1               ; ------------------------------------------------------------
00B2AC  1               ; TOKENIZER
00B2AC  1               ; Carry set   = token exists
00B2AC  1               ; Carry clear = end of line
00B2AC  1               ; ------------------------------------------------------------
00B2AC  1               .proc next_token
00B2AC  1  20 20 B4         jsr skip_spaces
00B2AF  1  A0 00            ldy #0
00B2B1  1  B1 C2            lda (lineptr),y
00B2B3  1  F0 02            beq token_eol
00B2B5  1  38               sec
00B2B6  1  60               rts
00B2B7  1               
00B2B7  1               token_eol:
00B2B7  1  18               clc
00B2B8  1  60               rts
00B2B9  1               .endproc
00B2B9  1               
00B2B9  1               ; ------------------------------------------------------------
00B2B9  1               ; PARAMETER PARSER
00B2B9  1               ; Default base is hex.
00B2B9  1               ; Supported prefixes:
00B2B9  1               ;   $ hex
00B2B9  1               ;   + decimal
00B2B9  1               ;   % binary   (byte only)
00B2B9  1               ;   ' ASCII    (byte only)
00B2B9  1               ; Result is returned in T0, size in value_size.
00B2B9  1               ; ------------------------------------------------------------
00B2B9  1               .proc parse_param
00B2B9  1  20 20 B4         jsr skip_spaces
00B2BC  1  A0 00            ldy #0
00B2BE  1  B1 C2            lda (lineptr),y
00B2C0  1  F0 2B            beq param_error
00B2C2  1               
00B2C2  1  C9 24            cmp #'$'
00B2C4  1  F0 0F            beq parse_hex_pref
00B2C6  1  C9 2B            cmp #'+'
00B2C8  1  F0 11            beq parse_dec
00B2CA  1  C9 25            cmp #'%'
00B2CC  1  F0 13            beq parse_bin
00B2CE  1  C9 27            cmp #$27
00B2D0  1  F0 15            beq parse_ascii
00B2D2  1               
00B2D2  1  4C 5B B3         jmp parse_hex
00B2D5  1               
00B2D5  1               parse_hex_pref:
00B2D5  1  20 19 B4         jsr advance_lineptr
00B2D8  1  4C 5B B3         jmp parse_hex
00B2DB  1               
00B2DB  1               parse_dec:
00B2DB  1  20 19 B4         jsr advance_lineptr
00B2DE  1  4C A2 B3         jmp parse_decimal
00B2E1  1               
00B2E1  1               parse_bin:
00B2E1  1  20 19 B4         jsr advance_lineptr
00B2E4  1  4C 14 B3         jmp parse_binary
00B2E7  1               
00B2E7  1               parse_ascii:
00B2E7  1  20 19 B4         jsr advance_lineptr
00B2EA  1  4C 00 B3         jmp parse_ascii_char
00B2ED  1               
00B2ED  1               param_error:
00B2ED  1  4C 27 B2         jmp cmd_error
00B2F0  1               .endproc
00B2F0  1               
00B2F0  1               .proc parse_byte
00B2F0  1  20 B9 B2         jsr parse_param
00B2F3  1  A5 D5            lda value_size
00B2F5  1  C9 01            cmp #1
00B2F7  1  F0 03            beq parse_byte_ok
00B2F9  1  4C 27 B2         jmp cmd_error
00B2FC  1               parse_byte_ok:
00B2FC  1  60               rts
00B2FD  1               .endproc
00B2FD  1               
00B2FD  1               .proc parse_word
00B2FD  1  4C B9 B2         jmp parse_param
00B300  1               .endproc
00B300  1               
00B300  1               ; ------------------------------------------------------------
00B300  1               ; ASCII PARSER
00B300  1               ; Syntax: 'A
00B300  1               ; ------------------------------------------------------------
00B300  1               .proc parse_ascii_char
00B300  1  A0 00            ldy #0
00B302  1  B1 C2            lda (lineptr),y
00B304  1  F0 0B            beq ascii_error
00B306  1  85 CE            sta T0L
00B308  1  64 CF            stz T0H
00B30A  1  A9 01            lda #1
00B30C  1  85 D5            sta value_size
00B30E  1  4C 19 B4         jmp advance_lineptr
00B311  1               
00B311  1               ascii_error:
00B311  1  4C 27 B2         jmp cmd_error
00B314  1               .endproc
00B314  1               
00B314  1               ; ------------------------------------------------------------
00B314  1               ; BINARY PARSER
00B314  1               ; Syntax: %10101010
00B314  1               ; Binary values are byte sized only.
00B314  1               ; ------------------------------------------------------------
00B314  1               .proc parse_binary
00B314  1  64 CE            stz T0L
00B316  1  64 CF            stz T0H
00B318  1  64 D6            stz tmp
00B31A  1               
00B31A  1               bin_loop:
00B31A  1  A0 00            ldy #0
00B31C  1  B1 C2            lda (lineptr),y
00B31E  1  C9 30            cmp #'0'
00B320  1  F0 0B            beq bin_zero
00B322  1  C9 31            cmp #'1'
00B324  1  F0 17            beq bin_one
00B326  1  C9 2D            cmp #'-'				; special case for S-register
00B328  1  F0 13            beq bin_one
00B32A  1  4C 4F B3         jmp bin_done
00B32D  1               
00B32D  1               bin_zero:
00B32D  1  A5 D6            lda tmp
00B32F  1  C9 08            cmp #8
00B331  1  B0 25            bcs bin_error
00B333  1  06 CE            asl T0L
00B335  1  20 19 B4         jsr advance_lineptr
00B338  1  E6 D6            inc tmp
00B33A  1  4C 1A B3         jmp bin_loop
00B33D  1               
00B33D  1               bin_one:
00B33D  1  A5 D6            lda tmp
00B33F  1  C9 08            cmp #8
00B341  1  B0 15            bcs bin_error
00B343  1  06 CE            asl T0L
00B345  1  E6 CE            inc T0L
00B347  1  20 19 B4         jsr advance_lineptr
00B34A  1  E6 D6            inc tmp
00B34C  1  4C 1A B3         jmp bin_loop
00B34F  1               
00B34F  1               bin_done:
00B34F  1  A5 D6            lda tmp
00B351  1  F0 05            beq bin_error
00B353  1  A9 01            lda #1
00B355  1  85 D5            sta value_size
00B357  1  60               rts
00B358  1               
00B358  1               bin_error:
00B358  1  4C 27 B2         jmp cmd_error
00B35B  1               .endproc
00B35B  1               
00B35B  1               ; ------------------------------------------------------------
00B35B  1               ; HEX PARSER
00B35B  1               ; 1-2 digits => byte, 3-4 digits => word.
00B35B  1               ; ------------------------------------------------------------
00B35B  1               .proc parse_hex
00B35B  1  64 CE            stz T0L
00B35D  1  64 CF            stz T0H
00B35F  1  64 D6            stz tmp
00B361  1               
00B361  1               hex_loop:
00B361  1  A0 00            ldy #0
00B363  1  B1 C2            lda (lineptr),y
00B365  1  20 F0 B3         jsr hex_digit
00B368  1  B0 1C            bcs hex_done
00B36A  1               
00B36A  1  06 CE            asl T0L
00B36C  1  26 CF            rol T0H
00B36E  1  06 CE            asl T0L
00B370  1  26 CF            rol T0H
00B372  1  06 CE            asl T0L
00B374  1  26 CF            rol T0H
00B376  1  06 CE            asl T0L
00B378  1  26 CF            rol T0H
00B37A  1               
00B37A  1  05 CE            ora T0L
00B37C  1  85 CE            sta T0L
00B37E  1               
00B37E  1  20 19 B4         jsr advance_lineptr
00B381  1  E6 D6            inc tmp
00B383  1  4C 61 B3         jmp hex_loop
00B386  1               
00B386  1               hex_done:
00B386  1  A5 D6            lda tmp
00B388  1  F0 15            beq hex_error
00B38A  1  C9 03            cmp #3
00B38C  1  90 07            bcc hex_byte
00B38E  1  C9 05            cmp #5
00B390  1  90 08            bcc hex_word
00B392  1  4C 27 B2         jmp cmd_error
00B395  1               
00B395  1               hex_byte:
00B395  1  A9 01            lda #1
00B397  1  85 D5            sta value_size
00B399  1  60               rts
00B39A  1               
00B39A  1               hex_word:
00B39A  1  A9 02            lda #2
00B39C  1  85 D5            sta value_size
00B39E  1  60               rts
00B39F  1               
00B39F  1               hex_error:
00B39F  1  4C 27 B2         jmp cmd_error
00B3A2  1               .endproc
00B3A2  1               
00B3A2  1               ; ------------------------------------------------------------
00B3A2  1               ; DECIMAL PARSER
00B3A2  1               ; Syntax: +1234
00B3A2  1               ; Uses repeated 16-bit add:
00B3A2  1               ;   T0 = T0 * 10 + digit
00B3A2  1               ; ------------------------------------------------------------
00B3A2  1               .proc parse_decimal
00B3A2  1  64 CE            stz T0L
00B3A4  1  64 CF            stz T0H
00B3A6  1  64 D5            stz value_size
00B3A8  1               
00B3A8  1               dec_loop:
00B3A8  1  A0 00            ldy #0
00B3AA  1  B1 C2            lda (lineptr),y
00B3AC  1  C9 30            cmp #'0'
00B3AE  1  90 2B            bcc dec_done
00B3B0  1  C9 3A            cmp #'9'+1
00B3B2  1  B0 27            bcs dec_done
00B3B4  1               
00B3B4  1  38               sec
00B3B5  1  E9 30            sbc #'0'
00B3B7  1  85 D6            sta tmp
00B3B9  1               
00B3B9  1  20 3A B4         jsr copy_T0_T1
00B3BC  1               
00B3BC  1  64 CE            stz T0L
00B3BE  1  64 CF            stz T0H
00B3C0  1  A2 0A            ldx #10
00B3C2  1               
00B3C2  1               dec_mul_loop:
00B3C2  1  20 B4 B4         jsr add_T1_T0
00B3C5  1  CA               dex
00B3C6  1  D0 FA            bne dec_mul_loop
00B3C8  1               
00B3C8  1  18               clc
00B3C9  1  A5 CE            lda T0L
00B3CB  1  65 D6            adc tmp
00B3CD  1  85 CE            sta T0L
00B3CF  1  90 02            bcc dec_next
00B3D1  1  E6 CF            inc T0H
00B3D3  1               
00B3D3  1               dec_next:
00B3D3  1  20 19 B4         jsr advance_lineptr
00B3D6  1  E6 D5            inc value_size
00B3D8  1  4C A8 B3         jmp dec_loop
00B3DB  1               
00B3DB  1               dec_done:
00B3DB  1  A5 D5            lda value_size
00B3DD  1  F0 0E            beq dec_error
00B3DF  1  A5 CF            lda T0H
00B3E1  1  F0 05            beq dec_byte
00B3E3  1  A9 02            lda #2
00B3E5  1  85 D5            sta value_size
00B3E7  1  60               rts
00B3E8  1               
00B3E8  1               dec_byte:
00B3E8  1  A9 01            lda #1
00B3EA  1  85 D5            sta value_size
00B3EC  1  60               rts
00B3ED  1               
00B3ED  1               dec_error:
00B3ED  1  4C 27 B2         jmp cmd_error
00B3F0  1               .endproc
00B3F0  1               
00B3F0  1               ; ------------------------------------------------------------
00B3F0  1               ; HEX_DIGIT
00B3F0  1               ; Convert ASCII hex digit to value 0..15.
00B3F0  1               ;
00B3F0  1               ; Input
00B3F0  1               ;   A = ASCII character
00B3F0  1               ;
00B3F0  1               ; Output
00B3F0  1               ;   A = digit value
00B3F0  1               ;   C = 0 valid digit
00B3F0  1               ;   C = 1 invalid digit
00B3F0  1               ; ------------------------------------------------------------
00B3F0  1               hex_digit:
00B3F0  1  C9 30            cmp #'0'
00B3F2  1  90 23            bcc hex_bad
00B3F4  1  C9 3A            cmp #'9'+1
00B3F6  1  90 1A            bcc hex_num

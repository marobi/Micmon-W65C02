00E6E0  2  85 CE            sta T1L
00E6E2  2               
00E6E2  2  A5 C8            lda R2L
00E6E4  2  18               clc
00E6E5  2  69 02            adc #2
00E6E7  2  85 CC            sta T0L
00E6E9  2  A5 C9            lda R2H
00E6EB  2  69 00            adc #0
00E6ED  2  85 CD            sta T0H
00E6EF  2               
00E6EF  2  A5 CE            lda T1L
00E6F1  2  30 0B            bmi rel_neg
00E6F3  2               
00E6F3  2  18               clc
00E6F4  2  65 CC            adc T0L
00E6F6  2  AA               tax
00E6F7  2  A5 CD            lda T0H
00E6F9  2  69 00            adc #0
00E6FB  2  4C 06 E7         jmp rel_print
00E6FE  2               
00E6FE  2               rel_neg:

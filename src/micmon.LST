00E4B2  1  18               clc
00E4B3  1  A5 CE            lda T0L
00E4B5  1  65 D0            adc T1L
00E4B7  1  85 CE            sta T0L
00E4B9  1  A5 CF            lda T0H
00E4BB  1  65 D1            adc T1H
00E4BD  1  85 CF            sta T0H
00E4BF  1  60               rts
00E4C0  1               
00E4C0  1               cmp_R2_R1:
00E4C0  1  A5 CB            lda R2H
00E4C2  1  C5 C9            cmp R1H
00E4C4  1  D0 04            bne cmp_r2_r1_done
00E4C6  1  A5 CA            lda R2L
00E4C8  1  C5 C8            cmp R1L
00E4CA  1               cmp_r2_r1_done:
00E4CA  1  60               rts
00E4CB  1               
00E4CB  1               ;------------------------------------------------
00E4CB  1               print_hex8:
00E4CB  1  48               pha
00E4CC  1  4A               lsr
00E4CD  1  4A               lsr
00E4CE  1  4A               lsr
00E4CF  1  4A               lsr
00E4D0  1  20 D6 E4         jsr print_hex_digit
00E4D3  1  68               pla
00E4D4  1  29 0F            and #$0F
00E4D6  1               
00E4D6  1               print_hex_digit:
00E4D6  1  C9 0A            cmp #10
00E4D8  1  90 06            bcc print_hex_num
00E4DA  1  18               clc
00E4DB  1  69 37            adc #'A'-10
00E4DD  1  4C 13 E5         jmp putchar
00E4E0  1               
00E4E0  1               print_hex_num:
00E4E0  1  18               clc
00E4E1  1  69 30            adc #'0'
00E4E3  1  4C 13 E5         jmp putchar
00E4E6  1               
00E4E6  1               ; ------------------------------------------------------------
00E4E6  1               ; PRINT_HEX16
00E4E6  1               ; Print 16-bit value in hexadecimal.
00E4E6  1               ;
00E4E6  1               ; Input
00E4E6  1               ;   A = high byte
00E4E6  1               ;   X = low byte
00E4E6  1               ; ------------------------------------------------------------
00E4E6  1               print_hex16:
00E4E6  1  DA               phx
00E4E7  1  20 CB E4         jsr print_hex8
00E4EA  1  FA               plx
00E4EB  1  8A               txa
00E4EC  1  4C CB E4         jmp print_hex8
00E4EF  1               
00E4EF  1               
00E4EF  1               print_ascii:
00E4EF  1  C9 20            cmp #$20
00E4F1  1  90 07            bcc ascii_dot
00E4F3  1  C9 7F            cmp #$7F
00E4F5  1  B0 03            bcs ascii_dot
00E4F7  1  4C 13 E5         jmp putchar
00E4FA  1               

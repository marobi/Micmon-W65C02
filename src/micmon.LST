00E4A5  1               ; ------------------------------------------------------------
00E4A5  1               ; ADD_R2_A
00E4A5  1               ; Add unsigned byte in A to 16-bit register R2.
00E4A5  1               ;
00E4A5  1               ; Returns:
00E4A5  1               ;   C = 1 only if 16-bit wrap occurred ($FFFF -> $0000)
00E4A5  1               ;   C = 0 otherwise
00E4A5  1               ; ------------------------------------------------------------
00E4A5  1               add_R2_A:
00E4A5  1  18               clc
00E4A6  1  65 C8            adc R2L
00E4A8  1  85 C8            sta R2L
00E4AA  1  90 04            bcc add_r2_no_wrap
00E4AC  1               
00E4AC  1  E6 C9            inc R2H
00E4AE  1  F0 02            beq add_r2_wrap
00E4B0  1               
00E4B0  1               add_r2_no_wrap:
00E4B0  1  18               clc
00E4B1  1  60               rts
00E4B2  1               
00E4B2  1               add_r2_wrap:

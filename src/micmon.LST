00BA41  2  A9 03            lda #3
00BA43  2  20 E7 B9         jsr compute_rel_offset
00BA46  2  85 D1            sta T1H
00BA48  2  4C 4B BA         jmp ei_store
00BA4B  2               
00BA4B  2               ei_store:
00BA4B  2  A0 00            ldy #0
00BA4D  2  A5 D8            lda asm_opcode
00BA4F  2  91 C6            sta (R0L),y
00BA51  2               
00BA51  2  A5 CD            lda R3H
00BA53  2  C9 01            cmp #1
00BA55  2  F0 32            beq ei_finish
00BA57  2               
00BA57  2  A5 D7            lda asm_mode
00BA59  2  C9 0D            cmp #AM_REL
00BA5B  2  F0 18            beq ei_rel
00BA5D  2  C9 0E            cmp #AM_ZPREL
00BA5F  2  F0 1D            beq ei_zprel
00BA61  2               
00BA61  2  A0 01            ldy #1
00BA63  2  A5 CE            lda T0L
00BA65  2  91 C6            sta (R0L),y
00BA67  2               
00BA67  2  A5 CD            lda R3H
00BA69  2  C9 02            cmp #2
00BA6B  2  F0 1C            beq ei_finish
00BA6D  2               
00BA6D  2  C8               iny
00BA6E  2  A5 CF            lda T0H
00BA70  2  91 C6            sta (R0L),y
00BA72  2  4C 89 BA         jmp ei_finish
00BA75  2               
00BA75  2               ei_rel:
00BA75  2  A0 01            ldy #1
00BA77  2  A5 D1            lda T1H
00BA79  2  91 C6            sta (R0L),y
00BA7B  2  4C 89 BA         jmp ei_finish
00BA7E  2               
00BA7E  2               ei_zprel:
00BA7E  2  A0 01            ldy #1
00BA80  2  A5 D0            lda T1L
00BA82  2  91 C6            sta (R0L),y
00BA84  2  C8               iny
00BA85  2  A5 D1            lda T1H
00BA87  2  91 C6            sta (R0L),y
00BA89  2               
00BA89  2               ei_finish:
00BA89  2  A5 CD            lda R3H
00BA8B  2  20 A6 B4         jsr add_R0_A
00BA8E  2  A5 C6            lda R0L
00BA90  2  85 D2            sta MEML
00BA92  2  A5 C7            lda R0H
00BA94  2  85 D3            sta MEMH

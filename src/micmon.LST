00E518  1               ; ------------------------------------------------------------
00E518  1               ; CHECK_ABORT
00E518  1               ; Test if the user pressed ^C.
00E518  1               ;
00E518  1               ; Returns
00E518  1               ;   C = 1  abort requested
00E518  1               ;   C = 0  continue
00E518  1               ;
00E518  1               ; Wrapper around BIOS_STPKEY so the monitor depends only on
00E518  1               ; this primitive instead of calling the BIOS everywhere.
00E518  1               ; ------------------------------------------------------------
00E518  1               check_abort:
00E518  1  4C 09 F0         jmp BIOS_STPKEY
00E51B  1               
00E51B  1               ; ------------------------------------------------------------
00E51B  1               ; GETLINE
00E51B  1               ; Read a line from input into linebuf.
00E51B  1               ;
00E51B  1               ; Assumptions
00E51B  1               ; - host terminal performs line editing
00E51B  1               ; - CR (0x0D) terminates the line
00E51B  1               ; - line is zero terminated
00E51B  1               ; - max length = 127 characters
00E51B  1               ; ------------------------------------------------------------
00E51B  1               getline:
00E51B  1  A2 00            ldx #0
00E51D  1               
00E51D  1               getline_loop:
00E51D  1  20 12 E5         jsr getchar
00E520  1  C9 0D            cmp #$0D
00E522  1  F0 0F            beq getline_done
00E524  1  C9 0A            cmp #$0A
00E526  1  F0 0B            beq getline_done
00E528  1               
00E528  1  E0 3B            cpx #59
00E52A  1  B0 F1            bcs getline_loop
00E52C  1               
00E52C  1  9D 00 02         sta linebuf,x
00E52F  1  E8               inx
00E530  1  4C 1D E5         jmp getline_loop
00E533  1               
00E533  1               getline_done:
00E533  1  A9 00            lda #0
00E535  1  9D 00 02         sta linebuf,x
00E538  1  60               rts
00E539  1               
00E539  1               print_error:
00E539  1  A9 3F        		lda #'?'
00E53B  1  20 15 E5     		jsr putchar
00E53E  1  4C 06 E5     		jmp newline
00E541  1               
00E541  1               ; command implementations
00E541  1               .include "disasm.asm"
00E541  2               ; ------------------------------------------------------------
00E541  2               ; DISASSEMBLER COMMAND
00E541  2               ; Syntax:
00E541  2               ;   D
00E541  2               ;   D start
00E541  2               ;   D start end
00E541  2               ;
00E541  2               ; Default start is MEM.
00E541  2               ; Default length is 12 instructions.
00E541  2               ; MEM is updated to the next address after the disassembly.
00E541  2               ; ------------------------------------------------------------
00E541  2               cmd_disasm:
00E541  2  20 19 E4         jsr advance_lineptr
00E544  2  20 AC E2         jsr next_token
00E547  2  90 14            bcc dis_default
00E549  2               
00E549  2  20 FD E2         jsr parse_word
00E54C  2  20 43 E4         jsr copy_T0_R0
00E54F  2               
00E54F  2  20 AC E2         jsr next_token
00E552  2  90 0C            bcc dis_one_param
00E554  2               
00E554  2  20 FD E2         jsr parse_word
00E557  2  20 4C E4         jsr copy_T0_R1
00E55A  2  4C 6A E5         jmp dis_prepare_range
00E55D  2               
00E55D  2               dis_default:
00E55D  2  20 67 E4         jsr copy_MEM_R0
00E560  2               
00E560  2               dis_one_param:
00E560  2  20 55 E4         jsr copy_R0_R1
00E563  2  A9 0C            lda #12
00E565  2  85 D2            sta parm_count
00E567  2  4C 72 E5         jmp dis_prepare_count
00E56A  2               
00E56A  2               dis_prepare_range:
00E56A  2  20 AC E2         jsr next_token
00E56D  2  90 21            bcc dis_range_ok
00E56F  2  4C 2C E2         jmp cmd_error
00E572  2               
00E572  2               dis_prepare_count:
00E572  2  20 AC E2         jsr next_token
00E575  2  90 03            bcc dis_count_ok
00E577  2  4C 2C E2         jmp cmd_error
00E57A  2               
00E57A  2               dis_count_ok:
00E57A  2  20 5E E4         jsr copy_R0_R2
00E57D  2               
00E57D  2               dis_loop_count:
00E57D  2  20 18 E5         jsr check_abort
00E580  2  B0 2D            bcs dis_abort
00E582  2  20 B2 E5         jsr disasm_line
00E585  2  B0 23            bcs dis_done
00E587  2  C6 D2            dec parm_count
00E589  2  D0 F2            bne dis_loop_count
00E58B  2  20 70 E4         jsr copy_R2_MEM
00E58E  2  18           		clc
00E58F  2  60           		rts
00E590  2               
00E590  2               dis_range_ok:
00E590  2  20 5E E4         jsr copy_R0_R2
00E593  2               
00E593  2               dis_loop_range:
00E593  2  20 18 E5         jsr check_abort
00E596  2  B0 17            bcs dis_abort
00E598  2               
00E598  2  20 C2 E4         jsr cmp_R2_R1
00E59B  2  90 05            bcc dis_do_line
00E59D  2  F0 03            beq dis_do_line
00E59F  2  4C AA E5         jmp dis_done
00E5A2  2               
00E5A2  2               dis_do_line:
00E5A2  2  20 B2 E5         jsr disasm_line
00E5A5  2  B0 03            bcs dis_done
00E5A7  2  4C 93 E5         jmp dis_loop_range
00E5AA  2               
00E5AA  2               dis_done:
00E5AA  2  20 70 E4         jsr copy_R2_MEM
00E5AD  2  18           		clc
00E5AE  2  60           		rts
00E5AF  2               
00E5AF  2               dis_abort:
00E5AF  2  4C 2C E2         jmp cmd_error
00E5B2  2               
00E5B2  2               ; ------------------------------------------------------------
00E5B2  2               ; DISASSEMBLE ONE LINE
00E5B2  2               ;
00E5B2  2               ; Input
00E5B2  2               ;   R2 = current PC
00E5B2  2               ;
00E5B2  2               ; Internal use
00E5B2  2               ;   T0L = opcode
00E5B2  2               ;   R3L = addressing mode
00E5B2  2               ;   R3H = instruction length
00E5B2  2               ;   T1  = pointer to mnemonic string
00E5B2  2               ;
00E5B2  2               ; Output
00E5B2  2               ;   prints one disassembly line
00E5B2  2               ;   advances R2 by instruction length
00E5B2  2               ; ------------------------------------------------------------
00E5B2  2               disasm_line:
00E5B2  2  20 E3 E5         jsr print_disasm_address
00E5B5  2               
00E5B5  2  A0 00            ldy #0
00E5B7  2  B1 C8            lda (R2L),y
00E5B9  2  85 CC            sta T0L
00E5BB  2  AA               tax
00E5BC  2               
00E5BC  2  BD 5D EC         lda mode_table,x
00E5BF  2  85 CA            sta R3L
00E5C1  2  20 5F E8         jsr get_oplen_from_mode
00E5C4  2  85 CB            sta R3H
00E5C6  2               
00E5C6  2  20 49 E8         jsr get_mnemonic_id_x
00E5C9  2  20 4D E8         jsr get_mnemonic_ptr_id
00E5CC  2               
00E5CC  2  20 F0 E5         jsr print_disasm_bytes
00E5CF  2  20 01 E5         jsr print_space
00E5D2  2  20 01 E5         jsr print_space
00E5D5  2  20 20 E6         jsr print_mnemonic
00E5D8  2  20 2A E6         jsr print_operand
00E5DB  2  20 06 E5         jsr newline
00E5DE  2               
00E5DE  2  A5 CB            lda R3H
00E5E0  2  4C A5 E4         jmp add_R2_A
00E5E3  2               
00E5E3  2               print_disasm_address:
00E5E3  2  A5 C9            lda R2H
00E5E5  2  A6 C8            ldx R2L
00E5E7  2  20 E8 E4         jsr print_hex16
00E5EA  2  20 01 E5         jsr print_space
00E5ED  2  4C 01 E5         jmp print_space
00E5F0  2               
00E5F0  2               ; ------------------------------------------------------------
00E5F0  2               ; PRINT RAW BYTES FIELD
00E5F0  2               ; Shows 1..3 actual instruction bytes and pads to fixed width.
00E5F0  2               ; R3H = instruction length
00E5F0  2               ; ------------------------------------------------------------
00E5F0  2               print_disasm_bytes:
00E5F0  2  A0 00            ldy #0
00E5F2  2               
00E5F2  2               pdb_real_loop:
00E5F2  2  C4 CB            cpy R3H
00E5F4  2  F0 0E            beq pdb_pad
00E5F6  2  B1 C8            lda (R2L),y
00E5F8  2  20 CD E4         jsr print_hex8
00E5FB  2  20 01 E5         jsr print_space
00E5FE  2  C8               iny
00E5FF  2  C0 03            cpy #3
00E601  2  D0 EF            bne pdb_real_loop
00E603  2  60               rts
00E604  2               
00E604  2               pdb_pad:
00E604  2  C0 03            cpy #3
00E606  2  F0 11            beq pdb_done
00E608  2  A9 20            lda #' '
00E60A  2  20 15 E5         jsr putchar
00E60D  2  A9 20            lda #' '
00E60F  2  20 15 E5         jsr putchar
00E612  2  20 01 E5         jsr print_space
00E615  2  C8               iny
00E616  2  4C 04 E6         jmp pdb_pad
00E619  2               
00E619  2               pdb_done:
00E619  2  60               rts
00E61A  2               
00E61A  2               ; ------------------------------------------------------------
00E61A  2               ; GAP BETWEEN BYTE FIELD AND MNEMONIC
00E61A  2               ; ------------------------------------------------------------
00E61A  2               print_disasm_gap:
00E61A  2  20 01 E5         jsr print_space
00E61D  2  4C 01 E5         jmp print_space
00E620  2               
00E620  2               ; ------------------------------------------------------------
00E620  2               ; PRINT MNEMONIC
00E620  2               ; T1 = pointer to zero-terminated mnemonic string
00E620  2               ; ------------------------------------------------------------
00E620  2               print_mnemonic:
00E620  2  A5 CE            lda T1L
00E622  2  A6 CF            ldx T1H
00E624  2  20 62 E2         jsr print_str
00E627  2  4C 01 E5         jmp print_space
00E62A  2               
00E62A  2               ; ------------------------------------------------------------
00E62A  2               ; PRINT OPERAND
00E62A  2               ; R3L = addressing mode
00E62A  2               ; R2  = current instruction address
00E62A  2               ; ------------------------------------------------------------
00E62A  2               print_operand:
00E62A  2  A5 CA            lda R3L
00E62C  2  0A               asl
00E62D  2  AA               tax
00E62E  2  BD 98 E7         lda operand_vecs,x
00E631  2  85 C2            sta jmpvec
00E633  2  E8               inx
00E634  2  BD 98 E7         lda operand_vecs,x
00E637  2  85 C3            sta jmpvec+1
00E639  2  6C C2 00         jmp (jmpvec)
00E63C  2               
00E63C  2               ; ------------------------------------------------------------
00E63C  2               ; ADDRESSING MODE FORMATTERS
00E63C  2               ; ------------------------------------------------------------
00E63C  2               fmt_imp:
00E63C  2  60               rts
00E63D  2               
00E63D  2               fmt_acc:
00E63D  2  A9 41            lda #'A'
00E63F  2  4C 15 E5         jmp putchar

00B9EC  2               ; ------------------------------------------------------------
00B9EC  2               ; COMPUTE_REL_OFFSET
00B9EC  2               ;
00B9EC  2               ; Input:
00B9EC  2               ;   A  = instruction length (2 or 3)
00B9EC  2               ;   R0 = instruction address
00B9EC  2               ;   T0 = target address
00B9EC  2               ;
00B9EC  2               ; Output:
00B9EC  2               ;   A  = signed 8-bit relative offset
00B9EC  2               ;
00B9EC  2               ; Error:
00B9EC  2               ;   jumps to cmd_error if target is out of range
00B9EC  2               ; ------------------------------------------------------------
00B9EC  2               compute_rel_offset:
00B9EC  2  85 D4            sta parm_count
00B9EE  2               
00B9EE  2                   ; R3 = base = R0 + instruction length
00B9EE  2  A5 C6            lda R0L
00B9F0  2  18               clc
00B9F1  2  65 D4            adc parm_count
00B9F3  2  85 CC            sta R3L
00B9F5  2  A5 C7            lda R0H
00B9F7  2  69 00            adc #0
00B9F9  2  85 CD            sta R3H
00B9FB  2               
00B9FB  2                   ; diff = target - base   (wrapped 16-bit subtraction)
00B9FB  2  38               sec
00B9FC  2  A5 CE            lda T0L
00B9FE  2  E5 CC            sbc R3L
00BA00  2  85 D0            sta T1L
00BA02  2  A5 CF            lda T0H
00BA04  2  E5 CD            sbc R3H
00BA06  2  85 D1            sta T1H
00BA08  2               
00BA08  2                   ; valid if:
00BA08  2                   ;   T1 = 00:00..00:7F   (+0 .. +127)
00BA08  2                   ;   T1 = FF:80..FF:FF   (-128 .. -1)
00BA08  2               
00BA08  2  A5 D1            lda T1H
00BA0A  2  F0 07            beq cro_pos
00BA0C  2  C9 FF            cmp #$FF
00BA0E  2  F0 0C            beq cro_neg
00BA10  2  4C 49 B2         jmp cmd_error
00BA13  2               
00BA13  2               cro_pos:
00BA13  2  A5 D0            lda T1L
00BA15  2  C9 80            cmp #$80
00BA17  2  90 0C            bcc cro_ok
00BA19  2  4C 49 B2         jmp cmd_error
00BA1C  2               
00BA1C  2               cro_neg:
00BA1C  2  A5 D0            lda T1L
00BA1E  2  C9 80            cmp #$80
00BA20  2  B0 03            bcs cro_ok
00BA22  2  4C 49 B2         jmp cmd_error
00BA25  2               
00BA25  2               cro_ok:
00BA25  2  A5 D0            lda T1L
00BA27  2  60               rts

00E98E  2               ; ------------------------------------------------------------
00E98E  2               ; FIND OPCODE
00E98E  2               ;
00E98E  2               ; Input:
00E98E  2               ;   mnemonic in R1/mnem_len
00E98E  2               ;   asm_mode
00E98E  2               ;
00E98E  2               ; Output:
00E98E  2               ;   C = 1 found
00E98E  2               ;   asm_opcode = opcode
00E98E  2               ;   C = 0 not found
00E98E  2               ;
00E98E  2               ; Special case:
00E98E  2               ;   branch mnemonics accept AM_REL when operand parsed as ZP or ABS
00E98E  2               ; ------------------------------------------------------------
00E98E  2               find_opcode:
00E98E  2  A2 00            ldx #0
00E990  2               
00E990  2               fo_loop:
00E990  2  BD 31 EC         lda mode_table,x
00E993  2  C5 D5            cmp asm_mode
00E995  2  F0 11            beq fo_check_mnemonic_direct
00E997  2               
00E997  2  C9 0D            cmp #AM_REL
00E999  2  D0 35            bne fo_next
00E99B  2               
00E99B  2  A5 D5            lda asm_mode
00E99D  2  C9 03            cmp #AM_ZP
00E99F  2  F0 15            beq fo_check_mnemonic_rel
00E9A1  2  C9 06            cmp #AM_ABS
00E9A3  2  F0 11            beq fo_check_mnemonic_rel
00E9A5  2  4C D0 E9         jmp fo_next
00E9A8  2               
00E9A8  2               fo_check_mnemonic_direct:
00E9A8  2  20 1D E8         jsr get_mnemonic_id_x
00E9AB  2  20 21 E8         jsr get_mnemonic_ptr_id
00E9AE  2  20 FC E7         jsr compare_mnemonic
00E9B1  2  B0 19            bcs fo_found_direct
00E9B3  2  4C D0 E9         jmp fo_next
00E9B6  2               
00E9B6  2               fo_check_mnemonic_rel:
00E9B6  2  20 1D E8         jsr get_mnemonic_id_x
00E9B9  2  20 21 E8         jsr get_mnemonic_ptr_id
00E9BC  2  20 FC E7         jsr compare_mnemonic
00E9BF  2  B0 03            bcs fo_found_rel
00E9C1  2  4C D0 E9         jmp fo_next
00E9C4  2               
00E9C4  2               fo_found_rel:
00E9C4  2  A9 0D            lda #AM_REL
00E9C6  2  85 D5            sta asm_mode
00E9C8  2  86 D6            stx asm_opcode
00E9CA  2  38               sec
00E9CB  2  60               rts
00E9CC  2               
00E9CC  2               fo_found_direct:
00E9CC  2  86 D6            stx asm_opcode

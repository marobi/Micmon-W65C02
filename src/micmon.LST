00E9D7  2  20 4D E8         jsr get_mnemonic_ptr_id
00E9DA  2  20 28 E8         jsr compare_mnemonic
00E9DD  2  B0 19            bcs fo_found_direct
00E9DF  2  4C FC E9         jmp fo_next
00E9E2  2               
00E9E2  2               fo_check_mnemonic_rel:
00E9E2  2  20 49 E8         jsr get_mnemonic_id_x
00E9E5  2  20 4D E8         jsr get_mnemonic_ptr_id
00E9E8  2  20 28 E8         jsr compare_mnemonic
00E9EB  2  B0 03            bcs fo_found_rel
00E9ED  2  4C FC E9         jmp fo_next
00E9F0  2               

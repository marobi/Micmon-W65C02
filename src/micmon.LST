00BA28  2               ; EMIT INSTRUCTION
00BA28  2               ; Uses asm_opcode, asm_mode and operand value(s).
00BA28  2               ; Updates MEM to next address.
00BA28  2               ; Writes nothing if relative offset is out of range.
00BA28  2               ; ------------------------------------------------------------
00BA28  2               emit_instruction:
00BA28  2  A5 D7            lda asm_mode
00BA2A  2  20 78 B8         jsr get_oplen_from_mode
00BA2D  2  85 CD            sta R3H
00BA2F  2               
00BA2F  2                   ; for relative forms, validate offset before storing opcode
00BA2F  2  A5 D7            lda asm_mode
00BA31  2  C9 0D            cmp #AM_REL
00BA33  2  F0 07            beq ei_prep_rel
00BA35  2  C9 0E            cmp #AM_ZPREL
00BA37  2  F0 0D            beq ei_prep_zprel
00BA39  2  4C 50 BA         jmp ei_store
00BA3C  2               
00BA3C  2               ei_prep_rel:
00BA3C  2  A9 02            lda #2
00BA3E  2  20 EC B9         jsr compute_rel_offset
00BA41  2  85 D1            sta T1H
00BA43  2  4C 50 BA         jmp ei_store
00BA46  2               
00BA46  2               ei_prep_zprel:
00BA46  2  A9 03            lda #3
00BA48  2  20 EC B9         jsr compute_rel_offset
00BA4B  2  85 D1            sta T1H
00BA4D  2  4C 50 BA         jmp ei_store
00BA50  2               
00BA50  2               ei_store:
00BA50  2  A0 00            ldy #0
00BA52  2  A5 D8            lda asm_opcode
00BA54  2  91 C6            sta (R0L),y
00BA56  2               
00BA56  2  A5 CD            lda R3H
00BA58  2  C9 01            cmp #1
00BA5A  2  F0 32            beq ei_finish
00BA5C  2               
00BA5C  2  A5 D7            lda asm_mode
00BA5E  2  C9 0D            cmp #AM_REL
00BA60  2  F0 18            beq ei_rel
00BA62  2  C9 0E            cmp #AM_ZPREL
00BA64  2  F0 1D            beq ei_zprel
00BA66  2               
00BA66  2  A0 01            ldy #1
00BA68  2  A5 CE            lda T0L
00BA6A  2  91 C6            sta (R0L),y
00BA6C  2               
00BA6C  2  A5 CD            lda R3H
00BA6E  2  C9 02            cmp #2
00BA70  2  F0 1C            beq ei_finish
00BA72  2               
00BA72  2  C8               iny
00BA73  2  A5 CF            lda T0H
00BA75  2  91 C6            sta (R0L),y
00BA77  2  4C 8E BA         jmp ei_finish
00BA7A  2               
00BA7A  2               ei_rel:
00BA7A  2  A0 01            ldy #1
00BA7C  2  A5 D1            lda T1H
00BA7E  2  91 C6            sta (R0L),y
00BA80  2  4C 8E BA         jmp ei_finish
00BA83  2               
00BA83  2               ei_zprel:
00BA83  2  A0 01            ldy #1
00BA85  2  A5 D0            lda T1L
00BA87  2  91 C6            sta (R0L),y
00BA89  2  C8               iny
00BA8A  2  A5 D1            lda T1H
00BA8C  2  91 C6            sta (R0L),y
00BA8E  2               
00BA8E  2               ei_finish:
00BA8E  2  A5 CD            lda R3H
00BA90  2  20 A9 B4         jsr add_R0_A
00BA93  2  A5 C6            lda R0L
00BA95  2  85 D2            sta MEML

00E499  1  60               rts
00E49A  1               
00E49A  1               ; ------------------------------------------------------------
00E49A  1               ; ADD_R2_A
00E49A  1               ; Add unsigned byte in A to 16-bit register R2.
00E49A  1               ;
00E49A  1               ; Returns:
00E49A  1               ;   C = 1 only if 16-bit wrap occurred ($FFFF -> $0000)
00E49A  1               ;   C = 0 otherwise
00E49A  1               ; ------------------------------------------------------------
00E49A  1               add_R2_A:
00E49A  1  18               clc
00E49B  1  65 C8            adc R2L
00E49D  1  85 C8            sta R2L
00E49F  1  90 04            bcc add_r2_no_wrap
00E4A1  1               
00E4A1  1  E6 C9            inc R2H
00E4A3  1  F0 02            beq add_r2_wrap
00E4A5  1               
00E4A5  1               add_r2_no_wrap:
00E4A5  1  18               clc
00E4A6  1  60               rts
00E4A7  1               
00E4A7  1               add_r2_wrap:
00E4A7  1  38               sec
00E4A8  1  60               rts
00E4A9  1               
00E4A9  1               add_T1_T0:

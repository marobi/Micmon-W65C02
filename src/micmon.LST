00B534  1               ; ------------------------------------------------------------
00B534  1               ; GETLINE
00B534  1               ; Read a line from input into linebuf.
00B534  1               ;
00B534  1               ; Assumptions
00B534  1               ; - host terminal performs line editing
00B534  1               ; - CR (0x0D) terminates the line
00B534  1               ; - line is zero terminated
00B534  1               ; - max length = 127 characters
00B534  1               ; ------------------------------------------------------------
00B534  1               .proc getline
00B534  1  A2 00            ldx #0
00B536  1               
00B536  1               getline_loop:
00B536  1  20 5A B5         jsr getchar
00B539  1  C9 0D            cmp #$0D
00B53B  1  F0 0F            beq getline_done
00B53D  1  C9 0A            cmp #$0A
00B53F  1  F0 0B            beq getline_done
00B541  1               
00B541  1  E0 3B            cpx #59
00B543  1  B0 F1            bcs getline_loop
00B545  1               
00B545  1  9D 00 02         sta linebuf,x
00B548  1  E8               inx
00B549  1  4C 36 B5         jmp getline_loop
00B54C  1               
00B54C  1               getline_done:
00B54C  1  A9 00            lda #0
00B54E  1  9D 00 02         sta linebuf,x
00B551  1  60               rts
00B552  1               .endproc
00B552  1               
00B552  1               .proc print_error
00B552  1  A9 3F        	lda #'?'
00B554  1  20 60 B5     	jsr putchar
00B557  1  4C 28 B5     	jmp newline
00B55A  1               .endproc
00B55A  1               

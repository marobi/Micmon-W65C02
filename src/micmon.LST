00BB2C  2  4F 52 41 00  mn_ORA:  .byte "ORA",0
00BB30  2  50 48 41 00  mn_PHA:  .byte "PHA",0
00BB34  2  50 48 50 00  mn_PHP:  .byte "PHP",0

00B9A5  2               ; FIND OPCODE
00B9A5  2               ;
00B9A5  2               ; Input:
00B9A5  2               ;   mnemonic in R1/mnem_len
00B9A5  2               ;   asm_mode
00B9A5  2               ;
00B9A5  2               ; Output:
00B9A5  2               ;   C = 1 found
00B9A5  2               ;   asm_opcode = opcode
00B9A5  2               ;   C = 0 not found
00B9A5  2               ;
00B9A5  2               ; Special case:
00B9A5  2               ;   branch mnemonics accept AM_REL when operand parsed as ZP or ABS
00B9A5  2               ; ------------------------------------------------------------
00B9A5  2               find_opcode:
00B9A5  2  A2 00            ldx #0
00B9A7  2               

00E4B3  1  D0 04            bne cmp_r2_r1_done
00E4B5  1  A5 C8            lda R2L
00E4B7  1  C5 C6            cmp R1L
00E4B9  1               cmp_r2_r1_done:
00E4B9  1  60               rts
00E4BA  1               
00E4BA  1               ;------------------------------------------------
00E4BA  1               print_hex8:
00E4BA  1  48               pha
00E4BB  1  4A               lsr
00E4BC  1  4A               lsr
00E4BD  1  4A               lsr
00E4BE  1  4A               lsr
00E4BF  1  20 C5 E4         jsr print_hex_digit
00E4C2  1  68               pla
00E4C3  1  29 0F            and #$0F
00E4C5  1               ;    jsr print_hex_digit
00E4C5  1               ;    rts
00E4C5  1               
00E4C5  1               print_hex_digit:
00E4C5  1  C9 0A            cmp #10
00E4C7  1  90 06            bcc print_hex_num
00E4C9  1  18               clc
00E4CA  1  69 37            adc #'A'-10
00E4CC  1  4C 02 E5         jmp putchar
00E4CF  1               
00E4CF  1               print_hex_num:
00E4CF  1  18               clc
00E4D0  1  69 30            adc #'0'
00E4D2  1  4C 02 E5         jmp putchar
00E4D5  1               
00E4D5  1               ; ------------------------------------------------------------
00E4D5  1               ; PRINT_HEX16
00E4D5  1               ; Print 16-bit value in hexadecimal.
00E4D5  1               ;
00E4D5  1               ; Input
00E4D5  1               ;   A = high byte
00E4D5  1               ;   X = low byte
00E4D5  1               ; ------------------------------------------------------------
00E4D5  1               print_hex16:
00E4D5  1  DA               phx
00E4D6  1  20 BA E4         jsr print_hex8
00E4D9  1  FA               plx
00E4DA  1  8A               txa
00E4DB  1  4C BA E4         jmp print_hex8
00E4DE  1               
00E4DE  1               
00E4DE  1               print_ascii:
00E4DE  1  C9 20            cmp #$20
00E4E0  1  90 07            bcc ascii_dot
00E4E2  1  C9 7F            cmp #$7F
00E4E4  1  B0 03            bcs ascii_dot
00E4E6  1  4C 02 E5         jmp putchar
00E4E9  1               
00E4E9  1               
00E4E9  1               ascii_dot:
00E4E9  1  A9 2E            lda #'.'
00E4EB  1  4C 02 E5         jmp putchar
00E4EE  1               
00E4EE  1               print_space:

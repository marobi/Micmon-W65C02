00B9C0  2  20 3C B8         jsr compare_mnemonic
00B9C3  2  B0 19            bcs fo_found_direct
00B9C5  2  4C E2 B9         jmp fo_next
00B9C8  2               
00B9C8  2               fo_check_mnemonic_rel:
00B9C8  2  20 5D B8         jsr get_mnemonic_id_x
00B9CB  2  20 61 B8         jsr get_mnemonic_ptr_id
00B9CE  2  20 3C B8         jsr compare_mnemonic
00B9D1  2  B0 03            bcs fo_found_rel

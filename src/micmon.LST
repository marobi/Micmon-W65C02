00E48C  1  65 C6            adc R1L
00E48E  1  85 C6            sta R1L
00E490  1  90 04            bcc add_r1_no_wrap
00E492  1  E6 C7            inc R1H
00E494  1  F0 02            beq add_r1_wrap
00E496  1               add_r1_no_wrap:

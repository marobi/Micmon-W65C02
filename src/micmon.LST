00E463  1  85 C8            sta R2L
00E465  1  A5 C5            lda R0H
00E467  1  85 C9            sta R2H
00E469  1  60               rts
00E46A  1               
00E46A  1               copy_MEM_R0:
00E46A  1  A5 D0            lda MEML
00E46C  1  85 C4            sta R0L
00E46E  1  A5 D1            lda MEMH
00E470  1  85 C5            sta R0H
00E472  1  60               rts
00E473  1               
00E473  1               copy_R2_MEM:
00E473  1  A5 C8            lda R2L
00E475  1  85 D0            sta MEML
00E477  1  A5 C9            lda R2H
00E479  1  85 D1            sta MEMH

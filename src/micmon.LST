00B9CA  2               ; ------------------------------------------------------------
00B9CA  2               ; COMPUTE_REL_OFFSET
00B9CA  2               ;
00B9CA  2               ; Input:
00B9CA  2               ;   A  = instruction length (2 or 3)
00B9CA  2               ;   R0 = instruction address
00B9CA  2               ;   T0 = target address
00B9CA  2               ;
00B9CA  2               ; Output:
00B9CA  2               ;   A  = signed 8-bit relative offset
00B9CA  2               ;
00B9CA  2               ; Error:
00B9CA  2               ;   jumps to cmd_error if target is out of range
00B9CA  2               ; ------------------------------------------------------------
00B9CA  2               compute_rel_offset:
00B9CA  2  85 D4            sta parm_count
00B9CC  2               
00B9CC  2                   ; R3 = base = R0 + instruction length
00B9CC  2  A5 C6            lda R0L
00B9CE  2  18               clc
00B9CF  2  65 D4            adc parm_count
00B9D1  2  85 CC            sta R3L
00B9D3  2  A5 C7            lda R0H
00B9D5  2  69 00            adc #0
00B9D7  2  85 CD            sta R3H
00B9D9  2               
00B9D9  2                   ; diff = target - base   (wrapped 16-bit subtraction)
00B9D9  2  38               sec
00B9DA  2  A5 CE            lda T0L
00B9DC  2  E5 CC            sbc R3L
00B9DE  2  85 D0            sta T1L
00B9E0  2  A5 CF            lda T0H
00B9E2  2  E5 CD            sbc R3H
00B9E4  2  85 D1            sta T1H
00B9E6  2               
00B9E6  2                   ; valid if:
00B9E6  2                   ;   T1 = 00:00..00:7F   (+0 .. +127)
00B9E6  2                   ;   T1 = FF:80..FF:FF   (-128 .. -1)
00B9E6  2               
00B9E6  2  A5 D1            lda T1H
00B9E8  2  F0 07            beq cro_pos
00B9EA  2  C9 FF            cmp #$FF
00B9EC  2  F0 0C            beq cro_neg
00B9EE  2  4C 27 B2         jmp cmd_error
00B9F1  2               
00B9F1  2               cro_pos:
00B9F1  2  A5 D0            lda T1L
00B9F3  2  C9 80            cmp #$80
00B9F5  2  90 0C            bcc cro_ok
00B9F7  2  4C 27 B2         jmp cmd_error
00B9FA  2               
00B9FA  2               cro_neg:
00B9FA  2  A5 D0            lda T1L
00B9FC  2  C9 80            cmp #$80
00B9FE  2  B0 03            bcs cro_ok
00BA00  2  4C 27 B2         jmp cmd_error
00BA03  2               
00BA03  2               cro_ok:
00BA03  2  A5 D0            lda T1L
00BA05  2  60               rts

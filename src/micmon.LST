00E425  1  B1 C0            lda (lineptr),y
00E427  1  C9 20            cmp #' '
00E429  1  D0 06            bne skip_done
00E42B  1  20 1C E4         jsr advance_lineptr
00E42E  1  4C 23 E4         jmp skip_spaces
00E431  1               
00E431  1               skip_done:
00E431  1  60               rts
00E432  1               
00E432  1               toupper:

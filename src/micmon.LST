00B840  2               
00B840  2               ; ------------------------------------------------------------
00B840  2               ; FETCH MNEMONIC ID FOR OPCODE IN X
00B840  2               ; Uses mnemonic_id_table as a 256-byte table.
00B840  2               ;
00B840  2               ; Output:
00B840  2               ;   A = mnemonic ID
00B840  2               ; Preserves X
00B840  2               ; ------------------------------------------------------------
00B840  2               get_mnemonic_id_x:
00B840  2  BD FD BD         lda mnemonic_id_table,x
00B843  2  60               rts
00B844  2               
00B844  2               ; ------------------------------------------------------------
00B844  2               ; FETCH MNEMONIC POINTER FOR MNEMONIC ID IN A
00B844  2               ; Uses mnemonic_text_ptrs as a compact unique-pointer table.
00B844  2               ;
00B844  2               ; Input:
00B844  2               ;   A = mnemonic ID
00B844  2               ;
00B844  2               ; Output:
00B844  2               ;   T1 = pointer to zero-terminated mnemonic string
00B844  2               ; Preserves X
00B844  2               ; ------------------------------------------------------------
00B844  2               get_mnemonic_ptr_id:
00B844  2  DA               phx
00B845  2               
00B845  2  85 D6            sta tmp
00B847  2  0A               asl
00B848  2  AA               tax
00B849  2               
00B849  2  BD 37 BD         lda mnemonic_text_ptrs,x
00B84C  2  85 D0            sta T1L
00B84E  2  E8               inx
00B84F  2  BD 37 BD         lda mnemonic_text_ptrs,x
00B852  2  85 D1            sta T1H
00B854  2               
00B854  2  FA               plx
00B855  2  60               rts
00B856  2               
00B856  2               ; ------------------------------------------------------------
00B856  2               ; GET INSTRUCTION LENGTH FROM ADDRESSING MODE
00B856  2               ;
00B856  2               ; Input:
00B856  2               ;   A = addressing mode
00B856  2               ;
00B856  2               ; Output:
00B856  2               ;   A = instruction length
00B856  2               ;
00B856  2               ; Notes:
00B856  2               ;   AM_IMP, AM_ACC, AM_ILL      -> 1
00B856  2               ;   AM_IMM, AM_ZP, AM_ZPX,
00B856  2               ;   AM_ZPY, AM_INDX, AM_INDY,
00B856  2               ;   AM_ZPIND, AM_REL            -> 2
00B856  2               ;   AM_ABS, AM_ABSX, AM_ABSY,
00B856  2               ;   AM_IND, AM_ZPREL, AM_AIX    -> 3
00B856  2               ; ------------------------------------------------------------
00B856  2               get_oplen_from_mode:
00B856  2  DA               phx
00B857  2  AA               tax
00B858  2  BD 26 BD         lda mode_len_table,x
00B85B  2  FA               plx
00B85C  2  60           		rts
00B85D  2               
00B85D  2               ; ------------------------------------------------------------
00B85D  2               ; PARSE ASSEMBLER OPERAND
00B85D  2               ;
00B85D  2               ; Output:
00B85D  2               ;   asm_mode = parsed addressing mode
00B85D  2               ;   T0       = primary operand value
00B85D  2               ;   T1L      = zp byte for ZPREL
00B85D  2               ;
00B85D  2               ; Supported:
00B85D  2               ;   implied
00B85D  2               ;   A
00B85D  2               ;   #imm
00B85D  2               ;   zp / abs
00B85D  2               ;   zp,X / abs,X
00B85D  2               ;   zp,Y / abs,Y
00B85D  2               ;   (zp)
00B85D  2               ;   (abs)
00B85D  2               ;   (zp,X)
00B85D  2               ;   (abs,X)
00B85D  2               ;   (zp),Y
00B85D  2               ;   zp,target   (for BBR/BBS)
00B85D  2               ; ------------------------------------------------------------
00B85D  2               parse_asm_operand:
00B85D  2  20 AC B2         jsr next_token
00B860  2  B0 05            bcs pa_have_operand
00B862  2  A9 00            lda #AM_IMP
00B864  2  85 D7            sta asm_mode
00B866  2  60               rts
00B867  2               
00B867  2               pa_have_operand:
00B867  2  A0 00            ldy #0
00B869  2  B1 C2            lda (lineptr),y
00B86B  2  C9 23            cmp #'#'
00B86D  2  F0 2B            beq pa_imm
00B86F  2  C9 28            cmp #'('
00B871  2  F0 32            beq pa_paren
00B873  2               
00B873  2                   ; bare A can mean accumulator, but only if it is exactly "A"
00B873  2  20 2F B4         jsr toupper
00B876  2  C9 41            cmp #'A'
00B878  2  F0 03            beq pa_have_a
00B87A  2  4C 23 B9     		jmp pa_value
00B87D  2               
00B87D  2               pa_have_a:
00B87D  2  A0 01            ldy #1
00B87F  2  B1 C2            lda (lineptr),y
00B881  2  F0 07            beq pa_try_acc
00B883  2  C9 20            cmp #' '
00B885  2  F0 03            beq pa_try_acc
00B887  2  4C 23 B9         jmp pa_value
00B88A  2               
00B88A  2               pa_try_acc:
00B88A  2  20 19 B4         jsr advance_lineptr
00B88D  2  20 AC B2         jsr next_token
00B890  2  90 03            bcc pa_acc
00B892  2  4C 27 B2         jmp cmd_error
00B895  2               
00B895  2               pa_acc:
00B895  2  A9 01            lda #AM_ACC
00B897  2  85 D7            sta asm_mode
00B899  2  60               rts
00B89A  2               
00B89A  2               pa_imm:
00B89A  2  20 19 B4         jsr advance_lineptr
00B89D  2  20 F0 B2         jsr parse_byte
00B8A0  2  A9 02            lda #AM_IMM
00B8A2  2  85 D7            sta asm_mode
00B8A4  2  60               rts
00B8A5  2               
00B8A5  2               pa_paren:
00B8A5  2  20 19 B4         jsr advance_lineptr
00B8A8  2  20 FD B2         jsr parse_word

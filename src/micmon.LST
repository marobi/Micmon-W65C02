00E7BA  1               
00E7BA  1               .include "asm.asm"
00E7BA  2               ; ------------------------------------------------------------
00E7BA  2               ; SIMPLE ASSEMBLER COMMAND
00E7BA  2               ; Syntax:
00E7BA  2               ;   A [addr] mnemonic [operand]
00E7BA  2               ;
00E7BA  2               ; If addr is omitted, MEM is used.
00E7BA  2               ; On success MEM is updated to the next address.
00E7BA  2               ; ------------------------------------------------------------
00E7BA  2               cmd_asm:
00E7BA  2  20 19 E4         jsr advance_lineptr
00E7BD  2  20 AC E2         jsr next_token
00E7C0  2  B0 03            bcs ca_have_first
00E7C2  2  4C 2C E2         jmp cmd_error
00E7C5  2               
00E7C5  2               ca_have_first:
00E7C5  2  A0 00            ldy #0
00E7C7  2  B1 C0            lda (lineptr),y
00E7C9  2  20 2F E4         jsr toupper
00E7CC  2  C9 41            cmp #'A'
00E7CE  2  90 04            bcc ca_with_addr
00E7D0  2  C9 5B            cmp #'Z'+1
00E7D2  2  90 0E            bcc ca_default_addr
00E7D4  2               
00E7D4  2               ca_with_addr:
00E7D4  2  20 FD E2         jsr parse_word
00E7D7  2  20 43 E4         jsr copy_T0_R0
00E7DA  2  20 AC E2         jsr next_token
00E7DD  2  B0 06            bcs ca_mnemonic
00E7DF  2  4C 2C E2         jmp cmd_error
00E7E2  2               
00E7E2  2               ca_default_addr:
00E7E2  2  20 67 E4         jsr copy_MEM_R0
00E7E5  2               
00E7E5  2               ca_mnemonic:
00E7E5  2  20 5E E4         jsr copy_R0_R2
00E7E8  2  20 01 E8         jsr parse_mnemonic
00E7EB  2  20 94 E8         jsr parse_asm_operand
00E7EE  2  20 AC E2         jsr next_token
00E7F1  2  90 03            bcc ca_find
00E7F3  2  4C 2C E2         jmp cmd_error
00E7F6  2               
00E7F6  2               ca_find:
00E7F6  2  20 BA E9         jsr find_opcode
00E7F9  2  B0 03            bcs ca_emit
00E7FB  2  4C 2C E2         jmp cmd_error
00E7FE  2               
00E7FE  2               ca_emit:
00E7FE  2  4C 3D EA         jmp emit_instruction
00E801  2               
00E801  2               ; ------------------------------------------------------------
00E801  2               ; PARSE MNEMONIC
00E801  2               ; lineptr must point at the first mnemonic character.
00E801  2               ; Saves start pointer in R1 and length in mnem_len.
00E801  2               ; Advances lineptr to the first character after the mnemonic.
00E801  2               ; ------------------------------------------------------------
00E801  2               parse_mnemonic:
00E801  2  20 20 E4         jsr skip_spaces
00E804  2  A5 C0            lda lineptr
00E806  2  85 C6            sta R1L
00E808  2  A5 C1            lda lineptr+1
00E80A  2  85 C7            sta R1H
00E80C  2  64 D7            stz mnem_len
00E80E  2               
00E80E  2               pm_loop:
00E80E  2  A0 00            ldy #0
00E810  2  B1 C0            lda (lineptr),y
00E812  2  F0 0C            beq pm_done
00E814  2  C9 20            cmp #' '
00E816  2  F0 08            beq pm_done
00E818  2  E6 D7            inc mnem_len
00E81A  2  20 19 E4         jsr advance_lineptr
00E81D  2  4C 0E E8         jmp pm_loop
00E820  2               
00E820  2               pm_done:
00E820  2  A5 D7            lda mnem_len
00E822  2  D0 03            bne pm_ok
00E824  2  4C 2C E2         jmp cmd_error
00E827  2               
00E827  2               pm_ok:
00E827  2  60               rts
00E828  2               
00E828  2               ; ------------------------------------------------------------
00E828  2               ; COMPARE INPUT MNEMONIC AGAINST CANDIDATE STRING
00E828  2               ; Input:
00E828  2               ;   R1 = input mnemonic start
00E828  2               ;   mnem_len = input mnemonic length
00E828  2               ;   T1 = candidate zero-terminated mnemonic pointer
00E828  2               ;
00E828  2               ; Output:
00E828  2               ;   C = 1 match
00E828  2               ;   C = 0 no match
00E828  2               ; ------------------------------------------------------------
00E828  2               compare_mnemonic:
00E828  2  A0 00            ldy #0
00E82A  2               
00E82A  2               cm_loop:
00E82A  2  C4 D7            cpy mnem_len
00E82C  2  F0 13            beq cm_end_input
00E82E  2               
00E82E  2  B1 C6            lda (R1L),y
00E830  2  20 2F E4         jsr toupper
00E833  2  85 D4            sta tmp
00E835  2               
00E835  2  B1 CE            lda (T1L),y
00E837  2  F0 0C            beq cm_no
00E839  2  C5 D4            cmp tmp
00E83B  2  D0 08            bne cm_no
00E83D  2               
00E83D  2  C8               iny
00E83E  2  4C 2A E8         jmp cm_loop
00E841  2               
00E841  2               cm_end_input:
00E841  2  B1 CE            lda (T1L),y
00E843  2  F0 02            beq cm_yes
00E845  2               
00E845  2               cm_no:
00E845  2  18               clc
00E846  2  60               rts
00E847  2               
00E847  2               cm_yes:
00E847  2  38               sec
00E848  2  60               rts
00E849  2               
00E849  2               
00E849  2               ; ------------------------------------------------------------
00E849  2               ; FETCH MNEMONIC ID FOR OPCODE IN X
00E849  2               ; Uses mnemonic_id_table as a 256-byte table.
00E849  2               ;
00E849  2               ; Output:
00E849  2               ;   A = mnemonic ID
00E849  2               ; Preserves X
00E849  2               ; ------------------------------------------------------------
00E849  2               get_mnemonic_id_x:
00E849  2  BD 23 EE         lda mnemonic_id_table,x
00E84C  2  60               rts
00E84D  2               
00E84D  2               ; ------------------------------------------------------------
00E84D  2               ; FETCH MNEMONIC POINTER FOR MNEMONIC ID IN A
00E84D  2               ; Uses mnemonic_text_ptrs as a compact unique-pointer table.
00E84D  2               ;
00E84D  2               ; Input:
00E84D  2               ;   A = mnemonic ID
00E84D  2               ;
00E84D  2               ; Output:
00E84D  2               ;   T1 = pointer to zero-terminated mnemonic string
00E84D  2               ; Preserves X
00E84D  2               ; ------------------------------------------------------------
00E84D  2               get_mnemonic_ptr_id:
00E84D  2  DA               phx
00E84E  2               
00E84E  2  85 D4            sta tmp
00E850  2  0A               asl
00E851  2  AA               tax
00E852  2               
00E852  2  BD 5D ED         lda mnemonic_text_ptrs,x
00E855  2  85 CE            sta T1L
00E857  2  E8               inx
00E858  2  BD 5D ED         lda mnemonic_text_ptrs,x
00E85B  2  85 CF            sta T1H
00E85D  2               
00E85D  2  FA               plx
00E85E  2  60               rts
00E85F  2               
00E85F  2               ; ------------------------------------------------------------
00E85F  2               ; GET INSTRUCTION LENGTH FROM ADDRESSING MODE
00E85F  2               ;
00E85F  2               ; Input:
00E85F  2               ;   A = addressing mode
00E85F  2               ;
00E85F  2               ; Output:
00E85F  2               ;   A = instruction length
00E85F  2               ;
00E85F  2               ; Notes:
00E85F  2               ;   AM_IMP, AM_ACC, AM_ILL      -> 1
00E85F  2               ;   AM_IMM, AM_ZP, AM_ZPX,
00E85F  2               ;   AM_ZPY, AM_INDX, AM_INDY,
00E85F  2               ;   AM_ZPIND, AM_REL            -> 2
00E85F  2               ;   AM_ABS, AM_ABSX, AM_ABSY,
00E85F  2               ;   AM_IND, AM_ZPREL, AM_AIX    -> 3
00E85F  2               ; ------------------------------------------------------------
00E85F  2               get_oplen_from_mode:
00E85F  2  C9 00            cmp #AM_IMP
00E861  2  F0 2E            beq gol_len1
00E863  2  C9 01            cmp #AM_ACC
00E865  2  F0 2A            beq gol_len1
00E867  2  C9 10            cmp #AM_ILL
00E869  2  F0 26            beq gol_len1
00E86B  2               
00E86B  2  C9 02            cmp #AM_IMM
00E86D  2  F0 1F            beq gol_len2
00E86F  2  C9 03            cmp #AM_ZP
00E871  2  F0 1B            beq gol_len2
00E873  2  C9 04            cmp #AM_ZPX
00E875  2  F0 17            beq gol_len2
00E877  2  C9 05            cmp #AM_ZPY
00E879  2  F0 13            beq gol_len2
00E87B  2  C9 0A            cmp #AM_INDX
00E87D  2  F0 0F            beq gol_len2
00E87F  2  C9 0B            cmp #AM_INDY
00E881  2  F0 0B            beq gol_len2
00E883  2  C9 0C            cmp #AM_ZPIND
00E885  2  F0 07            beq gol_len2
00E887  2  C9 0D            cmp #AM_REL
00E889  2  F0 03            beq gol_len2
00E88B  2               
00E88B  2  A9 03            lda #3
00E88D  2  60               rts
00E88E  2               
00E88E  2               gol_len2:
00E88E  2  A9 02            lda #2
00E890  2  60               rts
00E891  2               
00E891  2               gol_len1:
00E891  2  A9 01            lda #1
00E893  2  60               rts
00E894  2               
00E894  2               ; ------------------------------------------------------------
00E894  2               ; PARSE ASSEMBLER OPERAND
00E894  2               ;
00E894  2               ; Output:
00E894  2               ;   asm_mode = parsed addressing mode
00E894  2               ;   T0       = primary operand value
00E894  2               ;   T1L      = zp byte for ZPREL
00E894  2               ;
00E894  2               ; Supported:
00E894  2               ;   implied
00E894  2               ;   A
00E894  2               ;   #imm
00E894  2               ;   zp / abs
00E894  2               ;   zp,X / abs,X
00E894  2               ;   zp,Y / abs,Y
00E894  2               ;   (zp)
00E894  2               ;   (abs)
00E894  2               ;   (zp,X)
00E894  2               ;   (abs,X)
00E894  2               ;   (zp),Y
00E894  2               ;   zp,target   (for BBR/BBS)
00E894  2               ; ------------------------------------------------------------
00E894  2               parse_asm_operand:
00E894  2  20 AC E2         jsr next_token
00E897  2  B0 05            bcs pa_have_operand
00E899  2  A9 00            lda #AM_IMP
00E89B  2  85 D5            sta asm_mode
00E89D  2  60               rts
00E89E  2               
00E89E  2               pa_have_operand:
00E89E  2  A0 00            ldy #0
00E8A0  2  B1 C0            lda (lineptr),y
00E8A2  2  C9 23            cmp #'#'
00E8A4  2  F0 2B            beq pa_imm
00E8A6  2  C9 28            cmp #'('
00E8A8  2  F0 32            beq pa_paren
00E8AA  2               
00E8AA  2                   ; bare A can mean accumulator, but only if it is exactly "A"
00E8AA  2  20 2F E4         jsr toupper
00E8AD  2  C9 41            cmp #'A'
00E8AF  2  F0 03            beq pa_have_a
00E8B1  2  4C 5A E9     		jmp pa_value
00E8B4  2               
00E8B4  2               pa_have_a:
00E8B4  2  A0 01            ldy #1
00E8B6  2  B1 C0            lda (lineptr),y
00E8B8  2  F0 07            beq pa_try_acc
00E8BA  2  C9 20            cmp #' '
00E8BC  2  F0 03            beq pa_try_acc
00E8BE  2  4C 5A E9         jmp pa_value
00E8C1  2               
00E8C1  2               pa_try_acc:
00E8C1  2  20 19 E4         jsr advance_lineptr
00E8C4  2  20 AC E2         jsr next_token
00E8C7  2  90 03            bcc pa_acc
00E8C9  2  4C 2C E2         jmp cmd_error
00E8CC  2               
00E8CC  2               pa_acc:
00E8CC  2  A9 01            lda #AM_ACC
00E8CE  2  85 D5            sta asm_mode
00E8D0  2  60               rts
00E8D1  2               
00E8D1  2               pa_imm:
00E8D1  2  20 19 E4         jsr advance_lineptr
00E8D4  2  20 F0 E2         jsr parse_byte
00E8D7  2  A9 02            lda #AM_IMM
00E8D9  2  85 D5            sta asm_mode
00E8DB  2  60               rts
00E8DC  2               
00E8DC  2               pa_paren:
00E8DC  2  20 19 E4         jsr advance_lineptr

00E504  1  4C 57 E2         jmp print_str
00E507  1               
00E507  1               ; ------------------------------------------------------------
00E507  1               ; I/O
00E507  1               ; ------------------------------------------------------------
00E507  1               getchar
00E507  1  4C 00 F0     		jmp BIOS_INCHAR
00E50A  1               
00E50A  1               putchar:
00E50A  1  4C 03 F0         jmp BIOS_OUTCHAR
00E50D  1               
00E50D  1               ; ------------------------------------------------------------
00E50D  1               ; CHECK_ABORT
00E50D  1               ; Test if the user pressed ^C.
00E50D  1               ;
00E50D  1               ; Returns
00E50D  1               ;   C = 1  abort requested
00E50D  1               ;   C = 0  continue
00E50D  1               ;
00E50D  1               ; Wrapper around BIOS_STPKEY so the monitor depends only on
00E50D  1               ; this primitive instead of calling the BIOS everywhere.
00E50D  1               ; ------------------------------------------------------------
00E50D  1               check_abort:
00E50D  1  4C 09 F0         jmp BIOS_STPKEY
00E510  1               
00E510  1               ; ------------------------------------------------------------
00E510  1               ; GETLINE
00E510  1               ; Read a line from input into linebuf.
00E510  1               ;
00E510  1               ; Assumptions
00E510  1               ; - host terminal performs line editing
00E510  1               ; - CR (0x0D) terminates the line
00E510  1               ; - line is zero terminated
00E510  1               ; - max length = 127 characters
00E510  1               ; ------------------------------------------------------------
00E510  1               getline:
00E510  1  A2 00            ldx #0
00E512  1               
00E512  1               getline_loop:
00E512  1  20 07 E5         jsr getchar
00E515  1  C9 0D            cmp #$0D
00E517  1  F0 0F            beq getline_done
00E519  1  C9 0A            cmp #$0A
00E51B  1  F0 0B            beq getline_done
00E51D  1               
00E51D  1  E0 3B            cpx #59
00E51F  1  B0 F1            bcs getline_loop
00E521  1               
00E521  1  9D 00 02         sta linebuf,x
00E524  1  E8               inx
00E525  1  4C 12 E5         jmp getline_loop
00E528  1               
00E528  1               getline_done:
00E528  1  A9 00            lda #0
00E52A  1  9D 00 02         sta linebuf,x
00E52D  1  60               rts
00E52E  1               
00E52E  1               print_error:
00E52E  1  A9 3F        		lda #'?'
00E530  1  20 0A E5     		jsr putchar
00E533  1  4C FB E4     		jmp newline
00E536  1               
00E536  1               ; command implementations
00E536  1               .include "disasm.asm"
00E536  2               ; ------------------------------------------------------------
00E536  2               ; DISASSEMBLER COMMAND
00E536  2               ; Syntax:
00E536  2               ;   D
00E536  2               ;   D start
00E536  2               ;   D start end
00E536  2               ;
00E536  2               ; Default start is MEM.
00E536  2               ; Default length is 12 instructions.
00E536  2               ; MEM is updated to the next address after the disassembly.
00E536  2               ; ------------------------------------------------------------
00E536  2               cmd_disasm:
00E536  2  20 0E E4         jsr advance_lineptr
00E539  2  20 A1 E2         jsr next_token
00E53C  2  90 14            bcc dis_default
00E53E  2               
00E53E  2  20 F2 E2         jsr parse_word
00E541  2  20 38 E4         jsr copy_T0_R0
00E544  2               
00E544  2  20 A1 E2         jsr next_token
00E547  2  90 0C            bcc dis_one_param
00E549  2               
00E549  2  20 F2 E2         jsr parse_word
00E54C  2  20 41 E4         jsr copy_T0_R1
00E54F  2  4C 5F E5         jmp dis_prepare_range
00E552  2               
00E552  2               dis_default:
00E552  2  20 5C E4         jsr copy_MEM_R0
00E555  2               
00E555  2               dis_one_param:
00E555  2  20 4A E4         jsr copy_R0_R1
00E558  2  A9 0C            lda #12
00E55A  2  85 D2            sta parm_count
00E55C  2  4C 67 E5         jmp dis_prepare_count
00E55F  2               
00E55F  2               dis_prepare_range:
00E55F  2  20 A1 E2         jsr next_token
00E562  2  90 1F            bcc dis_range_ok
00E564  2  4C 23 E2         jmp cmd_error
00E567  2               
00E567  2               dis_prepare_count:
00E567  2  20 A1 E2         jsr next_token
00E56A  2  90 03            bcc dis_count_ok
00E56C  2  4C 23 E2         jmp cmd_error
00E56F  2               
00E56F  2               dis_count_ok:
00E56F  2  20 53 E4         jsr copy_R0_R2
00E572  2               
00E572  2               dis_loop_count:
00E572  2  20 0D E5         jsr check_abort
00E575  2  B0 29            bcs dis_abort
00E577  2  20 A3 E5         jsr disasm_line
00E57A  2  B0 21            bcs dis_done
00E57C  2  C6 D2            dec parm_count
00E57E  2  D0 F2            bne dis_loop_count
00E580  2  4C 65 E4         jmp copy_R2_MEM
00E583  2               
00E583  2               dis_range_ok:
00E583  2  20 53 E4         jsr copy_R0_R2
00E586  2               
00E586  2               dis_loop_range:
00E586  2  20 0D E5         jsr check_abort
00E589  2  B0 15            bcs dis_abort
00E58B  2               
00E58B  2  20 B7 E4         jsr cmp_R2_R1
00E58E  2  90 05            bcc dis_do_line
00E590  2  F0 03            beq dis_do_line
00E592  2  4C 9D E5         jmp dis_done
00E595  2               
00E595  2               dis_do_line:
00E595  2  20 A3 E5         jsr disasm_line
00E598  2  B0 03            bcs dis_done
00E59A  2  4C 86 E5         jmp dis_loop_range
00E59D  2               
00E59D  2               dis_done:
00E59D  2  4C 65 E4         jmp copy_R2_MEM
00E5A0  2               
00E5A0  2               dis_abort:
00E5A0  2  4C 23 E2         jmp cmd_error
00E5A3  2               
00E5A3  2               ; ------------------------------------------------------------
00E5A3  2               ; DISASSEMBLE ONE LINE
00E5A3  2               ;
00E5A3  2               ; Input
00E5A3  2               ;   R2 = current PC
00E5A3  2               ;
00E5A3  2               ; Internal use
00E5A3  2               ;   T0L = opcode
00E5A3  2               ;   R3L = addressing mode
00E5A3  2               ;   R3H = instruction length
00E5A3  2               ;   T1  = pointer to mnemonic string
00E5A3  2               ;
00E5A3  2               ; Output
00E5A3  2               ;   prints one disassembly line
00E5A3  2               ;   advances R2 by instruction length
00E5A3  2               ; ------------------------------------------------------------
00E5A3  2               disasm_line:
00E5A3  2  20 D4 E5         jsr print_disasm_address
00E5A6  2               
00E5A6  2  A0 00            ldy #0
00E5A8  2  B1 C8            lda (R2L),y
00E5AA  2  85 CC            sta T0L
00E5AC  2  AA               tax
00E5AD  2               
00E5AD  2  BD 4E EC         lda mode_table,x
00E5B0  2  85 CA            sta R3L
00E5B2  2  20 50 E8         jsr get_oplen_from_mode
00E5B5  2  85 CB            sta R3H
00E5B7  2               
00E5B7  2  20 3A E8         jsr get_mnemonic_id_x
00E5BA  2  20 3E E8         jsr get_mnemonic_ptr_id
00E5BD  2               
00E5BD  2  20 E1 E5         jsr print_disasm_bytes
00E5C0  2  20 F6 E4         jsr print_space
00E5C3  2  20 F6 E4         jsr print_space
00E5C6  2  20 11 E6         jsr print_mnemonic
00E5C9  2  20 1B E6         jsr print_operand
00E5CC  2  20 FB E4         jsr newline
00E5CF  2               
00E5CF  2  A5 CB            lda R3H
00E5D1  2  4C 9A E4         jmp add_R2_A
00E5D4  2               
00E5D4  2               print_disasm_address:
00E5D4  2  A5 C9            lda R2H
00E5D6  2  A6 C8            ldx R2L
00E5D8  2  20 DD E4         jsr print_hex16
00E5DB  2  20 F6 E4         jsr print_space
00E5DE  2  4C F6 E4         jmp print_space
00E5E1  2               
00E5E1  2               ; ------------------------------------------------------------
00E5E1  2               ; PRINT RAW BYTES FIELD
00E5E1  2               ; Shows 1..3 actual instruction bytes and pads to fixed width.
00E5E1  2               ; R3H = instruction length
00E5E1  2               ; ------------------------------------------------------------
00E5E1  2               print_disasm_bytes:
00E5E1  2  A0 00            ldy #0
00E5E3  2               
00E5E3  2               pdb_real_loop:
00E5E3  2  C4 CB            cpy R3H
00E5E5  2  F0 0E            beq pdb_pad
00E5E7  2  B1 C8            lda (R2L),y
00E5E9  2  20 C2 E4         jsr print_hex8
00E5EC  2  20 F6 E4         jsr print_space
00E5EF  2  C8               iny
00E5F0  2  C0 03            cpy #3
00E5F2  2  D0 EF            bne pdb_real_loop
00E5F4  2  60               rts
00E5F5  2               
00E5F5  2               pdb_pad:
00E5F5  2  C0 03            cpy #3
00E5F7  2  F0 11            beq pdb_done
00E5F9  2  A9 20            lda #' '
00E5FB  2  20 0A E5         jsr putchar
00E5FE  2  A9 20            lda #' '
00E600  2  20 0A E5         jsr putchar
00E603  2  20 F6 E4         jsr print_space
00E606  2  C8               iny
00E607  2  4C F5 E5         jmp pdb_pad
00E60A  2               
00E60A  2               pdb_done:
00E60A  2  60               rts
00E60B  2               
00E60B  2               ; ------------------------------------------------------------
00E60B  2               ; GAP BETWEEN BYTE FIELD AND MNEMONIC
00E60B  2               ; ------------------------------------------------------------
00E60B  2               print_disasm_gap:
00E60B  2  20 F6 E4         jsr print_space
00E60E  2  4C F6 E4         jmp print_space
00E611  2               
00E611  2               ; ------------------------------------------------------------
00E611  2               ; PRINT MNEMONIC
00E611  2               ; T1 = pointer to zero-terminated mnemonic string
00E611  2               ; ------------------------------------------------------------
00E611  2               print_mnemonic:
00E611  2  A5 CE            lda T1L
00E613  2  A6 CF            ldx T1H
00E615  2  20 57 E2         jsr print_str
00E618  2  4C F6 E4         jmp print_space
00E61B  2               
00E61B  2               ; ------------------------------------------------------------
00E61B  2               ; PRINT OPERAND
00E61B  2               ; R3L = addressing mode
00E61B  2               ; R2  = current instruction address
00E61B  2               ; ------------------------------------------------------------
00E61B  2               print_operand:
00E61B  2  A5 CA            lda R3L
00E61D  2  0A               asl
00E61E  2  AA               tax
00E61F  2  BD 89 E7         lda operand_vecs,x
00E622  2  85 C2            sta jmpvec
00E624  2  E8               inx
00E625  2  BD 89 E7         lda operand_vecs,x
00E628  2  85 C3            sta jmpvec+1
00E62A  2  6C C2 00         jmp (jmpvec)
00E62D  2               
00E62D  2               ; ------------------------------------------------------------
00E62D  2               ; ADDRESSING MODE FORMATTERS
00E62D  2               ; ------------------------------------------------------------
00E62D  2               fmt_imp:
00E62D  2  60               rts
00E62E  2               
00E62E  2               fmt_acc:
00E62E  2  A9 41            lda #'A'
00E630  2  4C 0A E5         jmp putchar
00E633  2               
00E633  2               fmt_imm:
00E633  2  A9 23            lda #'#'
00E635  2  20 0A E5         jsr putchar
00E638  2  A9 24            lda #'$'
00E63A  2  20 0A E5         jsr putchar
00E63D  2  A0 01            ldy #1
00E63F  2  B1 C8            lda (R2L),y
00E641  2  4C C2 E4         jmp print_hex8
00E644  2               
00E644  2               fmt_zp:
00E644  2  A9 24            lda #'$'
00E646  2  20 0A E5         jsr putchar
00E649  2  A0 01            ldy #1
00E64B  2  B1 C8            lda (R2L),y

000000r 1               ; ---------------------------------------------------------------------------
000000r 1               ; MICMON – Minimal Interactive Command Monitor for the W65C02
000000r 1               ; (c) 2026 Rien Matthijsse
000000r 1               
000000r 1               .include "readme.asm"
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               ; MICMON – Minimal Interactive Command Monitor for the W65C02
000000r 2               ; (c) 2026 Rien Matthijsse
000000r 2               ;
000000r 2               ; Overview
000000r 2               ; --------
000000r 2               ; Micmon is a compact machine-level monitor for the W65C02, designed to fit
000000r 2               ; within a 4 KB ROM. It provides essential debugging, inspection and control
000000r 2               ; facilities while remaining small, deterministic, and fully self-hosting.
000000r 2               ;
000000r 2               ; The monitor follows a strict "round-trip" philosophy: all output is valid
000000r 2               ; input. Any command output (e.g. memory dumps) can be edited and fed back
000000r 2               ; into the monitor for execution. This enables interactive workflows using
000000r 2               ; external terminals or VDUs with line editing capabilities.
000000r 2               ;
000000r 2               ; Design Goals
000000r 2               ; ------------
000000r 2               ; - Minimal footprint (fits in 4 KB ROM)
000000r 2               ; - Deterministic behaviour (no hidden state, no dynamic allocation)
000000r 2               ; - Table-driven architecture (command dispatch, disassembler, assembler)
000000r 2               ; - Round-trip capable output (monitor output is executable input)
000000r 2               ; - Tight integration with external VDU/GDU systems
000000r 2               ;
000000r 2               ; Functional Scope
000000r 2               ; ----------------
000000r 2               ; - Memory inspection and modification
000000r 2               ; - CPU register inspection and editing
000000r 2               ; - Program execution control (GO)
000000r 2               ; - Disassembler (W65C02 complete)
000000r 2               ; - Inline assembler (single-line, immediate emission)
000000r 2               ; - Command-driven interface with single-character dispatch
000000r 2               ;
000000r 2               ; Command Summary
000000r 2               ; ---------------
000000r 2               ;   H          Help / command overview
000000r 2               ;   M addr     Dump memory
000000r 2               ;   > addr     Modify memory (hex byte stream)
000000r 2               ;   R          Show CPU registers
000000r 2               ;   ;          Modify CPU registers
000000r 2               ;   G [addr]   Execute code at address
000000r 2               ;   D [addr]   Disassembler
000000r 2               ;   A [addr]   Assemble single instruction at address
000000r 2               ;
000000r 2               ; Notes:
000000r 2               ; - Default address is MEM unless explicitly provided
000000r 2               ; - Commands are line-oriented and CR-terminated
000000r 2               ; - Where possible: output format is compatible with monitor input (round-trip)
000000r 2               ;
000000r 2               ; Execution Model
000000r 2               ; ---------------
000000r 2               ; - RESET:
000000r 2               ;     Initializes CPU state and monitor environment
000000r 2               ;     Enters monitor via BRK vector
000000r 2               ;
000000r 2               ; - BRK handler:
000000r 2               ;     Saves full CPU context (A, X, Y, P, SP, PC)
000000r 2               ;     Transfers control to command interpreter
000000r 2               ;
000000r 2               ; - Command loop:
000000r 2               ;     Line-oriented input
000000r 2               ;     Single-character command dispatch via table
000000r 2               ;     Commands operate directly on memory and CPU image
000000r 2               ;
000000r 2               ; Interaction Model
000000r 2               ; -----------------
000000r 2               ; Micmon assumes the host terminal or VDU performs line editing.
000000r 2               ; Input is processed per line (CR-terminated).
000000r 2               ;
000000r 2               ; Output is formatted to be re-consumable:
000000r 2               ;
000000r 2               ;     M 0200 020F
000000r 2               ;     > 0200 A9 01 8D 00 02 ...
000000r 2               ;
000000r 2               ; Can be edited into:
000000r 2               ;
000000r 2               ;     > 0200 A9 FF 8D 00 02
000000r 2               ;
000000r 2               ; and executed directly by the monitor.
000000r 2               ;
000000r 2               ; Parameter Formats
000000r 2               ; -----------------
000000r 2               ; All numeric parameters support multiple input formats. The parser auto-
000000r 2               ; detects the format based on prefix or content.
000000r 2               ;
000000r 2               ; Supported formats:
000000r 2               ;
000000r 2               ;   Hexadecimal (default)
000000r 2               ;     0200      $0200
000000r 2               ;
000000r 2               ;   Decimal
000000r 2               ;     +123
000000r 2               ;
000000r 2               ;   Binary
000000r 2               ;     %10101010
000000r 2               ;
000000r 2               ;   ASCII
000000r 2               ;     'A        -> $41
000000r 2               ;
000000r 2               ; Rules:
000000r 2               ; - Hex is assumed if no prefix is present
000000r 2               ;       $   = hex (optional, since default)
000000r 2               ;       %   = binary
000000r 2               ;       +   = decimal
000000r 2               ;       '   = ASCII single byte
000000r 2               ;
000000r 2               ; - All parsed values result in:
000000r 2               ;       T0 = value (byte or word)
000000r 2               ;       value_size >= 1 indicates success
000000r 2               ;
000000r 2               ; - Commands are literal
000000r 2               ;
000000r 2               ; Examples:
000000r 2               ;   M $C000
000000r 2               ;   M %1100000000000000
000000r 2               ;   M +49152
000000r 2               ;
000000r 2               ;   > 0200 'A $42 %01000011
000000r 2               ;
000000r 2               ;   A 0300 LDA #'A
000000r 2               ;   A 0302 LDA #$41
000000r 2               ;
000000r 2               ; Architecture Notes
000000r 2               ; ------------------
000000r 2               ; - All decoding (disassembler/assembler) is table-driven
000000r 2               ; - Opcode metadata shared between assembler and disassembler
000000r 2               ; - Zero-page used from $00C0-$00DF
000000r 2               ; - Strict separation between parsing, decoding and execution
000000r 2               ;
000000r 2               ; Extensibility
000000r 2               ; -------------
000000r 2               ; Micmon is intentionally designed for easy extension:
000000r 2               ;
000000r 2               ; - New commands can be added by inserting entries in:
000000r 2               ;       cmd_chars / cmd_addrs tables
000000r 2               ;
000000r 2               ; - No central switch-case logic: dispatch is fully table-driven
000000r 2               ; - Parsing helpers (parse_word, next_token, etc.) are reusable
000000r 2               ; - Disassembler and assembler share data tables, reducing duplication
000000r 2               ; - New addressing modes or instructions require only table updates
000000r 2               ;
000000r 2               ; This allows incremental growth without restructuring the monitor core.
000000r 2               ;
000000r 2               ; Limitations
000000r 2               ; -----------
000000r 2               ; - No multi-line assembly or label resolution
000000r 2               ; - No expression evaluator
000000r 2               ; - Branch range limited to signed 8-bit (hardware constraint)
000000r 2               ;
000000r 2               ; Target
000000r 2               ; ------
000000r 2               ; WDC W65C02 (fully supported instruction set)
000000r 2               ;
000000r 2               ; ---------------------------------------------------------------------------
000000r 2               
000000r 1               
000000r 1               .setcpu "65C02"
000000r 1               
000000r 1               .include "../bios_mmu/bios.h"
000000r 2               ;
000000r 2               ;
000000r 2               ;
000000r 2               BIOS_BASE        =     $F000
000000r 2               BIOS_INCHAR      =     BIOS_BASE
000000r 2               BIOS_OUTCHAR     =     BIOS_BASE+3
000000r 2               BIOS_INKEY       =     BIOS_BASE+6
000000r 2               BIOS_STPKEY			 =		 BIOS_BASE+9
000000r 2               
000000r 1               
000000r 1               .segment "ZEROPAGE"
000000r 1               .org $00C0								; nicer listing
0000C0  1               
0000C0  1               ; parser / dispatcher pointers
0000C0  1  xx xx        lineptr:    .res 2
0000C2  1  xx xx        jmpvec:     .res 2
0000C4  1               
0000C4  1               ; 16-bit working registers for commands
0000C4  1  xx           R0L:        .res 1
0000C5  1  xx           R0H:        .res 1
0000C6  1  xx           R1L:        .res 1
0000C7  1  xx           R1H:        .res 1
0000C8  1  xx           R2L:        .res 1
0000C9  1  xx           R2H:        .res 1
0000CA  1  xx           R3L:        .res 1
0000CB  1  xx           R3H:        .res 1
0000CC  1               
0000CC  1               ; temporary registers used by parser and utility routines
0000CC  1  xx           T0L:        .res 1
0000CD  1  xx           T0H:        .res 1
0000CE  1  xx           T1L:        .res 1
0000CF  1  xx           T1H:        .res 1
0000D0  1               
0000D0  1               ; monitor remembers last referenced memory address
0000D0  1  xx           MEML:       .res 1
0000D1  1  xx           MEMH:       .res 1
0000D2  1               
0000D2  1               ; parser state
0000D2  1  xx           parm_count: .res 1
0000D3  1  xx           value_size: .res 1
0000D4  1  xx           tmp:        .res 1
0000D5  1               
0000D5  1  xx           asm_mode:   .res 1
0000D6  1  xx           asm_opcode: .res 1
0000D7  1  xx           mnem_len:   .res 1
0000D8  1               
0000D8  1               .segment "BSS"
0000D8  1               .org $0200							; nicer listing
000200  1               
000200  1               ; input buffer
000200  1  xx xx xx xx  linebuf:    .res 40
000204  1  xx xx xx xx  
000208  1  xx xx xx xx  
000228  1               
000228  1               ; saved CPU image
000228  1  xx           reg_pch:    .res 1
000229  1  xx           reg_pcl:    .res 1
00022A  1  xx           reg_sr:     .res 1
00022B  1  xx           reg_a:      .res 1
00022C  1  xx           reg_x:      .res 1
00022D  1  xx           reg_y:      .res 1
00022E  1  xx           reg_sp:     .res 1
00022F  1               
00022F  1               .segment "CODE"
00022F  1               .org $E000							; nicer listing
00E000  1               
00E000  1               ; ------------------------------------------------------------
00E000  1               ; RESET
00E000  1               ; Basic CPU setup, monitor state initialization, then enter
00E000  1               ; the monitor through BRK so startup uses the normal entry path.
00E000  1               ; ------------------------------------------------------------
00E000  1               		.export reset
00E000  1               reset:
00E000  1  78               sei
00E001  1  D8               cld
00E002  1  A2 FF            ldx #$FF
00E004  1  9A               txs
00E005  1  20 09 E0         jsr monitor_init
00E008  1  00               brk
00E009  1               
00E009  1               monitor_init:
00E009  1  64 D0            stz MEML
00E00B  1  64 D1            stz MEMH
00E00D  1  A9 3C        		lda #<welcome_text
00E00F  1  A2 EF            ldx #>welcome_text
00E011  1  4C 62 E2         jmp print_str
00E014  1               
00E014  1               ; ------------------------------------------------------------
00E014  1               ; IRQ / BRK ENTRY
00E014  1               ; The common IRQ vector saves A/X/Y, then distinguishes IRQ
00E014  1               ; from BRK by testing bit 4 of the stacked status byte.
00E014  1               ; IRQ returns immediately. BRK enters the monitor.
00E014  1               ; ------------------------------------------------------------
00E014  1               		.export irq_entry
00E014  1               irq_entry:
00E014  1  48               pha
00E015  1  8A               txa
00E016  1  48               pha
00E017  1  98               tya
00E018  1  48               pha
00E019  1               
00E019  1  BA               tsx
00E01A  1  BD 04 01         lda $0104,x
00E01D  1  29 10            and #$10
00E01F  1  D0 07            bne brk_entry
00E021  1               
00E021  1               irq_restore:
00E021  1  68               pla
00E022  1  A8               tay
00E023  1  68               pla
00E024  1  AA               tax
00E025  1  68               pla
00E026  1  40               rti
00E027  1               
00E027  1               		.export nmi_entry
00E027  1               nmi_entry:
00E027  1  40               rti
00E028  1               
00E028  1               ; ------------------------------------------------------------
00E028  1               ; BRK ENTRY
00E028  1               ; Save the CPU state into monitor RAM.
00E028  1               ; BRK pushes PC+2, so the saved PC is adjusted back to the
00E028  1               ; BRK opcode address for display and resume semantics.
00E028  1               ; ------------------------------------------------------------
00E028  1               brk_entry:
00E028  1  68               pla
00E029  1  8D 2D 02         sta reg_y
00E02C  1  68               pla
00E02D  1  8D 2C 02         sta reg_x
00E030  1  68               pla
00E031  1  8D 2B 02         sta reg_a
00E034  1  68               pla
00E035  1  8D 2A 02         sta reg_sr
00E038  1  68               pla
00E039  1  8D 29 02         sta reg_pcl
00E03C  1  68               pla
00E03D  1  8D 28 02         sta reg_pch
00E040  1               
00E040  1  D8               cld
00E041  1  38               sec						; correct PC by -2
00E042  1  AD 29 02         lda reg_pcl
00E045  1  E9 02            sbc #2
00E047  1  8D 29 02         sta reg_pcl
00E04A  1  AD 28 02         lda reg_pch
00E04D  1  E9 00            sbc #0
00E04F  1  8D 28 02         sta reg_pch
00E052  1               
00E052  1  BA               tsx
00E053  1  8E 2E 02         stx reg_sp
00E056  1               ;    jmp monitor_entry
00E056  1               
00E056  1               ; ------------------------------------------------------------
00E056  1               ; MONITOR ENTRY
00E056  1               ; Every BRK entry shows the saved registers, then drops into
00E056  1               ; the command loop.
00E056  1               ; ------------------------------------------------------------
00E056  1               monitor_entry:
00E056  1  58           		cli
00E057  1  20 3C E1         jsr show_registers	; show regs and fall through
00E05A  1               
00E05A  1               ; ------------------------------------------------------------
00E05A  1               ; MAIN MONITOR LOOP
00E05A  1               ; Read one full line, execute it
00E05A  1               ; ------------------------------------------------------------
00E05A  1               monitor_loop:
00E05A  1  20 1B E5         jsr getline					; read line
00E05D  1  A9 00            lda #<linebuf
00E05F  1  85 C0            sta lineptr
00E061  1  A9 02            lda #>linebuf
00E063  1  85 C1            sta lineptr+1
00E065  1               
00E065  1               execute_line:
00E065  1  20 20 E4         jsr skip_spaces
00E068  1  A0 00            ldy #0
00E06A  1  B1 C0            lda (lineptr),y			; get cmd
00E06C  1  F0 0A            beq exec_done
00E06E  1  20 2F E4         jsr toupper
00E071  1  91 C0            sta (lineptr),y			; save uppercase
00E073  1  20 7E E0         jsr dispatch_command
00E076  1  B0 03        		bcs exec_nopr
00E078  1               exec_done:
00E078  1  20 0B E5     		jsr print_prompt
00E07B  1               
00E07B  1               exec_nopr
00E07B  1  4C 5A E0         jmp monitor_loop
00E07E  1               
00E07E  1               ; ------------------------------------------------------------
00E07E  1               ; COMMAND DISPATCH
00E07E  1               ; ------------------------------------------------------------
00E07E  1               dispatch_command:
00E07E  1  A0 00            ldy #0
00E080  1  B1 C0            lda (lineptr),y
00E082  1  85 D4            sta tmp
00E084  1               
00E084  1  A2 00            ldx #0
00E086  1               dispatch_loop:
00E086  1  BD 23 EF         lda cmd_chars,x
00E089  1  F0 19            beq dispatch_error
00E08B  1  C5 D4            cmp tmp
00E08D  1  F0 04            beq dispatch_found
00E08F  1  E8               inx
00E090  1  4C 86 E0         jmp dispatch_loop
00E093  1               
00E093  1               dispatch_found:
00E093  1  8A               txa
00E094  1  0A               asl
00E095  1  AA               tax
00E096  1  BD 2C EF         lda cmd_addrs,x
00E099  1  85 C2            sta jmpvec
00E09B  1  E8               inx
00E09C  1  BD 2C EF         lda cmd_addrs,x
00E09F  1  85 C3            sta jmpvec+1
00E0A1  1  6C C2 00         jmp (jmpvec)
00E0A4  1               
00E0A4  1               dispatch_error:
00E0A4  1  20 2C E2         jsr cmd_error
00E0A7  1  38           		sec
00E0A8  1  60           		rts
00E0A9  1               
00E0A9  1               ; ------------------------------------------------------------
00E0A9  1               ; MEMORY DUMP COMMAND
00E0A9  1               ; Syntax:
00E0A9  1               ;   M
00E0A9  1               ;   M start
00E0A9  1               ;   M start end
00E0A9  1               ;
00E0A9  1               ; Default start is MEM.
00E0A9  1               ; Default length is 12 lines * 8 bytes = 96 bytes.
00E0A9  1               ; MEM is updated to the next address after the dump.
00E0A9  1               ; ------------------------------------------------------------
00E0A9  1               cmd_mem:
00E0A9  1  20 19 E4     		jsr advance_lineptr
00E0AC  1               
00E0AC  1  20 AC E2         jsr next_token
00E0AF  1  90 1F            bcc mem_default
00E0B1  1               
00E0B1  1  20 FD E2         jsr parse_word
00E0B4  1  20 43 E4         jsr copy_T0_R0
00E0B7  1               
00E0B7  1  20 AC E2         jsr next_token
00E0BA  1  90 09            bcc mem_one_param
00E0BC  1               
00E0BC  1  20 FD E2         jsr parse_word
00E0BF  1  20 4C E4         jsr copy_T0_R1
00E0C2  1  4C DB E0         jmp mem_prepare
00E0C5  1               
00E0C5  1               mem_one_param:
00E0C5  1  20 55 E4         jsr copy_R0_R1
00E0C8  1  A9 5F            lda #95
00E0CA  1  20 96 E4         jsr add_R1_A
00E0CD  1  4C DB E0         jmp mem_prepare
00E0D0  1               
00E0D0  1               mem_default:
00E0D0  1  20 67 E4         jsr copy_MEM_R0
00E0D3  1  20 55 E4         jsr copy_R0_R1
00E0D6  1  A9 5F            lda #95
00E0D8  1  20 96 E4         jsr add_R1_A
00E0DB  1               
00E0DB  1               mem_prepare:
00E0DB  1  20 AC E2         jsr next_token
00E0DE  1  90 03            bcc mem_prepare_ok
00E0E0  1  4C 2C E2         jmp cmd_error
00E0E3  1               
00E0E3  1               mem_prepare_ok:
00E0E3  1  20 5E E4         jsr copy_R0_R2
00E0E6  1               
00E0E6  1               mem_loop:
00E0E6  1  20 18 E5         jsr check_abort
00E0E9  1  B0 16            bcs mem_abort
00E0EB  1               
00E0EB  1  20 31 E2         jsr dump_line
00E0EE  1               
00E0EE  1  A9 08            lda #8
00E0F0  1  20 A5 E4         jsr add_R2_A
00E0F3  1  B0 07            bcs mem_ok
00E0F5  1               
00E0F5  1  20 C2 E4         jsr cmp_R2_R1
00E0F8  1  90 EC            bcc mem_loop
00E0FA  1  F0 EA            beq mem_loop
00E0FC  1               
00E0FC  1               mem_ok:
00E0FC  1  20 70 E4         jsr copy_R2_MEM
00E0FF  1  18               clc
00E100  1  60           		rts
00E101  1               
00E101  1               mem_abort:
00E101  1  4C 2C E2         jmp cmd_error
00E104  1               
00E104  1               ; ------------------------------------------------------------
00E104  1               ; MEMORY EDIT COMMAND
00E104  1               ; Syntax:
00E104  1               ;   > addr byte...
00E104  1               ; Writes 1..8 bytes.
00E104  1               ; Updates MEM to the next address after the last write.
00E104  1               ; ------------------------------------------------------------
00E104  1               cmd_memedit:
00E104  1  20 19 E4     		jsr advance_lineptr
00E107  1  20 FD E2         jsr parse_word
00E10A  1  20 43 E4         jsr copy_T0_R0				; init ptr
00E10D  1               
00E10D  1  64 D2            stz parm_count				; first of 8
00E10F  1               
00E10F  1               write_loop:
00E10F  1  A5 D2            lda parm_count
00E111  1  C9 08            cmp #8
00E113  1  B0 16            bcs write_done				; >= 7
00E115  1               
00E115  1  20 AC E2         jsr next_token
00E118  1  90 11            bcc write_done				; no more
00E11A  1               
00E11A  1  20 F0 E2         jsr parse_byte
00E11D  1               
00E11D  1  A0 00            ldy #0
00E11F  1  A5 CC            lda T0L
00E121  1  91 C4            sta (R0L),y						; store it
00E123  1               
00E123  1  20 79 E4         jsr inc_R0						; next location
00E126  1  E6 D2            inc parm_count				; next param
00E128  1  4C 0F E1         jmp write_loop				; loop
00E12B  1               
00E12B  1               write_done:
00E12B  1  A5 D2            lda parm_count
00E12D  1  F0 0A            beq write_error				; no locations given
00E12F  1               
00E12F  1               ;    jsr next_token
00E12F  1               ;    bcs write_error
00E12F  1               
00E12F  1  A5 C4            lda R0L								; advance mem ptr
00E131  1  85 D0            sta MEML
00E133  1  A5 C5            lda R0H
00E135  1  85 D1            sta MEMH
00E137  1  18               clc
00E138  1  60           		rts
00E139  1               
00E139  1               write_error:
00E139  1  4C 2C E2         jmp cmd_error
00E13C  1               
00E13C  1               
00E13C  1               ; ------------------------------------------------------------
00E13C  1               ; REGISTER DISPLAY COMMAND
00E13C  1               ; Explicit register display on user request.
00E13C  1               ; ------------------------------------------------------------
00E13C  1               cmd_regs:
00E13C  1               show_registers:
00E13C  1  A9 55            lda #<reg_header
00E13E  1  A2 EF            ldx #>reg_header
00E140  1  20 62 E2         jsr print_str
00E143  1               
00E143  1               print_reg_line:
00E143  1  A9 3B            lda #';'							; in sync with command table
00E145  1  20 15 E5         jsr putchar
00E148  1  20 01 E5         jsr print_space
00E14B  1               
00E14B  1  AD 28 02         lda reg_pch
00E14E  1  AE 29 02         ldx reg_pcl
00E151  1  20 E8 E4         jsr print_hex16
00E154  1  20 01 E5         jsr print_space
00E157  1               
00E157  1  AD 2B 02         lda reg_a
00E15A  1  20 CD E4         jsr print_hex8
00E15D  1  20 01 E5         jsr print_space
00E160  1               
00E160  1  AD 2C 02         lda reg_x
00E163  1  20 CD E4         jsr print_hex8
00E166  1  20 01 E5         jsr print_space
00E169  1               
00E169  1  AD 2D 02         lda reg_y
00E16C  1  20 CD E4         jsr print_hex8
00E16F  1  20 01 E5         jsr print_space
00E172  1               
00E172  1  AD 2E 02         lda reg_sp
00E175  1  20 CD E4         jsr print_hex8
00E178  1  20 01 E5         jsr print_space
00E17B  1               
00E17B  1               ;    lda reg_sr
00E17B  1               ;    jsr print_hex8
00E17B  1               ;    jsr print_space
00E17B  1               
00E17B  1  A9 25            lda #'%'
00E17D  1  20 15 E5     		jsr putchar
00E180  1  AD 2A 02         lda reg_sr
00E183  1  20 78 E2         jsr print_status_bits
00E186  1  20 06 E5         jsr newline
00E189  1  18           		clc
00E18A  1  60           		rts
00E18B  1               
00E18B  1               ; ------------------------------------------------------------
00E18B  1               ; REGISTER EDIT COMMAND
00E18B  1               ; Editable line format:
00E18B  1               ;   ; <PC> [A [X [Y [SP [SR]]]]]
00E18B  1               ;
00E18B  1               ; At least PC must be supplied.
00E18B  1               ; Missing trailing operands leave saved registers unchanged.
00E18B  1               ; ------------------------------------------------------------
00E18B  1               cmd_regedit:
00E18B  1  20 19 E4     		jsr advance_lineptr
00E18E  1               
00E18E  1  20 AC E2         jsr next_token
00E191  1  90 56            bcc regedit_error
00E193  1               
00E193  1  20 FD E2         jsr parse_word
00E196  1  A5 CC            lda T0L
00E198  1  8D 29 02         sta reg_pcl
00E19B  1  A5 CD            lda T0H
00E19D  1  8D 28 02         sta reg_pch
00E1A0  1               
00E1A0  1  20 AC E2         jsr next_token
00E1A3  1  90 3F            bcc regedit_done
00E1A5  1               
00E1A5  1  20 F0 E2         jsr parse_byte
00E1A8  1  A5 CC            lda T0L
00E1AA  1  8D 2B 02         sta reg_a
00E1AD  1               
00E1AD  1  20 AC E2         jsr next_token
00E1B0  1  90 32            bcc regedit_done
00E1B2  1               
00E1B2  1  20 F0 E2         jsr parse_byte
00E1B5  1  A5 CC            lda T0L
00E1B7  1  8D 2C 02         sta reg_x
00E1BA  1               
00E1BA  1  20 AC E2         jsr next_token
00E1BD  1  90 25            bcc regedit_done
00E1BF  1               
00E1BF  1  20 F0 E2         jsr parse_byte
00E1C2  1  A5 CC            lda T0L
00E1C4  1  8D 2D 02         sta reg_y
00E1C7  1               
00E1C7  1  20 AC E2         jsr next_token
00E1CA  1  90 18            bcc regedit_done
00E1CC  1               
00E1CC  1  20 F0 E2         jsr parse_byte
00E1CF  1  A5 CC            lda T0L
00E1D1  1  8D 2E 02         sta reg_sp
00E1D4  1               
00E1D4  1  20 AC E2         jsr next_token
00E1D7  1  90 0B            bcc regedit_done
00E1D9  1               
00E1D9  1  20 F0 E2         jsr parse_byte
00E1DC  1  A5 CC            lda T0L
00E1DE  1  8D 2A 02         sta reg_sr
00E1E1  1               
00E1E1  1  20 AC E2         jsr next_token
00E1E4  1               ;    bcc regedit_done
00E1E4  1               
00E1E4  1               regedit_done:
00E1E4  1               ;    jsr next_token
00E1E4  1               ;    bcs regedit_error
00E1E4  1  20 3C E1     		jsr show_registers
00E1E7  1  18           		clc
00E1E8  1  60               rts
00E1E9  1               
00E1E9  1               regedit_error:
00E1E9  1  4C 2C E2         jmp cmd_error
00E1EC  1               
00E1EC  1               
00E1EC  1               ; ------------------------------------------------------------
00E1EC  1               ; GO COMMAND
00E1EC  1               ; Syntax:
00E1EC  1               ;   G
00E1EC  1               ;   G <PC>
00E1EC  1               ; Restores the saved CPU image and resumes execution with RTI.
00E1EC  1               ; ------------------------------------------------------------
00E1EC  1               cmd_go:
00E1EC  1  20 19 E4     		jsr advance_lineptr
00E1EF  1  20 AC E2         jsr next_token
00E1F2  1  90 15            bcc go_now
00E1F4  1               
00E1F4  1  20 FD E2         jsr parse_word
00E1F7  1  A5 CC            lda T0L
00E1F9  1  8D 29 02         sta reg_pcl
00E1FC  1  A5 CD            lda T0H
00E1FE  1  8D 28 02         sta reg_pch
00E201  1               
00E201  1  20 AC E2         jsr next_token
00E204  1  90 03            bcc go_now
00E206  1  4C 2C E2         jmp cmd_error
00E209  1               
00E209  1               go_now:
00E209  1  AE 2E 02         ldx reg_sp
00E20C  1  9A               txs
00E20D  1  AD 28 02         lda reg_pch
00E210  1  48               pha
00E211  1  AD 29 02         lda reg_pcl
00E214  1  48               pha
00E215  1  AD 2A 02         lda reg_sr
00E218  1  48               pha
00E219  1  AD 2B 02         lda reg_a
00E21C  1  AE 2C 02         ldx reg_x
00E21F  1  AC 2D 02         ldy reg_y
00E222  1  40               rti
00E223  1               
00E223  1               ; ------------------------------------------------------------
00E223  1               ; HELP COMMAND
00E223  1               ; ------------------------------------------------------------
00E223  1               cmd_help:
00E223  1  A9 77            lda #<help_text
00E225  1  A2 EF            ldx #>help_text
00E227  1  20 62 E2         jsr print_str
00E22A  1  18           		clc
00E22B  1  60           		rts
00E22C  1               
00E22C  1               ; ------------------------------------------------------------
00E22C  1               ; ERROR HANDLER
00E22C  1               ; ------------------------------------------------------------
00E22C  1               cmd_error:
00E22C  1  20 39 E5         jsr print_error
00E22F  1  38           		sec
00E230  1  60           		rts
00E231  1               
00E231  1               ; ------------------------------------------------------------
00E231  1               ; MEMORY DUMP FORMATTERS
00E231  1               ; ------------------------------------------------------------
00E231  1               ; show 8 memory locs @R2
00E231  1               dump_line:
00E231  1  A9 3E            lda #'>'						; sync with command table
00E233  1  20 15 E5         jsr putchar
00E236  1               
00E236  1  A5 C8            lda R2L
00E238  1  85 CC            sta T0L
00E23A  1  A5 C9            lda R2H
00E23C  1  85 CD            sta T0H
00E23E  1  20 A2 E2         jsr print_address_T0
00E241  1               
00E241  1  A0 00            ldy #0
00E243  1               dump_hex_loop:
00E243  1  B1 C8            lda (R2L),y
00E245  1  20 CD E4         jsr print_hex8
00E248  1  20 01 E5         jsr print_space
00E24B  1  C8               iny
00E24C  1  C0 08            cpy #8
00E24E  1  D0 F3            bne dump_hex_loop
00E250  1               
00E250  1  20 01 E5         jsr print_space
00E253  1               
00E253  1  A0 00            ldy #0
00E255  1               dump_ascii_loop:
00E255  1  B1 C8            lda (R2L),y
00E257  1  20 F1 E4         jsr print_ascii
00E25A  1  C8               iny
00E25B  1  C0 08            cpy #8
00E25D  1  D0 F6            bne dump_ascii_loop
00E25F  1  4C 06 E5         jmp newline
00E262  1               
00E262  1               ; ------------------------------------------------------------
00E262  1               ; OUTPUT HELPERS
00E262  1               ; ------------------------------------------------------------
00E262  1               
00E262  1               ; ------------------------------------------------------------
00E262  1               ; STRING OUTPUT
00E262  1               ; A = low byte, X = high byte of zero-terminated string.
00E262  1               ; Uses T0 as the temporary string pointer.
00E262  1               ; ------------------------------------------------------------
00E262  1               print_str:
00E262  1  85 CC            sta T0L
00E264  1  86 CD            stx T0H
00E266  1  A0 00            ldy #0
00E268  1               
00E268  1               print_str_loop:
00E268  1  B1 CC            lda (T0L),y
00E26A  1  F0 0B            beq print_str_done
00E26C  1  20 15 E5         jsr putchar
00E26F  1  C8               iny
00E270  1  D0 F6            bne print_str_loop
00E272  1  E6 CD            inc T0H
00E274  1  4C 68 E2         jmp print_str_loop
00E277  1               
00E277  1               print_str_done:
00E277  1  60               rts
00E278  1               
00E278  1               ; ------------------------------------------------------------
00E278  1               ; PRINT_STATUS_BITS
00E278  1               ; Print processor status as:
00E278  1               ;   NV-BDIZC
00E278  1               ; using '1' for set bits and '0' for clear bits.
00E278  1               ;
00E278  1               ; Input
00E278  1               ;   A = status byte
00E278  1               ;
00E278  1               ; Clobbers
00E278  1               ;   A,X
00E278  1               ; ------------------------------------------------------------
00E278  1               print_status_bits:
00E278  1  85 D4            sta tmp
00E27A  1               
00E27A  1  06 D4            asl tmp              ; N -> C
00E27C  1  20 96 E2         jsr print_bit_c
00E27F  1               
00E27F  1  06 D4            asl tmp              ; V -> C
00E281  1  20 96 E2         jsr print_bit_c
00E284  1               
00E284  1  A9 2D            lda #'-'						 ; mmmhhhh
00E286  1  20 15 E5         jsr putchar
00E289  1               
00E289  1  06 D4            asl tmp              ; skip bit 5
00E28B  1               
00E28B  1  A2 05            ldx #5               ; B D I Z C
00E28D  1               ps_loop:
00E28D  1  06 D4            asl tmp              ; next bit -> C
00E28F  1  20 96 E2         jsr print_bit_c
00E292  1  CA               dex
00E293  1  D0 F8            bne ps_loop
00E295  1  60               rts
00E296  1               
00E296  1               ; ------------------------------------------------------------
00E296  1               ; PRINT_BIT_C
00E296  1               ; Print '1' if Carry set, else '0'.
00E296  1               ; ------------------------------------------------------------
00E296  1               print_bit_c:
00E296  1  90 05            bcc ps_zero
00E298  1  A9 31            lda #'1'
00E29A  1  4C 15 E5         jmp putchar
00E29D  1               ps_zero:
00E29D  1  A9 30            lda #'0'
00E29F  1  4C 15 E5         jmp putchar
00E2A2  1               
00E2A2  1               ; ------------------------------------------------------------
00E2A2  1               ; PRINT ADDRESS IN T0 + one trailing space
00E2A2  1               ; ------------------------------------------------------------
00E2A2  1               print_address_T0:
00E2A2  1  A5 CD            lda T0H
00E2A4  1  A6 CC            ldx T0L
00E2A6  1  20 E8 E4         jsr print_hex16
00E2A9  1  4C 01 E5         jmp print_space
00E2AC  1               
00E2AC  1               ; ------------------------------------------------------------
00E2AC  1               ; TOKENIZER
00E2AC  1               ; Carry set   = token exists
00E2AC  1               ; Carry clear = end of line
00E2AC  1               ; ------------------------------------------------------------
00E2AC  1               next_token:
00E2AC  1  20 20 E4         jsr skip_spaces
00E2AF  1  A0 00            ldy #0
00E2B1  1  B1 C0            lda (lineptr),y
00E2B3  1  F0 02            beq token_eol
00E2B5  1  38               sec
00E2B6  1  60               rts
00E2B7  1               
00E2B7  1               token_eol:
00E2B7  1  18               clc
00E2B8  1  60               rts
00E2B9  1               
00E2B9  1               ; ------------------------------------------------------------
00E2B9  1               ; PARAMETER PARSER
00E2B9  1               ; Default base is hex.
00E2B9  1               ; Supported prefixes:
00E2B9  1               ;   $ hex
00E2B9  1               ;   + decimal
00E2B9  1               ;   % binary   (byte only)
00E2B9  1               ;   ' ASCII    (byte only)
00E2B9  1               ; Result is returned in T0, size in value_size.
00E2B9  1               ; ------------------------------------------------------------
00E2B9  1               parse_param:
00E2B9  1  20 20 E4         jsr skip_spaces
00E2BC  1  A0 00            ldy #0
00E2BE  1  B1 C0            lda (lineptr),y
00E2C0  1  F0 2B            beq param_error
00E2C2  1               
00E2C2  1  C9 24            cmp #'$'
00E2C4  1  F0 0F            beq parse_hex_pref
00E2C6  1  C9 2B            cmp #'+'
00E2C8  1  F0 11            beq parse_dec
00E2CA  1  C9 25            cmp #'%'
00E2CC  1  F0 13            beq parse_bin
00E2CE  1  C9 27            cmp #$27
00E2D0  1  F0 15            beq parse_ascii
00E2D2  1               
00E2D2  1  4C 5B E3         jmp parse_hex
00E2D5  1               
00E2D5  1               parse_hex_pref:
00E2D5  1  20 19 E4         jsr advance_lineptr
00E2D8  1  4C 5B E3         jmp parse_hex
00E2DB  1               
00E2DB  1               parse_dec:
00E2DB  1  20 19 E4         jsr advance_lineptr
00E2DE  1  4C A2 E3         jmp parse_decimal
00E2E1  1               
00E2E1  1               parse_bin:
00E2E1  1  20 19 E4         jsr advance_lineptr
00E2E4  1  4C 14 E3         jmp parse_binary
00E2E7  1               
00E2E7  1               parse_ascii:
00E2E7  1  20 19 E4         jsr advance_lineptr
00E2EA  1  4C 00 E3         jmp parse_ascii_char
00E2ED  1               
00E2ED  1               param_error:
00E2ED  1  4C 2C E2         jmp cmd_error
00E2F0  1               
00E2F0  1               parse_byte:
00E2F0  1  20 B9 E2         jsr parse_param
00E2F3  1  A5 D3            lda value_size
00E2F5  1  C9 01            cmp #1
00E2F7  1  F0 03            beq parse_byte_ok
00E2F9  1  4C 2C E2         jmp cmd_error
00E2FC  1               parse_byte_ok:
00E2FC  1  60               rts
00E2FD  1               
00E2FD  1               parse_word:
00E2FD  1  4C B9 E2         jmp parse_param
00E300  1               ;    lda value_size
00E300  1               ;    cmp #2
00E300  1               ;    bne parse_word_ok
00E300  1               ;    jmp cmd_error
00E300  1               ;parse_word_ok:
00E300  1               ;    rts
00E300  1               
00E300  1               ; ------------------------------------------------------------
00E300  1               ; ASCII PARSER
00E300  1               ; Syntax: 'A
00E300  1               ; ------------------------------------------------------------
00E300  1               parse_ascii_char:
00E300  1  A0 00            ldy #0
00E302  1  B1 C0            lda (lineptr),y
00E304  1  F0 0B            beq ascii_error
00E306  1  85 CC            sta T0L
00E308  1  64 CD            stz T0H
00E30A  1  A9 01            lda #1
00E30C  1  85 D3            sta value_size
00E30E  1  4C 19 E4         jmp advance_lineptr
00E311  1               
00E311  1               ascii_error:
00E311  1  4C 2C E2         jmp cmd_error
00E314  1               
00E314  1               ; ------------------------------------------------------------
00E314  1               ; BINARY PARSER
00E314  1               ; Syntax: %10101010
00E314  1               ; Binary values are byte sized only.
00E314  1               ; ------------------------------------------------------------
00E314  1               parse_binary:
00E314  1  64 CC            stz T0L
00E316  1  64 CD            stz T0H
00E318  1  64 D4            stz tmp
00E31A  1               
00E31A  1               bin_loop:
00E31A  1  A0 00            ldy #0
00E31C  1  B1 C0            lda (lineptr),y
00E31E  1  C9 30            cmp #'0'
00E320  1  F0 0B            beq bin_zero
00E322  1  C9 31            cmp #'1'
00E324  1  F0 17            beq bin_one
00E326  1  C9 2D            cmp #'-'				; special case for S-register
00E328  1  F0 13            beq bin_one
00E32A  1  4C 4F E3         jmp bin_done
00E32D  1               
00E32D  1               bin_zero:
00E32D  1  A5 D4            lda tmp
00E32F  1  C9 08            cmp #8
00E331  1  B0 25            bcs bin_error
00E333  1  06 CC            asl T0L
00E335  1  20 19 E4         jsr advance_lineptr
00E338  1  E6 D4            inc tmp
00E33A  1  4C 1A E3         jmp bin_loop
00E33D  1               
00E33D  1               bin_one:
00E33D  1  A5 D4            lda tmp
00E33F  1  C9 08            cmp #8
00E341  1  B0 15            bcs bin_error
00E343  1  06 CC            asl T0L
00E345  1  E6 CC            inc T0L
00E347  1  20 19 E4         jsr advance_lineptr
00E34A  1  E6 D4            inc tmp
00E34C  1  4C 1A E3         jmp bin_loop
00E34F  1               
00E34F  1               bin_done:
00E34F  1  A5 D4            lda tmp
00E351  1  F0 05            beq bin_error2
00E353  1  A9 01            lda #1
00E355  1  85 D3            sta value_size
00E357  1  60               rts
00E358  1               
00E358  1               bin_error:
00E358  1               bin_error2:
00E358  1  4C 2C E2         jmp cmd_error
00E35B  1               
00E35B  1               ; ------------------------------------------------------------
00E35B  1               ; HEX PARSER
00E35B  1               ; 1-2 digits => byte, 3-4 digits => word.
00E35B  1               ; ------------------------------------------------------------
00E35B  1               parse_hex:
00E35B  1  64 CC            stz T0L
00E35D  1  64 CD            stz T0H
00E35F  1  64 D4            stz tmp
00E361  1               
00E361  1               hex_loop:
00E361  1  A0 00            ldy #0
00E363  1  B1 C0            lda (lineptr),y
00E365  1  20 F0 E3         jsr hex_digit
00E368  1  B0 1C            bcs hex_done
00E36A  1               
00E36A  1  06 CC            asl T0L
00E36C  1  26 CD            rol T0H
00E36E  1  06 CC            asl T0L
00E370  1  26 CD            rol T0H
00E372  1  06 CC            asl T0L
00E374  1  26 CD            rol T0H
00E376  1  06 CC            asl T0L
00E378  1  26 CD            rol T0H
00E37A  1               
00E37A  1  05 CC            ora T0L
00E37C  1  85 CC            sta T0L
00E37E  1               
00E37E  1  20 19 E4         jsr advance_lineptr
00E381  1  E6 D4            inc tmp
00E383  1  4C 61 E3         jmp hex_loop
00E386  1               
00E386  1               hex_done:
00E386  1  A5 D4            lda tmp
00E388  1  F0 15            beq hex_error
00E38A  1  C9 03            cmp #3
00E38C  1  90 07            bcc hex_byte
00E38E  1  C9 05            cmp #5
00E390  1  90 08            bcc hex_word
00E392  1  4C 2C E2         jmp cmd_error
00E395  1               
00E395  1               hex_byte:
00E395  1  A9 01            lda #1
00E397  1  85 D3            sta value_size
00E399  1  60               rts
00E39A  1               
00E39A  1               hex_word:
00E39A  1  A9 02            lda #2
00E39C  1  85 D3            sta value_size
00E39E  1  60               rts
00E39F  1               
00E39F  1               hex_error:
00E39F  1  4C 2C E2         jmp cmd_error
00E3A2  1               
00E3A2  1               ; ------------------------------------------------------------
00E3A2  1               ; DECIMAL PARSER
00E3A2  1               ; Syntax: +1234
00E3A2  1               ; Uses repeated 16-bit add:
00E3A2  1               ;   T0 = T0 * 10 + digit
00E3A2  1               ; ------------------------------------------------------------
00E3A2  1               parse_decimal:
00E3A2  1  64 CC            stz T0L
00E3A4  1  64 CD            stz T0H
00E3A6  1  64 D3            stz value_size
00E3A8  1               
00E3A8  1               dec_loop:
00E3A8  1  A0 00            ldy #0
00E3AA  1  B1 C0            lda (lineptr),y
00E3AC  1  C9 30            cmp #'0'
00E3AE  1  90 2B            bcc dec_done
00E3B0  1  C9 3A            cmp #'9'+1
00E3B2  1  B0 27            bcs dec_done
00E3B4  1               
00E3B4  1  38               sec
00E3B5  1  E9 30            sbc #'0'
00E3B7  1  85 D4            sta tmp
00E3B9  1               
00E3B9  1  20 3A E4         jsr copy_T0_T1
00E3BC  1               
00E3BC  1  64 CC            stz T0L
00E3BE  1  64 CD            stz T0H
00E3C0  1  A2 0A            ldx #10
00E3C2  1               
00E3C2  1               dec_mul_loop:
00E3C2  1  20 B4 E4         jsr add_T1_T0
00E3C5  1  CA               dex
00E3C6  1  D0 FA            bne dec_mul_loop
00E3C8  1               
00E3C8  1  18               clc
00E3C9  1  A5 CC            lda T0L
00E3CB  1  65 D4            adc tmp
00E3CD  1  85 CC            sta T0L
00E3CF  1  90 02            bcc dec_next
00E3D1  1  E6 CD            inc T0H
00E3D3  1               
00E3D3  1               dec_next:
00E3D3  1  20 19 E4         jsr advance_lineptr
00E3D6  1  E6 D3            inc value_size
00E3D8  1  4C A8 E3         jmp dec_loop
00E3DB  1               
00E3DB  1               dec_done:
00E3DB  1  A5 D3            lda value_size
00E3DD  1  F0 0E            beq dec_error
00E3DF  1  A5 CD            lda T0H
00E3E1  1  F0 05            beq dec_byte
00E3E3  1  A9 02            lda #2
00E3E5  1  85 D3            sta value_size
00E3E7  1  60               rts
00E3E8  1               
00E3E8  1               dec_byte:
00E3E8  1  A9 01            lda #1
00E3EA  1  85 D3            sta value_size
00E3EC  1  60               rts
00E3ED  1               
00E3ED  1               dec_error:
00E3ED  1  4C 2C E2         jmp cmd_error
00E3F0  1               
00E3F0  1               ; ------------------------------------------------------------
00E3F0  1               ; HEX_DIGIT
00E3F0  1               ; Convert ASCII hex digit to value 0..15.
00E3F0  1               ;
00E3F0  1               ; Input
00E3F0  1               ;   A = ASCII character
00E3F0  1               ;
00E3F0  1               ; Output
00E3F0  1               ;   A = digit value
00E3F0  1               ;   C = 0 valid digit
00E3F0  1               ;   C = 1 invalid digit
00E3F0  1               ; ------------------------------------------------------------
00E3F0  1               hex_digit:
00E3F0  1  C9 30            cmp #'0'
00E3F2  1  90 23            bcc hex_bad
00E3F4  1  C9 3A            cmp #'9'+1
00E3F6  1  90 1A            bcc hex_num
00E3F8  1               
00E3F8  1  C9 41            cmp #'A'
00E3FA  1  90 04            bcc hex_lower
00E3FC  1  C9 47            cmp #'F'+1
00E3FE  1  90 0D            bcc hex_upper
00E400  1               
00E400  1               hex_lower:
00E400  1  C9 61            cmp #'a'
00E402  1  90 13            bcc hex_bad
00E404  1  C9 67            cmp #'f'+1
00E406  1  B0 0F            bcs hex_bad

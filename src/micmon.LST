00E9DC  2               ; ------------------------------------------------------------
00E9DC  2               ; COMPUTE_REL_OFFSET
00E9DC  2               ;
00E9DC  2               ; Input:
00E9DC  2               ;   A  = instruction length (2 or 3)
00E9DC  2               ;   R0 = instruction address
00E9DC  2               ;   T0 = target address
00E9DC  2               ;
00E9DC  2               ; Output:
00E9DC  2               ;   A  = signed 8-bit relative offset
00E9DC  2               ;
00E9DC  2               ; Error:
00E9DC  2               ;   jumps to cmd_error if target is out of range
00E9DC  2               ; ------------------------------------------------------------
00E9DC  2               compute_rel_offset:
00E9DC  2  85 D2            sta parm_count
00E9DE  2               
00E9DE  2                   ; R3 = base = R0 + instruction length
00E9DE  2  A5 C4            lda R0L
00E9E0  2  18               clc
00E9E1  2  65 D2            adc parm_count
00E9E3  2  85 CA            sta R3L
00E9E5  2  A5 C5            lda R0H
00E9E7  2  69 00            adc #0
00E9E9  2  85 CB            sta R3H
00E9EB  2               
00E9EB  2                   ; diff = target - base   (wrapped 16-bit subtraction)
00E9EB  2  38               sec
00E9EC  2  A5 CC            lda T0L
00E9EE  2  E5 CA            sbc R3L
00E9F0  2  85 CE            sta T1L
00E9F2  2  A5 CD            lda T0H
00E9F4  2  E5 CB            sbc R3H
00E9F6  2  85 CF            sta T1H
00E9F8  2               
00E9F8  2                   ; valid if:
00E9F8  2                   ;   T1 = 00:00..00:7F   (+0 .. +127)
00E9F8  2                   ;   T1 = FF:80..FF:FF   (-128 .. -1)
00E9F8  2               
00E9F8  2  A5 CF            lda T1H
00E9FA  2  F0 07            beq cro_pos
00E9FC  2  C9 FF            cmp #$FF
00E9FE  2  F0 0C            beq cro_neg
00EA00  2  4C 2B E2         jmp cmd_error
00EA03  2               
00EA03  2               cro_pos:
00EA03  2  A5 CE            lda T1L
00EA05  2  C9 80            cmp #$80
00EA07  2  90 0C            bcc cro_ok
00EA09  2  4C 2B E2         jmp cmd_error
00EA0C  2               
00EA0C  2               cro_neg:
00EA0C  2  A5 CE            lda T1L
00EA0E  2  C9 80            cmp #$80
00EA10  2  B0 03            bcs cro_ok
00EA12  2  4C 2B E2         jmp cmd_error
00EA15  2               
00EA15  2               cro_ok:
00EA15  2  A5 CE            lda T1L
00EA17  2  60               rts
00EA18  2               
00EA18  2               ; ------------------------------------------------------------
00EA18  2               ; EMIT INSTRUCTION
00EA18  2               ; Uses asm_opcode, asm_mode and operand value(s).
00EA18  2               ; Updates MEM to next address.
00EA18  2               ; Writes nothing if relative offset is out of range.
00EA18  2               ; ------------------------------------------------------------
00EA18  2               emit_instruction:
00EA18  2  A5 D5            lda asm_mode
00EA1A  2  20 3A E8         jsr get_oplen_from_mode
00EA1D  2  85 D4            sta tmp
00EA1F  2               
00EA1F  2                   ; for relative forms, validate offset before storing opcode
00EA1F  2  A5 D5            lda asm_mode
00EA21  2  C9 0D            cmp #AM_REL
00EA23  2  F0 07            beq ei_prep_rel
00EA25  2  C9 0E            cmp #AM_ZPREL
00EA27  2  F0 0D            beq ei_prep_zprel
00EA29  2  4C 40 EA         jmp ei_store
00EA2C  2               
00EA2C  2               ei_prep_rel:
00EA2C  2  A9 02            lda #2
00EA2E  2  20 DC E9         jsr compute_rel_offset
00EA31  2  85 CF            sta T1H
00EA33  2  4C 40 EA         jmp ei_store
00EA36  2               
00EA36  2               ei_prep_zprel:
00EA36  2  A9 03            lda #3
00EA38  2  20 DC E9         jsr compute_rel_offset
00EA3B  2  85 CF            sta T1H
00EA3D  2  4C 40 EA         jmp ei_store
00EA40  2               
00EA40  2               ei_store:
00EA40  2  A0 00            ldy #0
00EA42  2  A5 D6            lda asm_opcode
00EA44  2  91 C4            sta (R0L),y
00EA46  2               
00EA46  2  A5 D4            lda tmp
00EA48  2  C9 01            cmp #1
00EA4A  2  F0 32            beq ei_finish
00EA4C  2               
00EA4C  2  A5 D5            lda asm_mode
00EA4E  2  C9 0D            cmp #AM_REL
00EA50  2  F0 18            beq ei_rel
00EA52  2  C9 0E            cmp #AM_ZPREL
00EA54  2  F0 1D            beq ei_zprel
00EA56  2               
00EA56  2  A0 01            ldy #1
00EA58  2  A5 CC            lda T0L
00EA5A  2  91 C4            sta (R0L),y
00EA5C  2               
00EA5C  2  A5 D4            lda tmp
00EA5E  2  C9 02            cmp #2
00EA60  2  F0 1C            beq ei_finish
00EA62  2               
00EA62  2  C8               iny
00EA63  2  A5 CD            lda T0H
00EA65  2  91 C4            sta (R0L),y
00EA67  2  4C 7E EA         jmp ei_finish
00EA6A  2               
00EA6A  2               ei_rel:
00EA6A  2  A0 01            ldy #1
00EA6C  2  A5 CF            lda T1H
00EA6E  2  91 C4            sta (R0L),y
00EA70  2  4C 7E EA         jmp ei_finish
00EA73  2               
00EA73  2               ei_zprel:
00EA73  2  A0 01            ldy #1
00EA75  2  A5 CE            lda T1L
00EA77  2  91 C4            sta (R0L),y
00EA79  2  C8               iny
00EA7A  2  A5 CF            lda T1H
00EA7C  2  91 C4            sta (R0L),y
00EA7E  2               
00EA7E  2               ei_finish:
00EA7E  2  A5 D4            lda tmp
00EA80  2  20 8A E4         jsr add_R0_A
00EA83  2  A5 C4            lda R0L
00EA85  2  85 D0            sta MEML
00EA87  2  A5 C5            lda R0H
00EA89  2  85 D1            sta MEMH
00EA8B  2  60               rts
